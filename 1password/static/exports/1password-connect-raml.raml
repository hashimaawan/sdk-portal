#%RAML 0.8
title: 1Password Connect
version: 1.5.7
documentation:
- title: 1Password Connect
  content: REST API interface for 1Password Connect.
baseUri: http://1password.local
securedBy: []
protocols:
- HTTP
baseUriParameters: {}
schemas:
- APIRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "APIRequest",
      "title": "APIRequest",
      "description": "Represents a request that was made to the API. Including what Token was used and what resource was accessed.",
      "type": "object",
      "properties": {
        "action": {
          "title": "Action",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "READ",
            "CREATE",
            "UPDATE",
            "DELETE"
          ]
        },
        "actor": {
          "id": "Actor",
          "title": "Actor",
          "type": "object",
          "properties": {
            "account": {
              "type": "string"
            },
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "jti": {
              "type": "string"
            },
            "requestIp": {
              "type": "string"
            },
            "userAgent": {
              "type": "string"
            }
          }
        },
        "requestId": {
          "description": "The unique id used to identify a single request.",
          "type": "string",
          "format": "uuid"
        },
        "resource": {
          "id": "Resource",
          "title": "Resource",
          "type": "object",
          "properties": {
            "item": {
              "id": "Item2",
              "title": "Item2",
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[\\da-z]{26}$"
                }
              }
            },
            "itemVersion": {
              "type": "integer",
              "format": "int32"
            },
            "type": {
              "title": "Type",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "ITEM",
                "VAULT"
              ]
            },
            "vault": {
              "id": "Vault3",
              "title": "Vault3",
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[\\da-z]{26}$"
                }
              }
            }
          }
        },
        "result": {
          "title": "Result",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "SUCCESS",
            "DENY"
          ]
        },
        "timestamp": {
          "description": "The time at which the request was processed by the server.",
          "readOnly": true,
          "type": "string",
          "format": "date-time"
        }
      }
    }
- ErrorResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ErrorResponse",
      "title": "ErrorResponse",
      "type": "object",
      "properties": {
        "message": {
          "description": "A message detailing the error",
          "type": "string"
        },
        "status": {
          "description": "HTTP Status Code",
          "type": "integer",
          "format": "int32"
        }
      }
    }
- Field: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Field",
      "title": "Field",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "title": "Type1",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "STRING",
            "EMAIL",
            "CONCEALED",
            "URL",
            "TOTP",
            "DATE",
            "MONTH_YEAR",
            "MENU"
          ]
        },
        "entropy": {
          "description": "For fields with a purpose of `PASSWORD` this is the entropy of the value",
          "readOnly": true,
          "type": "number"
        },
        "generate": {
          "description": "If value is not present then a new value should be generated for this field",
          "type": "boolean",
          "default": false
        },
        "label": {
          "type": "string"
        },
        "purpose": {
          "title": "Purpose",
          "description": "Some item types, Login and Password, have fields used for autofill. This property indicates that purpose and is required for some item types.",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "USERNAME",
            "PASSWORD",
            "NOTES"
          ]
        },
        "recipe": {
          "id": "GeneratorRecipe",
          "title": "GeneratorRecipe",
          "description": "The recipe is used in conjunction with the \"generate\" property to set the character set used to generate a new secure value",
          "type": "object",
          "properties": {
            "characterSets": {
              "description": "",
              "type": "array",
              "items": {
                "title": "CharacterSet",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "LETTERS",
                  "DIGITS",
                  "SYMBOLS"
                ]
              },
              "uniqueItems": true
            },
            "excludeCharacters": {
              "description": "List of all characters that should be excluded from generated passwords.",
              "example": "abc1",
              "type": "string"
            },
            "length": {
              "description": "Length of the generated value",
              "type": "integer",
              "default": 32,
              "minimum": 1.0,
              "maximum": 64.0,
              "format": "int32"
            }
          }
        },
        "section": {
          "id": "Section",
          "title": "Section",
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            }
          }
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "type"
      ]
    }
- File: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "File",
      "title": "File",
      "example": {
        "content": "VGhlIGZ1dHVyZSBiZWxvbmdzIHRvIHRoZSBjdXJpb3VzLgo=",
        "content_path": "v1/vaults/ionaiwtdvgclrixbt6ztpqcxnq/items/p7eflcy7f5mk7vg6zrzf5rjjyu/files/6r65pjq33banznomn7q22sj44e/content",
        "id": "6r65pjq33banznomn7q22sj44e",
        "name": "foo.txt",
        "size": 35
      },
      "type": "object",
      "properties": {
        "content": {
          "description": "Base64-encoded contents of the file. Only set if size <= OP_MAX_INLINE_FILE_SIZE_KB kb and `inline_files` is set to `true`.",
          "type": "string"
        },
        "content_path": {
          "description": "Path of the Connect API that can be used to download the contents of this file.",
          "readOnly": true,
          "type": "string"
        },
        "id": {
          "description": "ID of the file",
          "type": "string"
        },
        "name": {
          "description": "Name of the file",
          "type": "string"
        },
        "section": {
          "id": "Section1",
          "title": "Section1",
          "description": "For files that are in a section, this field describes the section.",
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            }
          }
        },
        "size": {
          "description": "Size in bytes of the file",
          "type": "integer",
          "format": "int32"
        }
      }
    }
- FullItem: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "FullItem",
      "title": "FullItem",
      "type": "object",
      "properties": {
        "category": {
          "title": "Category",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "LOGIN",
            "PASSWORD",
            "API_CREDENTIAL",
            "SERVER",
            "DATABASE",
            "CREDIT_CARD",
            "MEMBERSHIP",
            "PASSPORT",
            "SOFTWARE_LICENSE",
            "OUTDOOR_LICENSE",
            "SECURE_NOTE",
            "WIRELESS_ROUTER",
            "BANK_ACCOUNT",
            "DRIVER_LICENSE",
            "IDENTITY",
            "REWARD_PROGRAM",
            "DOCUMENT",
            "EMAIL_ACCOUNT",
            "SOCIAL_SECURITY_NUMBER",
            "MEDICAL_RECORD",
            "SSH_KEY",
            "CUSTOM"
          ]
        },
        "vault": {
          "id": "Vault1",
          "title": "Vault1",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[\\da-z]{26}$"
            }
          },
          "required": [
            "id"
          ]
        },
        "createdAt": {
          "readOnly": true,
          "type": "string",
          "format": "date-time"
        },
        "favorite": {
          "type": "boolean",
          "default": false
        },
        "id": {
          "type": "string",
          "pattern": "^[\\da-z]{26}$"
        },
        "lastEditedBy": {
          "readOnly": true,
          "type": "string"
        },
        "state": {
          "title": "State",
          "readOnly": true,
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "ARCHIVED",
            "DELETED"
          ]
        },
        "tags": {
          "description": "",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "title": {
          "type": "string"
        },
        "updatedAt": {
          "readOnly": true,
          "type": "string",
          "format": "date-time"
        },
        "urls": {
          "description": "",
          "example": [
            {
              "href": "https://example.com",
              "primary": true
            },
            {
              "href": "https://example.org"
            }
          ],
          "type": "array",
          "items": {
            "id": "Url",
            "title": "Url",
            "type": "object",
            "properties": {
              "href": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "primary": {
                "type": "boolean"
              }
            },
            "required": [
              "href"
            ]
          }
        },
        "version": {
          "type": "integer",
          "format": "int32"
        },
        "fields": {
          "description": "",
          "type": "array",
          "items": {
            "id": "Field",
            "title": "Field",
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "title": "Type1",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "STRING",
                  "EMAIL",
                  "CONCEALED",
                  "URL",
                  "TOTP",
                  "DATE",
                  "MONTH_YEAR",
                  "MENU"
                ]
              },
              "entropy": {
                "description": "For fields with a purpose of `PASSWORD` this is the entropy of the value",
                "readOnly": true,
                "type": "number"
              },
              "generate": {
                "description": "If value is not present then a new value should be generated for this field",
                "type": "boolean",
                "default": false
              },
              "label": {
                "type": "string"
              },
              "purpose": {
                "title": "Purpose",
                "description": "Some item types, Login and Password, have fields used for autofill. This property indicates that purpose and is required for some item types.",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "USERNAME",
                  "PASSWORD",
                  "NOTES"
                ]
              },
              "recipe": {
                "id": "GeneratorRecipe",
                "title": "GeneratorRecipe",
                "description": "The recipe is used in conjunction with the \"generate\" property to set the character set used to generate a new secure value",
                "type": "object",
                "properties": {
                  "characterSets": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "title": "CharacterSet",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "LETTERS",
                        "DIGITS",
                        "SYMBOLS"
                      ]
                    },
                    "uniqueItems": true
                  },
                  "excludeCharacters": {
                    "description": "List of all characters that should be excluded from generated passwords.",
                    "example": "abc1",
                    "type": "string"
                  },
                  "length": {
                    "description": "Length of the generated value",
                    "type": "integer",
                    "default": 32,
                    "minimum": 1.0,
                    "maximum": 64.0,
                    "format": "int32"
                  }
                }
              },
              "section": {
                "id": "Section",
                "title": "Section",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  }
                }
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "type"
            ]
          }
        },
        "files": {
          "description": "",
          "type": "array",
          "items": {
            "id": "File",
            "title": "File",
            "example": {
              "content": "VGhlIGZ1dHVyZSBiZWxvbmdzIHRvIHRoZSBjdXJpb3VzLgo=",
              "content_path": "v1/vaults/ionaiwtdvgclrixbt6ztpqcxnq/items/p7eflcy7f5mk7vg6zrzf5rjjyu/files/6r65pjq33banznomn7q22sj44e/content",
              "id": "6r65pjq33banznomn7q22sj44e",
              "name": "foo.txt",
              "size": 35
            },
            "type": "object",
            "properties": {
              "content": {
                "description": "Base64-encoded contents of the file. Only set if size <= OP_MAX_INLINE_FILE_SIZE_KB kb and `inline_files` is set to `true`.",
                "type": "string"
              },
              "content_path": {
                "description": "Path of the Connect API that can be used to download the contents of this file.",
                "readOnly": true,
                "type": "string"
              },
              "id": {
                "description": "ID of the file",
                "type": "string"
              },
              "name": {
                "description": "Name of the file",
                "type": "string"
              },
              "section": {
                "id": "Section1",
                "title": "Section1",
                "description": "For files that are in a section, this field describes the section.",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  }
                }
              },
              "size": {
                "description": "Size in bytes of the file",
                "type": "integer",
                "format": "int32"
              }
            }
          }
        },
        "sections": {
          "description": "",
          "type": "array",
          "items": {
            "id": "Section2",
            "title": "Section2",
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "category",
        "vault"
      ]
    }
- GeneratorRecipe: |
