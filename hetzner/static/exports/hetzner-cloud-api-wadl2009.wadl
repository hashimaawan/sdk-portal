  <resources base="https://api.hetzner.cloud/v1">
    <resource id="_actions" path="/actions">
      <method id="GetallActions" name="GET">
        <doc title="Get all Actions" xml:lang="en">Returns all Action objects. You can `sort` the results by using the sort URI parameter, and filter them with the `status` parameter.</doc>
        <request>
          <param name="id" style="query" type="xsd:integer">
            <doc title="id" xml:lang="en">Can be used multiple times, the response will contain only Actions with specified IDs</doc>
          </param>
          <param name="sort" style="query" default="">
            <doc title="sort" xml:lang="en">Can be used multiple times.</doc>
            <option value="id">
              <doc title="id" xml:lang="en" />
            </option>
            <option value="Enum_idasc">
              <doc title="Enum_idasc" xml:lang="en" />
            </option>
            <option value="Enum_iddesc">
              <doc title="Enum_iddesc" xml:lang="en" />
            </option>
            <option value="command">
              <doc title="command" xml:lang="en" />
            </option>
            <option value="Enum_commandasc">
              <doc title="Enum_commandasc" xml:lang="en" />
            </option>
            <option value="Enum_commanddesc">
              <doc title="Enum_commanddesc" xml:lang="en" />
            </option>
            <option value="status">
              <doc title="status" xml:lang="en" />
            </option>
            <option value="Enum_statusasc">
              <doc title="Enum_statusasc" xml:lang="en" />
            </option>
            <option value="Enum_statusdesc">
              <doc title="Enum_statusdesc" xml:lang="en" />
            </option>
            <option value="progress">
              <doc title="progress" xml:lang="en" />
            </option>
            <option value="Enum_progressasc">
              <doc title="Enum_progressasc" xml:lang="en" />
            </option>
            <option value="Enum_progressdesc">
              <doc title="Enum_progressdesc" xml:lang="en" />
            </option>
            <option value="started">
              <doc title="started" xml:lang="en" />
            </option>
            <option value="Enum_startedasc">
              <doc title="Enum_startedasc" xml:lang="en" />
            </option>
            <option value="Enum_starteddesc">
              <doc title="Enum_starteddesc" xml:lang="en" />
            </option>
            <option value="finished">
              <doc title="finished" xml:lang="en" />
            </option>
            <option value="Enum_finishedasc">
              <doc title="Enum_finishedasc" xml:lang="en" />
            </option>
            <option value="Enum_finisheddesc">
              <doc title="Enum_finisheddesc" xml:lang="en" />
            </option>
          </param>
          <param name="status" style="query" default="">
            <doc title="status" xml:lang="en">Can be used multiple times, the response will contain only Actions with specified statuses</doc>
            <option value="running">
              <doc title="running" xml:lang="en" />
            </option>
            <option value="success">
              <doc title="success" xml:lang="en" />
            </option>
            <option value="error">
              <doc title="error" xml:lang="en" />
            </option>
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">The `actions` key contains a list of Actions</doc>
          <representation element="schemas:GetallActions200_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
    <resource id="_actionsid" path="/actions/{id}">
      <param name="id" style="template" type="xsd:integer" required="true">
        <doc title="id" xml:lang="en">ID of the Resource</doc>
