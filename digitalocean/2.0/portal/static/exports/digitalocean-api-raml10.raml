  V2CertificatesResponse1:
    displayName: V2CertificatesResponse1
    type: object
    properties:
      certificate:
        required: false
        displayName: certificate
        type: Certificate
  V2CustomersMyBalanceResponse:
    displayName: V2CustomersMyBalanceResponse
    type: object
    properties:
      account_balance:
        required: false
        example:
          value: '12.23'
        displayName: account_balance
        description: Current balance of the customer's most recent billing activity.  Does not reflect `month_to_date_usage`.
        type: string
      generated_at:
        required: false
        example:
          value: 2019-07-09T15:01:12Z
        displayName: generated_at
        description: The time at which balances were most recently generated.
        type: datetime
      month_to_date_balance:
        required: false
        example:
          value: '23.44'
        displayName: month_to_date_balance
        description: Balance as of the `generated_at` time.  This value includes the `account_balance` and `month_to_date_usage`.
        type: string
      month_to_date_usage:
        required: false
        example:
          value: '11.21'
        displayName: month_to_date_usage
        description: Amount used in the current billing period as of the `generated_at` time.
        type: string
  V2CustomersMyBillingHistoryResponse:
    example:
      value:
        billing_history:
        - amount: '12.34'
          date: 2018-06-01T08:44:38Z
          description: Invoice for May 2018
          invoice_id: '123'
          invoice_uuid: example-uuid
          type: Invoice
        - amount: '-12.34'
          date: 2018-06-02T08:44:38Z
          description: Payment (MC 2018)
          type: Payment
        links:
          pages:
            last: https://api.digitalocean.com/v2/customers/my/billing_history?page=3&per_page=2
            next: https://api.digitalocean.com/v2/customers/my/billing_history?page=2&per_page=2
        meta:
          total: 5
    displayName: V2CustomersMyBillingHistoryResponse
    type: object
    properties:
      billing_history:
        required: false
        displayName: billing_history
        type: array
        items:
          type: BillingHistory
      links:
        required: false
        displayName: links
        type: Links
      meta:
        required: true
        displayName: meta
        description: Information about the response itself.
        type: Meta1
  BillingHistory:
    displayName: BillingHistory
    type: object
    properties:
      amount:
        required: false
        example:
          value: '12.34'
        displayName: amount
        description: Amount of the billing history entry.
        type: string
      date:
        required: false
        example:
          value: 2018-06-01T08:44:38Z
        displayName: date
        description: Time the billing history entry occurred.
        type: datetime
      description:
        required: false
        example:
          value: Invoice for May 2018
        displayName: description
        description: Description of the billing history entry.
        type: string
      invoice_id:
        required: false
        example:
          value: '123'
        displayName: invoice_id
        description: ID of the invoice associated with the billing history entry, if  applicable.
        type: string
      invoice_uuid:
        required: false
