      created_at:
        required: false
        example:
          value: 2019-01-11T18:37:36Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format that represents when the database cluster was created.
        type: datetime
      db_names:
        required: false
        example:
          value:
          - doadmin
        displayName: db_names
        description: An array of strings containing the names of databases created in the database cluster.
        type:
        - array
        - nil
        items:
          type: string
      engine:
        required: true
        example:
          value: pg
        displayName: engine
        description: 'A slug representing the database engine used for the cluster. The possible values are: "pg" for PostgreSQL, "mysql" for MySQL, "redis" for Redis, and "mongodb" for MongoDB.'
        type: string
        enum:
        - pg
        - mysql
        - redis
        - mongodb
      id:
        required: false
        example:
          value: 9cc10173-e9ea-4176-9dbc-a4cee4c4ff30
        displayName: id
        description: A unique ID that can be used to identify and reference a database cluster.
        type: any
      maintenance_window:
        required: false
        displayName: maintenance_window
        type:
        - MaintenanceWindow
        - nil
      name:
        required: true
        example:
          value: backend
        displayName: name
        description: A unique, human-readable name referring to a database cluster.
        type: string
      num_nodes:
        required: true
        example:
          value: 2
        displayName: num_nodes
        description: The number of nodes in the database cluster.
        type: integer
        format: int32
      private_connection:
        required: false
        displayName: private_connection
        type: PrivateConnection
      private_network_uuid:
        required: false
        example:
          value: d455e75d-4858-4eec-8c95-da2f0a5f93a7
        displayName: private_network_uuid
        description: A string specifying the UUID of the VPC to which the database cluster will be assigned. If excluded, the cluster when creating a new database cluster, it will be assigned to your account's default VPC for the region.
        type: string
        pattern: ^$|[0-9a-f]{8}\b-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-\b[0-9a-f]{12}
      project_id:
        required: false
        example:
          value: 9cc10173-e9ea-4176-9dbc-a4cee4c4ff30
        displayName: project_id
        description: The ID of the project that the database cluster is assigned to. If excluded when creating a new database cluster, it will be assigned to your default project.
        type: any
      region:
        required: true
        example:
          value: nyc3
        displayName: region
        description: The slug identifier for the region where the database cluster is located.
        type: string
      rules:
        required: false
        displayName: rules
        type: array
        items:
          type: Rule1
      size:
        required: true
        example:
          value: db-s-2vcpu-4gb
        displayName: size
        description: The slug identifier representing the size of the nodes in the database cluster.
        type: string
      status:
        required: false
        example:
          value: creating
        displayName: status
        description: A string representing the current status of the database cluster.
        type: string
        enum:
        - creating
        - online
        - resizing
        - migrating
        - forking
      tags:
        required: false
        example:
          value:
          - production
        displayName: tags
        description: An array of tags that have been applied to the database cluster.
        type:
        - array
        - nil
        items:
          type: string
      users:
        required: false
        displayName: users
        type:
        - array
        - nil
        items:
          type: User
      version:
        required: false
        example:
          value: '10'
        displayName: version
        description: A string representing the version of the database engine in use for the cluster.
        type: string
      version_end_of_availability:
        required: false
        example:
          value: 2023-05-09T00:00:00Z
        displayName: version_end_of_availability
        description: A timestamp referring to the date when the particular version will no longer be available for creating new clusters. If null, the version does not have an end of availability timeline.
        type: string
      version_end_of_life:
        required: false
        example:
          value: 2023-11-09T00:00:00Z
        displayName: version_end_of_life
        description: A timestamp referring to the date when the particular version will no longer be supported. If null, the version does not have an end of life timeline.
        type: string
      backup_restore:
        required: false
        displayName: backup_restore
        type: BackupRestore
  BackupRestore:
    displayName: BackupRestore
    type: object
    properties:
      backup_created_at:
        required: false
        example:
          value: 2019-01-31T19:25:22Z
        displayName: backup_created_at
        description: The timestamp of an existing database cluster backup in ISO8601 combined date and time format. The most recent backup will be used if excluded.
        type: datetime
      database_name:
        required: true
        example:
          value: backend
        displayName: database_name
        description: The name of an existing database cluster from which the backup will be restored.
        type: string
  V2DatabasesResponse1:
    displayName: V2DatabasesResponse1
    type: object
    properties:
      database:
        required: true
        displayName: database
        type: Database1
  V2DatabasesOptionsResponse:
    displayName: V2DatabasesOptionsResponse
    type: object
    properties:
      options:
        required: false
        displayName: options
        type: Options
      version_availability:
        required: false
        displayName: version_availability
        type: VersionAvailability
  Options:
    displayName: Options
    type: object
    properties:
      mongodb:
        required: false
        displayName: mongodb
        type: Mongodb
      mysql:
        required: false
        displayName: mysql
        type: Mysql
      pg:
        required: false
        displayName: pg
        type: Pg
      redis:
        required: false
        displayName: redis
        type: Redis
  Mongodb:
    displayName: Mongodb
    type: object
    properties:
      regions:
        required: false
        example:
          value:
          - ams3
          - blr1
        displayName: regions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      versions:
        required: false
        example:
          value:
          - '4.4'
          - '5.0'
        displayName: versions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      layouts:
        required: false
        displayName: layouts
        description: An array of objects, each indicating the node sizes (otherwise referred to as slugs) that are available with various numbers of nodes in the database cluster. Each slugs denotes the node's identifier, CPU, and RAM (in that order).
        type: array
        items:
          type: Layout
  Layout:
    displayName: Layout
    type: object
    properties:
      num_nodes:
        required: false
        example:
          value: 1
        displayName: num_nodes
        type: integer
        format: int32
      sizes:
        required: false
        example:
          value:
          - db-s-1vcpu-1gb
          - db-s-1vcpu-2gb
        displayName: sizes
        description: An array of objects containing the slugs available with various node counts
        type: array
        items:
          type: string
  Mysql:
    displayName: Mysql
    type: object
    properties:
      regions:
        required: false
        example:
          value:
          - ams3
          - blr1
        displayName: regions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      versions:
        required: false
        example:
          value:
          - '4.4'
          - '5.0'
        displayName: versions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      layouts:
        required: false
        displayName: layouts
        description: An array of objects, each indicating the node sizes (otherwise referred to as slugs) that are available with various numbers of nodes in the database cluster. Each slugs denotes the node's identifier, CPU, and RAM (in that order).
        type: array
        items:
          type: Layout
  Pg:
    displayName: Pg
    type: object
    properties:
      regions:
        required: false
        example:
          value:
          - ams3
          - blr1
        displayName: regions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      versions:
        required: false
        example:
          value:
          - '4.4'
          - '5.0'
        displayName: versions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      layouts:
        required: false
        displayName: layouts
        description: An array of objects, each indicating the node sizes (otherwise referred to as slugs) that are available with various numbers of nodes in the database cluster. Each slugs denotes the node's identifier, CPU, and RAM (in that order).
        type: array
        items:
          type: Layout
  Redis:
    displayName: Redis
    type: object
    properties:
      regions:
        required: false
        example:
          value:
          - ams3
          - blr1
        displayName: regions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      versions:
        required: false
        example:
          value:
          - '4.4'
          - '5.0'
        displayName: versions
        description: An array of strings containing the names of available regions
        type: array
        items:
          type: string
      layouts:
        required: false
        displayName: layouts
        description: An array of objects, each indicating the node sizes (otherwise referred to as slugs) that are available with various numbers of nodes in the database cluster. Each slugs denotes the node's identifier, CPU, and RAM (in that order).
        type: array
        items:
          type: Layout
  VersionAvailability:
    displayName: VersionAvailability
    type: object
    properties:
      mongodb:
        required: false
        displayName: mongodb
        description: An array of objects, each indicating the version end-of-life, end-of-availability for various database engines
        type: array
        items:
          type: Mongodb1
      mysql:
        required: false
        displayName: mysql
        description: An array of objects, each indicating the version end-of-life, end-of-availability for various database engines
        type: array
        items:
          type: Mongodb1
      pg:
        required: false
        displayName: pg
        description: An array of objects, each indicating the version end-of-life, end-of-availability for various database engines
        type: array
        items:
          type: Mongodb1
      redis:
        required: false
        displayName: redis
        description: An array of objects, each indicating the version end-of-life, end-of-availability for various database engines
        type: array
        items:
          type: Mongodb1
  Mongodb1:
    displayName: Mongodb1
    type: object
    properties:
      end_of_availability:
        required: false
        example:
          value: 2023-05-09T00:00:00Z
        displayName: end_of_availability
        description: A timestamp referring to the date when the particular version will no longer be available for creating new clusters. If null, the version does not have an end of availability timeline.
        type: string
      end_of_life:
        required: false
        example:
          value: 2023-11-09T00:00:00Z
        displayName: end_of_life
        description: A timestamp referring to the date when the particular version will no longer be supported. If null, the version does not have an end of life timeline.
        type: string
      version:
        required: false
        example:
          value: '8'
        displayName: version
        description: The engine version.
        type: string
  V2DatabasesBackupsResponse:
    displayName: V2DatabasesBackupsResponse
    type: object
    properties:
      backups:
        required: true
        displayName: backups
        type: array
        items:
          type: Backup
  Backup:
    displayName: Backup
    type: object
    properties:
      created_at:
        required: true
        example:
          value: 2019-01-31T19:25:22Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format at which the backup was created.
        type: datetime
      size_gigabytes:
        required: true
        example:
          value: 0.03364864
        displayName: size_gigabytes
        description: The size of the database backup in GBs.
        type: number
        format: double
  V2DatabasesCaResponse:
    displayName: V2DatabasesCaResponse
    type: object
    properties:
      ca:
        required: true
        displayName: ca
        type: Ca
  Ca:
    displayName: Ca
    type: object
    properties:
      certificate:
        required: true
        example:
          value: 
        displayName: certificate
        description: base64 encoding of the certificate used to secure database connections
        type: string
  V2DatabasesConfigResponse:
    displayName: V2DatabasesConfigResponse
    type: object
    properties:
      config:
        required: true
        displayName: config
        type: any
  Config:
    displayName: Config
    type: object
    properties:
      backup_hour:
        required: false
        example:
          value: 3
        displayName: backup_hour
        description: The hour of day (in UTC) when backup for the service starts. New backup only starts if previous backup has already completed.
        type: integer
        minimum: 0
        maximum: 23
        format: int32
      backup_minute:
        required: false
        example:
          value: 30
        displayName: backup_minute
        description: The minute of the backup hour when backup for the service starts. New backup  only starts if previous backup has already completed.
        type: integer
        minimum: 0
        maximum: 59
        format: int32
      binlog_retention_period:
        required: false
        example:
          value: 600
        displayName: binlog_retention_period
        description: The minimum amount of time, in seconds, to keep binlog entries before deletion.  This may be extended for services that require binlog entries for longer than the default, for example if using the MySQL Debezium Kafka connector.
        type: number
        minimum: 600
        maximum: 86400
        format: double
      connect_timeout:
        required: false
        example:
          value: 10
        displayName: connect_timeout
        description: The number of seconds that the mysqld server waits for a connect packet before responding with bad handshake.
        type: integer
        minimum: 2
        maximum: 3600
        format: int32
      default_time_zone:
        required: false
        example:
          value: +03:00
        displayName: default_time_zone
        description: Default server time zone, in the form of an offset from UTC (from -12:00 to +12:00), a time zone name (EST), or 'SYSTEM' to use the MySQL server default.
        type: string
        minLength: 2
        maxLength: 100
      group_concat_max_len:
        required: false
        example:
          value: 1024
        displayName: group_concat_max_len
        description: The maximum permitted result length, in bytes, for the GROUP_CONCAT() function.
        type: integer
        minimum: 4
        maximum: 1.8446744073709552E+19
        format: int32
      information_schema_stats_expiry:
        required: false
        example:
          value: 86400
        displayName: information_schema_stats_expiry
        description: The time, in seconds, before cached statistics expire.
        type: integer
        minimum: 900
        maximum: 31536000
        format: int32
      innodb_ft_min_token_size:
        required: false
        example:
          value: 3
        displayName: innodb_ft_min_token_size
        description: The minimum length of words that an InnoDB FULLTEXT index stores.
        type: integer
        minimum: 0
        maximum: 16
        format: int32
      innodb_ft_server_stopword_table:
        required: false
        example:
          value: db_name/table_name
        displayName: innodb_ft_server_stopword_table
        description: The InnoDB FULLTEXT index stopword list for all InnoDB tables.
        type: string
        pattern: ^.+/.+$
        maxLength: 1024
      innodb_lock_wait_timeout:
        required: false
        example:
          value: 50
        displayName: innodb_lock_wait_timeout
        description: The time, in seconds, that an InnoDB transaction waits for a row lock. before giving up.
        type: integer
        minimum: 1
        maximum: 3600
        format: int32
      innodb_log_buffer_size:
        required: false
        example:
          value: 16777216
        displayName: innodb_log_buffer_size
        description: The size of the buffer, in bytes, that InnoDB uses to write to the log files. on disk.
        type: integer
        minimum: 1048576
        maximum: 4294967295
        format: int32
      innodb_online_alter_log_max_size:
        required: false
        example:
          value: 134217728
        displayName: innodb_online_alter_log_max_size
        description: The upper limit, in bytes, of the size of the temporary log files used during online DDL operations for InnoDB tables.
        type: integer
        minimum: 65536
        maximum: 1099511627776
        format: int32
      innodb_print_all_deadlocks:
        required: false
        example:
          value: true
        displayName: innodb_print_all_deadlocks
        description: When enabled, records information about all deadlocks in InnoDB user transactions  in the error log. Disabled by default.
        type: boolean
      innodb_rollback_on_timeout:
        required: false
        example:
          value: true
        displayName: innodb_rollback_on_timeout
        description: When enabled, transaction timeouts cause InnoDB to abort and roll back the entire transaction.
        type: boolean
      interactive_timeout:
        required: false
        example:
          value: 3600
        displayName: interactive_timeout
        description: The time, in seconds, the server waits for activity on an interactive. connection before closing it.
        type: integer
        minimum: 30
        maximum: 604800
        format: int32
      internal_tmp_mem_storage_engine:
        required: false
        example:
          value: TempTable
        displayName: internal_tmp_mem_storage_engine
        description: The storage engine for in-memory internal temporary tables.
        type: string
        enum:
        - TempTable
        - MEMORY
      long_query_time:
        required: false
        example:
          value: 10
        displayName: long_query_time
        description: The time, in seconds, for a query to take to execute before  being captured by slow_query_logs. Default is 10 seconds.
        type: number
        minimum: 0
        maximum: 3600
        format: double
      max_allowed_packet:
        required: false
        example:
          value: 67108864
        displayName: max_allowed_packet
        description: The size of the largest message, in bytes, that can be received by the server. Default is 67108864 (64M).
        type: integer
        minimum: 102400
        maximum: 1073741824
        format: int32
      max_heap_table_size:
        required: false
        example:
          value: 16777216
        displayName: max_heap_table_size
        description: The maximum size, in bytes, of internal in-memory tables. Also set tmp_table_size. Default is 16777216 (16M)
        type: integer
        minimum: 1048576
        maximum: 1073741824
        format: int32
      net_read_timeout:
        required: false
        example:
          value: 30
        displayName: net_read_timeout
        description: The time, in seconds, to wait for more data from an existing connection. aborting the read.
        type: integer
        minimum: 1
        maximum: 3600
        format: int32
      net_write_timeout:
        required: false
        example:
          value: 30
        displayName: net_write_timeout
        description: The number of seconds to wait for a block to be written to a connection before aborting the write.
        type: integer
        minimum: 1
        maximum: 3600
        format: int32
      slow_query_log:
        required: false
        example:
          value: true
        displayName: slow_query_log
        description: When enabled, captures slow queries. When disabled, also truncates the mysql.slow_log table. Default is false.
        type: boolean
      sort_buffer_size:
        required: false
        example:
          value: 262144
        displayName: sort_buffer_size
        description: The sort buffer size, in bytes, for ORDER BY optimization. Default is 262144. (256K).
        type: integer
        minimum: 32768
        maximum: 1073741824
        format: int32
      sql_mode:
        required: false
        example:
          value: ANSI,TRADITIONAL
        displayName: sql_mode
        description: Global SQL mode. If empty, uses MySQL server defaults. Must only include uppercase alphabetic characters, underscores, and commas.
        type: string
        pattern: ^[A-Z_]*(,[A-Z_]+)*$
        maxLength: 1024
      sql_require_primary_key:
        required: false
        example:
          value: true
        displayName: sql_require_primary_key
        description: Require primary key to be defined for new tables or old tables modified with ALTER TABLE and fail if missing. It is recommended to always have primary keys because various functionality may break if any large table is missing them.
        type: boolean
      tmp_table_size:
        required: false
        example:
          value: 16777216
        displayName: tmp_table_size
        description: The maximum size, in bytes, of internal in-memory tables. Also set max_heap_table_size. Default is 16777216 (16M).
        type: integer
        minimum: 1048576
        maximum: 1073741824
        format: int32
      wait_timeout:
        required: false
        example:
          value: 28800
        displayName: wait_timeout
        description: The number of seconds the server waits for activity on a noninteractive connection before closing it.
        type: integer
        minimum: 1
        maximum: 2147483
        format: int32
  Config1:
    displayName: Config1
    type: object
    properties:
      autovacuum_analyze_scale_factor:
        required: false
        example:
          value: 0.2
        displayName: autovacuum_analyze_scale_factor
        description: Specifies a fraction, in a decimal value, of the table size to add to autovacuum_analyze_threshold when deciding whether to trigger an ANALYZE. The default is 0.2 (20% of table size).
        type: number
        minimum: 0
        maximum: 1
        format: double
      autovacuum_analyze_threshold:
        required: false
        example:
          value: 50
        displayName: autovacuum_analyze_threshold
        description: Specifies the minimum number of inserted, updated, or deleted tuples needed to trigger an ANALYZE in any one table. The default is 50 tuples.
        type: integer
        minimum: 0
        maximum: 2147483647
        format: int32
      autovacuum_freeze_max_age:
        required: false
        example:
          value: 200000000
        displayName: autovacuum_freeze_max_age
        description: Specifies the maximum age (in transactions) that a table's pg_class.relfrozenxid field can attain before a VACUUM operation is forced to prevent transaction ID wraparound within the table. Note that the system will launch autovacuum processes to prevent wraparound even when autovacuum is otherwise disabled. This parameter will cause the server to be restarted.
        type: integer
        minimum: 200000000
        maximum: 1500000000
        format: int32
      autovacuum_max_workers:
        required: false
        example:
          value: 5
        displayName: autovacuum_max_workers
        description: Specifies the maximum number of autovacuum processes (other than the autovacuum launcher) that may be running at any one time. The default is three. This parameter can only be set at server start.
        type: integer
        minimum: 1
        maximum: 20
        format: int32
      autovacuum_naptime:
        required: false
        example:
          value: 43200
        displayName: autovacuum_naptime
        description: Specifies the minimum delay, in seconds, between autovacuum runs on any given database. The default is one minute.
        type: integer
        minimum: 0
        maximum: 86400
        format: int32
      autovacuum_vacuum_cost_delay:
        required: false
        example:
          value: 20
        displayName: autovacuum_vacuum_cost_delay
        description: Specifies the cost delay value, in milliseconds, that will be used in automatic VACUUM operations. If -1, uses the regular vacuum_cost_delay value, which is 20 milliseconds.
        type: integer
        minimum: -1
        maximum: 100
        format: int32
      autovacuum_vacuum_cost_limit:
        required: false
        example:
          value: -1
        displayName: autovacuum_vacuum_cost_limit
        description: Specifies the cost limit value that will be used in automatic VACUUM operations. If -1 is specified (which is the default), the regular vacuum_cost_limit value will be used.
        type: integer
        minimum: -1
        maximum: 10000
        format: int32
      autovacuum_vacuum_scale_factor:
        required: false
        example:
          value: 0.2
        displayName: autovacuum_vacuum_scale_factor
        description: Specifies a fraction, in a decimal value, of the table size to add to autovacuum_vacuum_threshold when deciding whether to trigger a VACUUM. The default is 0.2 (20% of table size).
        type: number
        minimum: 0
        maximum: 1
        format: double
      autovacuum_vacuum_threshold:
        required: false
        example:
          value: 50
        displayName: autovacuum_vacuum_threshold
        description: Specifies the minimum number of updated or deleted tuples needed to trigger a VACUUM in any one table. The default is 50 tuples.
        type: integer
        minimum: 0
        maximum: 2147483647
        format: int32
      backup_hour:
        required: false
        example:
          value: 3
        displayName: backup_hour
        description: The hour of day (in UTC) when backup for the service starts. New backup only starts if previous backup has already completed.
        type: integer
        minimum: 0
        maximum: 23
        format: int32
      backup_minute:
        required: false
        example:
          value: 30
        displayName: backup_minute
        description: The minute of the backup hour when backup for the service starts. New backup is only started if previous backup has already completed.
        type: integer
        minimum: 0
        maximum: 59
        format: int32
      bgwriter_delay:
        required: false
        example:
          value: 200
        displayName: bgwriter_delay
        description: Specifies the delay, in milliseconds, between activity rounds for the background writer. Default is 200 ms.
        type: integer
        minimum: 10
        maximum: 10000
        format: int32
      bgwriter_flush_after:
        required: false
        example:
          value: 512
        displayName: bgwriter_flush_after
        description: The amount of kilobytes that need to be written by the background writer before attempting to force the OS to issue these writes to underlying storage. Specified in kilobytes, default is 512.  Setting of 0 disables forced writeback.
        type: integer
        minimum: 0
        maximum: 2048
        format: int32
      bgwriter_lru_maxpages:
        required: false
        example:
          value: 100
        displayName: bgwriter_lru_maxpages
        description: The maximum number of buffers that the background writer can write. Setting this to zero disables background writing. Default is 100.
        type: integer
        minimum: 0
        maximum: 1073741823
        format: int32
      bgwriter_lru_multiplier:
        required: false
        example:
          value: 2
        displayName: bgwriter_lru_multiplier
        description: The average recent need for new buffers is multiplied by bgwriter_lru_multiplier to arrive at an estimate of the number that will be needed during the next round, (up to bgwriter_lru_maxpages). 1.0 represents a “just in time” policy of writing exactly the number of buffers predicted to be needed. Larger values provide some cushion against spikes in demand, while smaller values intentionally leave writes to be done by server processes. The default is 2.0.
        type: number
        minimum: 0
        maximum: 10
        format: double
      deadlock_timeout:
        required: false
        example:
          value: 1000
        displayName: deadlock_timeout
        description: The amount of time, in milliseconds, to wait on a lock before checking to see if there is a deadlock condition.
        type: integer
        minimum: 500
        maximum: 1800000
        format: int32
      default_toast_compression:
        required: false
        example:
          value: lz4
        displayName: default_toast_compression
        description: Specifies the default TOAST compression method for values of compressible columns (the default is lz4).
        type: string
        enum:
        - lz4
        - pglz
      idle_in_transaction_session_timeout:
        required: false
        example:
          value: 10000
        displayName: idle_in_transaction_session_timeout
        description: Time out sessions with open transactions after this number of milliseconds
        type: integer
        minimum: 0
        maximum: 604800000
        format: int32
      jit:
        required: false
        example:
          value: true
        displayName: jit
        description: Activates, in a boolean, the system-wide use of Just-in-Time Compilation (JIT).
        type: boolean
      log_autovacuum_min_duration:
        required: false
        example:
          value: -1
        displayName: log_autovacuum_min_duration
        description: Causes each action executed by autovacuum to be logged if it ran for at least the specified number of milliseconds. Setting this to zero logs all autovacuum actions. Minus-one (the default) disables logging autovacuum actions.
        type: integer
        minimum: -1
        maximum: 2147483647
        format: int32
      log_error_verbosity:
        required: false
        example:
          value: VERBOSE
        displayName: log_error_verbosity
        description: Controls the amount of detail written in the server log for each message that is logged.
        type: string
        enum:
        - TERSE
        - DEFAULT
        - VERBOSE
      log_line_prefix:
        required: false
        example:
          value: pid=%p,user=%u,db=%d,app=%a,client=%h
        displayName: log_line_prefix
        description: Selects one of the available log-formats. These can support popular log analyzers like pgbadger, pganalyze, etc.
        type: string
        enum:
        - pid=%p,user=%u,db=%d,app=%a,client=%h
        - '%m [%p] %q[user=%u,db=%d,app=%a]'
        - '%t [%p]: [%l-1] user=%u,db=%d,app=%a,client=%h'
      log_min_duration_statement:
        required: false
        example:
          value: -1
        displayName: log_min_duration_statement
        description: Log statements that take more than this number of milliseconds to run. If -1, disables.
        type: integer
        minimum: -1
        maximum: 86400000
        format: int32
      max_files_per_process:
        required: false
        example:
          value: 2048
        displayName: max_files_per_process
        description: PostgreSQL maximum number of files that can be open per process.
        type: integer
        minimum: 1000
        maximum: 4096
        format: int32
      max_locks_per_transaction:
        required: false
        example:
          value: 128
        displayName: max_locks_per_transaction
        description: PostgreSQL maximum locks per transaction. Once increased, this parameter cannot be lowered from its set value.
        type: integer
        minimum: 64
        maximum: 6400
        format: int32
      max_logical_replication_workers:
        required: false
        example:
          value: 16
        displayName: max_logical_replication_workers
        description: PostgreSQL maximum logical replication workers (taken from the pool of max_parallel_workers).
        type: integer
        minimum: 4
        maximum: 64
        format: int32
      max_parallel_workers:
        required: false
        example:
          value: 12
        displayName: max_parallel_workers
        description: Sets the maximum number of workers that the system can support for parallel queries.
        type: integer
        minimum: 0
        maximum: 96
        format: int32
      max_parallel_workers_per_gather:
        required: false
        example:
          value: 16
        displayName: max_parallel_workers_per_gather
        description: Sets the maximum number of workers that can be started by a single Gather or Gather Merge node.
        type: integer
        minimum: 0
        maximum: 96
        format: int32
      max_pred_locks_per_transaction:
        required: false
        example:
          value: 128
        displayName: max_pred_locks_per_transaction
        description: PostgreSQL maximum predicate locks per transaction.
        type: integer
        minimum: 64
        maximum: 640
        format: int32
      max_prepared_transactions:
        required: false
        example:
          value: 20
        displayName: max_prepared_transactions
        description: PostgreSQL maximum prepared transactions. Once increased, this parameter cannot be lowered from its set value.
        type: integer
        minimum: 0
        maximum: 10000
        format: int32
      max_replication_slots:
        required: false
        example:
          value: 16
        displayName: max_replication_slots
        description: PostgreSQL maximum replication slots.
        type: integer
        minimum: 8
        maximum: 64
        format: int32
      max_stack_depth:
        required: false
        example:
          value: 2097152
        displayName: max_stack_depth
        description: Maximum depth of the stack in bytes.
        type: integer
        minimum: 2097152
        maximum: 6291456
        format: int32
      max_standby_archive_delay:
        required: false
        example:
          value: 43200
        displayName: max_standby_archive_delay
        description: Max standby archive delay in milliseconds.
        type: integer
        minimum: 1
        maximum: 43200000
        format: int32
      max_standby_streaming_delay:
        required: false
        example:
          value: 43200
        displayName: max_standby_streaming_delay
        description: Max standby streaming delay in milliseconds.
        type: integer
        minimum: 1
        maximum: 43200000
        format: int32
      max_wal_senders:
        required: false
        example:
          value: 32
        displayName: max_wal_senders
        description: PostgreSQL maximum WAL senders. Once increased, this parameter cannot be lowered from its set value.
        type: integer
        minimum: 20
        maximum: 64
        format: int32
      max_worker_processes:
        required: false
        example:
          value: 16
        displayName: max_worker_processes
        description: Sets the maximum number of background processes that the system can support. Once increased, this parameter cannot be lowered from its set value.
        type: integer
        minimum: 8
        maximum: 96
        format: int32
      pg_partman_bgw.interval:
        required: false
        example:
          value: 3600
        displayName: pg_partman_bgw.interval
        description: Sets the time interval to run pg_partman's scheduled tasks.
        type: integer
        minimum: 3600
        maximum: 604800
        format: int32
      pg_partman_bgw.role:
        required: false
        example:
          value: myrolename
        displayName: pg_partman_bgw.role
        description: Controls which role to use for pg_partman's scheduled background tasks. Must consist of alpha-numeric characters, dots, underscores, or dashes. May not start with dash or dot. Maximum of 64 characters.
        type: string
        pattern: ^[_A-Za-z0-9][-._A-Za-z0-9]{0,63}$
        maxLength: 64
      pg_stat_statements.track:
        required: false
        example:
          value: all
        displayName: pg_stat_statements.track
        description: Controls which statements are counted. Specify 'top' to track top-level statements (those issued directly by clients), 'all' to also track nested statements (such as statements invoked within functions), or 'none' to disable statement statistics collection. The default value is top.
        type: string
        enum:
        - all
        - top
        - none
      pgbouncer:
        required: false
        displayName: pgbouncer
        description: PGBouncer connection pooling settings
        type: Pgbouncer
      shared_buffers_percentage:
        required: false
        example:
          value: 41.5
        displayName: shared_buffers_percentage
        description: Percentage of total RAM that the database server uses for shared memory buffers.  Valid range is 20-60 (float), which corresponds to 20% - 60%.  This setting adjusts the shared_buffers configuration value.
        type: number
        minimum: 20
        maximum: 60
        format: double
      stat_monitor_enable:
        required: false
        example:
          value: false
        displayName: stat_monitor_enable
        description: Enable the pg_stat_monitor extension. <b>Enabling this extension will cause the cluster to be restarted.</b> When this extension is enabled, pg_stat_statements results for utility commands are unreliable.
        type: boolean
      synchronous_replication:
        required: false
        example:
          value: off
        displayName: synchronous_replication
        description: Synchronous replication type. Note that the service plan also needs to support synchronous replication.
        type: string
        enum:
        - off
        - quorum
      temp_file_limit:
        required: false
        example:
          value: 5000000
        displayName: temp_file_limit
        description: PostgreSQL temporary file limit in KiB. If -1, sets to unlimited.
        type: integer
        minimum: -1
        maximum: 2147483647
        format: int32
      timescaledb:
        required: false
        displayName: timescaledb
        description: TimescaleDB extension configuration values
        type: Timescaledb
      timezone:
        required: false
        example:
          value: Europe/Helsinki
        displayName: timezone
        description: PostgreSQL service timezone
        type: string
        maxLength: 64
      track_activity_query_size:
        required: false
        example:
          value: 1024
        displayName: track_activity_query_size
        description: Specifies the number of bytes reserved to track the currently executing command for each active session.
        type: integer
        minimum: 1024
        maximum: 10240
        format: int32
      track_commit_timestamp:
        required: false
        example:
          value: off
        displayName: track_commit_timestamp
        description: Record commit time of transactions.
        type: string
        enum:
        - off
        - on
      track_functions:
        required: false
        example:
          value: all
        displayName: track_functions
        description: Enables tracking of function call counts and time used.
        type: string
        enum:
        - all
        - pl
        - none
      track_io_timing:
        required: false
        example:
          value: off
        displayName: track_io_timing
        description: Enables timing of database I/O calls. This parameter is off by default, because it will repeatedly query the operating system for the current time, which may cause significant overhead on some platforms.
        type: string
        enum:
        - off
        - on
      wal_sender_timeout:
        required: false
        example:
          value: 60000
        displayName: wal_sender_timeout
        description: Terminate replication connections that are inactive for longer than this amount of time, in milliseconds. Setting this value to zero disables the timeout. Must be either 0 or between 5000 and 10800000.
        type: integer
        minimum: 0
        maximum: 10800000
        format: int32
      wal_writer_delay:
        required: false
        example:
          value: 50
        displayName: wal_writer_delay
        description: WAL flush interval in milliseconds. Note that setting this value to lower than the default 200ms may negatively impact performance
        type: integer
        minimum: 10
        maximum: 200
        format: int32
      work_mem:
        required: false
        example:
          value: 4
        displayName: work_mem
        description: The maximum amount of memory, in MB, used by a query operation (such as a sort or hash table) before writing to temporary disk files. Default is 1MB + 0.075% of total RAM (up to 32MB).
        type: integer
        minimum: 1
        maximum: 1024
        format: int32
  Pgbouncer:
    displayName: Pgbouncer
    description: PGBouncer connection pooling settings
    type: object
    properties:
      autodb_idle_timeout:
        required: false
        example:
          value: 3600
        displayName: autodb_idle_timeout
        description: If the automatically-created database pools have been unused this many seconds, they are freed. If 0, timeout is disabled.
        type: integer
        minimum: 0
        maximum: 86400
        format: int32
      autodb_max_db_connections:
        required: false
        example:
          value: 1
        displayName: autodb_max_db_connections
        description: Only allows a maximum this many server connections per database (regardless of user). If 0, allows unlimited connections.
        type: integer
        minimum: 0
        maximum: 2147483647
        format: int32
      autodb_pool_mode:
        required: false
        example:
          value: session
        displayName: autodb_pool_mode
        description: PGBouncer pool mode
        type: string
        enum:
        - session
        - transaction
        - statement
      autodb_pool_size:
        required: false
        example:
          value: 1
        displayName: autodb_pool_size
        description: If non-zero, automatically creates a pool of that size per user when a pool doesn't exist.
        type: integer
        minimum: 0
        maximum: 10000
        format: int32
      ignore_startup_parameters:
        required: false
        example:
          value:
          - extra_float_digits
          - search_path
        displayName: ignore_startup_parameters
        description: List of parameters to ignore when given in startup packet.
        type: array
        uniqueItems: false
        maxItems: 32
        items:
          type: string
          enum:
          - extra_float_digits
          - search_path
      min_pool_size:
        required: false
        example:
          value: 1
        displayName: min_pool_size
        description: If current server connections are below this number, adds more. Improves behavior when usual load comes suddenly back after period of total inactivity. The value is effectively capped at the pool size.
        type: integer
        minimum: 0
        maximum: 10000
        format: int32
      server_idle_timeout:
        required: false
        example:
          value: 600
        displayName: server_idle_timeout
        description: Drops server connections if they have been idle more than this many seconds.  If 0, timeout is disabled.
        type: integer
        minimum: 0
        maximum: 86400
        format: int32
      server_lifetime:
        required: false
        example:
          value: 3600
        displayName: server_lifetime
        description: The pooler closes any unused server connection that has been connected longer than this amount of seconds.
        type: integer
        minimum: 60
        maximum: 86400
        format: int32
      server_reset_query_always:
        required: false
        example:
          value: false
        displayName: server_reset_query_always
        description: Run server_reset_query (DISCARD ALL) in all pooling modes.
        type: boolean
  Timescaledb:
    displayName: Timescaledb
    description: TimescaleDB extension configuration values
    type: object
    properties:
      max_background_workers:
        required: false
        example:
          value: 8
        displayName: max_background_workers
        description: The number of background workers for timescaledb operations.  Set to the sum of your number of databases and the total number of concurrent background workers you want running at any given point in time.
        type: integer
        minimum: 1
        maximum: 4096
        format: int32
  Config2:
    displayName: Config2
    type: object
    properties:
      redis_acl_channels_default:
        required: false
        example:
          value: allchannels
        displayName: redis_acl_channels_default
        description: Determines default pub/sub channels' ACL for new users if ACL is not supplied. When this option is not defined, all_channels is assumed to keep backward compatibility. This option doesn't affect Redis configuration acl-pubsub-default.
        type: string
        enum:
        - allchannels
        - resetchannels
      redis_io_threads:
        required: false
        example:
          value: 1
        displayName: redis_io_threads
        description: Redis IO thread count
        type: integer
        minimum: 1
        maximum: 32
        format: int32
      redis_lfu_decay_time:
        required: false
        default: '1'
        example:
          value: 1
        displayName: redis_lfu_decay_time
        description: LFU maxmemory-policy counter decay time in minutes
        type: integer
        minimum: 1
        maximum: 120
        format: int32
      redis_lfu_log_factor:
        required: false
        default: '10'
        example:
          value: 10
        displayName: redis_lfu_log_factor
        description: Counter logarithm factor for volatile-lfu and allkeys-lfu maxmemory-policies
        type: integer
        minimum: 0
        maximum: 100
        format: int32
      redis_maxmemory_policy:
        required: false
        example:
          value: allkeys_lru
        displayName: redis_maxmemory_policy
        description: |
          A string specifying the desired eviction policy for the Redis cluster.


          - `noeviction`: Don't evict any data, returns error when memory limit is reached.

          - `allkeys_lru:` Evict any key, least recently used (LRU) first.

          - `allkeys_random`: Evict keys in a random order.

          - `volatile_lru`: Evict keys with expiration only, least recently used (LRU) first.

          - `volatile_random`: Evict keys with expiration only in a random order.

          - `volatile_ttl`: Evict keys with expiration only, shortest time-to-live (TTL) first.
        type: string
        enum:
        - noeviction
        - allkeys_lru
        - allkeys_random
        - volatile_lru
        - volatile_random
        - volatile_ttl
      redis_notify_keyspace_events:
        required: false
        example:
          value: K
        displayName: redis_notify_keyspace_events
        description: Set notify-keyspace-events option
        type: string
        pattern: ^[KEg\$lshzxeA]*$
        maxLength: 32
      redis_number_of_databases:
        required: false
        example:
          value: 16
        displayName: redis_number_of_databases
        description: Set number of redis databases. Changing this will cause a restart of redis service.
        type: integer
        minimum: 1
        maximum: 128
        format: int32
      redis_persistence:
        required: false
        example:
          value: rdb
        displayName: redis_persistence
        description: When persistence is 'rdb', Redis does RDB dumps each 10 minutes if any key is changed. Also RDB dumps are done according to backup schedule for backup purposes. When persistence is 'off', no RDB dumps and backups are done, so data can be lost at any moment if service is restarted for any reason, or if service is powered off. Also service can't be forked.
        type: string
        enum:
        - off
        - rdb
      redis_pubsub_client_output_buffer_limit:
        required: false
        example:
          value: 64
        displayName: redis_pubsub_client_output_buffer_limit
        description: Set output buffer limit for pub / sub clients in MB. The value is the hard limit, the soft limit is 1/4 of the hard limit. When setting the limit, be mindful of the available memory in the selected service plan.
        type: integer
        minimum: 32
        maximum: 512
        format: int32
      redis_ssl:
        required: false
        default: 'true'
        example:
          value: true
        displayName: redis_ssl
        description: Require SSL to access Redis
        type: boolean
      redis_timeout:
        required: false
        default: '300'
        example:
          value: 300
        displayName: redis_timeout
        description: Redis idle connection timeout in seconds
        type: integer
        minimum: 0
        maximum: 31536000
        format: int32
  V2DatabasesConfigRequest:
    displayName: V2DatabasesConfigRequest
    type: object
    properties:
      config:
        required: false
        displayName: config
        type: any
  V2DatabasesDbsResponse:
    displayName: V2DatabasesDbsResponse
    type: object
    properties:
      dbs:
        required: false
        displayName: dbs
        type: array
        items:
          type: Db
  Db:
    displayName: Db
    type: object
    properties:
      name:
        required: true
        example:
          value: alpha
        displayName: name
        description: The name of the database.
        type: string
  V2DatabasesDbsResponse1:
    displayName: V2DatabasesDbsResponse1
    type: object
    properties:
      db:
        required: true
        displayName: db
        type: Db
  V2DatabasesEvictionPolicyResponse:
    displayName: V2DatabasesEvictionPolicyResponse
    type: object
    properties:
      eviction_policy:
        required: true
        example:
          value: allkeys_lru
        displayName: eviction_policy
        description: |
          A string specifying the desired eviction policy for the Redis cluster.


          - `noeviction`: Don't evict any data, returns error when memory limit is reached.

          - `allkeys_lru:` Evict any key, least recently used (LRU) first.

          - `allkeys_random`: Evict keys in a random order.

          - `volatile_lru`: Evict keys with expiration only, least recently used (LRU) first.

          - `volatile_random`: Evict keys with expiration only in a random order.

          - `volatile_ttl`: Evict keys with expiration only, shortest time-to-live (TTL) first.
        type: string
        enum:
        - noeviction
        - allkeys_lru
        - allkeys_random
        - volatile_lru
        - volatile_random
        - volatile_ttl
  V2DatabasesEvictionPolicyRequest:
    displayName: V2DatabasesEvictionPolicyRequest
    type: object
    properties:
      eviction_policy:
        required: true
        example:
          value: allkeys_lru
        displayName: eviction_policy
        description: |
          A string specifying the desired eviction policy for the Redis cluster.


          - `noeviction`: Don't evict any data, returns error when memory limit is reached.

          - `allkeys_lru:` Evict any key, least recently used (LRU) first.

          - `allkeys_random`: Evict keys in a random order.

          - `volatile_lru`: Evict keys with expiration only, least recently used (LRU) first.

          - `volatile_random`: Evict keys with expiration only in a random order.

          - `volatile_ttl`: Evict keys with expiration only, shortest time-to-live (TTL) first.
        type: string
        enum:
        - noeviction
        - allkeys_lru
        - allkeys_random
        - volatile_lru
        - volatile_random
        - volatile_ttl
  V2DatabasesFirewallResponse:
    displayName: V2DatabasesFirewallResponse
    type: object
    properties:
      rules:
        required: false
        displayName: rules
        type: array
        items:
          type: Rule1
  V2DatabasesFirewallRequest:
    displayName: V2DatabasesFirewallRequest
    type: object
    properties:
      rules:
        required: false
        displayName: rules
        type: array
        items:
          type: Rule1
  V2DatabasesMaintenanceRequest:
    displayName: V2DatabasesMaintenanceRequest
    type: object
    properties:
      day:
        required: true
        example:
          value: tuesday
        displayName: day
        description: The day of the week on which to apply maintenance updates.
        type: string
      description:
        required: false
        example:
          value:
          - Update TimescaleDB to version 1.2.1
          - Upgrade to PostgreSQL 11.2 and 10.7 bugfix releases
        displayName: description
        description: A list of strings, each containing information about a pending maintenance update.
        type: array
        items:
          type: string
      hour:
        required: true
        example:
          value: 14:00
        displayName: hour
        description: The hour in UTC at which maintenance updates will be applied in 24 hour format.
        type: string
      pending:
        required: false
        example:
          value: true
        displayName: pending
        description: A boolean value indicating whether any maintenance is scheduled to be performed in the next window.
        type: boolean
  V2DatabasesMigrateRequest:
    example:
      value:
        region: lon1
    displayName: V2DatabasesMigrateRequest
    type: object
    properties:
      region:
        required: true
        example:
          value: lon1
        displayName: region
        description: A slug identifier for the region to which the database cluster will be migrated.
        type: string
  V2DatabasesOnlineMigrationResponse:
    displayName: V2DatabasesOnlineMigrationResponse
    type: object
    properties:
      created_at:
        required: false
        example:
          value: 2020-10-29T15:57:38Z
        displayName: created_at
        description: The time the migration was initiated, in ISO 8601 format.
        type: string
      id:
        required: false
        example:
          value: 77b28fc8-19ff-11eb-8c9c-c68e24557488
        displayName: id
        description: The ID of the most recent migration.
        type: string
      status:
        required: false
        example:
          value: running
        displayName: status
        description: The current status of the migration.
        type: string
        enum:
        - running
        - canceled
        - error
        - done
  V2DatabasesOnlineMigrationRequest:
    displayName: V2DatabasesOnlineMigrationRequest
    type: object
    properties:
      disable_ssl:
        required: false
        example:
          value: false
        displayName: disable_ssl
        description: Enables SSL encryption when connecting to the source database.
        type: boolean
      source:
        required: false
        displayName: source
        type: Source
  Source:
    displayName: Source
    type: object
    properties:
      database:
        required: false
        example:
          value: defaultdb
        displayName: database
        description: The name of the default database.
        type: string
      host:
        required: false
        example:
          value: backend-do-user-19081923-0.db.ondigitalocean.com
        displayName: host
        description: The FQDN pointing to the database cluster's current primary node.
        type: string
      password:
        required: false
        example:
          value: wv78n3zpz42xezdk
        displayName: password
        description: The randomly generated password for the default user.
        type: string
      port:
        required: false
        example:
          value: 25060
        displayName: port
        description: The port on which the database cluster is listening.
        type: integer
        format: int32
      ssl:
        required: false
        example:
          value: true
        displayName: ssl
        description: A boolean value indicating if the connection should be made over SSL.
        type: boolean
      uri:
        required: false
        example:
          value: postgres://doadmin:wv78n3zpz42xezdk@backend-do-user-19081923-0.db.ondigitalocean.com:25060/defaultdb?sslmode=require
        displayName: uri
        description: A connection string in the format accepted by the `psql` command. This is provided as a convenience and should be able to be constructed by the other attributes.
        type: string
      user:
        required: false
        example:
          value: doadmin
        displayName: user
        description: The default user for the database.
        type: string
  V2DatabasesPoolsResponse:
    displayName: V2DatabasesPoolsResponse
    type: object
    properties:
      pools:
        required: false
        displayName: pools
        description: An array of connection pool objects.
        type: array
        items:
          type: Pool
  Pool:
    displayName: Pool
    type: object
    properties:
      connection:
        required: false
        displayName: connection
        type: Connection
      db:
        required: true
        example:
          value: defaultdb
        displayName: db
        description: The database for use with the connection pool.
        type: string
      mode:
        required: true
        example:
          value: transaction
        displayName: mode
        description: The PGBouncer transaction mode for the connection pool. The allowed values are session, transaction, and statement.
        type: string
      name:
        required: true
        example:
          value: backend-pool
        displayName: name
        description: A unique name for the connection pool. Must be between 3 and 60 characters.
        type: string
      private_connection:
        required: false
        displayName: private_connection
        type: PrivateConnection
      size:
        required: true
        example:
          value: 10
        displayName: size
        description: The desired size of the PGBouncer connection pool. The maximum allowed size is determined by the size of the cluster's primary node. 25 backend server connections are allowed for every 1GB of RAM. Three are reserved for maintenance. For example, a primary node with 1 GB of RAM allows for a maximum of 22 backend server connections while one with 4 GB would allow for 97. Note that these are shared across all connection pools in a cluster.
        type: integer
        format: int32
      user:
        required: false
        example:
          value: doadmin
        displayName: user
        description: The name of the user for use with the connection pool. When excluded, all sessions connect to the database as the inbound user.
        type: string
  V2DatabasesPoolsResponse1:
    displayName: V2DatabasesPoolsResponse1
    type: object
    properties:
      pool:
        required: true
        displayName: pool
        type: Pool
  V2DatabasesPoolsRequest:
    displayName: V2DatabasesPoolsRequest
    type: object
    properties:
      db:
        required: true
        example:
          value: defaultdb
        displayName: db
        description: The database for use with the connection pool.
        type: string
      mode:
        required: true
        example:
          value: transaction
        displayName: mode
        description: The PGBouncer transaction mode for the connection pool. The allowed values are session, transaction, and statement.
        type: string
      size:
        required: true
        example:
          value: 10
        displayName: size
        description: The desired size of the PGBouncer connection pool. The maximum allowed size is determined by the size of the cluster's primary node. 25 backend server connections are allowed for every 1GB of RAM. Three are reserved for maintenance. For example, a primary node with 1 GB of RAM allows for a maximum of 22 backend server connections while one with 4 GB would allow for 97. Note that these are shared across all connection pools in a cluster.
        type: integer
        format: int32
      user:
        required: false
        example:
          value: doadmin
        displayName: user
        description: The name of the user for use with the connection pool. When excluded, all sessions connect to the database as the inbound user.
        type: string
  V2DatabasesReplicasResponse:
    displayName: V2DatabasesReplicasResponse
    type: object
    properties:
      replicas:
        required: false
        displayName: replicas
        type: array
        items:
          type: Replica
  Replica:
    displayName: Replica
    type: object
    properties:
      connection:
        required: false
        displayName: connection
        type: Connection
      created_at:
        required: false
        example:
          value: 2019-01-11T18:37:36Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format that represents when the database cluster was created.
        type: datetime
      id:
        required: false
        example:
          value: 9cc10173-e9ea-4176-9dbc-a4cee4c4ff30
        displayName: id
        description: A unique ID that can be used to identify and reference a database replica.
        type: any
      name:
        required: true
        example:
          value: read-nyc3-01
        displayName: name
        description: The name to give the read-only replicating
        type: string
      private_connection:
        required: false
        displayName: private_connection
        type: PrivateConnection
      private_network_uuid:
        required: false
        example:
          value: 9423cbad-9211-442f-820b-ef6915e99b5f
        displayName: private_network_uuid
        description: A string specifying the UUID of the VPC to which the read-only replica will be assigned. If excluded, the replica will be assigned to your account's default VPC for the region.
        type: string
      region:
        required: false
        example:
          value: nyc3
        displayName: region
        description: A slug identifier for the region where the read-only replica will be located. If excluded, the replica will be placed in the same region as the cluster.
        type: string
      size:
        required: false
        example:
          value: db-s-2vcpu-4gb
        displayName: size
        description: A slug identifier representing the size of the node for the read-only replica. The size of the replica must be at least as large as the node size for the database cluster from which it is replicating.
        type: string
      status:
        required: false
        example:
          value: creating
        displayName: status
        description: A string representing the current status of the database cluster.
        type: string
        enum:
        - creating
        - online
        - resizing
        - migrating
        - forking
      tags:
        required: false
        example:
          value:
          - production
        displayName: tags
        description: A flat array of tag names as strings to apply to the read-only replica after it is created. Tag names can either be existing or new tags.
        type: array
        items:
          type: string
  V2DatabasesReplicasResponse1:
    displayName: V2DatabasesReplicasResponse1
    type: object
    properties:
      replica:
        required: false
        displayName: replica
        type: Replica
  V2DatabasesResizeRequest:
    displayName: V2DatabasesResizeRequest
    type: object
    properties:
      num_nodes:
        required: true
        example:
          value: 3
        displayName: num_nodes
        description: The number of nodes in the database cluster. Valid values are are 1-3. In addition to the primary node, up to two standby nodes may be added for highly available configurations.
        type: integer
        format: int32
      size:
        required: true
        example:
          value: db-s-4vcpu-8gb
        displayName: size
        description: A slug identifier representing desired the size of the nodes in the database cluster.
        type: string
  V2DatabasesSqlModeResponse:
    displayName: V2DatabasesSqlModeResponse
    type: object
    properties:
      sql_mode:
        required: true
        example:
          value: ANSI,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE,STRICT_ALL_TABLES
        displayName: sql_mode
        description: A string specifying the configured SQL modes for the MySQL cluster.
        type: string
  V2DatabasesUpgradeRequest:
    displayName: V2DatabasesUpgradeRequest
    type: object
    properties:
      version:
        required: false
        example:
          value: '10'
        displayName: version
        description: A string representing the version of the database engine in use for the cluster.
        type: string
