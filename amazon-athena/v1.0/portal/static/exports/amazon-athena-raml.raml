          "type": "integer",
          "minimum": 10000000.0,
          "format": "int32"
        },
        "RemoveBytesScannedCutoffPerQuery": {
          "type": "boolean"
        },
        "RequesterPaysEnabled": {
          "type": "boolean"
        },
        "EngineVersion": {
          "id": "EngineVersion1",
          "title": "EngineVersion1",
          "type": "object",
          "properties": {
            "SelectedEngineVersion": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "EffectiveEngineVersion": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          }
        },
        "RemoveCustomerContentEncryptionConfiguration": {
          "type": "boolean"
        },
        "AdditionalConfiguration": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "ExecutionRole": {
          "type": "string",
          "minLength": 20,
          "maxLength": 2048,
          "pattern": "^arn:aws[a-z\\-]*:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$"
        },
        "CustomerContentEncryptionConfiguration": {
          "id": "CustomerContentEncryptionConfiguration",
          "title": "CustomerContentEncryptionConfiguration",
          "description": "Specifies the KMS key that is used to encrypt the user's data stores in Athena.",
          "type": "object",
          "properties": {
            "KmsKey": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048,
              "pattern": "^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:key/?[a-zA-Z_0-9+=,.@\\-_/]+$|^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:alias/?[a-zA-Z_0-9+=,.@\\-_/]+$|^alias/[a-zA-Z0-9/_-]+$|[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}"
            }
          },
