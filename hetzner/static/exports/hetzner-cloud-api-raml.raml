                          "format": "int32"
                        }
                      },
                      "required": [
                        "id"
                      ]
                    }
                  },
                  "required": [
                    "type"
                  ]
                }
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object"
              },
              "rules": {
                "description": "Array of rules",
                "example": [
                  {
                    "direction": "in",
                    "port": "80",
                    "protocol": "tcp",
                    "source_ips": [
                      "28.239.13.1/32",
                      "28.239.14.0/24",
                      "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                    ]
                  }
                ],
                "type": "array",
                "items": {
                  "id": "Rule",
                  "title": "Rule",
                  "type": "object",
                  "properties": {
                    "direction": {
                      "title": "Direction",
                      "description": "Select traffic direction on which rule should be applied. Use `source_ips` for direction `in` and `destination_ips` for direction `out`.",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "in",
                        "out"
                      ]
                    },
                    "protocol": {
                      "title": "Protocol",
                      "description": "Type of traffic to allow",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "tcp",
                        "udp",
                        "icmp",
                        "esp",
                        "gre"
                      ]
                    },
                    "description": {
                      "description": "Description of the Rule",
                      "type": [
                        "string",
                        "null"
                      ],
                      "maxLength": 255
                    },
                    "destination_ips": {
                      "description": "List of permitted IPv4/IPv6 addresses in CIDR notation. Use `0.0.0.0/0` to allow all IPv4 addresses and `::/0` to allow all IPv6 addresses. You can specify 100 CIDRs at most.",
                      "example": [
                        "28.239.13.1/32",
                        "28.239.14.0/24",
                        "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                      ],
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "port": {
                      "description": "Port or port range to which traffic will be allowed, only applicable for protocols TCP and UDP. A port range can be specified by separating two ports with a dash, e.g `1024-5000`.",
                      "example": "80",
                      "type": "string"
                    },
                    "source_ips": {
                      "description": "List of permitted IPv4/IPv6 addresses in CIDR notation. Use `0.0.0.0/0` to allow all IPv4 addresses and `::/0` to allow all IPv6 addresses. You can specify 100 CIDRs at most.",
                      "example": [
                        "28.239.13.1/32",
                        "28.239.14.0/24",
                        "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                      ],
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "required": [
                    "direction",
                    "protocol"
                  ]
                }
              }
            },
            "required": [
              "name"
            ]
          }
        example: '{"apply_to":[{"server":{"id":42},"type":"server"}],"labels":{"env":"dev"},"name":"Corporate Intranet Protection","rules":[{"description":"Allow port 80","direction":"in","port":"80","protocol":"tcp","source_ips":["28.239.13.1/32","28.239.14.0/24","ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"]}]}'
