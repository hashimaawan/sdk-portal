          <doc title="403" xml:lang="en">Bad OAuth request (wrong consumer key, bad nonce, expired
timestamp...). Unfortunately, re-authenticating the user won't help here.</doc>
          <representation element="schemas:reorder-or-replace-playlists-tracks403_Response0" mediaType="application/json" />
        </response>
        <response status="429">
          <doc title="429" xml:lang="en">The app has exceeded its rate limits.</doc>
          <representation element="schemas:reorder-or-replace-playlists-tracks429_Response0" mediaType="application/json" />
        </response>
      </method>
