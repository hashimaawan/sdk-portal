/vaults:
  /{vaultUuid}:
    uriParameters:
      vaultUuid:
        description: The UUID of the Vault to fetch Items from
        type: string
        required: true
        displayName: vaultUuid
        pattern: ^[\da-z]{26}$
    /items:
      uriParameters: {}
      /{itemUuid}:
        uriParameters:
          itemUuid:
            description: The UUID of the Item to update
            type: string
            required: true
            displayName: itemUuid
            pattern: ^[\da-z]{26}$
        /files:
          uriParameters: {}
          /{fileUuid}:
            uriParameters:
              fileUuid:
                description: The UUID of the File to fetch
                required: true
                displayName: fileUuid
            /content:
              uriParameters: {}
              get:
                securedBy:
                - ConnectToken
                responses:
                  '200':
                    description: Success
                    headers:
                      Content-Disposition:
                        required: false
                      Content-Length:
                        required: false
                  '401':
                    description: Invalid or missing token
                    body:
                      application/json:
                        schema: |
                          {
                            "id": "ErrorResponse",
                            "title": "ErrorResponse",
                            "example": {
                              "message": "Invalid token signature",
                              "status": 401
                            },
                            "type": "object",
                            "properties": {
                              "message": {
                                "description": "A message detailing the error",
                                "type": "string"
                              },
                              "status": {
                                "description": "HTTP Status Code",
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        example: '{"message":"Invalid token signature","status":401}'
                  '404':
                    description: File not found
                    body:
                      application/json:
                        schema: |
                          {
                            "id": "ErrorResponse",
                            "title": "ErrorResponse",
                            "examples": [
                              {
                                "Id": "fileNotFound",
                                "Name": "File not found",
                                "Value": "{\"message\":\"file {fileUuid} not found\",\"status\":404}",
                                "ExternalValue": null,
                                "Description": null
                              },
                              {
                                "Id": "itemNotFound",
                                "Name": "Item not found",
                                "Value": "{\"message\":\"item {itemUuid} not found\",\"status\":404}",
                                "ExternalValue": null,
                                "Description": null
                              },
                              {
                                "Id": "vaultNotFound",
                                "Name": "Vault not found",
                                "Value": "{\"message\":\"vault {vaultUuid} not found\",\"status\":404}",
                                "ExternalValue": null,
                                "Description": null
                              }
                            ],
                            "example": {
                              "message": "file {fileUuid} not found",
                              "status": 404
                            },
                            "type": "object",
                            "properties": {
                              "message": {
                                "description": "A message detailing the error",
                                "type": "string"
                              },
                              "status": {
                                "description": "HTTP Status Code",
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        example: '{"message":"file {fileUuid} not found","status":404}'
            get:
              securedBy:
              - ConnectToken
              queryParameters:
                inline_files:
                  description: Tells server to return the base64-encoded file contents in the response.
                  type: boolean
                  example: 'true'
                  required: false
                  displayName: inline_files
              responses:
                '200':
                  description: OK
                  body:
                    application/json:
                      schema: |
                        {
                          "id": "File",
                          "title": "File",
                          "example": {
                            "content": "VGhlIGZ1dHVyZSBiZWxvbmdzIHRvIHRoZSBjdXJpb3VzLgo=",
                            "content_path": "v1/vaults/ionaiwtdvgclrixbt6ztpqcxnq/items/p7eflcy7f5mk7vg6zrzf5rjjyu/files/6r65pjq33banznomn7q22sj44e/content",
                            "id": "6r65pjq33banznomn7q22sj44e",
                            "name": "foo.txt",
                            "size": 35
                          },
                          "type": "object",
                          "properties": {
                            "content": {
                              "description": "Base64-encoded contents of the file. Only set if size <= OP_MAX_INLINE_FILE_SIZE_KB kb and `inline_files` is set to `true`.",
                              "type": "string"
                            },
                            "content_path": {
                              "description": "Path of the Connect API that can be used to download the contents of this file.",
                              "readOnly": true,
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the file",
                              "type": "string"
                            },
                            "name": {
                              "description": "Name of the file",
                              "type": "string"
                            },
                            "section": {
                              "id": "Section1",
                              "title": "Section1",
                              "description": "For files that are in a section, this field describes the section.",
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                }
                              }
                            },
                            "size": {
                              "description": "Size in bytes of the file",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
                        }
                '401':
                  description: Invalid or missing token
                  body:
                    application/json:
                      schema: |
                        {
                          "id": "ErrorResponse",
                          "title": "ErrorResponse",
                          "example": {
                            "message": "Invalid token signature",
                            "status": 401
                          },
                          "type": "object",
                          "properties": {
                            "message": {
                              "description": "A message detailing the error",
                              "type": "string"
                            },
                            "status": {
                              "description": "HTTP Status Code",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
