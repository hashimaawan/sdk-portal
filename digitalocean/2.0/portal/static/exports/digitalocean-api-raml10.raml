  HealthCheck:
    displayName: HealthCheck
    type: object
    properties:
      failure_threshold:
        required: false
        example:
          value: 2
        displayName: failure_threshold
        description: The number of failed health checks before considered unhealthy.
        type: integer
        format: int32
      http_path:
        required: false
        example:
          value: /health
        displayName: http_path
        description: The route path used for the HTTP health check ping. If not set, the HTTP health check will be disabled and a TCP health check used instead.
        type: string
      initial_delay_seconds:
        required: false
        example:
          value: 30
        displayName: initial_delay_seconds
        description: The number of seconds to wait before beginning health checks.
        type: integer
        format: int32
      period_seconds:
        required: false
        example:
          value: 60
        displayName: period_seconds
        description: The number of seconds to wait between health checks.
        type: integer
        format: int32
      port:
        required: false
        example:
          value: 80
        displayName: port
        description: The port on which the health check will be performed. If not set, the health check will be performed on the component's http_port.
        type: integer
        minimum: 1
        maximum: 65535
        format: int64
      success_threshold:
        required: false
        example:
          value: 3
        displayName: success_threshold
        description: The number of successful health checks before considered healthy.
        type: integer
        format: int32
      timeout_seconds:
        required: false
        example:
          value: 45
        displayName: timeout_seconds
        description: The number of seconds after which the check times out.
        type: integer
        format: int32
