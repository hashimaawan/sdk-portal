  /top:
    /artists:
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - user-top-read
        description: >
          Get the current user's top artists based on calculated affinity.
        queryParameters:
          time_range:
            type: string
            example: medium_term
            default: medium_term
            required: false
            displayName: time_range
          limit:
            type: integer
            example: '10'
            default: '20'
            required: false
            displayName: limit
            minimum: '1'
            maximum: '50'
          offset:
            type: integer
            example: '5'
            default: '0'
            required: false
            displayName: offset
        responses:
          '200':
            description: Pages of artists
            body:
              application/json:
                schema: |
                  {
                    "id": "PagingArtistObject",
                    "title": "PagingArtistObject",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "A link to the Web API endpoint returning the full result of the request",
                        "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                        "type": "string"
                      },
                      "limit": {
                        "description": "The maximum number of items in the response (as set in the query or by default).",
                        "example": 20,
                        "type": "integer",
                        "format": "int32"
                      },
                      "next": {
                        "description": "URL to the next page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "offset": {
                        "description": "The offset of the items returned (as set in the query or by default)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "previous": {
                        "description": "URL to the previous page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "total": {
                        "description": "The total number of items available to return.",
                        "example": 4,
                        "type": "integer",
                        "format": "int32"
                      },
                      "items": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "ArtistObject",
                          "title": "ArtistObject",
                          "type": "object",
                          "properties": {
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "Known external URLs for this artist.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "followers": {
                              "id": "FollowersObject",
                              "title": "FollowersObject",
                              "description": "Information about the followers of the artist.",
                              "type": "object",
                              "properties": {
                                "href": {
                                  "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "total": {
                                  "description": "The total number of followers.",
                                  "type": "integer",
                                  "format": "int32"
                                }
                              }
                            },
                            "genres": {
                              "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                              "example": [
                                "Prog rock",
                                "Grunge"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the artist.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                              "type": "string"
                            },
                            "images": {
                              "description": "Images of the artist in various sizes, widest first.",
                              "type": "array",
                              "items": {
                                "id": "ImageObject",
                                "title": "ImageObject",
                                "type": "object",
                                "properties": {
                                  "url": {
                                    "description": "The source URL of the image.",
                                    "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                    "type": "string"
                                  },
                                  "height": {
                                    "description": "The image height in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  },
                                  "width": {
                                    "description": "The image width in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "url",
                                  "height",
                                  "width"
                                ]
                              }
                            },
                            "name": {
                              "description": "The name of the artist.",
                              "type": "string"
                            },
                            "popularity": {
                              "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                              "type": "integer",
                              "format": "int32"
                            },
                            "type": {
                              "title": "Type",
                              "description": "The object type.",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "artist"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                              "type": "string"
                            }
                          }
                        }
                      }
                    },
                    "required": [
                      "href",
                      "limit",
                      "next",
                      "offset",
                      "previous",
                      "total",
                      "items"
                    ]
                  }
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                schema: |
                  {
                    "id": "Unauthorized1",
                    "title": "Unauthorized1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                schema: |
                  {
                    "id": "Forbidden1",
                    "title": "Forbidden1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
                    "id": "TooManyRequests1",
                    "title": "TooManyRequests1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
    /tracks:
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - user-top-read
        description: >
          Get the current user's top tracks based on calculated affinity.
        queryParameters:
          time_range:
            type: string
            example: medium_term
            default: medium_term
            required: false
            displayName: time_range
          limit:
            type: integer
            example: '10'
            default: '20'
            required: false
            displayName: limit
            minimum: '1'
            maximum: '50'
          offset:
            type: integer
            example: '5'
            default: '0'
            required: false
            displayName: offset
        responses:
          '200':
            description: Pages of tracks
            body:
              application/json:
                schema: |
                  {
                    "id": "PagingTrackObject",
                    "title": "PagingTrackObject",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "A link to the Web API endpoint returning the full result of the request",
                        "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                        "type": "string"
                      },
                      "limit": {
                        "description": "The maximum number of items in the response (as set in the query or by default).",
                        "example": 20,
                        "type": "integer",
                        "format": "int32"
                      },
                      "next": {
                        "description": "URL to the next page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "offset": {
                        "description": "The offset of the items returned (as set in the query or by default)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "previous": {
                        "description": "URL to the previous page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "total": {
                        "description": "The total number of items available to return.",
                        "example": 4,
                        "type": "integer",
                        "format": "int32"
                      },
                      "items": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "TrackObject",
                          "title": "TrackObject",
                          "type": "object",
                          "properties": {
                            "album": {
                              "id": "SimplifiedAlbumObject",
                              "title": "SimplifiedAlbumObject",
                              "description": "The album on which the track appears. The album object includes a link in `href` to full information about the album.",
                              "type": "object",
                              "properties": {
                                "album_type": {
                                  "title": "AlbumType",
                                  "description": "The type of the album.",
                                  "example": "compilation",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "album",
                                    "single",
                                    "compilation"
                                  ]
                                },
                                "total_tracks": {
                                  "description": "The number of tracks in the album.",
                                  "example": 9,
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "available_markets": {
                                  "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                                  "example": [
                                    "CA",
                                    "BR",
                                    "IT"
                                  ],
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "external_urls": {
                                  "id": "ExternalUrlObject",
                                  "title": "ExternalUrlObject",
                                  "description": "Known external URLs for this track.",
                                  "type": "object",
                                  "properties": {
                                    "spotify": {
                                      "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                      "type": "string"
                                    }
                                  }
                                },
                                "href": {
                                  "description": "A link to the Web API endpoint providing full details of the album.",
                                  "type": "string"
                                },
                                "id": {
                                  "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                  "example": "2up3OPMp9Tb4dAKM2erWXQ",
                                  "type": "string"
                                },
                                "images": {
                                  "description": "The cover art for the album in various sizes, widest first.",
                                  "type": "array",
                                  "items": {
                                    "id": "ImageObject",
                                    "title": "ImageObject",
                                    "type": "object",
                                    "properties": {
                                      "url": {
                                        "description": "The source URL of the image.",
                                        "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                        "type": "string"
                                      },
                                      "height": {
                                        "description": "The image height in pixels.",
                                        "example": 300,
                                        "type": [
                                          "integer",
                                          "null"
                                        ],
                                        "format": "int32"
                                      },
                                      "width": {
                                        "description": "The image width in pixels.",
                                        "example": 300,
                                        "type": [
                                          "integer",
                                          "null"
                                        ],
                                        "format": "int32"
                                      }
                                    },
                                    "required": [
                                      "url",
                                      "height",
                                      "width"
                                    ]
                                  }
                                },
                                "name": {
                                  "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                                  "type": "string"
                                },
                                "release_date": {
                                  "description": "The date the album was first released.",
                                  "example": "1981-12",
                                  "type": "string"
                                },
                                "release_date_precision": {
                                  "title": "ReleaseDatePrecision",
                                  "description": "The precision with which `release_date` value is known.",
                                  "example": "year",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "year",
                                    "month",
                                    "day"
                                  ]
                                },
                                "type": {
                                  "description": "The object type.",
                                  "type": "string",
                                  "enum": [
                                    "album"
                                  ]
                                },
                                "uri": {
                                  "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                  "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                                  "type": "string"
                                },
                                "artists": {
                                  "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                                  "type": "array",
                                  "items": {
                                    "id": "SimplifiedArtistObject",
                                    "title": "SimplifiedArtistObject",
                                    "type": "object",
                                    "properties": {
                                      "external_urls": {
                                        "$ref": "ExternalUrlObject"
                                      },
                                      "href": {
                                        "description": "A link to the Web API endpoint providing full details of the artist.",
                                        "type": "string"
                                      },
                                      "id": {
                                        "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                        "type": "string"
                                      },
                                      "name": {
                                        "description": "The name of the artist.",
                                        "type": "string"
                                      },
                                      "type": {
                                        "title": "Type",
                                        "description": "The object type.",
                                        "type": "string",
                                        "additionalProperties": false,
                                        "enum": [
                                          "artist"
                                        ]
                                      },
                                      "uri": {
                                        "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                        "type": "string"
                                      }
                                    }
                                  }
                                },
                                "restrictions": {
                                  "id": "AlbumRestrictionObject",
                                  "title": "AlbumRestrictionObject",
                                  "description": "Included in the response when a content restriction is applied.",
                                  "type": "object",
                                  "properties": {
                                    "reason": {
                                      "title": "Reason",
                                      "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "market",
                                        "product",
                                        "explicit"
                                      ]
                                    }
                                  }
                                }
                              },
                              "required": [
                                "album_type",
                                "total_tracks",
                                "available_markets",
                                "external_urls",
                                "href",
                                "id",
                                "images",
                                "name",
                                "release_date",
                                "release_date_precision",
                                "type",
                                "uri",
                                "artists"
                              ]
                            },
                            "artists": {
                              "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                              "type": "array",
                              "items": {
                                "id": "ArtistObject",
                                "title": "ArtistObject",
                                "type": "object",
                                "properties": {
                                  "external_urls": {
                                    "$ref": "ExternalUrlObject"
                                  },
                                  "followers": {
                                    "id": "FollowersObject",
                                    "title": "FollowersObject",
                                    "description": "Information about the followers of the artist.",
                                    "type": "object",
                                    "properties": {
                                      "href": {
                                        "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "total": {
                                        "description": "The total number of followers.",
                                        "type": "integer",
                                        "format": "int32"
                                      }
                                    }
                                  },
                                  "genres": {
                                    "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                                    "example": [
                                      "Prog rock",
                                      "Grunge"
                                    ],
                                    "type": "array",
                                    "items": {
                                      "type": "string"
                                    }
                                  },
                                  "href": {
                                    "description": "A link to the Web API endpoint providing full details of the artist.",
                                    "type": "string"
                                  },
                                  "id": {
                                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  },
                                  "images": {
                                    "description": "Images of the artist in various sizes, widest first.",
                                    "type": "array",
                                    "items": {
                                      "$ref": "ImageObject"
                                    }
                                  },
                                  "name": {
                                    "description": "The name of the artist.",
                                    "type": "string"
                                  },
                                  "popularity": {
                                    "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "type": {
                                    "$ref": "SimplifiedArtistObject#/properties/type"
                                  },
                                  "uri": {
                                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  }
                                }
                              }
                            },
                            "available_markets": {
                              "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "disc_number": {
                              "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                              "type": "integer",
                              "format": "int32"
                            },
                            "duration_ms": {
                              "description": "The track length in milliseconds.",
                              "type": "integer",
                              "format": "int32"
                            },
                            "explicit": {
                              "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                              "type": "boolean"
                            },
                            "external_ids": {
                              "id": "ExternalIdObject",
                              "title": "ExternalIdObject",
                              "description": "Known external IDs for the track.",
                              "type": "object",
                              "properties": {
                                "isrc": {
                                  "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                                  "type": "string"
                                },
                                "ean": {
                                  "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                                  "type": "string"
                                },
                                "upc": {
                                  "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                                  "type": "string"
                                }
                              }
                            },
                            "external_urls": {
                              "$ref": "ExternalUrlObject"
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the track.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            },
                            "is_playable": {
                              "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                              "type": "boolean"
                            },
                            "linked_from": {
                              "id": "LinkedTrackObject",
                              "title": "LinkedTrackObject",
                              "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied, and the requested track has been replaced with different track. The track in the `linked_from` object contains information about the originally requested track.",
                              "type": "object",
                              "properties": {
                                "external_urls": {
                                  "$ref": "ExternalUrlObject"
                                },
                                "href": {
                                  "description": "A link to the Web API endpoint providing full details of the track.",
                                  "type": "string"
                                },
                                "id": {
                                  "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                  "type": "string"
                                },
                                "type": {
                                  "description": "The object type: \"track\".",
                                  "type": "string"
                                },
                                "uri": {
                                  "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                  "type": "string"
                                }
                              }
                            },
                            "restrictions": {
                              "id": "TrackRestrictionObject",
                              "title": "TrackRestrictionObject",
                              "description": "Included in the response when a content restriction is applied.",
                              "type": "object",
                              "properties": {
                                "reason": {
                                  "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                                  "type": "string"
                                }
                              }
                            },
                            "name": {
                              "description": "The name of the track.",
                              "type": "string"
                            },
                            "popularity": {
                              "description": "The popularity of the track. The value will be between 0 and 100, with 100 being the most popular.<br/>The popularity of a track is a value between 0 and 100, with 100 being the most popular. The popularity is calculated by algorithm and is based, in the most part, on the total number of plays the track has had and how recent those plays are.<br/>Generally speaking, songs that are being played a lot now will have a higher popularity than songs that were played a lot in the past. Duplicate tracks (e.g. the same track from a single and an album) are rated independently. Artist and album popularity is derived mathematically from track popularity. _**Note**: the popularity value may lag actual popularity by a few days: the value is not updated in real time._",
                              "type": "integer",
                              "format": "int32"
                            },
                            "preview_url": {
                              "description": "A link to a 30 second preview (MP3 format) of the track. Can be `null`",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "track_number": {
                              "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                              "type": "integer",
                              "format": "int32"
                            },
                            "type": {
                              "title": "Type2",
                              "description": "The object type: \"track\".",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "track"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            },
                            "is_local": {
                              "description": "Whether or not the track is from a local file.",
                              "type": "boolean"
                            }
                          }
                        }
                      }
                    },
                    "required": [
                      "href",
                      "limit",
                      "next",
                      "offset",
                      "previous",
                      "total",
                      "items"
                    ]
                  }
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                schema: |
                  {
                    "id": "Unauthorized1",
                    "title": "Unauthorized1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                schema: |
                  {
                    "id": "Forbidden1",
                    "title": "Forbidden1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
                    "id": "TooManyRequests1",
                    "title": "TooManyRequests1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
  get:
    securedBy:
    - oauth_2_0:
        scopes:
        - user-read-private
        - user-read-email
    description: >
      Get detailed profile information about the current user (including the

      current user's username).
    responses:
      '200':
        description: A user
        body:
          application/json:
            schema: |
              {
                "id": "PrivateUserObject",
                "title": "PrivateUserObject",
                "type": "object",
                "properties": {
                  "country": {
                    "description": "The country of the user, as set in the user's account profile. An [ISO 3166-1 alpha-2 country code](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _This field is only available when the current user has granted access to the [user-read-private](/documentation/web-api/concepts/scopes/#list-of-scopes) scope._",
                    "type": "string"
                  },
                  "display_name": {
                    "description": "The name displayed on the user's profile. `null` if not available.",
                    "type": "string"
                  },
                  "email": {
                    "description": "The user's email address, as entered by the user when creating their account. _**Important!** This email address is unverified; there is no proof that it actually belongs to the user._ _This field is only available when the current user has granted access to the [user-read-email](/documentation/web-api/concepts/scopes/#list-of-scopes) scope._",
                    "type": "string"
                  },
                  "explicit_content": {
                    "id": "ExplicitContentSettingsObject",
                    "title": "ExplicitContentSettingsObject",
                    "description": "The user's explicit content settings. _This field is only available when the current user has granted access to the [user-read-private](/documentation/web-api/concepts/scopes/#list-of-scopes) scope._",
                    "type": "object",
                    "properties": {
                      "filter_enabled": {
                        "description": "When `true`, indicates that explicit content should not be played.",
                        "type": "boolean"
                      },
                      "filter_locked": {
                        "description": "When `true`, indicates that the explicit content setting is locked and can't be changed by the user.",
                        "type": "boolean"
                      }
                    }
                  },
                  "external_urls": {
                    "id": "ExternalUrlObject",
                    "title": "ExternalUrlObject",
                    "description": "Known external URLs for this user.",
                    "type": "object",
                    "properties": {
                      "spotify": {
                        "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                        "type": "string"
                      }
                    }
                  },
                  "followers": {
                    "id": "FollowersObject",
                    "title": "FollowersObject",
                    "description": "Information about the followers of the user.",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "This will always be set to null, as the Web API does not support it at the moment.",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "total": {
                        "description": "The total number of followers.",
                        "type": "integer",
                        "format": "int32"
                      }
                    }
                  },
                  "href": {
                    "description": "A link to the Web API endpoint for this user.",
                    "type": "string"
                  },
                  "id": {
                    "description": "The [Spotify user ID](/documentation/web-api/concepts/spotify-uris-ids) for the user.",
                    "type": "string"
                  },
                  "images": {
                    "description": "The user's profile image.",
                    "type": "array",
                    "items": {
                      "id": "ImageObject",
                      "title": "ImageObject",
                      "type": "object",
                      "properties": {
                        "url": {
                          "description": "The source URL of the image.",
                          "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                          "type": "string"
                        },
                        "height": {
                          "description": "The image height in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "width": {
                          "description": "The image width in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        }
                      },
                      "required": [
                        "url",
                        "height",
                        "width"
                      ]
                    }
                  },
                  "product": {
                    "description": "The user's Spotify subscription level: \"premium\", \"free\", etc. (The subscription level \"open\" can be considered the same as \"free\".) _This field is only available when the current user has granted access to the [user-read-private](/documentation/web-api/concepts/scopes/#list-of-scopes) scope._",
                    "type": "string"
                  },
                  "type": {
                    "description": "The object type: \"user\"",
                    "type": "string"
                  },
                  "uri": {
                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the user.",
                    "type": "string"
                  }
                }
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/browse:
  /new-releases:
    get:
      securedBy:
      - oauth_2_0
      description: >
        Get a list of new album releases featured in Spotify (shown, for example, on a Spotify player’s “Browse” tab).
      queryParameters:
        limit:
          type: integer
          example: '10'
          default: '20'
          required: false
          displayName: limit
          minimum: '1'
          maximum: '50'
        offset:
          type: integer
          example: '5'
          default: '0'
          required: false
          displayName: offset
      responses:
        '200':
          description: A paged set of albums
          body:
            application/json:
              schema: |
                {
                  "id": "PagedAlbums",
                  "title": "PagedAlbums",
                  "type": "object",
                  "properties": {
                    "albums": {
                      "id": "PagingSimplifiedAlbumObject",
                      "title": "PagingSimplifiedAlbumObject",
                      "type": "object",
                      "properties": {
                        "href": {
                          "description": "A link to the Web API endpoint returning the full result of the request",
                          "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                          "type": "string"
                        },
                        "limit": {
                          "description": "The maximum number of items in the response (as set in the query or by default).",
                          "example": 20,
                          "type": "integer",
                          "format": "int32"
                        },
                        "next": {
                          "description": "URL to the next page of items. ( `null` if none)",
                          "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "offset": {
                          "description": "The offset of the items returned (as set in the query or by default)",
                          "example": 0,
                          "type": "integer",
                          "format": "int32"
                        },
                        "previous": {
                          "description": "URL to the previous page of items. ( `null` if none)",
                          "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "total": {
                          "description": "The total number of items available to return.",
                          "example": 4,
                          "type": "integer",
                          "format": "int32"
                        },
                        "items": {
                          "description": "",
                          "type": "array",
                          "items": {
                            "id": "SimplifiedAlbumObject",
                            "title": "SimplifiedAlbumObject",
                            "type": "object",
                            "properties": {
                              "album_type": {
                                "title": "AlbumType",
                                "description": "The type of the album.",
                                "example": "compilation",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "album",
                                  "single",
                                  "compilation"
                                ]
                              },
                              "total_tracks": {
                                "description": "The number of tracks in the album.",
                                "example": 9,
                                "type": "integer",
                                "format": "int32"
                              },
                              "available_markets": {
                                "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                                "example": [
                                  "CA",
                                  "BR",
                                  "IT"
                                ],
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "external_urls": {
                                "id": "ExternalUrlObject",
                                "title": "ExternalUrlObject",
                                "description": "Known external URLs for this artist.",
                                "type": "object",
                                "properties": {
                                  "spotify": {
                                    "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                    "type": "string"
                                  }
                                }
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the album.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                "example": "2up3OPMp9Tb4dAKM2erWXQ",
                                "type": "string"
                              },
                              "images": {
                                "description": "The cover art for the album in various sizes, widest first.",
                                "type": "array",
                                "items": {
                                  "id": "ImageObject",
                                  "title": "ImageObject",
                                  "type": "object",
                                  "properties": {
                                    "url": {
                                      "description": "The source URL of the image.",
                                      "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                      "type": "string"
                                    },
                                    "height": {
                                      "description": "The image height in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    },
                                    "width": {
                                      "description": "The image width in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    }
                                  },
                                  "required": [
                                    "url",
                                    "height",
                                    "width"
                                  ]
                                }
                              },
                              "name": {
                                "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                                "type": "string"
                              },
                              "release_date": {
                                "description": "The date the album was first released.",
                                "example": "1981-12",
                                "type": "string"
                              },
                              "release_date_precision": {
                                "title": "ReleaseDatePrecision",
                                "description": "The precision with which `release_date` value is known.",
                                "example": "year",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "year",
                                  "month",
                                  "day"
                                ]
                              },
                              "type": {
                                "description": "The object type.",
                                "type": "string",
                                "enum": [
                                  "album"
                                ]
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                                "type": "string"
                              },
                              "artists": {
                                "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                                "type": "array",
                                "items": {
                                  "id": "SimplifiedArtistObject",
                                  "title": "SimplifiedArtistObject",
                                  "type": "object",
                                  "properties": {
                                    "external_urls": {
                                      "$ref": "ExternalUrlObject"
                                    },
                                    "href": {
                                      "description": "A link to the Web API endpoint providing full details of the artist.",
                                      "type": "string"
                                    },
                                    "id": {
                                      "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                      "type": "string"
                                    },
                                    "name": {
                                      "description": "The name of the artist.",
                                      "type": "string"
                                    },
                                    "type": {
                                      "title": "Type",
                                      "description": "The object type.",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "artist"
                                      ]
                                    },
                                    "uri": {
                                      "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                      "type": "string"
                                    }
                                  }
                                }
                              },
                              "restrictions": {
                                "id": "AlbumRestrictionObject",
                                "title": "AlbumRestrictionObject",
                                "description": "Included in the response when a content restriction is applied.",
                                "type": "object",
                                "properties": {
                                  "reason": {
                                    "title": "Reason",
                                    "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "market",
                                      "product",
                                      "explicit"
                                    ]
                                  }
                                }
                              }
                            },
                            "required": [
                              "album_type",
                              "total_tracks",
                              "available_markets",
                              "external_urls",
                              "href",
                              "id",
                              "images",
                              "name",
                              "release_date",
                              "release_date_precision",
                              "type",
                              "uri",
                              "artists"
                            ]
                          }
                        }
                      },
                      "required": [
                        "href",
                        "limit",
                        "next",
                        "offset",
                        "previous",
                        "total",
                        "items"
                      ]
                    }
                  },
                  "required": [
                    "albums"
                  ]
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
  /categories:
    /{category_id}:
      uriParameters:
        category_id:
          type: string
          example: dinner
          required: true
          displayName: category_id
      /playlists:
        uriParameters: {}
        get:
          securedBy:
          - oauth_2_0
          description: >
            Get a list of Spotify playlists tagged with a particular category.
          queryParameters:
            limit:
              type: integer
              example: '10'
              default: '20'
              required: false
              displayName: limit
              minimum: '1'
              maximum: '50'
            offset:
              type: integer
              example: '5'
              default: '0'
              required: false
              displayName: offset
          responses:
            '200':
              description: A paged set of playlists
              body:
                application/json:
                  schema: |
                    {
                      "id": "PagingFeaturedPlaylistObject",
                      "title": "PagingFeaturedPlaylistObject",
                      "type": "object",
                      "properties": {
                        "message": {
                          "description": "The localized message of a playlist.",
                          "example": "Popular Playlists",
                          "type": "string"
                        },
                        "playlists": {
                          "id": "PagingPlaylistObject",
                          "title": "PagingPlaylistObject",
                          "type": "object",
                          "properties": {
                            "href": {
                              "description": "A link to the Web API endpoint returning the full result of the request",
                              "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                              "type": "string"
                            },
                            "limit": {
                              "description": "The maximum number of items in the response (as set in the query or by default).",
                              "example": 20,
                              "type": "integer",
                              "format": "int32"
                            },
                            "next": {
                              "description": "URL to the next page of items. ( `null` if none)",
                              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                              "type": [
