      /set_rules:
        uriParameters: {}
        post:
          description: >
            Sets the rules of a Firewall.


            All existing rules will be overwritten. Pass an empty `rules` array to remove all rules.

            The maximum amount of rules that can be defined is 50.


            #### Call specific error codes


            | Code                          | Description                                                   |

            |-------------------------------|---------------------------------------------------------------|

            | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              enum:
              - application/json
          body:
            application/json:
              schema: |
                {
                  "id": "SetRulesRequest",
                  "title": "SetRulesRequest",
                  "examples": [
                    {
                      "Id": "rules",
                      "Name": null,
                      "Value": "{\"rules\":[{\"description\":\"Allow port 80\",\"direction\":\"in\",\"port\":\"80\",\"protocol\":\"tcp\",\"source_ips\":[\"28.239.13.1/32\",\"28.239.14.0/24\",\"ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128\"]}]}",
                      "ExternalValue": null,
                      "Description": null
                    }
                  ],
                  "example": {
                    "rules": [
                      {
                        "description": "Allow port 80",
                        "direction": "in",
                        "port": "80",
                        "protocol": "tcp",
                        "source_ips": [
                          "28.239.13.1/32",
                          "28.239.14.0/24",
                          "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                        ]
                      }
                    ]
                  },
                  "type": "object",
                  "properties": {
                    "rules": {
                      "description": "Array of rules",
                      "type": "array",
                      "items": {
                        "id": "Rule",
                        "title": "Rule",
                        "type": "object",
                        "properties": {
                          "direction": {
                            "title": "Direction",
                            "description": "Select traffic direction on which rule should be applied. Use `source_ips` for direction `in` and `destination_ips` for direction `out`.",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "in",
                              "out"
                            ]
                          },
                          "protocol": {
                            "title": "Protocol",
                            "description": "Type of traffic to allow",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "tcp",
                              "udp",
                              "icmp",
                              "esp",
                              "gre"
                            ]
                          },
                          "description": {
                            "description": "Description of the Rule",
                            "type": [
                              "string",
                              "null"
                            ],
                            "maxLength": 255
                          },
                          "destination_ips": {
                            "description": "List of permitted IPv4/IPv6 addresses in CIDR notation. Use `0.0.0.0/0` to allow all IPv4 addresses and `::/0` to allow all IPv6 addresses. You can specify 100 CIDRs at most.",
                            "example": [
                              "28.239.13.1/32",
                              "28.239.14.0/24",
                              "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                            ],
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "port": {
                            "description": "Port or port range to which traffic will be allowed, only applicable for protocols TCP and UDP. A port range can be specified by separating two ports with a dash, e.g `1024-5000`.",
                            "example": "80",
                            "type": "string"
                          },
                          "source_ips": {
                            "description": "List of permitted IPv4/IPv6 addresses in CIDR notation. Use `0.0.0.0/0` to allow all IPv4 addresses and `::/0` to allow all IPv6 addresses. You can specify 100 CIDRs at most.",
                            "example": [
                              "28.239.13.1/32",
                              "28.239.14.0/24",
                              "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                            ],
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        },
                        "required": [
                          "direction",
                          "protocol"
                        ]
                      },
                      "maxItems": 50
                    }
                  },
                  "required": [
                    "rules"
                  ]
                }
              example: '{"rules":[{"description":"Allow port 80","direction":"in","port":"80","protocol":"tcp","source_ips":["28.239.13.1/32","28.239.14.0/24","ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"]}]}'
          responses:
            '201':
              description: The `action` key contains one `set_firewall_rules` Action plus one `apply_firewall` Action per resource where the Firewall is active
              body:
                application/json:
                  schema: |
                    {
                      "id": "ActionsResponse",
                      "title": "ActionsResponse",
                      "example": {
