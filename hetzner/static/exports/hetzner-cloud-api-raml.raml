                example: '{"actions":[{"command":"issue_certificate","error":{"code":"action_failed","message":"Action failed"},"finished":"2021-01-30T23:57:00+00:00","id":14,"progress":100,"resources":[{"id":896,"type":"certificate"}],"started":"2021-01-30T23:55:00+00:00","status":"success"}]}'
    delete:
      description: Deletes a Certificate.
      responses:
        '204':
          description: Certificate deleted
    get:
      description: Gets a specific Certificate object.
      responses:
        '200':
          description: The `certificate` key contains a Certificate object
          body:
            application/json:
              schema: |
                {
                  "id": "CertificateResponse",
                  "title": "CertificateResponse",
                  "example": {
                    "certificate": {
                      "certificate": "-----BEGIN CERTIFICATE-----\n...",
                      "created": "2019-01-08T12:10:00+00:00",
                      "domain_names": [
                        "example.com",
                        "webmail.example.com",
                        "www.example.com"
                      ],
                      "fingerprint": "03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f",
                      "id": 897,
                      "labels": {
                        "env": "dev"
                      },
                      "name": "my website cert",
                      "not_valid_after": "2019-07-08T09:59:59+00:00",
                      "not_valid_before": "2019-01-08T10:00:00+00:00",
                      "status": null,
                      "type": "uploaded",
                      "used_by": [
                        {
                          "id": 4711,
                          "type": "load_balancer"
                        }
                      ]
                    }
                  },
                  "type": "object",
                  "properties": {
                    "certificate": {
                      "id": "Certificate",
                      "title": "Certificate",
                      "type": "object",
                      "properties": {
                        "certificate": {
                          "description": "Certificate and chain in PEM format, in order so that each record directly certifies the one preceding",
                          "example": "-----BEGIN CERTIFICATE-----\n...",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "domain_names": {
                          "description": "Domains and subdomains covered by the Certificate",
                          "example": [
                            "example.com",
                            "webmail.example.com",
                            "www.example.com"
                          ],
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "fingerprint": {
                          "description": "SHA256 fingerprint of the Certificate",
                          "example": "03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "not_valid_after": {
                          "description": "Point in time when the Certificate stops being valid (in ISO-8601 format)",
                          "example": "2019-07-08T09:59:59+00:00",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "not_valid_before": {
                          "description": "Point in time when the Certificate becomes valid (in ISO-8601 format)",
                          "example": "2019-01-08T10:00:00+00:00",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "used_by": {
                          "description": "Resources currently using the Certificate",
                          "type": "array",
                          "items": {
                            "id": "UsedBy",
                            "title": "UsedBy",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "ID of resource referenced",
                                "example": 4711,
                                "type": "integer",
                                "format": "int32"
                              },
                              "type": {
                                "description": "Type of resource referenced",
                                "example": "load_balancer",
                                "type": "string"
                              }
                            },
                            "required": [
                              "id",
                              "type"
                            ]
                          }
                        },
                        "status": {
                          "id": "Status2",
                          "title": "Status2",
                          "description": "Current status of a type `managed` Certificate, always *null* for type `uploaded` Certificates",
                          "type": [
                            "object",
                            "null"
                          ],
                          "properties": {
                            "error": {
                              "id": "Error2",
                              "title": "Error2",
                              "description": "If issuance or renewal reports `failed`, this property contains information about what happened",
                              "type": [
                                "object",
                                "null"
                              ],
                              "properties": {
                                "code": {
                                  "type": "string"
                                },
                                "message": {
                                  "type": "string"
                                }
                              }
                            },
                            "issuance": {
                              "title": "Issuance",
                              "description": "Status of the issuance process of the Certificate",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "pending",
                                "completed",
                                "failed"
                              ]
                            },
                            "renewal": {
                              "title": "Renewal",
                              "description": "Status of the renewal process of the Certificate.",
                              "example": "scheduled",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "scheduled",
                                "pending",
                                "failed",
                                "unavailable"
                              ]
                            }
                          }
                        },
                        "type": {
                          "title": "Type",
                          "description": "Type of the Certificate",
                          "example": "uploaded",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "uploaded",
                            "managed"
                          ]
                        }
                      },
                      "required": [
                        "certificate",
                        "created",
                        "domain_names",
                        "fingerprint",
                        "id",
                        "labels",
                        "name",
                        "not_valid_after",
                        "not_valid_before",
                        "used_by"
                      ]
                    }
                  },
                  "required": [
                    "certificate"
                  ]
                }
              example: '{"certificate":{"certificate":"-----BEGIN CERTIFICATE-----\n...","created":"2019-01-08T12:10:00+00:00","domain_names":["example.com","webmail.example.com","www.example.com"],"fingerprint":"03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f","id":897,"labels":{"env":"dev"},"name":"my website cert","not_valid_after":"2019-07-08T09:59:59+00:00","not_valid_before":"2019-01-08T10:00:00+00:00","status":null,"type":"uploaded","used_by":[{"id":4711,"type":"load_balancer"}]}}'
    put:
      description: >
        Updates the Certificate properties.


        Note that when updating labels, the Certificate’s current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.


        Note: if the Certificate object changes during the request, the response will be a “conflict” error.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "UpdateCertificateRequest",
              "title": "UpdateCertificateRequest",
              "type": "object",
              "properties": {
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "example": {
                    "labelkey": "value"
                  },
                  "type": "object"
                },
                "name": {
                  "description": "New Certificate name",
                  "example": "my website cert",
                  "type": "string"
                }
              }
            }
          example: ''
      responses:
        '200':
          description: The `certificate` key contains the Certificate that was just updated
