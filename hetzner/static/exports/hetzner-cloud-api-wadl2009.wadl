            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="deleted" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Point in time where the Image was deleted (in ISO-8601 format)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="deprecated" nillable="true" type="xs:string">
            <xs:annotation>
