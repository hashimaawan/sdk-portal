    get:
      securedBy:
      - oauth_2_0
      description: >
        Get a list of categories used to tag items in Spotify (on, for example, the Spotify player’s “Browse” tab).
      queryParameters:
        locale:
          type: string
          example: sv_SE
          required: false
          displayName: locale
        limit:
          type: integer
          example: '10'
          default: '20'
          required: false
          displayName: limit
          minimum: '1'
          maximum: '50'
        offset:
          type: integer
          example: '5'
          default: '0'
          required: false
          displayName: offset
      responses:
        '200':
          description: A paged set of categories
          body:
            application/json:
              schema: |
                {
                  "id": "PagedCategories",
                  "title": "PagedCategories",
                  "type": "object",
                  "properties": {
