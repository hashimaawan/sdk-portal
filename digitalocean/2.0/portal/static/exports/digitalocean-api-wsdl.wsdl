              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="604800000" />
                <xs:minInclusive value="0" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="0" name="jit" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Activates, in a boolean, the system-wide use of Just-in-Time Compilation (JIT).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="log_autovacuum_min_duration">
            <xs:simpleType>
