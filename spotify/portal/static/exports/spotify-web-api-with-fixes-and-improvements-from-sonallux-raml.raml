/users:
  /{user_id}:
    uriParameters:
      user_id:
        type: string
        example: smedjan
        required: true
        displayName: user_id
    /playlists:
      uriParameters: {}
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - playlist-read-private
            - playlist-read-collaborative
        description: >
          Get a list of the playlists owned or followed by a Spotify user.
        queryParameters:
          limit:
            type: integer
            example: '10'
            default: '20'
            required: false
            displayName: limit
            minimum: '1'
            maximum: '50'
          offset:
            type: integer
            example: '5'
            default: '0'
            required: false
            displayName: offset
        responses:
          '200':
            description: A paged set of playlists
            body:
              application/json:
                schema: |
                  {
                    "id": "PagingPlaylistObject",
                    "title": "PagingPlaylistObject",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "A link to the Web API endpoint returning the full result of the request",
