          value: 2016-01-30T23:55:00+00:00
        displayName: created
        description: Point in time when the Resource was created (in ISO-8601 format)
        type: string
      id:
        required: true
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        additionalProperties: true
        properties:
          //:
            type: string
      name:
        required: true
        example:
          value: my-resource
        displayName: name
        description: Name of the Resource. Must be unique per Project.
        type: string
      servers:
        required: true
        example:
          value:
          - 42
        displayName: servers
        description: Array of IDs of Servers that are part of this Placement Group
        type: array
