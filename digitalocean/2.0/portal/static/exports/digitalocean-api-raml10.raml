      repo:
        required: false
        example:
          value: digitalocean/sample-golang
        displayName: repo
        description: 'The name of the repo in the format owner/repo. Example: `digitalocean/sample-golang`'
        type: string
  Configurationsforexternallogging.:
    displayName: Configurationsforexternallogging.
    type: object
    properties:
      datadog:
        required: false
        displayName: datadog
        description: DataDog configuration.
        type: Datadog
      logtail:
        required: false
        displayName: logtail
        description: Logtail configuration.
        type: Logtail
      name:
        required: true
        example:
          value: my_log_destination
        displayName: name
        type: string
        pattern: ^[A-Za-z0-9()\[\]'"][-A-Za-z0-9_. \/()\[\]]{0,40}[A-Za-z0-9()\[\]'"]$
        minLength: 2
        maxLength: 42
      papertrail:
        required: false
        displayName: papertrail
        description: Papertrail configuration.
        type: Papertrail
  Datadog:
    displayName: Datadog
    description: DataDog configuration.
    type: object
    properties:
      api_key:
        required: true
        example:
          value: abcdefghijklmnopqrstuvwxyz0123456789
        displayName: api_key
        description: Datadog API key.
        type: string
      endpoint:
        required: false
        example:
          value: https://mydatadogendpoint.com
        displayName: endpoint
        description: Datadog HTTP log intake endpoint.
        type: string
  Logtail:
    displayName: Logtail
    description: Logtail configuration.
    type: object
    properties:
      token:
        required: false
        example:
          value: abcdefghijklmnopqrstuvwxyz0123456789
        displayName: token
        description: Logtail token.
        type: string
  Papertrail:
    displayName: Papertrail
    description: Papertrail configuration.
    type: object
    properties:
      endpoint:
        required: true
        example:
          value: https://mypapertrailendpoint.com
        displayName: endpoint
        description: Papertrail syslog endpoint.
        type: string
  AcriterionforroutingHTTPtraffictoacomponent.:
    displayName: AcriterionforroutingHTTPtraffictoacomponent.
    type: object
    properties:
      path:
        required: false
        example:
          value: /api
        displayName: path
        description: An HTTP path prefix. Paths must start with / and must be unique across all components within an app.
        type: string
      preserve_path_prefix:
        required: false
        example:
          value: true
        displayName: preserve_path_prefix
        description: An optional flag to preserve the path that is forwarded to the backend service. By default, the HTTP request path will be trimmed from the left when forwarded to the component. For example, a component with `path=/api` will have requests to `/api/list` trimmed to `/list`. If this value is `true`, the path will remain `/api/list`.
        type: boolean
  Job:
    displayName: Job
    type: object
    properties:
      build_command:
        required: false
        example:
          value: npm run build
        displayName: build_command
        description: An optional build command to run while building this component from source.
        type: string
      dockerfile_path:
        required: false
        example:
          value: path/to/Dockerfile
        displayName: dockerfile_path
        description: The path to the Dockerfile relative to the root of the repo. If set, it will be used to build this component. Otherwise, App Platform will attempt to build it using buildpacks.
        type: string
      environment_slug:
        required: false
        example:
          value: node-js
        displayName: environment_slug
        description: An environment slug describing the type of this app. For a full list, please refer to [the product documentation](https://www.digitalocean.com/docs/app-platform/).
        type: string
      envs:
        required: false
        displayName: envs
        description: A list of environment variables made available to the component.
        type: array
        items:
          type: Env
      git:
        required: false
        displayName: git
        type: Git
      github:
        required: false
        displayName: github
        type: Github
      gitlab:
        required: false
        displayName: gitlab
        type: Gitlab
      image:
        required: false
        displayName: image
        type: Image
      log_destinations:
        required: false
        displayName: log_destinations
        type: Configurationsforexternallogging.
      name:
        required: true
        example:
          value: api
        displayName: name
        description: The name. Must be unique across all components within the same app.
        type: string
        pattern: ^[a-z][a-z0-9-]{0,30}[a-z0-9]$
        minLength: 2
        maxLength: 32
      run_command:
        required: false
        example:
          value: bin/api
        displayName: run_command
        description: An optional run command to override the component's default.
        type: string
      source_dir:
        required: false
        example:
          value: path/to/dir
        displayName: source_dir
        description: An optional path to the working directory to use for the build. For Dockerfile builds, this will be used as the build context. Must be relative to the root of the repo.
        type: string
      instance_count:
        required: false
        default: '1'
        example:
          value: 2
        displayName: instance_count
        description: 'The amount of instances that this component should be scaled to. Default: 1'
        type: integer
        minimum: 1
        format: int64
      instance_size_slug:
        required: false
        default: basic-xxs
        example:
          value: basic-xxs
        displayName: instance_size_slug
        description: 'The instance size to use for this component. Default: `basic-xxs`'
        type: string
        enum:
        - basic-xxs
        - basic-xs
        - basic-s
        - basic-m
        - professional-xs
        - professional-s
        - professional-m
        - professional-1l
        - professional-l
        - professional-xl
      kind:
        required: false
        default: UNSPECIFIED
        example:
          value: PRE_DEPLOY
        displayName: kind
        description: |
          - UNSPECIFIED: Default job type, will auto-complete to POST_DEPLOY kind.

          - PRE_DEPLOY: Indicates a job that runs before an app deployment.

          - POST_DEPLOY: Indicates a job that runs after an app deployment.

          - FAILED_DEPLOY: Indicates a job that runs after a component fails to deploy.
        type: string
        enum:
        - UNSPECIFIED
        - PRE_DEPLOY
        - POST_DEPLOY
        - FAILED_DEPLOY
  Image:
    displayName: Image
    type: object
    properties:
      registry:
        required: false
        example:
          value: registry.hub.docker.com
        displayName: registry
        description: The registry name. Must be left empty for the `DOCR` registry type.
        type: string
      registry_type:
        required: false
        example:
          value: DOCR
        displayName: registry_type
        description: |
