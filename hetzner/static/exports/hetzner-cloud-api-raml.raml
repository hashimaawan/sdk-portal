- ServerType1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ServerType1",
      "title": "ServerType1",
      "description": "Type of Server - determines how much ram, disk and cpu a Server has",
      "type": "object",
      "properties": {
        "cores": {
          "description": "Number of cpu cores a Server of this type will have",
          "example": 1,
          "type": "number"
        },
        "cpu_type": {
          "title": "CpuType",
          "description": "Type of cpu",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "shared",
            "dedicated"
          ]
        },
        "deprecated": {
          "description": "True if Server type is deprecated",
          "example": false,
          "type": "boolean"
        },
        "description": {
          "description": "Description of the Server type",
          "example": "CX11",
          "type": "string"
        },
        "disk": {
          "description": "Disk size a Server of this type will have in GB",
          "example": 25,
          "type": "number"
        },
        "id": {
          "description": "ID of the Server type",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "memory": {
          "description": "Memory a Server of this type will have in GB",
          "example": 1,
          "type": "number"
        },
        "name": {
          "description": "Unique identifier of the Server type",
          "example": "cx11",
          "type": "string"
        },
        "prices": {
          "description": "Prices in different Locations",
          "type": "array",
          "items": {
            "id": "Price9",
            "title": "Price9",
            "type": "object",
            "properties": {
              "location": {
                "description": "Name of the Location the price is for",
                "example": "fsn1",
                "type": "string"
              },
              "price_hourly": {
                "id": "PriceHourly8",
                "title": "PriceHourly8",
                "description": "Hourly costs for a Server type in this Location",
                "type": "object",
                "properties": {
                  "gross": {
                    "description": "Price with VAT added",
                    "example": "1.1900000000000000",
                    "type": "string"
                  },
                  "net": {
                    "description": "Price without VAT",
                    "example": "1.0000000000",
                    "type": "string"
                  }
                },
                "required": [
                  "gross",
                  "net"
                ]
              },
              "price_monthly": {
                "id": "PriceMonthly10",
                "title": "PriceMonthly10",
                "description": "Monthly costs for a Server type in this Location",
                "type": "object",
                "properties": {
                  "gross": {
                    "description": "Price with VAT added",
                    "example": "1.1900000000000000",
                    "type": "string"
                  },
                  "net": {
                    "description": "Price without VAT",
                    "example": "1.0000000000",
                    "type": "string"
                  }
                },
                "required": [
                  "gross",
                  "net"
                ]
              }
            },
            "required": [
              "location",
              "price_hourly",
              "price_monthly"
            ]
          }
        },
        "storage_type": {
          "title": "StorageType",
          "description": "Type of Server boot drive. Local has higher speed. Network has better availability.",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "local",
            "network"
          ]
        }
      },
      "required": [
        "cores",
        "cpu_type",
        "deprecated",
        "description",
        "disk",
        "id",
        "memory",
        "name",
        "prices",
        "storage_type"
      ]
    }
- Status73: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "Status73",
      "description": "Status of the Server",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "running",
        "initializing",
        "starting",
        "stopping",
        "off",
        "deleting",
        "migrating",
        "rebuilding",
        "unknown"
      ]
    }
- CreateServerRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CreateServerRequest",
      "title": "CreateServerRequest",
      "type": "object",
      "properties": {
        "image": {
          "description": "ID or name of the Image the Server is created from",
          "example": "ubuntu-20.04",
          "type": "string"
        },
        "name": {
          "description": "Name of the Server to create (must be unique per Project and a valid hostname as per RFC 1123)",
          "example": "my-server",
          "type": "string"
        },
        "server_type": {
          "description": "ID or name of the Server type this Server should be created with",
          "example": "cx11",
          "type": "string"
        },
        "automount": {
          "description": "Auto-mount Volumes after attach",
          "example": false,
          "type": "boolean"
        },
        "datacenter": {
          "description": "ID or name of Datacenter to create Server in (must not be used together with location)",
          "example": "nbg1-dc3",
          "type": "string"
        },
        "firewalls": {
          "description": "Firewalls which should be applied on the Server's public network interface at creation time",
          "example": [
            {
              "firewall": 38
            }
          ],
          "type": "array",
          "items": {
            "id": "Firewall4",
            "title": "Firewall4",
            "type": "object",
            "properties": {
              "firewall": {
                "description": "ID of the Firewall",
                "type": "integer",
                "format": "int32"
              }
            }
          }
        },
        "labels": {
          "description": "User-defined labels (key-value pairs)",
          "type": "object"
        },
        "location": {
          "description": "ID or name of Location to create Server in (must not be used together with datacenter)",
          "example": "nbg1",
          "type": "string"
        },
        "networks": {
          "description": "Network IDs which should be attached to the Server private network interface at the creation time",
          "example": [
            456
          ],
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "placement_group": {
          "description": "ID of the Placement Group the server should be in",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "public_net": {
          "id": "PublicNet5",
          "title": "PublicNet5",
          "description": "Public Network options",
          "type": "object",
          "properties": {
            "enable_ipv4": {
              "description": "Attach an IPv4 on the public NIC. If false, no IPv4 address will be attached. Defaults to true.",
              "type": "boolean"
            },
            "enable_ipv6": {
              "description": "Attach an IPv6 on the public NIC. If false, no IPv6 address will be attached. Defaults to true.",
              "type": "boolean"
            },
            "ipv4": {
              "description": "ID of the ipv4 Primary IP to use. If omitted and enable_ipv4 is true, a new ipv4 Primary IP will automatically be created.",
              "type": [
                "integer",
                "null"
              ],
              "format": "int32"
            },
            "ipv6": {
              "description": "ID of the ipv6 Primary IP to use. If omitted and enable_ipv6 is true, a new ipv6 Primary IP will automatically be created.",
              "type": [
                "integer",
                "null"
              ],
              "format": "int32"
            }
          }
        },
        "ssh_keys": {
          "description": "SSH key IDs (`integer`) or names (`string`) which should be injected into the Server at creation time",
          "example": [
            "my-ssh-key"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "start_after_create": {
          "description": "Start Server right after creation. Defaults to true.",
          "example": true,
          "type": "boolean"
        },
        "user_data": {
          "description": "Cloud-Init user data to use during Server creation. This field is limited to 32KiB.",
          "example": "#cloud-config\nruncmd:\n- [touch, /root/cloud-init-worked]\n",
          "type": "string"
        },
        "volumes": {
          "description": "Volume IDs which should be attached to the Server at the creation time. Volumes must be in the same Location.",
          "example": [
            123
          ],
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "required": [
        "image",
        "name",
        "server_type"
      ]
    }
- Firewall4: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Firewall4",
      "title": "Firewall4",
      "type": "object",
      "properties": {
        "firewall": {
          "description": "ID of the Firewall",
