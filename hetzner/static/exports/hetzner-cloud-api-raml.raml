    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Server18",
      "title": "Server18",
      "type": "object",
      "properties": {
        "backup_window": {
          "description": "Time window (UTC) in which the backup will run, or null if the backups are not enabled",
          "example": "22-02",
          "type": [
            "string",
            "null"
          ]
        },
        "created": {
          "description": "Point in time when the Resource was created (in ISO-8601 format)",
          "example": "2016-01-30T23:55:00+00:00",
          "type": "string"
        },
        "datacenter": {
          "id": "Datacenter6",
          "title": "Datacenter6",
          "description": "Datacenter this Resource is located at",
          "type": "object",
          "properties": {
            "description": {
              "description": "Description of the Datacenter",
              "example": "Falkenstein DC Park 8",
              "type": "string"
            },
            "id": {
              "description": "ID of the Resource",
              "example": 42,
              "type": "integer",
              "format": "int32"
            },
            "location": {
              "id": "Location",
              "title": "Location",
              "type": "object",
              "properties": {
                "city": {
                  "description": "City the Location is closest to",
                  "example": "Falkenstein",
                  "type": "string"
                },
                "country": {
                  "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                  "example": "DE",
                  "type": "string"
                },
                "description": {
                  "description": "Description of the Location",
                  "example": "Falkenstein DC Park 1",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Location",
                  "example": 1,
                  "type": "number"
                },
                "latitude": {
                  "description": "Latitude of the city closest to the Location",
                  "example": 50.47612,
                  "type": "number"
                },
                "longitude": {
                  "description": "Longitude of the city closest to the Location",
                  "example": 12.370071,
                  "type": "number"
                },
                "name": {
                  "description": "Unique identifier of the Location",
                  "example": "fsn1",
                  "type": "string"
                },
                "network_zone": {
                  "description": "Name of network zone this Location resides in",
                  "example": "eu-central",
                  "type": "string"
                }
              },
              "required": [
                "city",
                "country",
                "description",
                "id",
                "latitude",
                "longitude",
                "name",
                "network_zone"
              ]
            },
            "name": {
              "description": "Unique identifier of the Datacenter",
              "example": "fsn1-dc8",
              "type": "string"
            },
            "server_types": {
              "id": "ServerTypes",
              "title": "ServerTypes",
              "description": "The Server types the Datacenter can handle",
              "type": "object",
              "properties": {
                "available": {
                  "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                  "example": [
                    1,
                    2,
                    3
                  ],
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "available_for_migration": {
                  "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                  "example": [
                    1,
                    2,
                    3
                  ],
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "supported": {
                  "description": "IDs of Server types that are supported in the Datacenter",
                  "example": [
                    1,
                    2,
                    3
                  ],
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              },
              "required": [
                "available",
                "available_for_migration",
                "supported"
              ]
            }
          },
          "required": [
            "description",
            "id",
            "location",
            "name",
            "server_types"
          ]
        },
        "id": {
          "description": "ID of the Resource",
          "example": 42,
          "type": "integer",
          "format": "int32"
        },
        "image": {
