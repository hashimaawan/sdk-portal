        </request>
        <response status="200">
          <doc title="200" xml:lang="en">A snapshot ID for the playlist</doc>
          <representation element="schemas:reorder-or-replace-playlists-tracks200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Bad or expired token. This can happen if the user revoked a token or
the access token has expired. You should re-authenticate the user.</doc>
