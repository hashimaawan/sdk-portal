            "type": "object",
            "properties": {
              "name": {
                "description": "Name of the Firewall",
                "example": "Corporate Intranet Protection",
                "type": "string"
              },
              "apply_to": {
                "description": "Resources the Firewall should be applied to after creation",
                "type": "array",
                "items": {
                  "id": "ApplyTo",
                  "title": "ApplyTo",
                  "type": "object",
                  "properties": {
                    "type": {
                      "title": "Type7",
                      "description": "Type of the resource",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "server",
                        "label_selector"
