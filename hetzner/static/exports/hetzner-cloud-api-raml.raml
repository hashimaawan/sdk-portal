                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly10",
                                    "title": "PriceMonthly10",
                                    "description": "Monthly costs for a Server type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            },
                            "storage_type": {
                              "title": "StorageType",
                              "description": "Type of Server boot drive. Local has higher speed. Network has better availability.",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "local",
                                "network"
                              ]
                            }
                          },
                          "required": [
                            "cores",
                            "cpu_type",
                            "deprecated",
                            "description",
                            "disk",
                            "id",
                            "memory",
                            "name",
                            "prices",
                            "storage_type"
                          ]
                        },
                        "status": {
                          "title": "Status73",
                          "description": "Status of the Server",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "running",
                            "initializing",
                            "starting",
                            "stopping",
                            "off",
                            "deleting",
                            "migrating",
                            "rebuilding",
                            "unknown"
                          ]
                        },
                        "load_balancers": {
                          "description": "",
                          "type": "array",
                          "items": {
                            "type": "integer",
                            "format": "int32"
                          }
                        },
                        "placement_group": {
                          "id": "PlacementGroupNullable",
                          "title": "PlacementGroupNullable",
                          "type": [
                            "object",
                            "null"
                          ],
                          "properties": {
                            "created": {
                              "description": "Point in time when the Resource was created (in ISO-8601 format)",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Resource",
                              "example": 42,
                              "type": "integer",
                              "format": "int32"
                            },
                            "labels": {
                              "description": "User-defined labels (key-value pairs)",
                              "type": "object",
                              "additionalProperties": {
                                "type": "string"
                              }
                            },
                            "name": {
                              "description": "Name of the Resource. Must be unique per Project.",
                              "example": "my-resource",
                              "type": "string"
                            },
                            "servers": {
                              "description": "Array of IDs of Servers that are part of this Placement Group",
                              "example": [
                                42
                              ],
                              "type": "array",
                              "items": {
                                "type": "integer",
                                "format": "int32"
                              }
