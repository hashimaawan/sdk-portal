          "type": "string",
          "pattern": "[a-zA-Z0-9._-]{1,128}"
        },
        "CreationTime": {
          "type": "string",
          "format": "date-time"
        },
        "Type": {
          "title": "NotebookType1",
          "description": "The type of notebook. Currently, the only valid type is <code>IPYNB</code>.",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "IPYNB"
          ]
        },
        "LastModifiedTime": {
          "type": "string",
          "format": "date-time"
        }
      }
