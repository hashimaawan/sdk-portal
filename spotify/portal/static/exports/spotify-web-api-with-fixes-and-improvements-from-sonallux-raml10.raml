/search:
  get:
    displayName: search
    description: >
      Get Spotify catalog information about albums, artists, playlists, tracks, shows, episodes or audiobooks

      that match a keyword string. Audiobooks are only available within the US, UK, Canada, Ireland, New Zealand and Australia markets.
    securedBy:
    - oauth_2_0
    queryParameters:
      q:
        required: true
        example:
          value: remaster%20track:Doxy%20artist:Miles%20Davis
        displayName: q
        type: string
      type:
        required: true
        displayName: type
        type: array
        items:
          type: string
          enum:
          - album
          - artist
          - playlist
          - track
          - show
          - episode
          - audiobook
      market:
        required: false
        example:
          value: ES
        displayName: market
        type: string
      limit:
        required: false
        default: '20'
        example:
          value: 10
        displayName: limit
        type: integer
        minimum: 1
        maximum: 50
        format: int32
      offset:
        required: false
        default: '0'
        example:
          value: 5
        displayName: offset
        type: integer
        minimum: 0
        maximum: 1000
        format: int32
      include_external:
        required: false
        displayName: include_external
        type: string
        enum:
        - audio
    responses:
      '200':
        description: Search response
        body:
          application/json:
            displayName: response200
            description: ''
            type: SearchItems
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            displayName: response401
            description: ''
            type: Unauthorized1
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            displayName: response403
            description: ''
            type: Forbidden1
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            displayName: response429
            description: ''
            type: TooManyRequests1
