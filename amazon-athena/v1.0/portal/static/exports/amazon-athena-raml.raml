/#X-Amz-Target=AmazonAthena.ListExecutors:
  post:
    description: Lists, in descending order, the executors that joined a session. Newer executors are listed first; older executors are listed later. The result can be optionally filtered by state.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.ListExecutors
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    queryParameters:
      MaxResults:
        description: Pagination limit
        type: string
        required: false
        displayName: MaxResults
      NextToken:
        description: Pagination token
        type: string
        required: false
        displayName: NextToken
    body:
      application/json:
        schema: |
          {
            "id": "ListExecutorsRequest",
            "title": "ListExecutorsRequest",
            "type": "object",
            "properties": {
              "SessionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "ExecutorStateFilter": {
                "title": "ExecutorState1",
                "description": "<p>A filter for a specific executor state. A description of each state follows.</p> <p> <code>CREATING</code> - The executor is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The executor has been started.</p> <p> <code>REGISTERED</code> - The executor has been registered.</p> <p> <code>TERMINATING</code> - The executor is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The executor is no longer running.</p> <p> <code>FAILED</code> - Due to a failure, the executor is no longer running.</p>",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "CREATING",
                  "CREATED",
                  "REGISTERED",
                  "TERMINATING",
                  "TERMINATED",
                  "FAILED"
                ]
              },
              "MaxResults": {
                "type": "integer",
                "minimum": 1.0,
                "maximum": 100.0,
                "format": "int32"
              },
              "NextToken": {
                "type": "string",
                "maxLength": 2048
              }
            },
            "required": [
              "SessionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "ListExecutorsResponse",
                "title": "ListExecutorsResponse",
                "type": "object",
                "properties": {
                  "SessionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "NextToken": {
                    "type": "string",
                    "maxLength": 2048
                  },
                  "ExecutorsSummary": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "ExecutorsSummary",
                      "title": "ExecutorsSummary",
                      "description": "Contains summary information about an executor.",
                      "type": "object",
                      "properties": {
                        "ExecutorId": {
                          "type": "string",
                          "maxLength": 100000,
                          "pattern": ".*"
                        },
                        "ExecutorType": {
                          "title": "ExecutorType2",
                          "description": "The type of executor used for the application (<code>COORDINATOR</code>, <code>GATEWAY</code>, or <code>WORKER</code>).",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "COORDINATOR",
                            "GATEWAY",
                            "WORKER"
                          ]
                        },
                        "StartDateTime": {
                          "type": "integer",
                          "format": "int32"
                        },
                        "TerminationDateTime": {
                          "type": "integer",
                          "format": "int32"
                        },
                        "ExecutorState": {
                          "title": "ExecutorState3",
                          "description": "<p>The processing state of the executor. A description of each state follows.</p> <p> <code>CREATING</code> - The executor is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The executor has been started.</p> <p> <code>REGISTERED</code> - The executor has been registered.</p> <p> <code>TERMINATING</code> - The executor is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The executor is no longer running.</p> <p> <code>FAILED</code> - Due to a failure, the executor is no longer running.</p>",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "CREATING",
                            "CREATED",
                            "REGISTERED",
                            "TERMINATING",
                            "TERMINATED",
                            "FAILED"
                          ]
                        },
                        "ExecutorSize": {
                          "type": "integer",
                          "format": "int32"
                        }
                      },
                      "required": [
                        "ExecutorId"
                      ]
                    }
                  }
                },
                "required": [
                  "SessionId"
                ]
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
