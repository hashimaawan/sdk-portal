                          "IDLE",
                          "BUSY",
                          "TERMINATING",
                          "TERMINATED",
                          "DEGRADED",
                          "FAILED"
                        ]
                      },
                      "StateChangeReason": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                      }
                    }
                  }
                }
              }
      '480':
