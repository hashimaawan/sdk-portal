        "text": "[\n  {\n    \"op\": \"add\",\n    \"path\": \"/fields\",\n    \"value\": {\n      \"label\": \"New Field\",\n      \"type\": \"string\",\n      \"value\": \"hunter2\"\n    }\n  }\n]"
