                                ]
                              }
                            },
                            "started": {
                              "description": "Point in time when the Action was started (in ISO-8601 format)",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": "string"
                            },
                            "status": {
                              "title": "Status",
                              "description": "Status of the Action",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "success",
                                "running",
                                "error"
                              ]
                            }
                          },
                          "required": [
                            "command",
                            "error",
                            "finished",
                            "id",
                            "progress",
                            "resources",
                            "started",
                            "status"
                          ]
                        }
                      }
                    },
                    "required": [
                      "actions"
                    ]
                  }
                example: '{"actions":[{"command":"assign_floating_ip","error":{"code":"action_failed","message":"Action failed"},"finished":"2016-01-30T23:56:00+00:00","id":13,"progress":100,"resources":[{"id":4711,"type":"server"},{"id":4712,"type":"floating_ip"}],"started":"2016-01-30T23:55:00+00:00","status":"success"}]}'
    delete:
      description: Deletes a Floating IP. If it is currently assigned to a Server it will automatically get unassigned.
      responses:
        '204':
          description: Floating IP deleted
    get:
      description: Returns a specific Floating IP object.
      responses:
        '200':
          description: The `floating_ip` key in the reply contains a Floating IP object with this structure
          body:
            application/json:
              schema: |
                {
                  "id": "FloatingIpsResponse2",
                  "title": "FloatingIpsResponse2",
                  "type": "object",
                  "properties": {
                    "floating_ip": {
                      "id": "FloatingIp",
                      "title": "FloatingIp",
                      "type": "object",
                      "properties": {
                        "blocked": {
                          "description": "Whether the IP is blocked",
                          "example": false,
                          "type": "boolean"
                        },
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "description": {
                          "description": "Description of the Resource",
                          "example": "this describes my resource",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "dns_ptr": {
                          "description": "Array of reverse DNS entries",
                          "type": "array",
                          "items": {
                            "id": "DnsPtr",
                            "title": "DnsPtr",
                            "type": "object",
                            "properties": {
                              "dns_ptr": {
                                "description": "DNS pointer for the specific IP address",
                                "example": "server.example.com",
                                "type": "string"
                              },
                              "ip": {
                                "description": "Single IPv4 or IPv6 address",
                                "example": "2001:db8::1",
                                "type": "string"
                              }
                            },
                            "required": [
                              "dns_ptr",
                              "ip"
                            ]
                          }
                        },
                        "home_location": {
                          "id": "HomeLocation",
                          "title": "HomeLocation",
                          "description": "Location the Floating IP was created in. Routing is optimized for this Location.",
                          "type": "object",
                          "properties": {
                            "city": {
                              "description": "City the Location is closest to",
                              "example": "Falkenstein",
                              "type": "string"
                            },
                            "country": {
                              "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                              "example": "DE",
                              "type": "string"
                            },
                            "description": {
                              "description": "Description of the Location",
                              "example": "Falkenstein DC Park 1",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Location",
                              "example": 1,
                              "type": "number"
                            },
                            "latitude": {
                              "description": "Latitude of the city closest to the Location",
                              "example": 50.47612,
                              "type": "number"
                            },
                            "longitude": {
                              "description": "Longitude of the city closest to the Location",
                              "example": 12.370071,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Location",
                              "example": "fsn1",
                              "type": "string"
                            },
                            "network_zone": {
                              "description": "Name of network zone this Location resides in",
                              "example": "eu-central",
                              "type": "string"
                            }
                          },
                          "required": [
                            "city",
                            "country",
                            "description",
                            "id",
                            "latitude",
                            "longitude",
                            "name",
                            "network_zone"
                          ]
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "ip": {
                          "description": "IP address",
                          "example": "131.232.99.1",
                          "type": "string"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "protection": {
                          "id": "Protection",
                          "title": "Protection",
                          "description": "Protection configuration for the Resource",
                          "type": "object",
                          "properties": {
                            "delete": {
                              "description": "If true, prevents the Resource from being deleted",
                              "example": false,
