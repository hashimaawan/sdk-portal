          application/json:
            examples:
              spread:
                displayName: Response when creating a type `spread` PlacementGroup
                value:
                  placement_group:
                    created: 2019-01-08T12:10:00+00:00
                    id: 897
                    labels:
                      key: value
                    name: my Placement Group
                    servers: []
                    type: spread
            displayName: response201
            description: ''
            type: CreatePlacementGroupResponse
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of the resource
        type: integer
        format: int32
    delete:
      displayName: DeleteaPlacementGroup
      description: Deletes a PlacementGroup.
      responses:
        '204':
          description: PlacementGroup deleted
          body: {}
    get:
      displayName: GetaPlacementGroup
