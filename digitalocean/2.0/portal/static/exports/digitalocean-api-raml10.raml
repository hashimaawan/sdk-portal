          application/json:
            example:
              value:
                app_id: b6bdf840-2854-4f87-a36c-5f231c617c84
                spec:
                  name: web-app
                  region: nyc
                  services:
                  - environment_slug: node-js
                    github:
                      branch: main
                      deploy_on_push: true
                      repo: digitalocean/sample-golang
                    instance_count: 2
