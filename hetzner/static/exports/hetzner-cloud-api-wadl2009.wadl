          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="DeleteSubnetRequest">
        <xs:sequence>
          <xs:element minOccurs="1" name="ip_range" type="xs:string">
            <xs:annotation>
              <xs:documentation>IP range of subnet to delete</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="ParameterType1">
        <xs:restriction base="xs:string">
          <xs:enumeration value="spread" />
