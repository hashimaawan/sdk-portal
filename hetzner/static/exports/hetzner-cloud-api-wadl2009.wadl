      </param>
      <method id="DeleteasubnetfromaNetwork" name="POST">
        <doc title="Delete a subnet from a Network" xml:lang="en">Deletes a single subnet entry from a Network. You cannot delete subnets which still have Servers attached. If you have Servers attached you first need to detach all Servers that use IPs from this subnet before you can delete the subnet.

Note: if the Network object changes during the request, the response will be a “conflict” error.
</doc>
        <request>
          <param name="Content-Type" style="header" type="xsd:string" default="application/json" required="true" fixed="application/json">
            <doc title="Content-Type" xml:lang="en" />
          </param>
          <representation element="schemas:DeleteasubnetfromaNetwork_Request" mediaType="application/json" />
        </request>
        <response status="201">
          <doc title="201" xml:lang="en">The `action` key contains the `delete_subnet` Action</doc>
          <representation element="schemas:DeleteasubnetfromaNetwork201_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
