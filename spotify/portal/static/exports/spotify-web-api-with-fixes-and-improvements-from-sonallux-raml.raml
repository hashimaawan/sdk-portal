                        "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                        "example": "2up3OPMp9Tb4dAKM2erWXQ",
                        "type": "string"
                      },
                      "images": {
                        "description": "The cover art for the album in various sizes, widest first.",
