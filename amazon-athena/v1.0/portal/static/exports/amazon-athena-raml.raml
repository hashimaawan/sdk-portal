      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetSessionStatusResponse",
      "title": "GetSessionStatusResponse",
      "type": "object",
      "properties": {
        "SessionId": {
          "type": "string",
          "minLength": 1,
