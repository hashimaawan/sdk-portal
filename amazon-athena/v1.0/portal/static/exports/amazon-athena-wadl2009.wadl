          </param>
          <param name="X-Amz-Content-Sha256" style="header" type="xsd:string">
            <doc title="X-Amz-Content-Sha256" xml:lang="en" />
          </param>
          <param name="X-Amz-Date" style="header" type="xsd:string">
            <doc title="X-Amz-Date" xml:lang="en" />
          </param>
          <param name="X-Amz-Algorithm" style="header" type="xsd:string">
            <doc title="X-Amz-Algorithm" xml:lang="en" />
          </param>
          <param name="X-Amz-Credential" style="header" type="xsd:string">
            <doc title="X-Amz-Credential" xml:lang="en" />
          </param>
          <param name="X-Amz-Security-Token" style="header" type="xsd:string">
            <doc title="X-Amz-Security-Token" xml:lang="en" />
