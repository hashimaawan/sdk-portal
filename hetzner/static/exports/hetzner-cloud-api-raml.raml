- LoadBalancerTarget: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LoadBalancerTarget",
      "title": "LoadBalancerTarget",
      "type": "object",
      "properties": {
        "type": {
          "title": "Type29",
          "description": "Type of the resource",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "server",
            "label_selector",
            "ip"
          ]
        },
        "health_status": {
          "description": "List of health statuses of the services on this target",
          "type": "array",
          "items": {
            "id": "HealthStatus",
            "title": "HealthStatus",
            "type": "object",
            "properties": {
              "listen_port": {
                "example": 443,
                "type": "integer",
                "format": "int32"
              },
              "status": {
                "title": "Status30",
                "example": "healthy",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "healthy",
                  "unhealthy",
                  "unknown"
                ]
              }
            }
          }
        },
        "ip": {
          "id": "Ip",
          "title": "Ip",
          "description": "IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.",
          "type": "object",
          "properties": {
            "ip": {
              "description": "IP of a server that belongs to the same customer (public IPv4/IPv6) or private IP in a Subnetwork type vswitch.",
              "example": "203.0.113.1",
              "type": "string"
            }
          },
          "required": [
            "ip"
          ]
        },
        "label_selector": {
          "id": "LabelSelector7",
          "title": "LabelSelector7",
          "description": "Label selector and a list of selected targets",
          "type": "object",
          "properties": {
            "selector": {
              "description": "Label selector",
              "example": "env=prod",
              "type": "string"
            }
          },
          "required": [
            "selector"
          ]
        },
        "server": {
          "id": "LoadBalancerTargetServer",
          "title": "LoadBalancerTargetServer",
          "description": "Server where the traffic should be routed through",
          "type": "object",
          "properties": {
            "id": {
              "description": "ID of the Server",
              "example": 80,
              "type": "integer",
              "format": "int32"
            }
          },
          "required": [
            "id"
          ]
        },
        "targets": {
          "description": "List of selected targets",
          "type": "array",
          "items": {
            "id": "Target",
            "title": "Target",
            "type": "object",
            "properties": {
              "health_status": {
                "description": "",
                "type": "array",
                "items": {
                  "$ref": "HealthStatus"
                }
              },
              "server": {
                "id": "Server11",
                "title": "Server11",
                "type": "object",
                "properties": {
                  "id": {
                    "description": "ID of the Server",
                    "example": 85,
                    "type": "integer",
                    "format": "int32"
                  }
                },
                "required": [
                  "id"
                ]
              },
              "type": {
                "example": "server",
                "type": "string"
              },
              "use_private_ip": {
                "example": false,
                "type": "boolean"
              }
            }
          }
        },
        "use_private_ip": {
          "description": "Use the private network IP instead of the public IP. Default value is false.",
          "type": "boolean"
        }
      },
      "required": [
        "type"
      ]
    }
