      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetPreparedStatementOutput",
      "title": "GetPreparedStatementOutput",
      "type": "object",
      "properties": {
        "PreparedStatement": {
          "id": "PreparedStatement1",
          "title": "PreparedStatement1",
          "type": "object",
          "properties": {
            "StatementName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "[a-zA-Z_][a-zA-Z0-9_@:]{1,256}"
            },
            "QueryStatement": {
              "type": "string",
              "minLength": 1,
              "maxLength": 262144
            },
            "WorkGroupName": {
              "type": "string",
              "pattern": "[a-zA-Z0-9._-]{1,128}"
            },
            "Description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            },
            "LastModifiedTime": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
- GetPreparedStatementInput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetPreparedStatementInput",
      "title": "GetPreparedStatementInput",
      "type": "object",
      "properties": {
        "StatementName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "[a-zA-Z_][a-zA-Z0-9_@:]{1,256}"
        },
        "WorkGroup": {
          "type": "string",
          "pattern": "[a-zA-Z0-9._-]{1,128}"
        }
      },
      "required": [
        "StatementName",
        "WorkGroup"
      ]
    }
- GetQueryExecutionOutput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryExecutionOutput",
      "title": "GetQueryExecutionOutput",
      "type": "object",
      "properties": {
        "QueryExecution": {
          "id": "QueryExecution1",
          "title": "QueryExecution1",
          "type": "object",
          "properties": {
            "QueryExecutionId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "\\S+"
            },
            "Query": {
              "type": "string",
              "minLength": 1,
              "maxLength": 262144
            },
            "StatementType": {
              "title": "StatementType1",
              "description": "The type of query statement that was run. <code>DDL</code> indicates DDL query statements. <code>DML</code> indicates DML (Data Manipulation Language) query statements, such as <code>CREATE TABLE AS SELECT</code>. <code>UTILITY</code> indicates query statements other than DDL and DML, such as <code>SHOW CREATE TABLE</code>, or <code>DESCRIBE TABLE</code>.",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "DDL",
                "DML",
                "UTILITY"
              ]
            },
            "ResultConfiguration": {
              "id": "ResultConfiguration1",
              "title": "ResultConfiguration1",
              "type": "object",
              "properties": {
                "OutputLocation": {
                  "type": "string"
                },
                "EncryptionConfiguration": {
                  "id": "EncryptionConfiguration2",
                  "title": "EncryptionConfiguration2",
                  "type": "object",
                  "properties": {
                    "EncryptionOption": {
                      "title": "EncryptionOption1",
                      "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "SSE_S3",
                        "SSE_KMS",
                        "CSE_KMS"
                      ]
                    },
                    "KmsKey": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "EncryptionOption"
                  ]
                },
                "ExpectedBucketOwner": {
                  "type": "string",
                  "minLength": 12,
                  "maxLength": 12,
                  "pattern": "^[0-9]+$"
                },
                "AclConfiguration": {
                  "id": "AclConfiguration1",
                  "title": "AclConfiguration1",
                  "type": "object",
                  "properties": {
                    "S3AclOption": {
                      "title": "S3AclOption1",
                      "description": "The Amazon S3 canned ACL that Athena should specify when storing query results. Currently the only supported canned ACL is <code>BUCKET_OWNER_FULL_CONTROL</code>. If a query runs in a workgroup and the workgroup overrides client-side settings, then the Amazon S3 canned ACL specified in the workgroup's settings is used for all queries that run in the workgroup. For more information about Amazon S3 canned ACLs, see <a href=\"https://docs.aws.amazon.com/AmazonS3/latest/userguide/acl-overview.html#canned-acl\">Canned ACL</a> in the <i>Amazon S3 User Guide</i>.",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "BUCKET_OWNER_FULL_CONTROL"
                      ]
                    }
                  },
                  "required": [
                    "S3AclOption"
                  ]
                }
              }
            },
            "ResultReuseConfiguration": {
              "id": "ResultReuseConfiguration1",
              "title": "ResultReuseConfiguration1",
              "type": "object",
              "properties": {
                "ResultReuseByAgeConfiguration": {
                  "id": "ResultReuseByAgeConfiguration2",
                  "title": "ResultReuseByAgeConfiguration2",
                  "type": "object",
                  "properties": {
                    "Enabled": {
                      "type": "boolean"
                    },
                    "MaxAgeInMinutes": {
                      "type": "integer",
                      "minimum": 0.0,
                      "maximum": 10080.0,
                      "format": "int32"
                    }
                  },
                  "required": [
                    "Enabled"
                  ]
                }
              }
            },
            "QueryExecutionContext": {
              "id": "QueryExecutionContext1",
              "title": "QueryExecutionContext1",
              "type": "object",
              "properties": {
                "Database": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 255
                },
                "Catalog": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              }
            },
            "Status": {
              "id": "Status",
              "title": "Status",
              "type": "object",
              "properties": {
                "State": {
                  "title": "QueryExecutionState1",
                  "description": "<p>The state of query execution. <code>QUEUED</code> indicates that the query has been submitted to the service, and Athena will execute the query as soon as resources are available. <code>RUNNING</code> indicates that the query is in execution phase. <code>SUCCEEDED</code> indicates that the query completed without errors. <code>FAILED</code> indicates that the query experienced an error and did not complete processing. <code>CANCELLED</code> indicates that a user input interrupted query execution.</p> <note> <p>Athena automatically retries your queries in cases of certain transient errors. As a result, you may see the query state transition from <code>RUNNING</code> or <code>FAILED</code> to <code>QUEUED</code>. </p> </note>",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "QUEUED",
                    "RUNNING",
                    "SUCCEEDED",
                    "FAILED",
                    "CANCELLED"
                  ]
                },
                "StateChangeReason": {
                  "type": "string"
                },
                "SubmissionDateTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "CompletionDateTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "AthenaError": {
                  "id": "AthenaError2",
                  "title": "AthenaError2",
                  "type": "object",
                  "properties": {
                    "ErrorCategory": {
                      "type": "integer",
                      "minimum": 1.0,
                      "maximum": 3.0,
                      "format": "int32"
                    },
                    "ErrorType": {
                      "type": "integer",
                      "minimum": 0.0,
                      "maximum": 9999.0,
                      "format": "int32"
                    },
                    "Retryable": {
                      "type": "boolean"
                    },
                    "ErrorMessage": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "Statistics": {
              "id": "Statistics",
              "title": "Statistics",
              "type": "object",
              "properties": {
                "EngineExecutionTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "DataScannedInBytes": {
                  "type": "integer",
                  "format": "int32"
                },
                "DataManifestLocation": {
                  "type": "string"
                },
                "TotalExecutionTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "QueryQueueTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "QueryPlanningTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "ServiceProcessingTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "ResultReuseInformation": {
                  "id": "ResultReuseInformation2",
                  "title": "ResultReuseInformation2",
                  "type": "object",
                  "properties": {
                    "ReusedPreviousResult": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ReusedPreviousResult"
                  ]
                }
              }
            },
            "WorkGroup": {
              "type": "string",
              "pattern": "[a-zA-Z0-9._-]{1,128}"
            },
            "EngineVersion": {
              "id": "EngineVersion1",
              "title": "EngineVersion1",
              "type": "object",
              "properties": {
                "SelectedEngineVersion": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "EffectiveEngineVersion": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              }
            },
            "ExecutionParameters": {
              "description": "",
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "minItems": 1
            },
            "SubstatementType": {
              "type": "string"
            }
          }
        }
      }
    }
- GetQueryExecutionInput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryExecutionInput",
      "title": "GetQueryExecutionInput",
      "type": "object",
      "properties": {
        "QueryExecutionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "\\S+"
        }
      },
      "required": [
        "QueryExecutionId"
      ]
    }
- GetQueryResultsOutput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryResultsOutput",
      "title": "GetQueryResultsOutput",
      "type": "object",
      "properties": {
        "UpdateCount": {
          "type": "integer",
          "format": "int32"
        },
        "ResultSet": {
          "id": "ResultSet2",
          "title": "ResultSet2",
          "type": "object",
          "properties": {
            "Rows": {
              "description": "",
              "type": "array",
              "items": {
                "id": "Row",
                "title": "Row",
                "description": "The rows that make up a query result table.",
                "type": "object",
                "properties": {
                  "Data": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "Datum",
                      "title": "Datum",
                      "description": "A piece of data (a field in the table).",
                      "type": "object",
                      "properties": {
                        "VarCharValue": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "ResultSetMetadata": {
              "id": "ResultSetMetadata2",
              "title": "ResultSetMetadata2",
              "type": "object",
              "properties": {
                "ColumnInfo": {
                  "description": "",
                  "type": "array",
                  "items": {
                    "id": "ColumnInfo",
                    "title": "ColumnInfo",
                    "description": "Information about the columns in a query execution result.",
                    "type": "object",
                    "properties": {
                      "Name": {
                        "type": "string"
                      },
                      "Type": {
                        "type": "string"
                      },
                      "CatalogName": {
                        "type": "string"
                      },
                      "SchemaName": {
                        "type": "string"
                      },
                      "TableName": {
                        "type": "string"
                      },
                      "Label": {
                        "type": "string"
                      },
                      "Precision": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "Scale": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "Nullable": {
                        "title": "ColumnNullable2",
                        "description": "Indicates the column's nullable status.",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "NOT_NULL",
                          "NULLABLE",
                          "UNKNOWN"
                        ]
                      },
                      "CaseSensitive": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "Name",
                      "Type"
                    ]
                  }
                }
              }
            }
          }
        },
        "NextToken": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    }
- GetQueryResultsInput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryResultsInput",
      "title": "GetQueryResultsInput",
      "type": "object",
      "properties": {
        "QueryExecutionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "\\S+"
        },
        "NextToken": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "MaxResults": {
          "type": "integer",
          "minimum": 1.0,
          "maximum": 1000.0,
          "format": "int32"
        }
      },
      "required": [
        "QueryExecutionId"
      ]
    }
- GetQueryRuntimeStatisticsOutput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryRuntimeStatisticsOutput",
      "title": "GetQueryRuntimeStatisticsOutput",
      "type": "object",
      "properties": {
        "QueryRuntimeStatistics": {
          "id": "QueryRuntimeStatistics2",
          "title": "QueryRuntimeStatistics2",
          "type": "object",
          "properties": {
            "Timeline": {
              "id": "QueryRuntimeStatisticsTimeline",
              "title": "QueryRuntimeStatisticsTimeline",
              "description": "Timeline statistics such as query queue time, planning time, execution time, service processing time, and total execution time.",
              "type": "object",
              "properties": {
                "QueryQueueTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "QueryPlanningTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "EngineExecutionTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "ServiceProcessingTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                },
                "TotalExecutionTimeInMillis": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            },
            "Rows": {
              "id": "QueryRuntimeStatisticsRows",
              "title": "QueryRuntimeStatisticsRows",
              "description": "Statistics such as input rows and bytes read by the query, rows and bytes output by the query, and the number of rows written by the query.",
              "type": "object",
              "properties": {
                "InputRows": {
                  "type": "integer",
                  "format": "int32"
                },
                "InputBytes": {
                  "type": "integer",
                  "format": "int32"
                },
                "OutputBytes": {
                  "type": "integer",
                  "format": "int32"
                },
                "OutputRows": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            },
            "OutputStage": {
              "id": "OutputStage",
              "title": "OutputStage",
              "type": "object",
              "properties": {
                "StageId": {
                  "type": "integer",
                  "format": "int32"
                },
                "State": {
                  "type": "string"
                },
                "OutputBytes": {
                  "type": "integer",
                  "format": "int32"
                },
                "OutputRows": {
                  "type": "integer",
                  "format": "int32"
                },
                "InputBytes": {
                  "type": "integer",
                  "format": "int32"
                },
                "InputRows": {
                  "type": "integer",
                  "format": "int32"
                },
                "ExecutionTime": {
                  "type": "integer",
                  "format": "int32"
                },
                "QueryStagePlan": {
                  "id": "QueryStagePlan",
                  "title": "QueryStagePlan",
                  "type": "object",
                  "properties": {
                    "Name": {
                      "type": "string"
                    },
                    "Identifier": {
                      "type": "string"
                    },
                    "Children": {
                      "description": "",
                      "type": "array",
                      "items": {
                        "id": "QueryStagePlanNode",
                        "title": "QueryStagePlanNode",
                        "description": "Stage plan information such as name, identifier, sub plans, and remote sources.",
                        "type": "object",
                        "properties": {
                          "Name": {
                            "type": "string"
                          },
                          "Identifier": {
                            "type": "string"
                          },
                          "Children": {
                            "description": "",
                            "type": "array",
                            "items": {
                              "$ref": "QueryStagePlanNode"
                            }
                          },
                          "RemoteSources": {
                            "description": "",
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    },
                    "RemoteSources": {
                      "description": "",
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "SubStages": {
                  "description": "",
                  "type": "array",
                  "items": {
                    "id": "QueryStage",
                    "title": "QueryStage",
                    "description": "Stage statistics such as input and output rows and bytes, execution time and stage state. This information also includes substages and the query stage plan.",
                    "type": "object",
                    "properties": {
                      "StageId": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "State": {
                        "type": "string"
                      },
                      "OutputBytes": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "OutputRows": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "InputBytes": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "InputRows": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "ExecutionTime": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "QueryStagePlan": {
                        "$ref": "QueryStagePlan"
                      },
                      "SubStages": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "$ref": "QueryStage"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
- GetQueryRuntimeStatisticsInput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetQueryRuntimeStatisticsInput",
      "title": "GetQueryRuntimeStatisticsInput",
      "type": "object",
      "properties": {
        "QueryExecutionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "\\S+"
        }
      },
      "required": [
        "QueryExecutionId"
      ]
    }
- GetSessionResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetSessionResponse",
      "title": "GetSessionResponse",
      "type": "object",
      "properties": {
        "SessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "Description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "WorkGroup": {
          "type": "string",
          "pattern": "[a-zA-Z0-9._-]{1,128}"
        },
        "EngineVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "EngineConfiguration": {
          "id": "EngineConfiguration1",
          "title": "EngineConfiguration1",
          "type": "object",
          "properties": {
            "MaxConcurrentDpus": {
              "type": "integer",
              "minimum": 2.0,
              "maximum": 5000.0,
              "format": "int32"
            },
            "CoordinatorDpuSize": {
              "type": "integer",
              "minimum": 1.0,
              "maximum": 1.0,
              "format": "int32"
            },
            "DefaultExecutorDpuSize": {
              "type": "integer",
              "minimum": 1.0,
              "maximum": 1.0,
              "format": "int32"
            },
            "AdditionalConfigs": {
              "id": "AdditionalConfigs",
              "title": "AdditionalConfigs",
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "maxLength": 51200
              }
            }
          },
          "required": [
            "MaxConcurrentDpus"
          ]
        },
        "NotebookVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "SessionConfiguration": {
          "id": "SessionConfiguration2",
          "title": "SessionConfiguration2",
          "type": "object",
          "properties": {
            "ExecutionRole": {
              "type": "string",
              "minLength": 20,
              "maxLength": 2048,
              "pattern": "^arn:aws[a-z\\-]*:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$"
            },
            "WorkingDirectory": {
              "type": "string"
            },
            "IdleTimeoutSeconds": {
              "type": "integer",
              "format": "int32"
            },
            "EncryptionConfiguration": {
              "id": "EncryptionConfiguration",
              "title": "EncryptionConfiguration",
              "description": "If query and calculation results are encrypted in Amazon S3, indicates the encryption option used (for example, <code>SSE_KMS</code> or <code>CSE_KMS</code>) and key information.",
              "type": "object",
              "properties": {
                "EncryptionOption": {
                  "title": "EncryptionOption1",
                  "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "SSE_S3",
                    "SSE_KMS",
                    "CSE_KMS"
                  ]
                },
                "KmsKey": {
                  "type": "string"
                }
              },
              "required": [
                "EncryptionOption"
              ]
            }
          }
        },
        "Status": {
          "id": "Status3",
          "title": "Status3",
          "type": "object",
          "properties": {
            "StartDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "LastModifiedDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "EndDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "IdleSinceDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "State": {
              "title": "SessionState1",
              "description": "<p>The state of the session. A description of each state follows.</p> <p> <code>CREATING</code> - The session is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The session has been started.</p> <p> <code>IDLE</code> - The session is able to accept a calculation.</p> <p> <code>BUSY</code> - The session is processing another task and is unable to accept a calculation.</p> <p> <code>TERMINATING</code> - The session is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The session and its resources are no longer running.</p> <p> <code>DEGRADED</code> - The session has no healthy coordinators.</p> <p> <code>FAILED</code> - Due to a failure, the session and its resources are no longer running.</p>",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "CREATING",
                "CREATED",
                "IDLE",
                "BUSY",
                "TERMINATING",
                "TERMINATED",
                "DEGRADED",
                "FAILED"
              ]
            },
