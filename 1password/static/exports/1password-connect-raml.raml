                          "id": "ErrorResponse",
                          "title": "ErrorResponse",
                          "example": {
                            "message": "vault {vaultUuid} is not in scope",
                            "status": 403
                          },
                          "type": "object",
                          "properties": {
                            "message": {
                              "description": "A message detailing the error",
                              "type": "string"
                            },
                            "status": {
                              "description": "HTTP Status Code",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
