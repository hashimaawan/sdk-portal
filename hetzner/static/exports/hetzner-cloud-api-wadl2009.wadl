    <resource id="_certificates" path="/certificates">
      <method id="GetallCertificates" name="GET">
        <doc title="Get all Certificates" xml:lang="en">Returns all Certificate objects.</doc>
        <request>
          <param name="sort" style="query" default="">
            <doc title="sort" xml:lang="en">Can be used multiple times.</doc>
            <option value="id">
              <doc title="id" xml:lang="en" />
            </option>
            <option value="Enum_idasc">
