          <xs:documentation>#### Call specific error codes| Code                          | Description                                                   ||------------------------------ |-------------------------------------------------------------- || `floating_ip_assigned`        | The floating IP is already assigned                           |</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="server" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Server the Floating IP shall be assigned to</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ChangeDNSPTRRequest">
        <xs:sequence>
          <xs:element minOccurs="1" name="dns_ptr" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Hostname to set as a reverse DNS PTR entry, will reset to original default value if `null`</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ip" type="xs:string">
            <xs:annotation>
              <xs:documentation>IP address for which to set the reverse DNS entry</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ChangeProtectionRequest">
        <xs:sequence>
          <xs:element minOccurs="0" name="delete" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>If true, prevents the Floating IP from being deleted</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="type21">
        <xs:restriction base="xs:string">
          <xs:enumeration value="system" />
          <xs:enumeration value="snapshot" />
          <xs:enumeration value="backup" />
          <xs:enumeration value="app" />
        </xs:restriction>
      </xs:simpleType>
      <xs:simpleType name="status23">
        <xs:restriction base="xs:string">
          <xs:enumeration value="available" />
          <xs:enumeration value="creating" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="ImagesResponse">
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="images" type="schemas:Image" />
          <xs:element minOccurs="0" name="meta" type="schemas:Meta" />
