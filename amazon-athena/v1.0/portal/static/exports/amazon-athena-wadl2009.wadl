          <param name="X-Amz-Credential" style="header" type="xsd:string">
            <doc title="X-Amz-Credential" xml:lang="en" />
          </param>
          <param name="X-Amz-Security-Token" style="header" type="xsd:string">
            <doc title="X-Amz-Security-Token" xml:lang="en" />
          </param>
          <param name="X-Amz-Signature" style="header" type="xsd:string">
            <doc title="X-Amz-Signature" xml:lang="en" />
          </param>
          <param name="X-Amz-SignedHeaders" style="header" type="xsd:string">
            <doc title="X-Amz-SignedHeaders" xml:lang="en" />
