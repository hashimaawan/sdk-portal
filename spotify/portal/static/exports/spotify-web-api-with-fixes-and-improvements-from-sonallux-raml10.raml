/recommendations:
  get:
    displayName: get-recommendations
    description: >
      Recommendations are generated based on the available information for a given seed entity and matched against similar artists and tracks. If there is sufficient information about the provided seeds, a list of tracks will be returned together with pool size details.


      For artists and tracks that are very new or obscure there might not be enough data to generate a list of tracks.
    securedBy:
    - oauth_2_0
    queryParameters:
      limit:
        required: false
        default: '20'
        example:
          value: 10
        displayName: limit
        type: integer
        minimum: 1
        maximum: 100
        format: int32
      market:
        required: false
        example:
          value: ES
        displayName: market
        type: string
      seed_artists:
        required: false
        example:
          value: 4NHQUGzhtTLFvgF5SZesLK
        displayName: seed_artists
        type: string
      seed_genres:
        required: false
        example:
          value: classical,country
        displayName: seed_genres
        type: string
      seed_tracks:
        required: false
        example:
          value: 0c6xIDDpzE81m2q797ordA
        displayName: seed_tracks
        type: string
      min_acousticness:
        required: false
        displayName: min_acousticness
        type: number
        minimum: 0
        maximum: 1
        format: double
      max_acousticness:
        required: false
        displayName: max_acousticness
        type: number
        minimum: 0
        maximum: 1
        format: double
      target_acousticness:
        required: false
        displayName: target_acousticness
        type: number
        minimum: 0
        maximum: 1
        format: double
      min_danceability:
        required: false
