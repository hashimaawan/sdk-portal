- GetWorkGroupOutput: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetWorkGroupOutput",
      "title": "GetWorkGroupOutput",
      "type": "object",
      "properties": {
        "WorkGroup": {
          "id": "WorkGroup2",
          "title": "WorkGroup2",
          "type": "object",
          "properties": {
            "Name": {
              "type": "string",
              "pattern": "[a-zA-Z0-9._-]{1,128}"
            },
            "State": {
              "title": "WorkGroupState3",
              "description": "The state of the workgroup: ENABLED or DISABLED.",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "ENABLED",
                "DISABLED"
              ]
            },
            "Configuration": {
              "id": "Configuration",
              "title": "Configuration",
              "type": "object",
              "properties": {
                "ResultConfiguration": {
                  "id": "ResultConfiguration1",
                  "title": "ResultConfiguration1",
                  "type": "object",
                  "properties": {
                    "OutputLocation": {
                      "type": "string"
                    },
                    "EncryptionConfiguration": {
                      "id": "EncryptionConfiguration2",
                      "title": "EncryptionConfiguration2",
                      "type": "object",
                      "properties": {
                        "EncryptionOption": {
                          "title": "EncryptionOption1",
                          "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "SSE_S3",
                            "SSE_KMS",
                            "CSE_KMS"
                          ]
                        },
                        "KmsKey": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "EncryptionOption"
                      ]
                    },
                    "ExpectedBucketOwner": {
                      "type": "string",
                      "minLength": 12,
                      "maxLength": 12,
                      "pattern": "^[0-9]+$"
                    },
                    "AclConfiguration": {
                      "id": "AclConfiguration1",
                      "title": "AclConfiguration1",
                      "type": "object",
                      "properties": {
                        "S3AclOption": {
                          "title": "S3AclOption1",
                          "description": "The Amazon S3 canned ACL that Athena should specify when storing query results. Currently the only supported canned ACL is <code>BUCKET_OWNER_FULL_CONTROL</code>. If a query runs in a workgroup and the workgroup overrides client-side settings, then the Amazon S3 canned ACL specified in the workgroup's settings is used for all queries that run in the workgroup. For more information about Amazon S3 canned ACLs, see <a href=\"https://docs.aws.amazon.com/AmazonS3/latest/userguide/acl-overview.html#canned-acl\">Canned ACL</a> in the <i>Amazon S3 User Guide</i>.",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "BUCKET_OWNER_FULL_CONTROL"
                          ]
                        }
                      },
                      "required": [
                        "S3AclOption"
                      ]
                    }
                  }
                },
                "EnforceWorkGroupConfiguration": {
                  "type": "boolean"
                },
                "PublishCloudWatchMetricsEnabled": {
                  "type": "boolean"
                },
                "BytesScannedCutoffPerQuery": {
                  "type": "integer",
                  "minimum": 10000000.0,
                  "format": "int32"
                },
                "RequesterPaysEnabled": {
                  "type": "boolean"
                },
                "EngineVersion": {
                  "id": "EngineVersion1",
                  "title": "EngineVersion1",
                  "type": "object",
                  "properties": {
                    "SelectedEngineVersion": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "EffectiveEngineVersion": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    }
                  }
                },
                "AdditionalConfiguration": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "ExecutionRole": {
                  "type": "string",
                  "minLength": 20,
                  "maxLength": 2048,
                  "pattern": "^arn:aws[a-z\\-]*:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$"
                },
                "CustomerContentEncryptionConfiguration": {
                  "id": "CustomerContentEncryptionConfiguration2",
                  "title": "CustomerContentEncryptionConfiguration2",
                  "type": "object",
                  "properties": {
                    "KmsKey": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 2048,
                      "pattern": "^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:key/?[a-zA-Z_0-9+=,.@\\-_/]+$|^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:alias/?[a-zA-Z_0-9+=,.@\\-_/]+$|^alias/[a-zA-Z0-9/_-]+$|[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}"
                    }
                  },
                  "required": [
                    "KmsKey"
                  ]
                },
                "EnableMinimumEncryptionConfiguration": {
                  "type": "boolean"
                }
              }
            },
            "Description": {
              "type": "string",
              "minLength": 0,
              "maxLength": 1024
            },
            "CreationTime": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "Name"
          ]
        }
      }
    }
