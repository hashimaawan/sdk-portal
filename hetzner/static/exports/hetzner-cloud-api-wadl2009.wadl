            <xs:annotation>
              <xs:documentation>List of selected targets</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="type" type="schemas:Type29">
            <xs:annotation>
              <xs:documentation>Type of the resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="use_private_ip" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Use the private network IP instead of the public IP. Default value is false.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
