                            "id",
                            "labels",
                            "name",
                            "servers",
                            "type"
                          ]
                        },
                        "volumes": {
                          "description": "IDs of Volumes assigned to this Server",
                          "type": "array",
                          "items": {
                            "type": "integer",
                            "format": "int32"
                          }
                        }
                      },
                      "required": [
                        "backup_window",
                        "created",
                        "datacenter",
                        "id",
                        "image",
                        "included_traffic",
                        "ingoing_traffic",
                        "iso",
                        "labels",
                        "locked",
                        "name",
                        "outgoing_traffic",
