  post:
    description: >
      Creates a new Certificate.


      The default type **uploaded** allows for uploading your existing `certificate` and `private_key` in PEM format. You have to monitor its expiration date and handle renewal yourself.


      In contrast, type **managed** requests a new Certificate from *Let's Encrypt* for the specified `domain_names`. Only domains managed by *Hetzner DNS* are supported. We handle renewal and timely alert the project owner via email if problems occur.


      For type `managed` Certificates the `action` key of the response contains the Action that allows for tracking the issuance process. For type `uploaded` Certificates the `action` is always null.
    headers:
      Content-Type:
        example: application/json
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "CreateCertificateRequest",
            "title": "CreateCertificateRequest",
            "examples": [
              {
                "Id": "managed",
                "Name": "Creating a type `managed` Certificate",
                "Value": "{\"domain_names\":[\"example.com\",\"webmail.example.com\",\"www.example.com\"],\"name\":\"my website cert\",\"type\":\"managed\"}",
                "ExternalValue": null,
                "Description": null
              },
              {
                "Id": "uploaded",
                "Name": "Creating a type `uploaded` Certificate",
                "Value": "{\"certificate\":\"-----BEGIN CERTIFICATE-----\\n...\",\"name\":\"my website cert\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\",\"type\":\"uploaded\"}",
                "ExternalValue": null,
                "Description": null
              }
            ],
            "example": {
              "domain_names": [
                "example.com",
                "webmail.example.com",
                "www.example.com"
              ],
              "name": "my website cert",
              "type": "managed"
            },
            "type": "object",
            "properties": {
              "name": {
                "description": "Name of the Certificate",
                "example": "my website cert",
                "type": "string"
              },
              "certificate": {
                "description": "Certificate and chain in PEM format, in order so that each record directly certifies the one preceding. Required for type `uploaded` Certificates.",
                "example": "-----BEGIN CERTIFICATE-----\n...",
                "type": "string"
              },
              "domain_names": {
                "description": "Domains and subdomains that should be contained in the Certificate issued by *Let's Encrypt*. Required for type `managed` Certificates.",
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object"
              },
              "private_key": {
                "description": "Certificate key in PEM format. Required for type `uploaded` Certificates.",
                "example": "-----BEGIN PRIVATE KEY-----\n...",
                "type": "string"
              },
              "type": {
                "title": "Type1",
                "description": "Choose between uploading a Certificate in PEM format or requesting a managed *Let's Encrypt* Certificate. If omitted defaults to `uploaded`.",
                "example": "uploaded",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "uploaded",
                  "managed"
                ]
              }
            },
            "required": [
              "name"
            ]
          }
        example: '{"domain_names":["example.com","webmail.example.com","www.example.com"],"name":"my website cert","type":"managed"}'
    responses:
      '201':
        description: The `certificate` key contains the Certificate that was just created. For type `managed` Certificates the `action` key contains the Action that allows for tracking the issuance process. For type `uploaded` Certificates the `action` is always null.
        body:
          application/json:
            schema: |
              {
                "id": "CreateCertificateResponse",
                "title": "CreateCertificateResponse",
                "examples": [
                  {
                    "Id": "managed",
                    "Name": "Response when creating a type `managed` Certificate",
                    "Value": "{\"action\":{\"command\":\"create_certificate\",\"error\":{\"code\":\"action_failed\",\"message\":\"Action failed\"},\"finished\":null,\"id\":13,\"progress\":0,\"resources\":[{\"id\":879,\"type\":\"certificate\"}],\"started\":\"2019-01-08T12:10:00+00:00\",\"status\":\"running\"},\"certificate\":{\"certificate\":null,\"created\":\"2019-01-08T12:10:00+00:00\",\"domain_names\":[\"example.com\",\"webmail.example.com\",\"www.example.com\"],\"fingerprint\":null,\"id\":897,\"labels\":{\"env\":\"dev\"},\"name\":\"my website cert\",\"not_valid_after\":null,\"not_valid_before\":null,\"status\":{\"error\":null,\"issuance\":\"pending\",\"renewal\":\"unavailable\"},\"type\":\"managed\",\"used_by\":[{\"id\":4711,\"type\":\"load_balancer\"}]}}",
                    "ExternalValue": null,
                    "Description": null
                  },
                  {
                    "Id": "uploaded",
                    "Name": "Response when creating a type `uploaded` Certificate",
                    "Value": "{\"action\":null,\"certificate\":{\"certificate\":\"-----BEGIN CERTIFICATE-----\\n...\",\"created\":\"2019-01-08T12:10:00+00:00\",\"domain_names\":[\"example.com\",\"webmail.example.com\",\"www.example.com\"],\"fingerprint\":\"03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f\",\"id\":897,\"labels\":{\"env\":\"dev\"},\"name\":\"my website cert\",\"not_valid_after\":\"2019-07-08T09:59:59+00:00\",\"not_valid_before\":\"2019-01-08T10:00:00+00:00\",\"status\":null,\"type\":\"uploaded\",\"used_by\":[{\"id\":4711,\"type\":\"load_balancer\"}]}}",
                    "ExternalValue": null,
                    "Description": null
                  }
                ],
                "example": {
                  "action": {
                    "command": "create_certificate",
                    "error": {
                      "code": "action_failed",
                      "message": "Action failed"
                    },
                    "finished": null,
                    "id": 13,
                    "progress": 0,
                    "resources": [
                      {
                        "id": 879,
                        "type": "certificate"
                      }
                    ],
                    "started": "2019-01-08T12:10:00+00:00",
                    "status": "running"
                  },
                  "certificate": {
                    "certificate": null,
                    "created": "2019-01-08T12:10:00+00:00",
                    "domain_names": [
                      "example.com",
                      "webmail.example.com",
                      "www.example.com"
                    ],
                    "fingerprint": null,
                    "id": 897,
                    "labels": {
                      "env": "dev"
                    },
                    "name": "my website cert",
                    "not_valid_after": null,
                    "not_valid_before": null,
                    "status": {
                      "error": null,
                      "issuance": "pending",
                      "renewal": "unavailable"
                    },
                    "type": "managed",
                    "used_by": [
                      {
                        "id": 4711,
                        "type": "load_balancer"
                      }
                    ]
                  }
                },
                "type": "object",
                "properties": {
                  "certificate": {
                    "id": "Certificate",
                    "title": "Certificate",
                    "type": "object",
                    "properties": {
                      "certificate": {
                        "description": "Certificate and chain in PEM format, in order so that each record directly certifies the one preceding",
                        "example": "-----BEGIN CERTIFICATE-----\n...",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "created": {
                        "description": "Point in time when the Resource was created (in ISO-8601 format)",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": "string"
                      },
                      "domain_names": {
                        "description": "Domains and subdomains covered by the Certificate",
                        "example": [
                          "example.com",
                          "webmail.example.com",
                          "www.example.com"
                        ],
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "fingerprint": {
                        "description": "SHA256 fingerprint of the Certificate",
                        "example": "03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "labels": {
                        "description": "User-defined labels (key-value pairs)",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "name": {
                        "description": "Name of the Resource. Must be unique per Project.",
                        "example": "my-resource",
                        "type": "string"
                      },
                      "not_valid_after": {
                        "description": "Point in time when the Certificate stops being valid (in ISO-8601 format)",
                        "example": "2019-07-08T09:59:59+00:00",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "not_valid_before": {
                        "description": "Point in time when the Certificate becomes valid (in ISO-8601 format)",
                        "example": "2019-01-08T10:00:00+00:00",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "used_by": {
                        "description": "Resources currently using the Certificate",
                        "type": "array",
                        "items": {
                          "id": "UsedBy",
                          "title": "UsedBy",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "ID of resource referenced",
                              "example": 4711,
                              "type": "integer",
                              "format": "int32"
                            },
                            "type": {
                              "description": "Type of resource referenced",
                              "example": "load_balancer",
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "type"
                          ]
                        }
                      },
                      "status": {
                        "id": "Status2",
                        "title": "Status2",
                        "description": "Current status of a type `managed` Certificate, always *null* for type `uploaded` Certificates",
                        "type": [
                          "object",
                          "null"
                        ],
                        "properties": {
                          "error": {
                            "id": "Error2",
                            "title": "Error2",
                            "description": "If issuance or renewal reports `failed`, this property contains information about what happened",
                            "type": [
                              "object",
                              "null"
                            ],
                            "properties": {
                              "code": {
                                "type": "string"
                              },
                              "message": {
                                "type": "string"
                              }
                            }
                          },
                          "issuance": {
                            "title": "Issuance",
                            "description": "Status of the issuance process of the Certificate",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "pending",
                              "completed",
                              "failed"
                            ]
                          },
                          "renewal": {
                            "title": "Renewal",
                            "description": "Status of the renewal process of the Certificate.",
                            "example": "scheduled",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "scheduled",
                              "pending",
                              "failed",
                              "unavailable"
                            ]
                          }
                        }
                      },
                      "type": {
                        "title": "Type",
                        "description": "Type of the Certificate",
                        "example": "uploaded",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "uploaded",
                          "managed"
                        ]
                      }
                    },
                    "required": [
                      "certificate",
                      "created",
                      "domain_names",
                      "fingerprint",
                      "id",
                      "labels",
                      "name",
                      "not_valid_after",
                      "not_valid_before",
                      "used_by"
                    ]
                  },
                  "action": {
                    "id": "NullableAction",
                    "title": "NullableAction",
                    "type": [
                      "object",
                      "null"
                    ],
                    "properties": {
                      "command": {
                        "description": "Command executed in the Action",
                        "example": "start_server",
                        "type": "string"
                      },
                      "error": {
                        "id": "Error",
                        "title": "Error",
                        "description": "Error message for the Action if error occurred, otherwise null",
                        "type": [
                          "object",
                          "null"
                        ],
                        "properties": {
                          "code": {
                            "description": "Fixed machine readable code",
                            "example": "action_failed",
                            "type": "string"
                          },
                          "message": {
                            "description": "Humanized error message",
                            "example": "Action failed",
                            "type": "string"
                          }
                        },
                        "required": [
                          "code",
                          "message"
                        ]
                      },
                      "finished": {
                        "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "progress": {
                        "description": "Progress of Action in percent",
                        "example": 100,
                        "type": "number"
                      },
                      "resources": {
                        "description": "Resources the Action relates to",
                        "type": "array",
                        "items": {
                          "id": "Resource",
                          "title": "Resource",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "ID of the Resource",
                              "example": 42,
                              "type": "integer",
                              "format": "int32"
                            },
                            "type": {
                              "description": "Type of resource referenced",
                              "example": "server",
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "type"
                          ]
                        }
                      },
                      "started": {
                        "description": "Point in time when the Action was started (in ISO-8601 format)",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": "string"
                      },
                      "status": {
                        "title": "Status",
                        "description": "Status of the Action",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "success",
                          "running",
                          "error"
                        ]
                      }
                    },
                    "required": [
                      "command",
                      "error",
                      "finished",
                      "id",
                      "progress",
                      "resources",
                      "started",
                      "status"
                    ]
                  }
                },
                "required": [
                  "certificate"
                ]
              }
            example: '{"action":{"command":"create_certificate","error":{"code":"action_failed","message":"Action failed"},"finished":null,"id":13,"progress":0,"resources":[{"id":879,"type":"certificate"}],"started":"2019-01-08T12:10:00+00:00","status":"running"},"certificate":{"certificate":null,"created":"2019-01-08T12:10:00+00:00","domain_names":["example.com","webmail.example.com","www.example.com"],"fingerprint":null,"id":897,"labels":{"env":"dev"},"name":"my website cert","not_valid_after":null,"not_valid_before":null,"status":{"error":null,"issuance":"pending","renewal":"unavailable"},"type":"managed","used_by":[{"id":4711,"type":"load_balancer"}]}}'
/datacenters:
  /{id}:
    uriParameters:
      id:
        description: ID of Datacenter
        type: integer
        required: true
        displayName: id
    get:
      description: Returns a specific Datacenter object.
      responses:
        '200':
          description: The `datacenter` key in the reply contains a Datacenter object with this structure
          body:
            application/json:
              schema: |
                {
                  "id": "DatacentersResponse1",
                  "title": "DatacentersResponse1",
                  "type": "object",
                  "properties": {
                    "datacenter": {
                      "id": "Datacenter",
                      "title": "Datacenter",
                      "type": "object",
                      "properties": {
                        "description": {
                          "description": "Description of the Datacenter",
                          "example": "Falkenstein DC Park 8",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "location": {
                          "id": "Location",
                          "title": "Location",
                          "type": "object",
                          "properties": {
                            "city": {
                              "description": "City the Location is closest to",
                              "example": "Falkenstein",
                              "type": "string"
                            },
                            "country": {
                              "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                              "example": "DE",
                              "type": "string"
                            },
                            "description": {
                              "description": "Description of the Location",
                              "example": "Falkenstein DC Park 1",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Location",
                              "example": 1,
                              "type": "number"
                            },
                            "latitude": {
                              "description": "Latitude of the city closest to the Location",
                              "example": 50.47612,
                              "type": "number"
                            },
                            "longitude": {
                              "description": "Longitude of the city closest to the Location",
                              "example": 12.370071,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Location",
                              "example": "fsn1",
                              "type": "string"
                            },
                            "network_zone": {
                              "description": "Name of network zone this Location resides in",
                              "example": "eu-central",
                              "type": "string"
                            }
                          },
                          "required": [
                            "city",
                            "country",
                            "description",
                            "id",
                            "latitude",
                            "longitude",
                            "name",
                            "network_zone"
                          ]
                        },
                        "name": {
                          "description": "Unique identifier of the Datacenter",
                          "example": "fsn1-dc8",
                          "type": "string"
                        },
                        "server_types": {
                          "id": "ServerTypes",
                          "title": "ServerTypes",
                          "description": "The Server types the Datacenter can handle",
                          "type": "object",
                          "properties": {
                            "available": {
                              "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                              "example": [
                                1,
                                2,
                                3
                              ],
                              "type": "array",
                              "items": {
                                "type": "number"
                              }
                            },
                            "available_for_migration": {
                              "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                              "example": [
                                1,
                                2,
                                3
                              ],
                              "type": "array",
                              "items": {
                                "type": "number"
                              }
                            },
                            "supported": {
                              "description": "IDs of Server types that are supported in the Datacenter",
                              "example": [
                                1,
                                2,
                                3
                              ],
                              "type": "array",
                              "items": {
                                "type": "number"
                              }
                            }
                          },
                          "required": [
                            "available",
                            "available_for_migration",
                            "supported"
                          ]
                        }
                      },
                      "required": [
                        "description",
                        "id",
                        "location",
                        "name",
                        "server_types"
                      ]
                    }
                  },
                  "required": [
                    "datacenter"
                  ]
                }
  get:
    description: Returns all Datacenter objects.
    queryParameters:
      name:
        description: Can be used to filter Datacenters by their name. The response will only contain the Datacenter matching the specified name. When the name does not match the Datacenter name format, an `invalid_input` error is returned.
