          "type": "integer",
          "minimum": 1.0,
          "maximum": 1.0,
          "format": "int32"
        },
        "DefaultExecutorDpuSize": {
          "type": "integer",
          "minimum": 1.0,
          "maximum": 1.0,
          "format": "int32"
        },
        "AdditionalConfigs": {
          "id": "AdditionalConfigs",
          "title": "AdditionalConfigs",
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 51200
          }
        }
      },
      "required": [
