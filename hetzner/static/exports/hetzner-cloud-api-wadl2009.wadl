      </xs:complexType>
      <xs:complexType name="Image">
        <xs:sequence>
          <xs:element minOccurs="1" name="bound_to" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of Server the Image is bound to. Only set for Images of type `backup`.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="created" type="xs:string">
            <xs:annotation>
              <xs:documentation>Point in time when the Resource was created (in ISO-8601 format)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="created_from" nillable="true" type="schemas:CreatedFrom">
