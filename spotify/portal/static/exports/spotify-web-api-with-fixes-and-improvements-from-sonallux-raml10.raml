/audiobooks:
  get:
    displayName: get-multiple-audiobooks
    description: >
      Get Spotify catalog information for several audiobooks identified by their Spotify IDs. Audiobooks are only available within the US, UK, Canada, Ireland, New Zealand and Australia markets.
    securedBy:
    - oauth_2_0
    queryParameters:
      ids:
        required: true
        example:
          value: 18yVqkdbdRvS24c0Ilj2ci,1HGw3J3NxZO1TP1BTtVhpZ,7iHfbu1YPACw6oZPAFJtqe
        displayName: ids
        type: string
      market:
        required: false
        example:
          value: ES
        displayName: market
        type: string
    responses:
      '200':
        description: A set of audiobooks. If one of the requested audiobooks is unavailable then you'll find a `null` item in the `audiobooks` array where the audiobook object would otherwise be.
        body:
          application/json:
            displayName: response200
            description: ''
            type: ManyAudiobooks
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            displayName: response401
            description: ''
            type: Unauthorized1
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            displayName: response403
            description: ''
            type: Forbidden1
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            displayName: response429
            description: ''
            type: TooManyRequests1
  /{id}:
    uriParameters:
      id:
        required: true
        example:
          value: 7iHfbu1YPACw6oZPAFJtqe
        displayName: id
        type: string
    get:
      displayName: get-an-audiobook
      description: >
        Get Spotify catalog information for a single audiobook. Audiobooks are only available within the US, UK, Canada, Ireland, New Zealand and Australia markets.
      securedBy:
      - oauth_2_0
      queryParameters:
        market:
          required: false
          example:
            value: ES
          displayName: market
          type: string
      responses:
        '200':
          description: An Audiobook
          body:
            application/json:
              displayName: response200
              description: ''
              type: AudiobookObject
        '400':
          description: The request contains malformed data in path, query parameters, or body.
          body:
            application/json:
              displayName: response400
              description: ''
              type: BadRequest1
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '404':
          description: The requested resource cannot be found.
          body:
            application/json:
              displayName: response404
              description: ''
              type: NotFound1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    /chapters:
      get:
        displayName: get-audiobook-chapters
        description: >
          Get Spotify catalog information about an audiobook's chapters. Audiobooks are only available within the US, UK, Canada, Ireland, New Zealand and Australia markets.
        securedBy:
        - oauth_2_0
        queryParameters:
          market:
            required: false
            example:
              value: ES
            displayName: market
            type: string
          limit:
            required: false
            default: '20'
            example:
              value: 10
            displayName: limit
            type: integer
            minimum: 1
            maximum: 50
            format: int32
          offset:
            required: false
            default: '0'
            example:
              value: 5
            displayName: offset
            type: integer
            format: int32
        responses:
          '200':
            description: Pages of chapters
            body:
              application/json:
                displayName: response200
                description: ''
                type: PagingSimplifiedChapterObject
          '401':
