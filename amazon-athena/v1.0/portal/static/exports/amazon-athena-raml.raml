                              "type": "object",
                              "properties": {
                                "ReusedPreviousResult": {
                                  "type": "boolean"
                                }
                              },
                              "required": [
                                "ReusedPreviousResult"
                              ]
                            }
                          }
                        },
                        "WorkGroup": {
                          "type": "string",
                          "pattern": "[a-zA-Z0-9._-]{1,128}"
                        },
                        "EngineVersion": {
                          "id": "EngineVersion1",
