                                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                          "type": "string"
                                        },
                                        "name": {
                                          "description": "The name of the artist.",
                                          "type": "string"
                                        },
                                        "type": {
                                          "title": "Type",
                                          "description": "The object type.",
                                          "type": "string",
                                          "additionalProperties": false,
