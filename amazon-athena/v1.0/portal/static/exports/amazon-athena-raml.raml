/#X-Amz-Target=AmazonAthena.GetCalculationExecution:
  post:
    description: Describes a previously submitted calculation execution.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.GetCalculationExecution
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "GetCalculationExecutionRequest",
            "title": "GetCalculationExecutionRequest",
            "type": "object",
            "properties": {
              "CalculationExecutionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 36
              }
            },
            "required": [
              "CalculationExecutionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "GetCalculationExecutionResponse",
                "title": "GetCalculationExecutionResponse",
                "type": "object",
                "properties": {
                  "CalculationExecutionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 36
                  },
                  "SessionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "Description": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                  },
                  "WorkingDirectory": {
                    "type": "string",
                    "maxLength": 1024,
                    "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
                  },
                  "Status": {
                    "id": "Status1",
                    "title": "Status1",
                    "type": "object",
                    "properties": {
                      "SubmissionDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "CompletionDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "State": {
                        "title": "CalculationExecutionState1",
                        "description": "<p>The state of the calculation execution. A description of each state follows.</p> <p> <code>CREATING</code> - The calculation is in the process of being created.</p> <p> <code>CREATED</code> - The calculation has been created and is ready to run.</p> <p> <code>QUEUED</code> - The calculation has been queued for processing.</p> <p> <code>RUNNING</code> - The calculation is running.</p> <p> <code>CANCELING</code> - A request to cancel the calculation has been received and the system is working to stop it.</p> <p> <code>CANCELED</code> - The calculation is no longer running as the result of a cancel request.</p> <p> <code>COMPLETED</code> - The calculation has completed without error.</p> <p> <code>FAILED</code> - The calculation failed and is no longer running.</p>",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "CREATING",
                          "CREATED",
                          "QUEUED",
                          "RUNNING",
                          "CANCELING",
                          "CANCELED",
                          "COMPLETED",
                          "FAILED"
                        ]
                      },
                      "StateChangeReason": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                      }
                    }
                  },
                  "Statistics": {
                    "id": "Statistics1",
                    "title": "Statistics1",
                    "type": "object",
                    "properties": {
                      "DpuExecutionInMillis": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "Progress": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                      }
                    }
                  },
                  "Result": {
                    "id": "Result",
                    "title": "Result",
                    "type": "object",
                    "properties": {
                      "StdOutS3Uri": {
                        "type": "string",
                        "maxLength": 1024,
                        "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
                      },
                      "StdErrorS3Uri": {
                        "type": "string",
                        "maxLength": 1024,
                        "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
                      },
                      "ResultS3Uri": {
                        "type": "string",
                        "maxLength": 1024,
                        "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
                      },
                      "ResultType": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 256,
                        "pattern": "\\w+\\/[-+.\\w]+"
                      }
                    }
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
