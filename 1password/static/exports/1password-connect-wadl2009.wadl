  <resources base="http://1password.local">
    <resource id="_vaultsvaultUuiditems" path="/vaults/{vaultUuid}/items">
      <param name="vaultUuid" style="template" type="xsd:string" required="true">
        <doc title="vaultUuid" xml:lang="en">The UUID of the Vault to fetch Items from</doc>
      </param>
      <param name="vaultUuid" style="template" type="xsd:string" required="true">
