        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
