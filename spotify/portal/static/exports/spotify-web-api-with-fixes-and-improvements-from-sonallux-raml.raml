              "maximum": 599.0,
              "format": "int32"
            },
            "message": {
              "description": "A short description of the cause of the error.",
              "type": "string"
            }
          },
          "required": [
            "status",
            "message"
          ]
        }
      },
      "required": [
        "error"
      ]
    }
