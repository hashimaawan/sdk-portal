          <xs:element minOccurs="0" name="innodb_lock_wait_timeout">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>The time, in seconds, that an InnoDB transaction waits for a row lock. before giving up.</xs:documentation>
