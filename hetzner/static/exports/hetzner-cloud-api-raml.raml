- PrimaryIPsResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PrimaryIPsResponse",
      "title": "PrimaryIPsResponse",
      "type": "object",
      "properties": {
        "primary_ips": {
          "description": "",
          "type": "array",
          "items": {
            "id": "PrimaryIP1",
            "title": "PrimaryIP1",
            "type": "object",
            "properties": {
              "assignee_id": {
                "description": "ID of the resource the Primary IP is assigned to, null if it is not assigned at all",
                "example": 17,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "assignee_type": {
                "description": "Resource type the Primary IP can be assigned to",
                "type": "string",
                "enum": [
                  "server"
                ]
              },
              "auto_delete": {
                "description": "Delete this Primary IP when the resource it is assigned to is deleted",
                "example": true,
                "type": "boolean"
              },
              "blocked": {
                "description": "Whether the IP is blocked",
                "example": false,
                "type": "boolean"
              },
              "created": {
                "description": "Point in time when the Resource was created (in ISO-8601 format)",
                "example": "2016-01-30T23:55:00+00:00",
                "type": "string"
              },
              "datacenter": {
                "id": "Datacenter2",
                "title": "Datacenter2",
                "description": "Datacenter this Primary IP is located at",
                "type": "object",
                "properties": {
                  "description": {
                    "description": "Description of the Datacenter",
                    "example": "Falkenstein DC Park 8",
                    "type": "string"
                  },
                  "id": {
                    "description": "ID of the Resource",
                    "example": 42,
                    "type": "integer",
                    "format": "int32"
                  },
                  "location": {
                    "id": "Location",
                    "title": "Location",
                    "type": "object",
                    "properties": {
                      "city": {
                        "description": "City the Location is closest to",
                        "example": "Falkenstein",
                        "type": "string"
                      },
                      "country": {
                        "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                        "example": "DE",
                        "type": "string"
                      },
                      "description": {
                        "description": "Description of the Location",
                        "example": "Falkenstein DC Park 1",
                        "type": "string"
                      },
                      "id": {
                        "description": "ID of the Location",
                        "example": 1,
                        "type": "number"
                      },
                      "latitude": {
                        "description": "Latitude of the city closest to the Location",
                        "example": 50.47612,
                        "type": "number"
                      },
                      "longitude": {
                        "description": "Longitude of the city closest to the Location",
                        "example": 12.370071,
                        "type": "number"
                      },
                      "name": {
                        "description": "Unique identifier of the Location",
                        "example": "fsn1",
                        "type": "string"
                      },
                      "network_zone": {
                        "description": "Name of network zone this Location resides in",
                        "example": "eu-central",
                        "type": "string"
                      }
                    },
                    "required": [
                      "city",
                      "country",
                      "description",
                      "id",
                      "latitude",
                      "longitude",
                      "name",
                      "network_zone"
                    ]
                  },
                  "name": {
                    "description": "Unique identifier of the Datacenter",
                    "example": "fsn1-dc8",
                    "type": "string"
                  },
                  "server_types": {
                    "id": "ServerTypes",
                    "title": "ServerTypes",
                    "description": "The Server types the Datacenter can handle",
                    "type": "object",
                    "properties": {
                      "available": {
                        "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                        "example": [
                          1,
                          2,
                          3
                        ],
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      },
                      "available_for_migration": {
                        "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                        "example": [
                          1,
                          2,
                          3
                        ],
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      },
                      "supported": {
                        "description": "IDs of Server types that are supported in the Datacenter",
                        "example": [
                          1,
                          2,
                          3
                        ],
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    },
                    "required": [
                      "available",
                      "available_for_migration",
                      "supported"
                    ]
                  }
                },
                "required": [
                  "description",
                  "id",
                  "location",
                  "name",
                  "server_types"
                ]
              },
              "dns_ptr": {
                "description": "Array of reverse DNS entries",
                "type": "array",
                "items": {
                  "id": "DnsPtr",
                  "title": "DnsPtr",
                  "type": "object",
                  "properties": {
                    "dns_ptr": {
                      "description": "DNS pointer for the specific IP address",
                      "example": "server.example.com",
                      "type": "string"
                    },
                    "ip": {
                      "description": "Single IPv4 or IPv6 address",
                      "example": "2001:db8::1",
                      "type": "string"
                    }
                  },
                  "required": [
                    "dns_ptr",
                    "ip"
                  ]
                }
              },
              "id": {
                "description": "ID of the Resource",
                "example": 42,
                "type": "integer",
                "format": "int32"
              },
              "ip": {
                "description": "IP address",
                "example": "131.232.99.1",
                "type": "string"
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "name": {
                "description": "Name of the Resource. Must be unique per Project.",
                "example": "my-resource",
                "type": "string"
              },
              "protection": {
                "id": "Protection",
                "title": "Protection",
                "description": "Protection configuration for the Resource",
                "type": "object",
                "properties": {
                  "delete": {
                    "description": "If true, prevents the Resource from being deleted",
                    "example": false,
                    "type": "boolean"
                  }
                },
                "required": [
                  "delete"
                ]
              },
              "type": {
                "title": "Type50",
                "description": "Type of the Primary IP",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "ipv4",
                  "ipv6"
                ]
              }
            },
            "required": [
              "assignee_id",
              "assignee_type",
              "auto_delete",
              "blocked",
              "created",
              "datacenter",
              "dns_ptr",
              "id",
              "ip",
              "labels",
              "name",
              "protection",
              "type"
            ]
          }
        },
        "meta": {
          "id": "Meta",
          "title": "Meta",
          "type": "object",
          "properties": {
            "pagination": {
              "id": "Pagination",
              "title": "Pagination",
              "type": "object",
              "properties": {
                "last_page": {
                  "description": "ID of the last page available. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "next_page": {
                  "description": "ID of the next page. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "page": {
                  "description": "Current page number",
                  "example": 3,
                  "type": "number"
                },
                "per_page": {
                  "description": "Maximum number of items shown per page in the response",
                  "example": 25,
                  "type": "number"
                },
                "previous_page": {
                  "description": "ID of the previous page. Can be null if the current page is the first one.",
                  "example": 2,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "total_entries": {
                  "description": "The total number of entries that exist in the database for this query. Nullable if unknown.",
                  "example": 100,
                  "type": [
                    "number",
                    "null"
                  ]
                }
              },
              "required": [
                "last_page",
                "next_page",
                "page",
                "per_page",
                "previous_page",
                "total_entries"
              ]
            }
          },
          "required": [
            "pagination"
          ]
        }
      },
      "required": [
        "primary_ips"
      ]
    }
