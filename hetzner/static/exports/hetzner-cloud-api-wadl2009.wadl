          </xs:element>
          <xs:element minOccurs="1" name="health_check" type="schemas:LoadBalancerServiceHealthCheck">
            <xs:annotation>
              <xs:documentation>Service health check</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="http" type="schemas:LoadBalancerServiceHTTP">
            <xs:annotation>
              <xs:documentation>Configuration option for protocols http and https</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="listen_port" type="xs:integer">
