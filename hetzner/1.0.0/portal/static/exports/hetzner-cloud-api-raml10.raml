          format: int32
      type:
        required: true
        example:
          value: spread
        displayName: type
        description: Type of the Placement Group
        type: string
        enum:
        - spread
  CreatePlacementGroupRequest:
    displayName: CreatePlacementGroupRequest
    type: object
    properties:
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: true
        example:
          value: my Placement Group
        displayName: name
        description: Name of the PlacementGroup
        type: string
      type:
        required: true
        example:
          value: spread
        displayName: type
        description: Define the Placement Group Type.
        type: string
        enum:
        - spread
  CreatePlacementGroupResponse:
    displayName: CreatePlacementGroupResponse
    type: object
    properties:
      action:
        required: false
        displayName: action
