      external_ids:
        required: true
        displayName: external_ids
        description: Known external IDs for the album.
        type: ExternalIdObject
      genres:
        required: true
        example:
          value:
          - Egg punk
          - Noise rock
        displayName: genres
        description: A list of the genres the album is associated with. If not yet classified, the array is empty.
        type: array
        items:
          type: string
      label:
        required: true
        displayName: label
        description: The label associated with the album.
        type: string
      popularity:
        required: true
        displayName: popularity
        description: The popularity of the album. The value will be between 0 and 100, with 100 being the most popular.
        type: integer
        format: int32
  ContextObject:
    displayName: ContextObject
    type: object
    properties:
      type:
        required: false
        displayName: type
        description: The object type, e.g. "artist", "playlist", "album", "show".
        type: string
      href:
        required: false
        displayName: href
        description: A link to the Web API endpoint providing full details of the track.
        type: string
      external_urls:
        required: false
        displayName: external_urls
        description: External URLs for this context.
        type: ExternalUrlObject
      uri:
        required: false
        displayName: uri
        description: The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the context.
        type: string
  CopyrightObject:
    displayName: CopyrightObject
    type: object
    properties:
      text:
        required: false
        displayName: text
        description: The copyright text for this content.
        type: string
      type:
        required: false
        displayName: type
        description: 'The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.'
        type: string
  AuthorObject:
    displayName: AuthorObject
    type: object
    properties:
      name:
        required: false
        displayName: name
        description: The name of the author.
        type: string
  NarratorObject:
    displayName: NarratorObject
    type: object
    properties:
      name:
        required: false
        displayName: name
        description: The name of the Narrator.
        type: string
  ExternalIdObject:
    displayName: ExternalIdObject
    type: object
    properties:
      isrc:
        required: false
        displayName: isrc
        description: '[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)'
        type: string
      ean:
        required: false
        displayName: ean
        description: '[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)'
        type: string
      upc:
        required: false
        displayName: upc
        description: '[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)'
        type: string
  ExternalUrlObject:
    displayName: ExternalUrlObject
    type: object
    properties:
      spotify:
        required: false
        displayName: spotify
        description: The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.
        type: string
  FollowersObject:
    displayName: FollowersObject
    type: object
    properties:
      href:
        required: false
        displayName: href
        description: This will always be set to null, as the Web API does not support it at the moment.
        type:
        - string
        - nil
      total:
        required: false
        displayName: total
        description: The total number of followers.
        type: integer
        format: int32
  ImageObject:
    displayName: ImageObject
    type: object
    properties:
      url:
        required: true
        example:
          value: >
            https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228
        displayName: url
        description: The source URL of the image.
        type: string
      height:
        required: true
        example:
          value: 300
        displayName: height
        description: The image height in pixels.
        type:
        - integer
        - nil
        format: int32
      width:
        required: true
        example:
          value: 300
        displayName: width
        description: The image width in pixels.
        type:
        - integer
        - nil
        format: int32
  ExplicitContentSettingsObject:
    displayName: ExplicitContentSettingsObject
    type: object
    properties:
      filter_enabled:
        required: false
        displayName: filter_enabled
        description: When `true`, indicates that explicit content should not be played.
        type: boolean
      filter_locked:
        required: false
        displayName: filter_locked
        description: When `true`, indicates that the explicit content setting is locked and can't be changed by the user.
        type: boolean
  CurrentlyPlayingObject:
    displayName: CurrentlyPlayingObject
    type: object
    properties:
      context:
        required: false
        displayName: context
        description: A Context Object. Can be `null`.
        type: ContextObject
      timestamp:
        required: false
        displayName: timestamp
        description: Unix Millisecond Timestamp when data was fetched
        type: integer
        format: int64
      progress_ms:
        required: false
        displayName: progress_ms
        description: Progress into the currently playing track or episode. Can be `null`.
        type: integer
        format: int32
      is_playing:
        required: false
        displayName: is_playing
        description: If something is currently playing, return `true`.
        type: boolean
      item:
        required: false
        displayName: item
        description: The currently playing track or episode. Can be `null`.
        type: TrackObject | EpisodeObject
      currently_playing_type:
        required: false
        displayName: currently_playing_type
        description: The object type of the currently playing item. Can be one of `track`, `episode`, `ad` or `unknown`.
        type: string
      actions:
        required: false
        displayName: actions
        description: Allows to update the user interface based on which playback actions are available within the current context.
        type: DisallowsObject
  SavedAudiobookObject:
    displayName: SavedAudiobookObject
    type: object
    properties:
      added_at:
        required: false
        displayName: added_at
        description: |
          The date and time the audiobook was saved

          Timestamps are returned in ISO 8601 format as Coordinated Universal Time (UTC) with a zero offset: YYYY-MM-DDTHH:MM:SSZ.

          If the time is imprecise (for example, the date/time of an album release), an additional field indicates the precision; see for example, release_date in an album object.
        type: datetime
      audiobook:
        required: false
        displayName: audiobook
        description: Information about the audiobook.
        type: AudiobookObject
  PagingSavedAudiobookObject:
    displayName: PagingSavedAudiobookObject
    type: object
    properties:
      href:
        required: true
        example:
          value: >
            https://api.spotify.com/v1/me/shows?offset=0&limit=20
        displayName: href
        description: A link to the Web API endpoint returning the full result of the request
        type: string
      limit:
        required: true
        example:
          value: 20
        displayName: limit
        description: The maximum number of items in the response (as set in the query or by default).
        type: integer
        format: int32
      next:
        required: true
        example:
          value: https://api.spotify.com/v1/me/shows?offset=1&limit=1
        displayName: next
        description: URL to the next page of items. ( `null` if none)
        type:
        - string
        - nil
      offset:
        required: true
        example:
          value: 0
        displayName: offset
        description: The offset of the items returned (as set in the query or by default)
        type: integer
        format: int32
      previous:
        required: true
        example:
          value: https://api.spotify.com/v1/me/shows?offset=1&limit=1
        displayName: previous
        description: URL to the previous page of items. ( `null` if none)
        type:
        - string
        - nil
      total:
        required: true
        example:
          value: 4
        displayName: total
        description: The total number of items available to return.
        type: integer
        format: int32
      items:
        required: true
        displayName: items
        type: array
        items:
          type: SavedAudiobookObject
  BadRequest1:
    displayName: BadRequest1
    type: object
    properties:
      error:
        required: true
        displayName: error
        type: ErrorObject
  Categories:
    displayName: Categories
    type: object
    properties:
      href:
        required: true
        example:
          value: >
            https://api.spotify.com/v1/me/shows?offset=0&limit=20
        displayName: href
        description: A link to the Web API endpoint returning the full result of the request
        type: string
      limit:
        required: true
        example:
          value: 20
        displayName: limit
        description: The maximum number of items in the response (as set in the query or by default).
        type: integer
        format: int32
      next:
        required: true
        example:
          value: https://api.spotify.com/v1/me/shows?offset=1&limit=1
        displayName: next
        description: URL to the next page of items. ( `null` if none)
        type:
        - string
        - nil
      offset:
        required: true
        example:
          value: 0
        displayName: offset
        description: The offset of the items returned (as set in the query or by default)
        type: integer
        format: int32
      previous:
        required: true
        example:
          value: https://api.spotify.com/v1/me/shows?offset=1&limit=1
        displayName: previous
        description: URL to the previous page of items. ( `null` if none)
        type:
        - string
        - nil
      total:
        required: true
        example:
          value: 4
        displayName: total
        description: The total number of items available to return.
        type: integer
        format: int32
      items:
        required: true
        displayName: items
        type: array
        items:
          type: CategoryObject
  CursorPagedArtists:
    displayName: CursorPagedArtists
    type: object
    properties:
      artists:
        required: true
        displayName: artists
        type: CursorPagingSimplifiedArtistObject
  Forbidden1:
    displayName: Forbidden1
    type: object
    properties:
      error:
        required: true
        displayName: error
        type: ErrorObject
  ManyAlbums:
    displayName: ManyAlbums
    type: object
    properties:
      albums:
        required: true
        displayName: albums
        type: array
        items:
          type: AlbumObject
  ManyArtists:
    displayName: ManyArtists
    type: object
    properties:
      artists:
        required: true
        displayName: artists
        type: array
        items:
          type: ArtistObject
  ManyAudiobooks:
    displayName: ManyAudiobooks
    type: object
    properties:
      audiobooks:
        required: true
        displayName: audiobooks
        type: array
        items:
          type: AudiobookObject
  ManyAudioFeatures:
    displayName: ManyAudioFeatures
    type: object
    properties:
      audio_features:
        required: true
        displayName: audio_features
        type: array
        items:
          type: AudioFeaturesObject
  ManyChapters:
    displayName: ManyChapters
    type: object
    properties:
      chapters:
        required: true
        displayName: chapters
        type: array
        items:
          type: ChapterObject
  ManyDevices:
    displayName: ManyDevices
    type: object
    properties:
      devices:
        required: true
        displayName: devices
        type: array
        items:
          type: DeviceObject
  ManyEpisodes:
    displayName: ManyEpisodes
    type: object
    properties:
      episodes:
        required: true
        displayName: episodes
        type: array
        items:
          type: EpisodeObject
  ManyGenres:
    displayName: ManyGenres
    type: object
    properties:
      genres:
        required: true
        example:
          value:
          - alternative
          - samba
        displayName: genres
        type: array
        items:
          type: string
  ManySimplifiedShows:
    displayName: ManySimplifiedShows
    type: object
    properties:
      shows:
        required: true
        displayName: shows
        type: array
        items:
          type: ShowBase
  ManyTracks:
    displayName: ManyTracks
    type: object
    properties:
      tracks:
        required: true
        displayName: tracks
        type: array
        items:
          type: TrackObject
  Markets:
    displayName: Markets
    type: object
    properties:
      markets:
        required: false
        example:
          value:
          - CA
          - BR
          - IT
        displayName: markets
        type: array
        items:
          type: string
  MeAlbumsRequest:
    displayName: MeAlbumsRequest
    type: object
    properties:
      ids:
        required: false
        displayName: ids
        description: 'A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `["4iV5W9uYEdYUVa79Axb7Rh", "1301WleyT98MSxVHPZCA6M"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  MeEpisodesRequest:
    displayName: MeEpisodesRequest
    type: object
    properties:
      ids:
        required: true
        displayName: ids
        description: 'A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). <br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  MeEpisodesRequest1:
    displayName: MeEpisodesRequest1
    type: object
    properties:
      ids:
        required: false
        displayName: ids
        description: 'A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). <br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  MeFollowingRequest:
    displayName: MeFollowingRequest
    type: object
    properties:
      ids:
        required: true
        displayName: ids
        description: |
          A JSON array of the artist or user [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids).

          For example: `{ids:["74ASZWbe4lXaubB36ztrGX", "08td7MxkoHQkXnWAYD8d6Q"]}`. A maximum of 50 IDs can be sent in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._
        type: array
        items:
          type: string
  MeFollowingRequest1:
    displayName: MeFollowingRequest1
    type: object
    properties:
      ids:
        required: false
        displayName: ids
        description: 'A JSON array of the artist or user [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `{ids:["74ASZWbe4lXaubB36ztrGX", "08td7MxkoHQkXnWAYD8d6Q"]}`. A maximum of 50 IDs can be sent in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  MePlayerPlayRequest:
    example:
      value:
        context_uri: spotify:album:5ht7ItJgpBH7W6vJ5BqpPr
        offset:
          position: 5
        position_ms: 0
    displayName: MePlayerPlayRequest
    type: object
    properties:
      context_uri:
        required: false
        displayName: context_uri
        description: |
          Optional. Spotify URI of the context to play.

          Valid contexts are albums, artists & playlists.

          `{context_uri:"spotify:album:1Je1IMUlBXcx1Fz0WE7oPT"}`
        type: string
      uris:
        required: false
        displayName: uris
        description: |
          Optional. A JSON array of the Spotify track URIs to play.

          For example: `{"uris": ["spotify:track:4iV5W9uYEdYUVa79Axb7Rh", "spotify:track:1301WleyT98MSxVHPZCA6M"]}`
        type: array
        items:
          type: string
      offset:
        required: false
        displayName: offset
        description: |
          Optional. Indicates from where in the context playback should start. Only available when context_uri corresponds to an album or playlist object

          "position" is zero based and can’t be negative. Example: `"offset": {"position": 5}`

          "uri" is a string representing the uri of the item to start at. Example: `"offset": {"uri": "spotify:track:1301WleyT98MSxVHPZCA6M"}`
        type: object
        properties: {}
      position_ms:
        required: false
        displayName: position_ms
        description: Indicates from what position to start playback. Must be a positive number. Passing in a position that is greater than the length of the track will cause the player to start playing the next song.
        type: integer
        format: int32
  MePlayerRequest:
    example:
      value:
        device_ids:
        - 74ASZWbe4lXaubB36ztrGX
    displayName: MePlayerRequest
    type: object
    properties:
      device_ids:
        required: true
        displayName: device_ids
        description: 'A JSON array containing the ID of the device on which playback should be started/transferred.<br/>For example:`{device_ids:["74ASZWbe4lXaubB36ztrGX"]}`<br/>_**Note**: Although an array is accepted, only a single device_id is currently supported. Supplying more than one will return `400 Bad Request`_'
        type: array
        items:
          type: string
      play:
        required: false
        displayName: play
        description: '**true**: ensure playback happens on new device.<br/>**false** or not provided: keep the current playback state.'
        type: boolean
  MeShowsRequest:
    displayName: MeShowsRequest
    type: object
    properties:
      ids:
        required: false
        displayName: ids
        description: "A JSON array of the [Spotify IDs](https://developer.spotify.com/documentation/web-api/#spotify-uris-and-ids).  \nA maximum of 50 items can be specified in one request. *Note: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored.*"
        type: array
        items:
          type: string
  MeTracksRequest:
    displayName: MeTracksRequest
    type: object
    properties:
      ids:
        required: true
        displayName: ids
        description: 'A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `["4iV5W9uYEdYUVa79Axb7Rh", "1301WleyT98MSxVHPZCA6M"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  MeTracksRequest1:
    displayName: MeTracksRequest1
    type: object
    properties:
      ids:
        required: false
        displayName: ids
        description: 'A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `["4iV5W9uYEdYUVa79Axb7Rh", "1301WleyT98MSxVHPZCA6M"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._'
        type: array
        items:
          type: string
  Meta:
    displayName: Meta
    type: object
    properties:
      analyzer_version:
        required: false
        example:
          value: 4.0.0
        displayName: analyzer_version
        description: The version of the Analyzer used to analyze this track.
        type: string
      platform:
        required: false
        example:
          value: Linux
        displayName: platform
        description: The platform used to read the track's audio data.
        type: string
      detailed_status:
        required: false
        example:
          value: OK
        displayName: detailed_status
        description: A detailed status code for this track. If analysis data is missing, this code may explain why.
        type: string
      status_code:
        required: false
        example:
          value: 0
        displayName: status_code
        description: The return code of the analyzer process. 0 if successful, 1 if any errors occurred.
        type: integer
        format: int32
      timestamp:
        required: false
        example:
          value: 1495193577
        displayName: timestamp
        description: The Unix timestamp (in seconds) at which this track was analyzed.
        type: integer
        format: int64
      analysis_time:
        required: false
        example:
          value: 6.93906
        displayName: analysis_time
        description: The amount of time taken to analyze this track.
        type: number
        format: double
      input_process:
        required: false
        example:
          value: libvorbisfile L+R 44100->22050
        displayName: input_process
        description: The method used to read the track's audio data.
        type: string
  NotFound1:
    displayName: NotFound1
    type: object
    properties:
      error:
        required: true
        displayName: error
        type: ErrorObject
  PagedAlbums:
    displayName: PagedAlbums
    type: object
    properties:
      albums:
        required: true
        displayName: albums
        type: PagingSimplifiedAlbumObject
  PagedCategories:
    displayName: PagedCategories
    type: object
    properties:
      categories:
        required: true
        displayName: categories
        type: Categories
  PlaylistsFollowersRequest:
    example:
      value:
        public: false
    displayName: PlaylistsFollowersRequest
    type: object
    properties:
      public:
        required: false
        displayName: public
        description: Defaults to `true`. If `true` the playlist will be included in user's public playlists, if `false` it will remain private.
        type: boolean
  PlaylistsRequest:
    example:
      value:
        name: Updated Playlist Name
        description: Updated playlist description
        public: false
    displayName: PlaylistsRequest
    type: object
    properties:
      name:
        required: false
        displayName: name
        description: The new name for the playlist, for example `"My New Playlist Title"`
        type: string
      public:
        required: false
        displayName: public
        description: If `true` the playlist will be public, if `false` it will be private.
        type: boolean
      collaborative:
        required: false
        displayName: collaborative
        description: |
          If `true`, the playlist will become collaborative and other users will be able to modify the playlist in their Spotify client. <br/>

          _**Note**: You can only set `collaborative` to `true` on non-public playlists._
        type: boolean
      description:
        required: false
        displayName: description
        description: Value for playlist description as displayed in Spotify Clients and in the Web API.
        type: string
  PlaylistsTracksRequest:
    displayName: PlaylistsTracksRequest
    type: object
    properties:
      uris:
        required: false
        displayName: uris
        description: 'A JSON array of the [Spotify URIs](/documentation/web-api/concepts/spotify-uris-ids) to add. For example: `{"uris": ["spotify:track:4iV5W9uYEdYUVa79Axb7Rh","spotify:track:1301WleyT98MSxVHPZCA6M", "spotify:episode:512ojhOuo1ktJprKbVcKyQ"]}`<br/>A maximum of 100 items can be added in one request. _**Note**: if the `uris` parameter is present in the query string, any URIs listed here in the body will be ignored._'
        type: array
        items:
          type: string
      position:
        required: false
        displayName: position
        description: 'The position to insert the items, a zero-based index. For example, to insert the items in the first position: `position=0` ; to insert the items in the third position: `position=2`. If omitted, the items will be appended to the playlist. Items are added in the order they appear in the uris array. For example: `{"uris": ["spotify:track:4iV5W9uYEdYUVa79Axb7Rh","spotify:track:1301WleyT98MSxVHPZCA6M"], "position": 3}`'
        type: integer
        format: int32
  PlaylistsTracksRequest1:
    example:
      value:
        range_start: 1
        insert_before: 3
        range_length: 2
    displayName: PlaylistsTracksRequest1
    type: object
    properties:
      uris:
        required: false
        displayName: uris
        type: array
        items:
          type: string
      range_start:
        required: false
        displayName: range_start
        description: The position of the first item to be reordered.
        type: integer
        format: int32
      insert_before:
        required: false
        displayName: insert_before
        description: The position where the items should be inserted.<br/>To reorder the items to the end of the playlist, simply set _insert_before_ to the position after the last item.<br/>Examples:<br/>To reorder the first item to the last position in a playlist with 10 items, set _range_start_ to 0, and _insert_before_ to 10.<br/>To reorder the last item in a playlist with 10 items to the start of the playlist, set _range_start_ to 9, and _insert_before_ to 0.
        type: integer
        format: int32
      range_length:
        required: false
        displayName: range_length
        description: The amount of items to be reordered. Defaults to 1 if not set.<br/>The range of items to be reordered begins from the _range_start_ position, and includes the _range_length_ subsequent items.<br/>Example:<br/>To move the items at index 9-10 to the start of the playlist, _range_start_ is set to 9, and _range_length_ is set to 2.
        type: integer
        format: int32
      snapshot_id:
        required: false
        displayName: snapshot_id
        description: The playlist's snapshot ID against which you want to make the changes.
        type: string
  PlaylistsTracksRequest2:
    displayName: PlaylistsTracksRequest2
    type: object
    properties:
      tracks:
        required: true
        displayName: tracks
        description: |
          An array of objects containing [Spotify URIs](/documentation/web-api/concepts/spotify-uris-ids) of the tracks or episodes to remove.

          For example: `{ "tracks": [{ "uri": "spotify:track:4iV5W9uYEdYUVa79Axb7Rh" },{ "uri": "spotify:track:1301WleyT98MSxVHPZCA6M" }] }`. A maximum of 100 objects can be sent at once.
        type: array
        items:
          type: Track1
      snapshot_id:
        required: false
        displayName: snapshot_id
        description: |
          The playlist's snapshot ID against which you want to make the changes.

          The API will validate that the specified items exist and in the specified positions and make the changes,

          even if more recent changes have been made to the playlist.
        type: string
  PlaylistSnapshotId:
    displayName: PlaylistSnapshotId
    type: object
    properties:
      snapshot_id:
        required: false
        example:
          value: abc
        displayName: snapshot_id
        type: string
  SearchItems:
    displayName: SearchItems
    type: object
    properties:
      tracks:
        required: false
        displayName: tracks
        type: PagingTrackObject
      artists:
        required: false
        displayName: artists
        type: PagingArtistObject
      albums:
        required: false
        displayName: albums
        type: PagingSimplifiedAlbumObject
      playlists:
        required: false
        displayName: playlists
        type: PagingPlaylistObject
      shows:
        required: false
        displayName: shows
        type: PagingSimplifiedShowObject
      episodes:
        required: false
        displayName: episodes
        type: PagingSimplifiedEpisodeObject
      audiobooks:
        required: false
        displayName: audiobooks
        type: PagingSimplifiedAudiobookObject
  TooManyRequests1:
    displayName: TooManyRequests1
    type: object
    properties:
      error:
        required: true
        displayName: error
        type: ErrorObject
  Track:
    displayName: Track
    type: object
    properties:
      num_samples:
        required: false
        example:
          value: 4585515
        displayName: num_samples
        description: The exact number of audio samples analyzed from this track. See also `analysis_sample_rate`.
        type: integer
        format: int32
      duration:
        required: false
        example:
          value: 207.95985
        displayName: duration
        description: Length of the track in seconds.
        type: number
        format: double
      sample_md5:
        required: false
        displayName: sample_md5
        description: This field will always contain the empty string.
        type: string
      offset_seconds:
        required: false
        example:
          value: 0
        displayName: offset_seconds
        description: An offset to the start of the region of the track that was analyzed. (As the entire track is analyzed, this should always be 0.)
        type: integer
        format: int32
      window_seconds:
        required: false
        example:
          value: 0
        displayName: window_seconds
        description: The length of the region of the track was analyzed, if a subset of the track was analyzed. (As the entire track is analyzed, this should always be 0.)
        type: integer
        format: int32
      analysis_sample_rate:
        required: false
        example:
          value: 22050
        displayName: analysis_sample_rate
        description: The sample rate used to decode and analyze this track. May differ from the actual sample rate of this track available on Spotify.
        type: integer
        format: int32
      analysis_channels:
        required: false
        example:
          value: 1
        displayName: analysis_channels
        description: The number of channels used for analysis. If 1, all channels are summed together to mono before analysis.
        type: integer
        format: int32
      end_of_fade_in:
        required: false
        example:
          value: 0
        displayName: end_of_fade_in
        description: The time, in seconds, at which the track's fade-in period ends. If the track has no fade-in, this will be 0.0.
        type: number
        format: double
      start_of_fade_out:
        required: false
        example:
          value: 201.13705
        displayName: start_of_fade_out
        description: The time, in seconds, at which the track's fade-out period starts. If the track has no fade-out, this should match the track's length.
        type: number
        format: double
      loudness:
        required: false
        example:
          value: -5.883
        displayName: loudness
        description: The overall loudness of a track in decibels (dB). Loudness values are averaged across the entire track and are useful for comparing relative loudness of tracks. Loudness is the quality of a sound that is the primary psychological correlate of physical strength (amplitude). Values typically range between -60 and 0 db.
        type: number
        format: double
      tempo:
        required: false
        example:
          value: 118.211
        displayName: tempo
        description: The overall estimated tempo of a track in beats per minute (BPM). In musical terminology, tempo is the speed or pace of a given piece and derives directly from the average beat duration.
        type: number
        format: double
      tempo_confidence:
        required: false
        example:
          value: 0.73
        displayName: tempo_confidence
        description: The confidence, from 0.0 to 1.0, of the reliability of the `tempo`.
        type: number
        minimum: 0
        maximum: 1
        format: double
      time_signature:
        required: false
        example:
          value: 4
        displayName: time_signature
        description: An estimated time signature. The time signature (meter) is a notational convention to specify how many beats are in each bar (or measure). The time signature ranges from 3 to 7 indicating time signatures of "3/4", to "7/4".
        type: integer
        minimum: 3
        maximum: 7
        format: int32
      time_signature_confidence:
        required: false
        example:
          value: 0.994
        displayName: time_signature_confidence
        description: The confidence, from 0.0 to 1.0, of the reliability of the `time_signature`.
        type: number
        minimum: 0
        maximum: 1
        format: double
      key:
        required: false
        example:
          value: 9
        displayName: key
        description: The key the track is in. Integers map to pitches using standard [Pitch Class notation](https://en.wikipedia.org/wiki/Pitch_class). E.g. 0 = C, 1 = C♯/D♭, 2 = D, and so on. If no key was detected, the value is -1.
        type: integer
        minimum: -1
        maximum: 11
        format: int32
      key_confidence:
        required: false
        example:
          value: 0.408
        displayName: key_confidence
        description: The confidence, from 0.0 to 1.0, of the reliability of the `key`.
        type: number
        minimum: 0
        maximum: 1
        format: double
      mode:
        required: false
        example:
          value: 0
        displayName: mode
        description: Mode indicates the modality (major or minor) of a track, the type of scale from which its melodic content is derived. Major is represented by 1 and minor is 0.
        type: integer
        format: int32
      mode_confidence:
        required: false
        example:
          value: 0.485
        displayName: mode_confidence
        description: The confidence, from 0.0 to 1.0, of the reliability of the `mode`.
        type: number
        minimum: 0
        maximum: 1
        format: double
      codestring:
        required: false
        displayName: codestring
        description: An [Echo Nest Musical Fingerprint (ENMFP)](https://academiccommons.columbia.edu/doi/10.7916/D8Q248M4) codestring for this track.
        type: string
      code_version:
        required: false
        example:
          value: 3.15
        displayName: code_version
        description: A version number for the Echo Nest Musical Fingerprint format used in the codestring field.
        type: number
        format: double
      echoprintstring:
        required: false
        displayName: echoprintstring
        description: An [EchoPrint](https://github.com/spotify/echoprint-codegen) codestring for this track.
        type: string
      echoprint_version:
        required: false
        example:
          value: 4.15
        displayName: echoprint_version
        description: A version number for the EchoPrint format used in the echoprintstring field.
        type: number
        format: double
      synchstring:
        required: false
        displayName: synchstring
        description: A [Synchstring](https://github.com/echonest/synchdata) for this track.
        type: string
      synch_version:
        required: false
        example:
          value: 1
        displayName: synch_version
        description: A version number for the Synchstring used in the synchstring field.
        type: number
        format: double
      rhythmstring:
        required: false
        displayName: rhythmstring
        description: A Rhythmstring for this track. The format of this string is similar to the Synchstring.
        type: string
      rhythm_version:
        required: false
        example:
          value: 1
        displayName: rhythm_version
        description: A version number for the Rhythmstring used in the rhythmstring field.
        type: number
        format: double
  Track1:
    displayName: Track1
    type: object
    properties:
      uri:
        required: false
        displayName: uri
        description: Spotify URI
        type: string
  Unauthorized1:
    displayName: Unauthorized1
    type: object
    properties:
      error:
        required: true
        displayName: error
        type: ErrorObject
  UsersPlaylistsRequest:
    example:
      value:
        name: New Playlist
        description: New playlist description
        public: false
    displayName: UsersPlaylistsRequest
    type: object
    properties:
      name:
        required: true
        displayName: name
        description: The name for the new playlist, for example `"Your Coolest Playlist"`. This name does not need to be unique; a user may have several playlists with the same name.
        type: string
      public:
        required: false
        displayName: public
        description: Defaults to `true`. If `true` the playlist will be public, if `false` it will be private. To be able to create private playlists, the user must have granted the `playlist-modify-private` [scope](/documentation/web-api/concepts/scopes/#list-of-scopes)
        type: boolean
      collaborative:
        required: false
        displayName: collaborative
        description: 'Defaults to `false`. If `true` the playlist will be collaborative. _**Note**: to create a collaborative playlist you must also set `public` to `false`. To create collaborative playlists you must have granted `playlist-modify-private` and `playlist-modify-public` [scopes](/documentation/web-api/concepts/scopes/#list-of-scopes)._'
        type: boolean
      description:
        required: false
        displayName: description
        description: value for playlist description as displayed in Spotify Clients and in the Web API.
        type: string
/albums:
  get:
    displayName: get-multiple-albums
    description: >
      Get Spotify catalog information for multiple albums identified by their Spotify IDs.
    securedBy:
    - oauth_2_0
    queryParameters:
      ids:
        required: true
        example:
          value: 382ObEPsp2rxGrnsizN5TX,1A2GTWGtFfWp7KSQTwWOyo,2noRn2Aes5aoNVsU6iWThc
        displayName: ids
        type: string
      market:
        required: false
        example:
          value: ES
        displayName: market
        type: string
    responses:
      '200':
        description: A set of albums
        body:
          application/json:
            displayName: response200
            description: ''
            type: ManyAlbums
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            displayName: response401
            description: ''
            type: Unauthorized1
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            displayName: response403
            description: ''
            type: Forbidden1
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            displayName: response429
            description: ''
            type: TooManyRequests1
  /{id}:
    uriParameters:
      id:
        required: true
        example:
          value: 4aawyAB9vmqN3uQ7FjRGTy
        displayName: id
        type: string
    get:
      displayName: get-an-album
      description: >
        Get Spotify catalog information for a single album.
      securedBy:
      - oauth_2_0
      queryParameters:
        market:
          required: false
          example:
            value: ES
          displayName: market
          type: string
      responses:
        '200':
          description: An album
          body:
            application/json:
              displayName: response200
              description: ''
              type: AlbumObject
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    /tracks:
      get:
        displayName: get-an-albums-tracks
        description: >
          Get Spotify catalog information about an album’s tracks.

          Optional parameters can be used to limit the number of tracks returned.
        securedBy:
        - oauth_2_0
        queryParameters:
          market:
            required: false
            example:
              value: ES
            displayName: market
            type: string
          limit:
            required: false
            default: '20'
            example:
              value: 10
            displayName: limit
            type: integer
            minimum: 1
            maximum: 50
            format: int32
          offset:
            required: false
            default: '0'
            example:
              value: 5
            displayName: offset
            type: integer
            format: int32
        responses:
          '200':
            description: Pages of tracks
            body:
              application/json:
                displayName: response200
                description: ''
                type: PagingSimplifiedTrackObject
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                displayName: response401
                description: ''
                type: Unauthorized1
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                displayName: response403
                description: ''
                type: Forbidden1
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                displayName: response429
                description: ''
                type: TooManyRequests1
