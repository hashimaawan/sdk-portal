                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
    /related-artists:
      uriParameters: {}
      get:
        securedBy:
        - oauth_2_0
        description: >
          Get Spotify catalog information about artists similar to a given artist. Similarity is based on analysis of the Spotify community's listening history.
        responses:
          '200':
            description: A set of artists
            body:
              application/json:
                schema: |
                  {
                    "id": "ManyArtists",
                    "title": "ManyArtists",
                    "type": "object",
                    "properties": {
                      "artists": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "ArtistObject",
                          "title": "ArtistObject",
                          "type": "object",
                          "properties": {
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "Known external URLs for this artist.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "followers": {
                              "id": "FollowersObject",
                              "title": "FollowersObject",
                              "description": "Information about the followers of the artist.",
                              "type": "object",
                              "properties": {
                                "href": {
                                  "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "total": {
                                  "description": "The total number of followers.",
                                  "type": "integer",
                                  "format": "int32"
                                }
                              }
                            },
                            "genres": {
                              "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                              "example": [
                                "Prog rock",
                                "Grunge"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "href": {
