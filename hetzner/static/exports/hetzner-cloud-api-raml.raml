                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "included_traffic": {
                          "description": "Free Traffic for the current billing period in bytes",
                          "example": 10000,
                          "type": "integer",
                          "format": "int32"
                        },
                        "ingoing_traffic": {
                          "description": "Inbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "load_balancer_type": {
                          "id": "LoadBalancerType",
                          "title": "LoadBalancerType",
                          "type": "object",
                          "properties": {
                            "deprecated": {
                              "description": "Point in time when the Load Balancer type is deprecated (in ISO-8601 format)",
                              "example": "2016-01-30T23:50:00+00:00",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "description": {
                              "description": "Description of the Load Balancer type",
                              "example": "LB11",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Load Balancer type",
                              "example": 1,
                              "type": "number"
                            },
                            "max_assigned_certificates": {
                              "description": "Number of SSL Certificates that can be assigned to a single Load Balancer",
                              "example": 10,
                              "type": "number"
                            },
                            "max_connections": {
                              "description": "Number of maximum simultaneous open connections",
                              "example": 20000,
                              "type": "number"
                            },
                            "max_services": {
                              "description": "Number of services a Load Balancer of this type can have",
                              "example": 5,
                              "type": "number"
                            },
                            "max_targets": {
                              "description": "Number of targets a single Load Balancer can have",
                              "example": 25,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Load Balancer type",
                              "example": "lb11",
                              "type": "string"
                            },
                            "prices": {
                              "description": "Prices in different network zones",
                              "type": "array",
                              "items": {
                                "id": "Price",
                                "title": "Price",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly",
                                    "title": "PriceHourly",
                                    "description": "Hourly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly",
                                    "title": "PriceMonthly",
                                    "description": "Monthly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            }
                          },
                          "required": [
                            "deprecated",
                            "description",
                            "id",
                            "max_assigned_certificates",
                            "max_connections",
                            "max_services",
                            "max_targets",
                            "name",
                            "prices"
                          ]
                        },
                        "location": {
                          "id": "Location",
                          "title": "Location",
                          "type": "object",
                          "properties": {
                            "city": {
                              "description": "City the Location is closest to",
                              "example": "Falkenstein",
                              "type": "string"
                            },
                            "country": {
                              "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                              "example": "DE",
                              "type": "string"
                            },
                            "description": {
                              "description": "Description of the Location",
                              "example": "Falkenstein DC Park 1",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Location",
                              "example": 1,
                              "type": "number"
                            },
                            "latitude": {
                              "description": "Latitude of the city closest to the Location",
                              "example": 50.47612,
                              "type": "number"
                            },
                            "longitude": {
                              "description": "Longitude of the city closest to the Location",
                              "example": 12.370071,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Location",
                              "example": "fsn1",
                              "type": "string"
                            },
                            "network_zone": {
                              "description": "Name of network zone this Location resides in",
                              "example": "eu-central",
                              "type": "string"
                            }
                          },
                          "required": [
                            "city",
                            "country",
                            "description",
                            "id",
                            "latitude",
                            "longitude",
                            "name",
                            "network_zone"
                          ]
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "outgoing_traffic": {
                          "description": "Outbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "private_net": {
                          "description": "Private networks information",
                          "type": "array",
                          "items": {
                            "id": "PrivateNet",
                            "title": "PrivateNet",
                            "type": "object",
                            "properties": {
                              "ip": {
                                "example": "10.0.0.2",
                                "type": "string"
                              },
                              "network": {
                                "example": 4711,
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        },
                        "protection": {
                          "id": "Protection",
                          "title": "Protection",
                          "description": "Protection configuration for the Resource",
                          "type": "object",
                          "properties": {
                            "delete": {
                              "description": "If true, prevents the Resource from being deleted",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "delete"
                          ]
                        },
                        "public_net": {
                          "id": "PublicNet",
                          "title": "PublicNet",
                          "description": "Public network information",
                          "type": "object",
                          "properties": {
                            "enabled": {
                              "description": "Public Interface enabled or not",
                              "type": "boolean"
                            },
                            "ipv4": {
                              "id": "Ipv4",
                              "title": "Ipv4",
                              "description": "IP address (v4)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv4 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v4) of this Load Balancer",
                                  "example": "1.2.3.4",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            },
                            "ipv6": {
                              "id": "Ipv6",
                              "title": "Ipv6",
                              "description": "IP address (v6)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv6 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v6) of this Load Balancer",
                                  "example": "2001:db8::1",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "enabled",
                            "ipv4",
                            "ipv6"
                          ]
                        },
                        "services": {
                          "description": "List of services that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerService",
                            "title": "LoadBalancerService",
                            "type": "object",
                            "properties": {
                              "destination_port": {
                                "description": "Port the Load Balancer will balance to",
                                "example": 80,
                                "type": "integer",
                                "format": "int32"
                              },
                              "health_check": {
                                "id": "LoadBalancerServiceHealthCheck",
                                "title": "LoadBalancerServiceHealthCheck",
                                "description": "Service health check",
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                  "interval": {
                                    "description": "Time interval in seconds health checks are performed",
                                    "example": 15,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "port": {
                                    "description": "Port the health check will be performed on",
                                    "example": 4711,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "protocol": {
                                    "title": "Protocol6",
                                    "description": "Type of the health check",
                                    "example": "http",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "tcp",
                                      "http"
                                    ]
                                  },
                                  "retries": {
                                    "description": "Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again",
                                    "example": 3,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "timeout": {
                                    "description": "Time in seconds after an attempt is considered a timeout",
                                    "example": 10,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "http": {
                                    "id": "Http",
                                    "title": "Http",
                                    "description": "Additional configuration for protocol http",
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                      "domain": {
                                        "description": "Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.",
                                        "example": "example.com",
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "path": {
                                        "description": "HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.",
                                        "example": "/",
                                        "type": "string"
                                      },
                                      "response": {
                                        "description": "String that must be contained in HTTP response in order to pass the health check",
                                        "example": {
                                          "status": "ok"
                                        },
                                        "type": "string"
                                      },
                                      "status_codes": {
                                        "description": "List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.",
                                        "example": [
                                          "2??",
                                          "3??"
                                        ],
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      },
                                      "tls": {
                                        "description": "Use HTTPS for health check",
                                        "example": false,
                                        "type": "boolean"
                                      }
                                    },
                                    "required": [
                                      "domain",
                                      "path"
                                    ]
                                  }
                                },
                                "required": [
                                  "interval",
                                  "port",
                                  "protocol",
                                  "retries",
                                  "timeout"
                                ]
                              },
                              "listen_port": {
                                "description": "Port the Load Balancer listens on",
                                "example": 443,
                                "type": "integer",
                                "format": "int32"
                              },
                              "protocol": {
                                "title": "Protocol7",
                                "description": "Protocol of the Load Balancer",
                                "example": "https",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "tcp",
                                  "http",
                                  "https"
                                ]
                              },
                              "proxyprotocol": {
                                "description": "Is Proxyprotocol enabled or not",
                                "example": false,
                                "type": "boolean"
                              },
                              "http": {
                                "id": "LoadBalancerServiceHTTP",
                                "title": "LoadBalancerServiceHTTP",
                                "description": "Configuration option for protocols http and https",
                                "type": "object",
                                "properties": {
                                  "certificates": {
                                    "description": "IDs of the Certificates to use for TLS/SSL termination by the Load Balancer; empty for TLS/SSL passthrough or if `protocol` is \"http\"",
                                    "example": [
                                      897
                                    ],
                                    "type": "array",
                                    "items": {
                                      "type": "integer",
                                      "format": "int32"
                                    }
                                  },
                                  "cookie_lifetime": {
                                    "description": "Lifetime of the cookie used for sticky sessions",
                                    "example": 300,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "cookie_name": {
                                    "description": "Name of the cookie used for sticky sessions",
                                    "example": "HCLBSTICKY",
                                    "type": "string"
                                  },
                                  "redirect_http": {
                                    "description": "Redirect HTTP requests to HTTPS. Only available if protocol is \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  },
                                  "sticky_sessions": {
                                    "description": "Use sticky sessions. Only available if protocol is \"http\" or \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  }
                                }
                              }
                            },
                            "required": [
                              "destination_port",
                              "health_check",
                              "listen_port",
                              "protocol",
                              "proxyprotocol"
                            ]
                          }
                        },
                        "targets": {
                          "description": "List of targets that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerTarget",
                            "title": "LoadBalancerTarget",
                            "type": "object",
                            "properties": {
                              "type": {
                                "title": "Type29",
                                "description": "Type of the resource",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "server",
                                  "label_selector",
                                  "ip"
                                ]
                              },
                              "health_status": {
                                "description": "List of health statuses of the services on this target",
                                "type": "array",
                                "items": {
                                  "id": "HealthStatus",
                                  "title": "HealthStatus",
                                  "type": "object",
                                  "properties": {
                                    "listen_port": {
                                      "example": 443,
                                      "type": "integer",
                                      "format": "int32"
                                    },
                                    "status": {
                                      "title": "Status30",
                                      "example": "healthy",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "healthy",
                                        "unhealthy",
                                        "unknown"
                                      ]
                                    }
                                  }
                                }
                              },
                              "ip": {
                                "id": "Ip",
                                "title": "Ip",
                                "description": "IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.",
                                "type": "object",
                                "properties": {
                                  "ip": {
                                    "description": "IP of a server that belongs to the same customer (public IPv4/IPv6) or private IP in a Subnetwork type vswitch.",
                                    "example": "203.0.113.1",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "ip"
                                ]
                              },
                              "label_selector": {
                                "id": "LabelSelector7",
                                "title": "LabelSelector7",
                                "description": "Label selector and a list of selected targets",
                                "type": "object",
                                "properties": {
                                  "selector": {
                                    "description": "Label selector",
                                    "example": "env=prod",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "selector"
                                ]
                              },
                              "server": {
                                "id": "LoadBalancerTargetServer",
                                "title": "LoadBalancerTargetServer",
                                "description": "Server where the traffic should be routed through",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Server",
                                    "example": 80,
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "id"
                                ]
                              },
                              "targets": {
                                "description": "List of selected targets",
                                "type": "array",
                                "items": {
                                  "id": "Target",
                                  "title": "Target",
                                  "type": "object",
                                  "properties": {
                                    "health_status": {
                                      "description": "",
                                      "type": "array",
                                      "items": {
                                        "$ref": "HealthStatus"
                                      }
                                    },
                                    "server": {
                                      "id": "Server11",
                                      "title": "Server11",
                                      "type": "object",
                                      "properties": {
                                        "id": {
                                          "description": "ID of the Server",
                                          "example": 85,
                                          "type": "integer",
                                          "format": "int32"
                                        }
                                      },
                                      "required": [
                                        "id"
                                      ]
                                    },
                                    "type": {
                                      "example": "server",
                                      "type": "string"
                                    },
                                    "use_private_ip": {
                                      "example": false,
                                      "type": "boolean"
                                    }
                                  }
                                }
                              },
                              "use_private_ip": {
                                "description": "Use the private network IP instead of the public IP. Default value is false.",
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "type"
                            ]
                          }
                        }
                      },
                      "required": [
                        "algorithm",
                        "created",
                        "id",
                        "included_traffic",
                        "ingoing_traffic",
                        "labels",
                        "load_balancer_type",
                        "location",
                        "name",
                        "outgoing_traffic",
                        "private_net",
                        "protection",
                        "public_net",
                        "services",
                        "targets"
                      ]
                    }
                  },
                  "required": [
                    "load_balancer"
                  ]
                }
    put:
      description: >
        Updates a Load Balancer. You can update a Load Balancer’s name and a Load Balancer’s labels.


        Note that when updating labels, the Load Balancer’s current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.


        Note: if the Load Balancer object changes during the request, the response will be a “conflict” error.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "LoadBalancersRequest",
              "title": "LoadBalancersRequest",
              "type": "object",
              "properties": {
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "example": {
                    "labelkey": "value"
                  },
                  "type": "object"
                },
                "name": {
                  "description": "New Load Balancer name",
                  "example": "new-name",
                  "type": "string"
                }
              }
            }
          example: ''
      responses:
        '200':
          description: The `load_balancer` key contains the updated Load Balancer
          body:
            application/json:
              schema: |
                {
                  "id": "LoadBalancersResponse2",
                  "title": "LoadBalancersResponse2",
                  "example": {
                    "load_balancer": {
                      "algorithm": {
                        "type": "round_robin"
                      },
                      "created": "2016-01-30T23:50:00+00:00",
                      "id": 4711,
                      "included_traffic": 654321,
                      "ingoing_traffic": 123456,
                      "labels": {
                        "labelkey": "value"
                      },
                      "load_balancer_type": {
                        "deprecated": "2016-01-30T23:50:00+00:00",
                        "description": "LB11",
                        "id": 1,
                        "max_assigned_certificates": 10,
                        "max_connections": 20000,
                        "max_services": 5,
                        "max_targets": 25,
                        "name": "lb11",
                        "prices": [
                          {
                            "location": "fsn1",
                            "price_hourly": {
                              "gross": "1.1900000000000000",
                              "net": "1.0000000000"
                            },
                            "price_monthly": {
                              "gross": "1.1900000000000000",
                              "net": "1.0000000000"
                            }
                          }
                        ]
                      },
                      "location": {
                        "city": "Falkenstein",
                        "country": "DE",
                        "description": "Falkenstein DC Park 1",
                        "id": 1,
                        "latitude": 50.47612,
                        "longitude": 12.370071,
                        "name": "fsn1",
                        "network_zone": "eu-central"
                      },
                      "name": "new-name",
                      "outgoing_traffic": 123456,
                      "private_net": [
                        {
                          "ip": "10.0.0.2",
                          "network": 4711
                        }
                      ],
                      "protection": {
                        "delete": false
                      },
                      "public_net": {
                        "enabled": false,
                        "ipv4": {
                          "ip": "1.2.3.4"
                        },
                        "ipv6": {
                          "ip": "2001:db8::1"
                        }
                      },
                      "services": [
                        {
                          "destination_port": 80,
                          "health_check": {
                            "http": {
                              "domain": "example.com",
                              "path": "/",
                              "response": "{\"status\": \"ok\"}",
                              "status_codes": [
                                "2??,3??"
                              ],
                              "tls": false
                            },
                            "interval": 15,
                            "port": 4711,
                            "protocol": "http",
                            "retries": 3,
                            "timeout": 10
                          },
                          "http": {
                            "certificates": [
                              897
                            ],
                            "cookie_lifetime": 300,
                            "cookie_name": "HCLBSTICKY",
                            "redirect_http": true,
                            "sticky_sessions": true
                          },
                          "listen_port": 443,
                          "protocol": "http",
                          "proxyprotocol": false
                        }
                      ],
                      "targets": [
                        {
                          "health_status": [
                            {
                              "listen_port": 443,
                              "status": "healthy"
                            }
                          ],
                          "ip": {
                            "ip": "203.0.113.1"
                          },
                          "label_selector": {
                            "selector": "env=prod"
                          },
                          "server": {
                            "id": 80
                          },
                          "targets": [
                            {
                              "health_status": [
                                {
                                  "listen_port": 443,
                                  "status": "healthy"
                                }
                              ],
                              "label_selector": null,
                              "server": {
                                "id": 80
                              },
                              "type": "server",
                              "use_private_ip": true
                            }
                          ],
                          "type": "server",
                          "use_private_ip": true
                        }
                      ]
                    }
                  },
                  "type": "object",
                  "properties": {
                    "load_balancer": {
                      "id": "LoadBalancer",
                      "title": "LoadBalancer",
                      "type": "object",
                      "properties": {
                        "algorithm": {
                          "id": "Algorithm",
                          "title": "Algorithm",
                          "description": "Algorithm of the Load Balancer",
                          "type": "object",
                          "properties": {
                            "type": {
                              "title": "Type28",
                              "description": "Type of the algorithm",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "round_robin",
                                "least_connections"
                              ]
                            }
                          },
                          "required": [
                            "type"
                          ]
                        },
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "included_traffic": {
                          "description": "Free Traffic for the current billing period in bytes",
                          "example": 10000,
                          "type": "integer",
                          "format": "int32"
                        },
                        "ingoing_traffic": {
                          "description": "Inbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "load_balancer_type": {
                          "id": "LoadBalancerType",
                          "title": "LoadBalancerType",
                          "type": "object",
                          "properties": {
                            "deprecated": {
                              "description": "Point in time when the Load Balancer type is deprecated (in ISO-8601 format)",
                              "example": "2016-01-30T23:50:00+00:00",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "description": {
                              "description": "Description of the Load Balancer type",
                              "example": "LB11",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Load Balancer type",
                              "example": 1,
                              "type": "number"
                            },
                            "max_assigned_certificates": {
                              "description": "Number of SSL Certificates that can be assigned to a single Load Balancer",
                              "example": 10,
                              "type": "number"
                            },
                            "max_connections": {
                              "description": "Number of maximum simultaneous open connections",
                              "example": 20000,
                              "type": "number"
                            },
                            "max_services": {
                              "description": "Number of services a Load Balancer of this type can have",
                              "example": 5,
                              "type": "number"
                            },
                            "max_targets": {
                              "description": "Number of targets a single Load Balancer can have",
                              "example": 25,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Load Balancer type",
                              "example": "lb11",
                              "type": "string"
                            },
                            "prices": {
                              "description": "Prices in different network zones",
                              "type": "array",
                              "items": {
                                "id": "Price",
                                "title": "Price",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly",
                                    "title": "PriceHourly",
                                    "description": "Hourly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly",
                                    "title": "PriceMonthly",
                                    "description": "Monthly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            }
                          },
                          "required": [
                            "deprecated",
                            "description",
                            "id",
                            "max_assigned_certificates",
                            "max_connections",
                            "max_services",
                            "max_targets",
                            "name",
                            "prices"
                          ]
                        },
                        "location": {
                          "id": "Location",
                          "title": "Location",
                          "type": "object",
                          "properties": {
                            "city": {
                              "description": "City the Location is closest to",
                              "example": "Falkenstein",
                              "type": "string"
                            },
                            "country": {
                              "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                              "example": "DE",
                              "type": "string"
                            },
                            "description": {
                              "description": "Description of the Location",
                              "example": "Falkenstein DC Park 1",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Location",
                              "example": 1,
                              "type": "number"
                            },
                            "latitude": {
                              "description": "Latitude of the city closest to the Location",
                              "example": 50.47612,
                              "type": "number"
                            },
                            "longitude": {
                              "description": "Longitude of the city closest to the Location",
                              "example": 12.370071,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Location",
                              "example": "fsn1",
                              "type": "string"
                            },
                            "network_zone": {
                              "description": "Name of network zone this Location resides in",
                              "example": "eu-central",
                              "type": "string"
                            }
                          },
                          "required": [
                            "city",
                            "country",
                            "description",
                            "id",
                            "latitude",
                            "longitude",
                            "name",
                            "network_zone"
                          ]
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "outgoing_traffic": {
                          "description": "Outbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "private_net": {
                          "description": "Private networks information",
                          "type": "array",
                          "items": {
                            "id": "PrivateNet",
                            "title": "PrivateNet",
                            "type": "object",
                            "properties": {
                              "ip": {
                                "example": "10.0.0.2",
                                "type": "string"
                              },
                              "network": {
                                "example": 4711,
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        },
                        "protection": {
                          "id": "Protection",
                          "title": "Protection",
                          "description": "Protection configuration for the Resource",
                          "type": "object",
                          "properties": {
                            "delete": {
                              "description": "If true, prevents the Resource from being deleted",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "delete"
                          ]
                        },
                        "public_net": {
                          "id": "PublicNet",
                          "title": "PublicNet",
                          "description": "Public network information",
                          "type": "object",
                          "properties": {
                            "enabled": {
                              "description": "Public Interface enabled or not",
                              "type": "boolean"
                            },
                            "ipv4": {
                              "id": "Ipv4",
                              "title": "Ipv4",
                              "description": "IP address (v4)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv4 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v4) of this Load Balancer",
                                  "example": "1.2.3.4",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            },
                            "ipv6": {
                              "id": "Ipv6",
                              "title": "Ipv6",
                              "description": "IP address (v6)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv6 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v6) of this Load Balancer",
                                  "example": "2001:db8::1",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "enabled",
                            "ipv4",
                            "ipv6"
                          ]
                        },
                        "services": {
                          "description": "List of services that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerService",
                            "title": "LoadBalancerService",
                            "type": "object",
                            "properties": {
                              "destination_port": {
                                "description": "Port the Load Balancer will balance to",
                                "example": 80,
                                "type": "integer",
                                "format": "int32"
                              },
                              "health_check": {
                                "id": "LoadBalancerServiceHealthCheck",
                                "title": "LoadBalancerServiceHealthCheck",
                                "description": "Service health check",
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                  "interval": {
                                    "description": "Time interval in seconds health checks are performed",
                                    "example": 15,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "port": {
                                    "description": "Port the health check will be performed on",
                                    "example": 4711,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "protocol": {
                                    "title": "Protocol6",
                                    "description": "Type of the health check",
                                    "example": "http",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "tcp",
                                      "http"
                                    ]
                                  },
                                  "retries": {
                                    "description": "Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again",
                                    "example": 3,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "timeout": {
                                    "description": "Time in seconds after an attempt is considered a timeout",
                                    "example": 10,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "http": {
                                    "id": "Http",
                                    "title": "Http",
                                    "description": "Additional configuration for protocol http",
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                      "domain": {
                                        "description": "Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.",
                                        "example": "example.com",
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "path": {
                                        "description": "HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.",
                                        "example": "/",
                                        "type": "string"
                                      },
                                      "response": {
                                        "description": "String that must be contained in HTTP response in order to pass the health check",
                                        "example": {
                                          "status": "ok"
                                        },
                                        "type": "string"
                                      },
                                      "status_codes": {
                                        "description": "List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.",
                                        "example": [
                                          "2??",
                                          "3??"
                                        ],
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      },
                                      "tls": {
                                        "description": "Use HTTPS for health check",
                                        "example": false,
                                        "type": "boolean"
                                      }
                                    },
                                    "required": [
                                      "domain",
                                      "path"
                                    ]
                                  }
                                },
                                "required": [
                                  "interval",
                                  "port",
                                  "protocol",
                                  "retries",
                                  "timeout"
                                ]
                              },
                              "listen_port": {
                                "description": "Port the Load Balancer listens on",
                                "example": 443,
                                "type": "integer",
                                "format": "int32"
                              },
                              "protocol": {
                                "title": "Protocol7",
                                "description": "Protocol of the Load Balancer",
                                "example": "https",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "tcp",
                                  "http",
                                  "https"
                                ]
                              },
                              "proxyprotocol": {
                                "description": "Is Proxyprotocol enabled or not",
                                "example": false,
                                "type": "boolean"
                              },
                              "http": {
                                "id": "LoadBalancerServiceHTTP",
                                "title": "LoadBalancerServiceHTTP",
                                "description": "Configuration option for protocols http and https",
                                "type": "object",
                                "properties": {
                                  "certificates": {
                                    "description": "IDs of the Certificates to use for TLS/SSL termination by the Load Balancer; empty for TLS/SSL passthrough or if `protocol` is \"http\"",
                                    "example": [
                                      897
                                    ],
                                    "type": "array",
                                    "items": {
                                      "type": "integer",
                                      "format": "int32"
                                    }
                                  },
                                  "cookie_lifetime": {
                                    "description": "Lifetime of the cookie used for sticky sessions",
                                    "example": 300,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "cookie_name": {
                                    "description": "Name of the cookie used for sticky sessions",
                                    "example": "HCLBSTICKY",
                                    "type": "string"
                                  },
                                  "redirect_http": {
                                    "description": "Redirect HTTP requests to HTTPS. Only available if protocol is \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  },
                                  "sticky_sessions": {
                                    "description": "Use sticky sessions. Only available if protocol is \"http\" or \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  }
                                }
                              }
                            },
                            "required": [
                              "destination_port",
                              "health_check",
                              "listen_port",
                              "protocol",
                              "proxyprotocol"
                            ]
                          }
                        },
                        "targets": {
                          "description": "List of targets that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerTarget",
                            "title": "LoadBalancerTarget",
                            "type": "object",
                            "properties": {
                              "type": {
                                "title": "Type29",
                                "description": "Type of the resource",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "server",
                                  "label_selector",
                                  "ip"
                                ]
                              },
                              "health_status": {
                                "description": "List of health statuses of the services on this target",
                                "type": "array",
                                "items": {
                                  "id": "HealthStatus",
                                  "title": "HealthStatus",
                                  "type": "object",
                                  "properties": {
                                    "listen_port": {
                                      "example": 443,
                                      "type": "integer",
                                      "format": "int32"
                                    },
                                    "status": {
                                      "title": "Status30",
                                      "example": "healthy",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "healthy",
                                        "unhealthy",
                                        "unknown"
                                      ]
                                    }
                                  }
                                }
                              },
                              "ip": {
                                "id": "Ip",
                                "title": "Ip",
                                "description": "IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.",
                                "type": "object",
                                "properties": {
                                  "ip": {
                                    "description": "IP of a server that belongs to the same customer (public IPv4/IPv6) or private IP in a Subnetwork type vswitch.",
                                    "example": "203.0.113.1",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "ip"
                                ]
                              },
                              "label_selector": {
                                "id": "LabelSelector7",
                                "title": "LabelSelector7",
                                "description": "Label selector and a list of selected targets",
                                "type": "object",
                                "properties": {
                                  "selector": {
                                    "description": "Label selector",
                                    "example": "env=prod",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "selector"
                                ]
                              },
                              "server": {
                                "id": "LoadBalancerTargetServer",
                                "title": "LoadBalancerTargetServer",
                                "description": "Server where the traffic should be routed through",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Server",
                                    "example": 80,
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "id"
                                ]
                              },
                              "targets": {
                                "description": "List of selected targets",
                                "type": "array",
                                "items": {
                                  "id": "Target",
                                  "title": "Target",
                                  "type": "object",
                                  "properties": {
                                    "health_status": {
                                      "description": "",
                                      "type": "array",
                                      "items": {
                                        "$ref": "HealthStatus"
                                      }
                                    },
                                    "server": {
                                      "id": "Server11",
                                      "title": "Server11",
                                      "type": "object",
                                      "properties": {
                                        "id": {
                                          "description": "ID of the Server",
                                          "example": 85,
                                          "type": "integer",
                                          "format": "int32"
                                        }
                                      },
                                      "required": [
                                        "id"
                                      ]
                                    },
                                    "type": {
                                      "example": "server",
                                      "type": "string"
                                    },
                                    "use_private_ip": {
                                      "example": false,
                                      "type": "boolean"
                                    }
                                  }
                                }
                              },
                              "use_private_ip": {
                                "description": "Use the private network IP instead of the public IP. Default value is false.",
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "type"
                            ]
                          }
                        }
                      },
                      "required": [
                        "algorithm",
                        "created",
                        "id",
                        "included_traffic",
                        "ingoing_traffic",
                        "labels",
                        "load_balancer_type",
                        "location",
                        "name",
                        "outgoing_traffic",
                        "private_net",
                        "protection",
                        "public_net",
                        "services",
                        "targets"
                      ]
                    }
                  },
                  "required": [
                    "load_balancer"
                  ]
                }
              example: '{"load_balancer":{"algorithm":{"type":"round_robin"},"created":"2016-01-30T23:50:00+00:00","id":4711,"included_traffic":654321,"ingoing_traffic":123456,"labels":{"labelkey":"value"},"load_balancer_type":{"deprecated":"2016-01-30T23:50:00+00:00","description":"LB11","id":1,"max_assigned_certificates":10,"max_connections":20000,"max_services":5,"max_targets":25,"name":"lb11","prices":[{"location":"fsn1","price_hourly":{"gross":"1.1900000000000000","net":"1.0000000000"},"price_monthly":{"gross":"1.1900000000000000","net":"1.0000000000"}}]},"location":{"city":"Falkenstein","country":"DE","description":"Falkenstein DC Park 1","id":1,"latitude":50.47612,"longitude":12.370071,"name":"fsn1","network_zone":"eu-central"},"name":"new-name","outgoing_traffic":123456,"private_net":[{"ip":"10.0.0.2","network":4711}],"protection":{"delete":false},"public_net":{"enabled":false,"ipv4":{"ip":"1.2.3.4"},"ipv6":{"ip":"2001:db8::1"}},"services":[{"destination_port":80,"health_check":{"http":{"domain":"example.com","path":"/","response":"{\"status\": \"ok\"}","status_codes":["2??,3??"],"tls":false},"interval":15,"port":4711,"protocol":"http","retries":3,"timeout":10},"http":{"certificates":[897],"cookie_lifetime":300,"cookie_name":"HCLBSTICKY","redirect_http":true,"sticky_sessions":true},"listen_port":443,"protocol":"http","proxyprotocol":false}],"targets":[{"health_status":[{"listen_port":443,"status":"healthy"}],"ip":{"ip":"203.0.113.1"},"label_selector":{"selector":"env=prod"},"server":{"id":80},"targets":[{"health_status":[{"listen_port":443,"status":"healthy"}],"label_selector":null,"server":{"id":80},"type":"server","use_private_ip":true}],"type":"server","use_private_ip":true}]}}'
  get:
    description: Gets all existing Load Balancers that you have available.
    queryParameters:
      sort:
        description: Can be used multiple times.
        required: false
        displayName: sort
        enum:
        - id
        - id:asc
        - id:desc
        - name
        - name:asc
        - name:desc
        - created
        - created:asc
        - created:desc
      name:
        description: Can be used to filter resources by their name. The response will only contain the resources matching the specified name
        type: string
        required: false
        displayName: name
      label_selector:
        description: Can be used to filter resources by labels. The response will only contain resources matching the label selector.
        type: string
        required: false
        displayName: label_selector
    responses:
      '200':
        description: The `load_balancers` key contains a list of Load Balancers
        body:
          application/json:
            schema: |
              {
                "id": "LoadBalancersResponse",
                "title": "LoadBalancersResponse",
                "type": "object",
                "properties": {
                  "load_balancers": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "LoadBalancer",
                      "title": "LoadBalancer",
                      "type": "object",
                      "properties": {
                        "algorithm": {
                          "id": "Algorithm",
                          "title": "Algorithm",
                          "description": "Algorithm of the Load Balancer",
                          "type": "object",
                          "properties": {
                            "type": {
                              "title": "Type28",
                              "description": "Type of the algorithm",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "round_robin",
                                "least_connections"
                              ]
                            }
                          },
                          "required": [
                            "type"
                          ]
                        },
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "included_traffic": {
                          "description": "Free Traffic for the current billing period in bytes",
                          "example": 10000,
                          "type": "integer",
                          "format": "int32"
                        },
                        "ingoing_traffic": {
                          "description": "Inbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "load_balancer_type": {
                          "id": "LoadBalancerType",
                          "title": "LoadBalancerType",
                          "type": "object",
                          "properties": {
                            "deprecated": {
                              "description": "Point in time when the Load Balancer type is deprecated (in ISO-8601 format)",
                              "example": "2016-01-30T23:50:00+00:00",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "description": {
                              "description": "Description of the Load Balancer type",
                              "example": "LB11",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Load Balancer type",
                              "example": 1,
                              "type": "number"
                            },
                            "max_assigned_certificates": {
                              "description": "Number of SSL Certificates that can be assigned to a single Load Balancer",
                              "example": 10,
                              "type": "number"
                            },
                            "max_connections": {
                              "description": "Number of maximum simultaneous open connections",
                              "example": 20000,
                              "type": "number"
                            },
                            "max_services": {
                              "description": "Number of services a Load Balancer of this type can have",
                              "example": 5,
                              "type": "number"
                            },
                            "max_targets": {
                              "description": "Number of targets a single Load Balancer can have",
                              "example": 25,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Load Balancer type",
                              "example": "lb11",
                              "type": "string"
                            },
                            "prices": {
                              "description": "Prices in different network zones",
                              "type": "array",
                              "items": {
                                "id": "Price",
                                "title": "Price",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly",
                                    "title": "PriceHourly",
                                    "description": "Hourly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly",
                                    "title": "PriceMonthly",
                                    "description": "Monthly costs for a Resource in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            }
                          },
                          "required": [
                            "deprecated",
                            "description",
                            "id",
                            "max_assigned_certificates",
                            "max_connections",
                            "max_services",
                            "max_targets",
                            "name",
                            "prices"
                          ]
                        },
                        "location": {
                          "id": "Location",
                          "title": "Location",
                          "type": "object",
                          "properties": {
                            "city": {
                              "description": "City the Location is closest to",
                              "example": "Falkenstein",
                              "type": "string"
                            },
                            "country": {
                              "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                              "example": "DE",
                              "type": "string"
                            },
                            "description": {
                              "description": "Description of the Location",
                              "example": "Falkenstein DC Park 1",
                              "type": "string"
                            },
                            "id": {
                              "description": "ID of the Location",
                              "example": 1,
                              "type": "number"
                            },
                            "latitude": {
                              "description": "Latitude of the city closest to the Location",
                              "example": 50.47612,
                              "type": "number"
                            },
                            "longitude": {
                              "description": "Longitude of the city closest to the Location",
                              "example": 12.370071,
                              "type": "number"
                            },
                            "name": {
                              "description": "Unique identifier of the Location",
                              "example": "fsn1",
                              "type": "string"
                            },
                            "network_zone": {
                              "description": "Name of network zone this Location resides in",
                              "example": "eu-central",
                              "type": "string"
                            }
                          },
                          "required": [
                            "city",
                            "country",
                            "description",
                            "id",
                            "latitude",
                            "longitude",
                            "name",
                            "network_zone"
                          ]
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "outgoing_traffic": {
                          "description": "Outbound Traffic for the current billing period in bytes",
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "private_net": {
                          "description": "Private networks information",
                          "type": "array",
                          "items": {
                            "id": "PrivateNet",
                            "title": "PrivateNet",
                            "type": "object",
                            "properties": {
                              "ip": {
                                "example": "10.0.0.2",
                                "type": "string"
                              },
                              "network": {
                                "example": 4711,
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        },
                        "protection": {
                          "id": "Protection",
                          "title": "Protection",
                          "description": "Protection configuration for the Resource",
                          "type": "object",
                          "properties": {
                            "delete": {
                              "description": "If true, prevents the Resource from being deleted",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "delete"
                          ]
                        },
                        "public_net": {
                          "id": "PublicNet",
                          "title": "PublicNet",
                          "description": "Public network information",
                          "type": "object",
                          "properties": {
                            "enabled": {
                              "description": "Public Interface enabled or not",
                              "type": "boolean"
                            },
                            "ipv4": {
                              "id": "Ipv4",
                              "title": "Ipv4",
                              "description": "IP address (v4)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv4 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v4) of this Load Balancer",
                                  "example": "1.2.3.4",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            },
                            "ipv6": {
                              "id": "Ipv6",
                              "title": "Ipv6",
                              "description": "IP address (v6)",
                              "type": "object",
                              "properties": {
                                "dns_ptr": {
                                  "description": "Reverse DNS PTR entry for the IPv6 address of this Load Balancer",
                                  "example": "lb1.example.com",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                },
                                "ip": {
                                  "description": "IP address (v6) of this Load Balancer",
                                  "example": "2001:db8::1",
                                  "type": [
                                    "string",
                                    "null"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "enabled",
                            "ipv4",
                            "ipv6"
                          ]
                        },
                        "services": {
                          "description": "List of services that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerService",
                            "title": "LoadBalancerService",
                            "type": "object",
                            "properties": {
                              "destination_port": {
                                "description": "Port the Load Balancer will balance to",
                                "example": 80,
                                "type": "integer",
                                "format": "int32"
                              },
                              "health_check": {
                                "id": "LoadBalancerServiceHealthCheck",
                                "title": "LoadBalancerServiceHealthCheck",
                                "description": "Service health check",
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                  "interval": {
                                    "description": "Time interval in seconds health checks are performed",
                                    "example": 15,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "port": {
                                    "description": "Port the health check will be performed on",
                                    "example": 4711,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "protocol": {
                                    "title": "Protocol6",
                                    "description": "Type of the health check",
                                    "example": "http",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "tcp",
                                      "http"
                                    ]
                                  },
                                  "retries": {
                                    "description": "Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again",
                                    "example": 3,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "timeout": {
                                    "description": "Time in seconds after an attempt is considered a timeout",
                                    "example": 10,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "http": {
                                    "id": "Http",
                                    "title": "Http",
                                    "description": "Additional configuration for protocol http",
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                      "domain": {
                                        "description": "Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.",
                                        "example": "example.com",
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "path": {
                                        "description": "HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.",
                                        "example": "/",
                                        "type": "string"
                                      },
                                      "response": {
                                        "description": "String that must be contained in HTTP response in order to pass the health check",
                                        "example": {
                                          "status": "ok"
                                        },
                                        "type": "string"
                                      },
                                      "status_codes": {
                                        "description": "List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.",
                                        "example": [
                                          "2??",
                                          "3??"
                                        ],
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      },
                                      "tls": {
                                        "description": "Use HTTPS for health check",
                                        "example": false,
                                        "type": "boolean"
                                      }
                                    },
                                    "required": [
                                      "domain",
                                      "path"
                                    ]
                                  }
                                },
                                "required": [
                                  "interval",
                                  "port",
                                  "protocol",
                                  "retries",
                                  "timeout"
                                ]
                              },
                              "listen_port": {
                                "description": "Port the Load Balancer listens on",
                                "example": 443,
                                "type": "integer",
                                "format": "int32"
                              },
                              "protocol": {
                                "title": "Protocol7",
                                "description": "Protocol of the Load Balancer",
                                "example": "https",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "tcp",
                                  "http",
                                  "https"
                                ]
                              },
                              "proxyprotocol": {
                                "description": "Is Proxyprotocol enabled or not",
                                "example": false,
                                "type": "boolean"
                              },
                              "http": {
                                "id": "LoadBalancerServiceHTTP",
                                "title": "LoadBalancerServiceHTTP",
                                "description": "Configuration option for protocols http and https",
                                "type": "object",
                                "properties": {
                                  "certificates": {
                                    "description": "IDs of the Certificates to use for TLS/SSL termination by the Load Balancer; empty for TLS/SSL passthrough or if `protocol` is \"http\"",
                                    "example": [
                                      897
                                    ],
                                    "type": "array",
                                    "items": {
                                      "type": "integer",
                                      "format": "int32"
                                    }
                                  },
                                  "cookie_lifetime": {
                                    "description": "Lifetime of the cookie used for sticky sessions",
                                    "example": 300,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "cookie_name": {
                                    "description": "Name of the cookie used for sticky sessions",
                                    "example": "HCLBSTICKY",
                                    "type": "string"
                                  },
                                  "redirect_http": {
                                    "description": "Redirect HTTP requests to HTTPS. Only available if protocol is \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  },
                                  "sticky_sessions": {
                                    "description": "Use sticky sessions. Only available if protocol is \"http\" or \"https\". Default `false`",
                                    "example": true,
                                    "type": "boolean"
                                  }
                                }
                              }
                            },
                            "required": [
                              "destination_port",
                              "health_check",
                              "listen_port",
                              "protocol",
                              "proxyprotocol"
                            ]
                          }
                        },
                        "targets": {
                          "description": "List of targets that belong to this Load Balancer",
                          "type": "array",
                          "items": {
                            "id": "LoadBalancerTarget",
                            "title": "LoadBalancerTarget",
                            "type": "object",
                            "properties": {
                              "type": {
                                "title": "Type29",
                                "description": "Type of the resource",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "server",
                                  "label_selector",
                                  "ip"
                                ]
                              },
                              "health_status": {
                                "description": "List of health statuses of the services on this target",
                                "type": "array",
                                "items": {
                                  "id": "HealthStatus",
                                  "title": "HealthStatus",
                                  "type": "object",
                                  "properties": {
                                    "listen_port": {
                                      "example": 443,
                                      "type": "integer",
                                      "format": "int32"
                                    },
                                    "status": {
                                      "title": "Status30",
                                      "example": "healthy",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "healthy",
                                        "unhealthy",
                                        "unknown"
                                      ]
                                    }
                                  }
                                }
                              },
                              "ip": {
                                "id": "Ip",
                                "title": "Ip",
                                "description": "IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.",
                                "type": "object",
                                "properties": {
                                  "ip": {
                                    "description": "IP of a server that belongs to the same customer (public IPv4/IPv6) or private IP in a Subnetwork type vswitch.",
                                    "example": "203.0.113.1",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "ip"
                                ]
                              },
                              "label_selector": {
                                "id": "LabelSelector7",
                                "title": "LabelSelector7",
                                "description": "Label selector and a list of selected targets",
                                "type": "object",
                                "properties": {
                                  "selector": {
                                    "description": "Label selector",
                                    "example": "env=prod",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "selector"
                                ]
                              },
                              "server": {
                                "id": "LoadBalancerTargetServer",
                                "title": "LoadBalancerTargetServer",
                                "description": "Server where the traffic should be routed through",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Server",
                                    "example": 80,
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "id"
                                ]
                              },
                              "targets": {
                                "description": "List of selected targets",
                                "type": "array",
                                "items": {
                                  "id": "Target",
                                  "title": "Target",
                                  "type": "object",
                                  "properties": {
                                    "health_status": {
                                      "description": "",
                                      "type": "array",
                                      "items": {
                                        "$ref": "HealthStatus"
                                      }
                                    },
                                    "server": {
                                      "id": "Server11",
                                      "title": "Server11",
                                      "type": "object",
                                      "properties": {
                                        "id": {
                                          "description": "ID of the Server",
                                          "example": 85,
                                          "type": "integer",
                                          "format": "int32"
                                        }
                                      },
                                      "required": [
                                        "id"
                                      ]
                                    },
                                    "type": {
                                      "example": "server",
                                      "type": "string"
                                    },
                                    "use_private_ip": {
                                      "example": false,
                                      "type": "boolean"
                                    }
                                  }
                                }
                              },
                              "use_private_ip": {
                                "description": "Use the private network IP instead of the public IP. Default value is false.",
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "type"
                            ]
                          }
                        }
                      },
                      "required": [
                        "algorithm",
                        "created",
                        "id",
                        "included_traffic",
                        "ingoing_traffic",
                        "labels",
                        "load_balancer_type",
                        "location",
                        "name",
                        "outgoing_traffic",
                        "private_net",
                        "protection",
                        "public_net",
                        "services",
                        "targets"
                      ]
                    }
                  },
                  "meta": {
                    "id": "Meta",
                    "title": "Meta",
                    "type": "object",
                    "properties": {
                      "pagination": {
                        "id": "Pagination",
                        "title": "Pagination",
                        "type": "object",
                        "properties": {
                          "last_page": {
                            "description": "ID of the last page available. Can be null if the current page is the last one.",
                            "example": 4,
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "next_page": {
                            "description": "ID of the next page. Can be null if the current page is the last one.",
                            "example": 4,
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "page": {
                            "description": "Current page number",
                            "example": 3,
                            "type": "number"
                          },
                          "per_page": {
                            "description": "Maximum number of items shown per page in the response",
                            "example": 25,
                            "type": "number"
                          },
                          "previous_page": {
                            "description": "ID of the previous page. Can be null if the current page is the first one.",
                            "example": 2,
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "total_entries": {
                            "description": "The total number of entries that exist in the database for this query. Nullable if unknown.",
                            "example": 100,
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "last_page",
                          "next_page",
                          "page",
                          "per_page",
                          "previous_page",
                          "total_entries"
                        ]
                      }
                    },
                    "required": [
                      "pagination"
                    ]
                  }
                },
                "required": [
                  "load_balancers"
                ]
              }
  post:
    description: >
      Creates a Load Balancer.


      #### Call specific error codes


      | Code                                    | Description                                                                                           |

      |-----------------------------------------|-------------------------------------------------------------------------------------------------------|

      | `cloud_resource_ip_not_allowed`         | The IP you are trying to add as a target belongs to a Hetzner Cloud resource                          |

      | `ip_not_owned`                          | The IP is not owned by the owner of the project of the Load Balancer                                  |

      | `load_balancer_not_attached_to_network` | The Load Balancer is not attached to a network                                                        |

      | `robot_unavailable`                     | Robot was not available. The caller may retry the operation after a short delay.                      |

      | `server_not_attached_to_network`        | The server you are trying to add as a target is not attached to the same network as the Load Balancer |

      | `source_port_already_used`              | The source port you are trying to add is already in use                                               |

      | `target_already_defined`                | The Load Balancer target you are trying to define is already defined                                  |
    headers:
      Content-Type:
        example: application/json
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "CreateLoadBalancerRequest",
            "title": "CreateLoadBalancerRequest",
            "type": "object",
            "properties": {
              "algorithm": {
                "id": "LoadBalancerAlgorithm",
                "title": "LoadBalancerAlgorithm",
                "description": "Algorithm of the Load Balancer",
                "type": "object",
                "properties": {
                  "type": {
                    "title": "Type28",
                    "description": "Type of the algorithm",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "round_robin",
                      "least_connections"
                    ]
                  }
                },
                "required": [
                  "type"
                ]
              },
              "load_balancer_type": {
                "description": "ID or name of the Load Balancer type this Load Balancer should be created with",
                "example": "lb11",
                "type": "string"
              },
              "name": {
                "description": "Name of the Load Balancer",
                "example": "Web Frontend",
                "type": "string"
              },
              "labels": {
                "id": "Labels",
                "title": "Labels",
                "description": "User-defined labels (key-value pairs)",
                "type": "object",
                "properties": {
                  "labelkey": {
                    "description": "New label",
                    "example": "value",
                    "type": "string"
                  }
                }
              },
              "location": {
                "description": "ID or name of Location to create Load Balancer in",
                "type": "string"
              },
              "network": {
                "description": "ID of the network the Load Balancer should be attached to on creation",
                "example": 123,
                "type": "integer",
                "format": "int32"
              },
              "network_zone": {
                "description": "Name of network zone",
                "example": "eu-central",
                "type": "string"
              },
              "public_interface": {
                "description": "Enable or disable the public interface of the Load Balancer",
                "example": true,
                "type": "boolean"
              },
              "services": {
                "description": "Array of services",
                "type": "array",
                "items": {
                  "id": "LoadBalancerService",
                  "title": "LoadBalancerService",
                  "type": "object",
                  "properties": {
                    "destination_port": {
                      "description": "Port the Load Balancer will balance to",
                      "example": 80,
                      "type": "integer",
                      "format": "int32"
                    },
                    "health_check": {
                      "id": "LoadBalancerServiceHealthCheck",
                      "title": "LoadBalancerServiceHealthCheck",
                      "description": "Service health check",
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "interval": {
                          "description": "Time interval in seconds health checks are performed",
                          "example": 15,
                          "type": "integer",
                          "format": "int32"
                        },
                        "port": {
                          "description": "Port the health check will be performed on",
                          "example": 4711,
                          "type": "integer",
                          "format": "int32"
                        },
                        "protocol": {
                          "title": "Protocol6",
                          "description": "Type of the health check",
                          "example": "http",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "tcp",
                            "http"
                          ]
                        },
                        "retries": {
                          "description": "Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again",
                          "example": 3,
                          "type": "integer",
                          "format": "int32"
                        },
                        "timeout": {
                          "description": "Time in seconds after an attempt is considered a timeout",
                          "example": 10,
                          "type": "integer",
                          "format": "int32"
                        },
                        "http": {
                          "id": "Http",
                          "title": "Http",
                          "description": "Additional configuration for protocol http",
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "domain": {
                              "description": "Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.",
                              "example": "example.com",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "path": {
                              "description": "HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.",
                              "example": "/",
                              "type": "string"
                            },
                            "response": {
                              "description": "String that must be contained in HTTP response in order to pass the health check",
                              "example": {
                                "status": "ok"
                              },
                              "type": "string"
                            },
                            "status_codes": {
                              "description": "List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.",
                              "example": [
                                "2??",
                                "3??"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "tls": {
                              "description": "Use HTTPS for health check",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "domain",
                            "path"
                          ]
                        }
                      },
