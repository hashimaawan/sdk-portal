                  example: '{"action":{"command":"issue_certificate","error":{"code":"action_failed","message":"Action failed"},"finished":"2021-01-30T23:57:00+00:00","id":14,"progress":100,"resources":[{"id":896,"type":"certificate"}],"started":"2021-01-30T23:55:00+00:00","status":"success"}}'
      get:
        description: >
          Returns all Action objects for a Certificate. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.


          Only type `managed` Certificates can have Actions. For type `uploaded` Certificates the `actions` key will always contain an empty array.
        queryParameters:
          sort:
            description: Can be used multiple times.
            required: false
            displayName: sort
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            required: false
            displayName: status
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                schema: |
                  {
                    "id": "ActionsResponse",
                    "title": "ActionsResponse",
                    "example": {
                      "actions": [
                        {
                          "command": "issue_certificate",
                          "error": {
                            "code": "action_failed",
