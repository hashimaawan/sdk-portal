            </option>
            <option value="Enum_finisheddesc">
              <doc title="Enum_finisheddesc" xml:lang="en" />
            </option>
          </param>
          <param name="status" style="query" default="">
            <doc title="status" xml:lang="en">Can be used multiple times, the response will contain only Actions with specified statuses</doc>
            <option value="running">
