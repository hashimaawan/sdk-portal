- CreateLoadBalancerRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CreateLoadBalancerRequest",
      "title": "CreateLoadBalancerRequest",
      "type": "object",
      "properties": {
        "algorithm": {
          "id": "LoadBalancerAlgorithm",
          "title": "LoadBalancerAlgorithm",
          "description": "Algorithm of the Load Balancer",
          "type": "object",
          "properties": {
            "type": {
              "title": "Type28",
              "description": "Type of the algorithm",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "round_robin",
                "least_connections"
              ]
            }
          },
          "required": [
            "type"
          ]
        },
        "load_balancer_type": {
          "description": "ID or name of the Load Balancer type this Load Balancer should be created with",
          "example": "lb11",
          "type": "string"
        },
        "name": {
          "description": "Name of the Load Balancer",
          "example": "Web Frontend",
          "type": "string"
        },
        "labels": {
          "id": "Labels",
          "title": "Labels",
          "description": "User-defined labels (key-value pairs)",
          "type": "object",
          "properties": {
            "labelkey": {
              "description": "New label",
              "example": "value",
              "type": "string"
            }
          }
        },
        "location": {
          "description": "ID or name of Location to create Load Balancer in",
          "type": "string"
        },
        "network": {
          "description": "ID of the network the Load Balancer should be attached to on creation",
          "example": 123,
          "type": "integer",
          "format": "int32"
        },
        "network_zone": {
          "description": "Name of network zone",
          "example": "eu-central",
          "type": "string"
        },
        "public_interface": {
          "description": "Enable or disable the public interface of the Load Balancer",
          "example": true,
          "type": "boolean"
        },
        "services": {
          "description": "Array of services",
          "type": "array",
          "items": {
            "id": "LoadBalancerService",
            "title": "LoadBalancerService",
            "type": "object",
            "properties": {
              "destination_port": {
                "description": "Port the Load Balancer will balance to",
                "example": 80,
                "type": "integer",
                "format": "int32"
              },
              "health_check": {
                "id": "LoadBalancerServiceHealthCheck",
                "title": "LoadBalancerServiceHealthCheck",
                "description": "Service health check",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "interval": {
                    "description": "Time interval in seconds health checks are performed",
                    "example": 15,
