- SshKeysResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SshKeysResponse",
      "title": "SshKeysResponse",
      "type": "object",
      "properties": {
        "ssh_keys": {
          "description": "",
          "type": "array",
          "items": {
            "id": "SshKey",
            "title": "SshKey",
            "type": "object",
            "properties": {
              "created": {
                "description": "Point in time when the Resource was created (in ISO-8601 format)",
                "example": "2016-01-30T23:55:00+00:00",
                "type": "string"
              },
              "fingerprint": {
                "description": "Fingerprint of public key",
                "example": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                "type": "string"
              },
              "id": {
                "description": "ID of the Resource",
                "example": 42,
                "type": "integer",
                "format": "int32"
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "name": {
                "description": "Name of the Resource. Must be unique per Project.",
                "example": "my-resource",
                "type": "string"
              },
              "public_key": {
                "description": "Public key",
                "example": "ssh-rsa AAAjjk76kgf...Xt",
                "type": "string"
              }
            },
            "required": [
              "created",
              "fingerprint",
              "id",
              "labels",
              "name",
              "public_key"
            ]
          }
        },
        "meta": {
          "id": "Meta",
          "title": "Meta",
          "type": "object",
          "properties": {
            "pagination": {
              "id": "Pagination",
              "title": "Pagination",
              "type": "object",
              "properties": {
                "last_page": {
                  "description": "ID of the last page available. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "next_page": {
                  "description": "ID of the next page. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "page": {
                  "description": "Current page number",
                  "example": 3,
                  "type": "number"
                },
                "per_page": {
                  "description": "Maximum number of items shown per page in the response",
                  "example": 25,
                  "type": "number"
                },
                "previous_page": {
                  "description": "ID of the previous page. Can be null if the current page is the first one.",
                  "example": 2,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "total_entries": {
                  "description": "The total number of entries that exist in the database for this query. Nullable if unknown.",
                  "example": 100,
                  "type": [
                    "number",
                    "null"
                  ]
                }
              },
              "required": [
                "last_page",
                "next_page",
                "page",
                "per_page",
                "previous_page",
                "total_entries"
              ]
            }
          },
          "required": [
            "pagination"
          ]
        }
      },
      "required": [
        "ssh_keys"
      ]
    }
