- ChapterObject: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ChapterObject",
      "title": "ChapterObject",
      "type": "object",
      "properties": {
        "audio_preview_url": {
          "description": "A URL to a 30 second preview (MP3 format) of the chapter. `null` if not available.",
          "example": "https://p.scdn.co/mp3-preview/2f37da1d4221f40b9d1a98cd191f4d6f1646ad17",
          "type": [
            "string",
            "null"
          ]
        },
        "chapter_number": {
          "description": "The number of the chapter",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "description": {
          "description": "A description of the chapter. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
          "example": "We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.\n",
          "type": "string"
        },
        "html_description": {
          "description": "A description of the chapter. This field may contain HTML tags.",
          "example": "<p>We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.</p>\n",
          "type": "string"
        },
        "duration_ms": {
          "description": "The chapter length in milliseconds.",
          "example": 1686230,
          "type": "integer",
          "format": "int32"
        },
        "explicit": {
          "description": "Whether or not the chapter has explicit content (true = yes it does; false = no it does not OR unknown).",
          "type": "boolean"
        },
        "external_urls": {
          "id": "ExternalUrlObject",
          "title": "ExternalUrlObject",
          "description": "External URLs for this chapter.",
          "type": "object",
          "properties": {
            "spotify": {
              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
              "type": "string"
            }
          }
        },
        "href": {
          "description": "A link to the Web API endpoint providing full details of the chapter.",
          "example": "https://api.spotify.com/v1/episodes/5Xt5DXGzch68nYYamXrNxZ",
          "type": "string"
        },
        "id": {
          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
          "example": "5Xt5DXGzch68nYYamXrNxZ",
          "type": "string"
        },
        "images": {
          "description": "The cover art for the chapter in various sizes, widest first.",
          "type": "array",
          "items": {
            "id": "ImageObject",
            "title": "ImageObject",
            "type": "object",
            "properties": {
              "url": {
                "description": "The source URL of the image.",
                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                "type": "string"
              },
              "height": {
                "description": "The image height in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "width": {
                "description": "The image width in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              }
            },
            "required": [
              "url",
              "height",
              "width"
            ]
          }
        },
        "is_playable": {
          "description": "True if the chapter is playable in the given market. Otherwise false.",
          "type": "boolean"
        },
        "languages": {
          "description": "A list of the languages used in the chapter, identified by their [ISO 639-1](https://en.wikipedia.org/wiki/ISO_639) code.",
          "example": [
            "fr",
            "en"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "description": "The name of the chapter.",
          "example": "Starting Your Own Podcast: Tips, Tricks, and Advice From Anchor Creators\n",
          "type": "string"
        },
        "release_date": {
          "description": "The date the chapter was first released, for example `\"1981-12-15\"`. Depending on the precision, it might be shown as `\"1981\"` or `\"1981-12\"`.",
          "example": "1981-12-15",
          "type": "string"
        },
        "release_date_precision": {
          "title": "ReleaseDatePrecision",
          "description": "The precision with which `release_date` value is known.",
          "example": "year",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "type": {
          "description": "The object type.",
          "type": "string",
          "enum": [
            "episode"
          ]
        },
        "uri": {
          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
          "example": "spotify:episode:0zLhl3WsOCQHbe1BPTiHgr",
          "type": "string"
        },
        "audiobook": {
          "id": "AudiobookBase",
          "title": "AudiobookBase",
          "description": "The audiobook for which the chapter belongs.",
          "type": "object",
          "properties": {
            "authors": {
              "description": "The author(s) for the audiobook.",
              "type": "array",
              "items": {
                "id": "AuthorObject",
                "title": "AuthorObject",
                "type": "object",
                "properties": {
                  "name": {
                    "description": "The name of the author.",
                    "type": "string"
                  }
                }
              }
            },
            "available_markets": {
              "description": "A list of the countries in which the audiobook can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "copyrights": {
              "description": "The copyright statements of the audiobook.",
              "type": "array",
              "items": {
                "id": "CopyrightObject",
                "title": "CopyrightObject",
                "type": "object",
                "properties": {
                  "text": {
                    "description": "The copyright text for this content.",
                    "type": "string"
                  },
                  "type": {
                    "description": "The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.",
                    "type": "string"
                  }
                }
              }
            },
            "description": {
              "description": "A description of the audiobook. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
              "type": "string"
            },
            "html_description": {
              "description": "A description of the audiobook. This field may contain HTML tags.",
              "type": "string"
            },
            "explicit": {
              "description": "Whether or not the audiobook has explicit content (true = yes it does; false = no it does not OR unknown).",
              "type": "boolean"
            },
            "external_urls": {
              "$ref": "ExternalUrlObject"
            },
            "href": {
              "description": "A link to the Web API endpoint providing full details of the audiobook.",
              "type": "string"
            },
            "id": {
              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the audiobook.",
              "type": "string"
            },
            "images": {
              "description": "The cover art for the audiobook in various sizes, widest first.",
              "type": "array",
              "items": {
                "$ref": "ImageObject"
              }
            },
            "languages": {
              "description": "A list of the languages used in the audiobook, identified by their [ISO 639](https://en.wikipedia.org/wiki/ISO_639) code.",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "media_type": {
              "description": "The media type of the audiobook.",
              "type": "string"
            },
            "name": {
              "description": "The name of the audiobook.",
              "type": "string"
            },
            "narrators": {
              "description": "The narrator(s) for the audiobook.",
              "type": "array",
              "items": {
                "id": "NarratorObject",
                "title": "NarratorObject",
                "type": "object",
                "properties": {
                  "name": {
                    "description": "The name of the Narrator.",
                    "type": "string"
                  }
                }
              }
            },
            "publisher": {
              "description": "The publisher of the audiobook.",
              "type": "string"
            },
            "type": {
              "description": "The object type.",
              "type": "string",
              "enum": [
                "audiobook"
              ]
            },
            "uri": {
              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the audiobook.",
              "type": "string"
            },
            "total_chapters": {
              "description": "The number of chapters in this audiobook.",
              "type": "integer",
              "format": "int32"
            },
            "edition": {
              "description": "The edition of the audiobook.",
              "example": "Unabridged",
              "type": "string"
            }
          },
          "required": [
            "authors",
            "available_markets",
            "copyrights",
            "description",
            "html_description",
            "explicit",
            "external_urls",
            "href",
            "id",
            "images",
            "languages",
            "media_type",
            "name",
            "narrators",
            "publisher",
            "type",
            "uri",
            "total_chapters"
          ]
        },
        "available_markets": {
          "description": "A list of the countries in which the chapter can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resume_point": {
          "id": "ResumePointObject",
          "title": "ResumePointObject",
          "description": "The user's most recent position in the chapter. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.",
          "type": "object",
          "properties": {
            "fully_played": {
              "description": "Whether or not the episode has been fully played by the user.",
              "type": "boolean"
            },
            "resume_position_ms": {
              "description": "The user's most recent position in the episode in milliseconds.",
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "restrictions": {
          "id": "ChapterRestrictionObject",
          "title": "ChapterRestrictionObject",
          "description": "Included in the response when a content restriction is applied.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n- `payment_required` - Payment is required to play the content item.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
              "type": "string"
            }
          }
        }
      },
      "required": [
        "audio_preview_url",
        "chapter_number",
        "description",
        "html_description",
        "duration_ms",
        "explicit",
        "external_urls",
        "href",
        "id",
        "images",
        "is_playable",
        "languages",
        "name",
        "release_date",
        "release_date_precision",
        "type",
        "uri",
        "audiobook"
      ]
    }
- ChapterBase: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ChapterBase",
      "title": "ChapterBase",
      "type": "object",
      "properties": {
        "audio_preview_url": {
          "description": "A URL to a 30 second preview (MP3 format) of the chapter. `null` if not available.",
          "example": "https://p.scdn.co/mp3-preview/2f37da1d4221f40b9d1a98cd191f4d6f1646ad17",
          "type": [
            "string",
            "null"
          ]
        },
        "chapter_number": {
          "description": "The number of the chapter",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "description": {
          "description": "A description of the chapter. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
          "example": "We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.\n",
          "type": "string"
        },
        "html_description": {
          "description": "A description of the chapter. This field may contain HTML tags.",
          "example": "<p>We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.</p>\n",
          "type": "string"
        },
        "duration_ms": {
          "description": "The chapter length in milliseconds.",
          "example": 1686230,
          "type": "integer",
          "format": "int32"
        },
        "explicit": {
          "description": "Whether or not the chapter has explicit content (true = yes it does; false = no it does not OR unknown).",
          "type": "boolean"
        },
        "external_urls": {
          "id": "ExternalUrlObject",
          "title": "ExternalUrlObject",
          "description": "External URLs for this chapter.",
          "type": "object",
          "properties": {
            "spotify": {
              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
              "type": "string"
            }
          }
        },
        "href": {
          "description": "A link to the Web API endpoint providing full details of the chapter.",
          "example": "https://api.spotify.com/v1/episodes/5Xt5DXGzch68nYYamXrNxZ",
          "type": "string"
        },
        "id": {
          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
          "example": "5Xt5DXGzch68nYYamXrNxZ",
          "type": "string"
        },
        "images": {
          "description": "The cover art for the chapter in various sizes, widest first.",
          "type": "array",
          "items": {
            "id": "ImageObject",
            "title": "ImageObject",
            "type": "object",
            "properties": {
              "url": {
                "description": "The source URL of the image.",
                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                "type": "string"
              },
              "height": {
                "description": "The image height in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "width": {
                "description": "The image width in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              }
            },
            "required": [
              "url",
              "height",
              "width"
            ]
          }
        },
        "is_playable": {
          "description": "True if the chapter is playable in the given market. Otherwise false.",
          "type": "boolean"
        },
        "languages": {
          "description": "A list of the languages used in the chapter, identified by their [ISO 639-1](https://en.wikipedia.org/wiki/ISO_639) code.",
          "example": [
            "fr",
            "en"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "description": "The name of the chapter.",
          "example": "Starting Your Own Podcast: Tips, Tricks, and Advice From Anchor Creators\n",
          "type": "string"
        },
        "release_date": {
          "description": "The date the chapter was first released, for example `\"1981-12-15\"`. Depending on the precision, it might be shown as `\"1981\"` or `\"1981-12\"`.",
          "example": "1981-12-15",
          "type": "string"
        },
        "release_date_precision": {
          "title": "ReleaseDatePrecision",
          "description": "The precision with which `release_date` value is known.",
          "example": "year",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "type": {
          "description": "The object type.",
          "type": "string",
          "enum": [
            "episode"
          ]
        },
        "uri": {
          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
          "example": "spotify:episode:0zLhl3WsOCQHbe1BPTiHgr",
          "type": "string"
        },
        "available_markets": {
          "description": "A list of the countries in which the chapter can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resume_point": {
          "id": "ResumePointObject",
          "title": "ResumePointObject",
          "description": "The user's most recent position in the chapter. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.",
          "type": "object",
          "properties": {
            "fully_played": {
              "description": "Whether or not the episode has been fully played by the user.",
              "type": "boolean"
            },
            "resume_position_ms": {
              "description": "The user's most recent position in the episode in milliseconds.",
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "restrictions": {
          "id": "ChapterRestrictionObject",
          "title": "ChapterRestrictionObject",
          "description": "Included in the response when a content restriction is applied.",
          "type": "object",
          "properties": {
            "reason": {
              "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n- `payment_required` - Payment is required to play the content item.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
              "type": "string"
            }
          }
        }
      },
      "required": [
        "audio_preview_url",
        "chapter_number",
        "description",
        "html_description",
        "duration_ms",
        "explicit",
        "external_urls",
        "href",
        "id",
        "images",
        "is_playable",
        "languages",
        "name",
        "release_date",
        "release_date_precision",
        "type",
        "uri"
      ]
    }
- AlbumObject: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AlbumObject",
      "title": "AlbumObject",
      "description": "Information about the album.",
      "type": "object",
      "properties": {
        "album_type": {
          "title": "AlbumType",
          "description": "The type of the album.",
          "example": "compilation",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "album",
            "single",
            "compilation"
          ]
        },
        "total_tracks": {
          "description": "The number of tracks in the album.",
          "example": 9,
          "type": "integer",
          "format": "int32"
        },
        "available_markets": {
          "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
          "example": [
            "CA",
            "BR",
            "IT"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_urls": {
          "id": "ExternalUrlObject",
          "title": "ExternalUrlObject",
          "description": "External URLs for this chapter.",
          "type": "object",
          "properties": {
            "spotify": {
              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
              "type": "string"
            }
          }
        },
        "href": {
          "description": "A link to the Web API endpoint providing full details of the album.",
          "type": "string"
        },
        "id": {
          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
          "example": "2up3OPMp9Tb4dAKM2erWXQ",
          "type": "string"
        },
        "images": {
          "description": "The cover art for the album in various sizes, widest first.",
          "type": "array",
          "items": {
            "id": "ImageObject",
            "title": "ImageObject",
            "type": "object",
            "properties": {
              "url": {
                "description": "The source URL of the image.",
                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                "type": "string"
              },
              "height": {
                "description": "The image height in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "width": {
                "description": "The image width in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              }
            },
            "required": [
              "url",
              "height",
              "width"
            ]
          }
        },
        "name": {
          "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
          "type": "string"
        },
        "release_date": {
          "description": "The date the album was first released.",
          "example": "1981-12",
          "type": "string"
        },
        "release_date_precision": {
          "title": "ReleaseDatePrecision",
          "description": "The precision with which `release_date` value is known.",
          "example": "year",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "type": {
          "description": "The object type.",
          "type": "string",
          "enum": [
            "album"
          ]
        },
        "uri": {
          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
          "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
          "type": "string"
        },
        "artists": {
          "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
          "type": "array",
          "items": {
            "id": "SimplifiedArtistObject",
            "title": "SimplifiedArtistObject",
            "type": "object",
            "properties": {
              "external_urls": {
                "$ref": "ExternalUrlObject"
              },
              "href": {
                "description": "A link to the Web API endpoint providing full details of the artist.",
                "type": "string"
              },
              "id": {
                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                "type": "string"
              },
              "name": {
                "description": "The name of the artist.",
                "type": "string"
              },
              "type": {
                "title": "Type",
                "description": "The object type.",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "artist"
                ]
              },
              "uri": {
                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                "type": "string"
              }
            }
          }
        },
        "tracks": {
          "id": "PagingSimplifiedTrackObject",
          "title": "PagingSimplifiedTrackObject",
          "description": "The tracks of the album.",
          "type": "object",
          "properties": {
            "href": {
              "description": "A link to the Web API endpoint returning the full result of the request",
              "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
              "type": "string"
            },
            "limit": {
              "description": "The maximum number of items in the response (as set in the query or by default).",
              "example": 20,
              "type": "integer",
              "format": "int32"
            },
            "next": {
              "description": "URL to the next page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "offset": {
              "description": "The offset of the items returned (as set in the query or by default)",
              "example": 0,
              "type": "integer",
              "format": "int32"
            },
            "previous": {
              "description": "URL to the previous page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "total": {
              "description": "The total number of items available to return.",
              "example": 4,
              "type": "integer",
              "format": "int32"
            },
            "items": {
              "description": "",
              "type": "array",
              "items": {
                "id": "SimplifiedTrackObject",
                "title": "SimplifiedTrackObject",
                "type": "object",
                "properties": {
                  "artists": {
                    "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                    "type": "array",
                    "items": {
                      "$ref": "SimplifiedArtistObject"
                    }
                  },
                  "available_markets": {
                    "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "disc_number": {
                    "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                    "type": "integer",
                    "format": "int32"
                  },
                  "duration_ms": {
                    "description": "The track length in milliseconds.",
                    "type": "integer",
                    "format": "int32"
                  },
                  "explicit": {
                    "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                    "type": "boolean"
                  },
                  "external_urls": {
                    "$ref": "ExternalUrlObject"
                  },
                  "href": {
                    "description": "A link to the Web API endpoint providing full details of the track.",
                    "type": "string"
                  },
                  "id": {
                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                    "type": "string"
                  },
                  "is_playable": {
                    "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking/) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                    "type": "boolean"
                  },
                  "linked_from": {
                    "id": "LinkedTrackObject",
                    "title": "LinkedTrackObject",
                    "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking/) is applied and is only part of the response if the track linking, in fact, exists. The requested track has been replaced with a different track. The track in the `linked_from` object contains information about the originally requested track.",
                    "type": "object",
                    "properties": {
                      "external_urls": {
                        "$ref": "ExternalUrlObject"
                      },
                      "href": {
                        "description": "A link to the Web API endpoint providing full details of the track.",
                        "type": "string"
                      },
                      "id": {
                        "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                        "type": "string"
                      },
                      "type": {
                        "description": "The object type: \"track\".",
                        "type": "string"
                      },
                      "uri": {
                        "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                        "type": "string"
                      }
                    }
                  },
                  "restrictions": {
                    "id": "TrackRestrictionObject",
                    "title": "TrackRestrictionObject",
                    "description": "Included in the response when a content restriction is applied.",
                    "type": "object",
                    "properties": {
                      "reason": {
                        "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                        "type": "string"
                      }
                    }
                  },
                  "name": {
                    "description": "The name of the track.",
                    "type": "string"
                  },
                  "preview_url": {
                    "description": "A URL to a 30 second preview (MP3 format) of the track.",
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "track_number": {
                    "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                    "type": "integer",
                    "format": "int32"
                  },
                  "type": {
                    "description": "The object type: \"track\".",
                    "type": "string"
                  },
                  "uri": {
                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                    "type": "string"
                  },
                  "is_local": {
                    "description": "Whether or not the track is from a local file.",
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "required": [
            "href",
            "limit",
            "next",
            "offset",
            "previous",
            "total",
            "items"
          ]
        },
        "copyrights": {
          "description": "The copyright statements of the album.",
          "type": "array",
          "items": {
            "id": "CopyrightObject",
            "title": "CopyrightObject",
            "type": "object",
            "properties": {
              "text": {
                "description": "The copyright text for this content.",
                "type": "string"
              },
              "type": {
                "description": "The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.",
                "type": "string"
              }
            }
          }
        },
        "external_ids": {
          "id": "ExternalIdObject",
          "title": "ExternalIdObject",
          "description": "Known external IDs for the album.",
          "type": "object",
          "properties": {
            "isrc": {
              "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
              "type": "string"
            },
            "ean": {
              "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
              "type": "string"
            },
            "upc": {
              "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
              "type": "string"
            }
          }
        },
        "genres": {
          "description": "A list of the genres the album is associated with. If not yet classified, the array is empty.",
          "example": [
            "Egg punk",
            "Noise rock"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "label": {
          "description": "The label associated with the album.",
          "type": "string"
        },
        "popularity": {
          "description": "The popularity of the album. The value will be between 0 and 100, with 100 being the most popular.",
          "type": "integer",
          "format": "int32"
        },
        "restrictions": {
          "id": "AlbumRestrictionObject",
          "title": "AlbumRestrictionObject",
          "description": "Included in the response when a content restriction is applied.",
          "type": "object",
          "properties": {
            "reason": {
              "title": "Reason",
              "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "market",
                "product",
                "explicit"
              ]
            }
          }
        }
      },
      "required": [
        "album_type",
        "total_tracks",
        "available_markets",
        "external_urls",
        "href",
        "id",
        "images",
        "name",
        "release_date",
        "release_date_precision",
        "type",
        "uri",
        "artists",
        "tracks",
        "copyrights",
        "external_ids",
        "genres",
        "label",
        "popularity"
      ]
    }
- ContextObject: |
