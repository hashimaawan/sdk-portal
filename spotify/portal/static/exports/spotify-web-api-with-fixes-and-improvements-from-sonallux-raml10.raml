  /tracks:
    get:
      displayName: get-playlists-tracks
      description: >
        Get full details of the items of a playlist owned by a Spotify user.
      securedBy:
      - oauth_2_0:
          scopes:
          - playlist-read-private
      queryParameters:
        market:
          required: false
          example:
            value: ES
          displayName: market
          type: string
        fields:
          required: false
          example:
            value: items(added_by.id,track(name,href,album(name,href)))
          displayName: fields
          type: string
        limit:
          required: false
          default: '20'
          example:
            value: 10
          displayName: limit
          type: integer
          minimum: 1
          maximum: 100
          format: int32
        offset:
          required: false
          default: '0'
          example:
            value: 5
          displayName: offset
          type: integer
          format: int32
        additional_types:
          required: false
          displayName: additional_types
          type: string
      responses:
        '200':
          description: Pages of tracks
          body:
            application/json:
              displayName: response200
              description: ''
              type: PagingPlaylistTrackObject
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    post:
      displayName: add-tracks-to-playlist
      description: >
        Add one or more items to a user's playlist.
      body:
        application/json:
          displayName: body
          type: PlaylistsTracksRequest
      securedBy:
      - oauth_2_0:
          scopes:
          - playlist-modify-public
          - playlist-modify-private
      queryParameters:
        position:
          required: false
          example:
            value: 0
          displayName: position
          type: integer
          format: int32
        uris:
          required: false
          example:
            value: spotify:track:4iV5W9uYEdYUVa79Axb7Rh,spotify:track:1301WleyT98MSxVHPZCA6M
          displayName: uris
          type: string
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '201':
          description: A snapshot ID for the playlist
          body:
            application/json:
              displayName: response201
              description: ''
              type: PlaylistSnapshotId
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    put:
      displayName: reorder-or-replace-playlists-tracks
      description: >
        Either reorder or replace items in a playlist depending on the request's parameters.

        To reorder items, include `range_start`, `insert_before`, `range_length` and `snapshot_id` in the request's body.

        To replace items, include `uris` as either a query parameter or in the request's body.

        Replacing items in a playlist will overwrite its existing items. This operation can be used for replacing or clearing items in a playlist.

        <br/>

        **Note**: Replace and reorder are mutually exclusive operations which share the same endpoint, but have different parameters.

        These operations can't be applied together in a single request.
      body:
        application/json:
          displayName: body
          type: PlaylistsTracksRequest1
      securedBy:
      - oauth_2_0:
          scopes:
          - playlist-modify-public
          - playlist-modify-private
      queryParameters:
        uris:
          required: false
          displayName: uris
          type: string
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: A snapshot ID for the playlist
          body:
            application/json:
              displayName: response200
              description: ''
              type: PlaylistSnapshotId
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    delete:
      displayName: remove-tracks-playlist
      description: >
        Remove one or more items from a user's playlist.
      body:
        application/json:
          displayName: body
          type: PlaylistsTracksRequest2
      securedBy:
      - oauth_2_0:
