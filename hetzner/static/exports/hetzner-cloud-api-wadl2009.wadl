      <xs:complexType name="LoadBalancerTypesResponse">
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="load_balancer_types" type="schemas:LoadBalancerType" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="LoadBalancerType">
        <xs:sequence>
          <xs:element minOccurs="1" name="deprecated" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Point in time when the Load Balancer type is deprecated (in ISO-8601 format)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>Description of the Load Balancer type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:double">
            <xs:annotation>
              <xs:documentation>ID of the Load Balancer type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="max_assigned_certificates" type="xs:double">
            <xs:annotation>
              <xs:documentation>Number of SSL Certificates that can be assigned to a single Load Balancer</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="max_connections" type="xs:double">
            <xs:annotation>
              <xs:documentation>Number of maximum simultaneous open connections</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="max_services" type="xs:double">
            <xs:annotation>
              <xs:documentation>Number of services a Load Balancer of this type can have</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="max_targets" type="xs:double">
            <xs:annotation>
              <xs:documentation>Number of targets a single Load Balancer can have</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique identifier of the Load Balancer type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="prices" type="schemas:Price">
            <xs:annotation>
              <xs:documentation>Prices in different network zones</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Price">
        <xs:sequence>
          <xs:element minOccurs="1" name="location" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the Location the price is for</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="price_hourly" type="schemas:PriceHourly">
            <xs:annotation>
              <xs:documentation>Hourly costs for a Resource in this Location</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="price_monthly" type="schemas:PriceMonthly">
            <xs:annotation>
              <xs:documentation>Monthly costs for a Resource in this Location</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PriceHourly">
        <xs:annotation>
          <xs:documentation>Hourly costs for a Resource in this Location</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="gross" type="xs:string">
            <xs:annotation>
              <xs:documentation>Price with VAT added</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="net" type="xs:string">
            <xs:annotation>
              <xs:documentation>Price without VAT</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PriceMonthly">
        <xs:annotation>
          <xs:documentation>Monthly costs for a Resource in this Location</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="gross" type="xs:string">
            <xs:annotation>
              <xs:documentation>Price with VAT added</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="net" type="xs:string">
            <xs:annotation>
              <xs:documentation>Price without VAT</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="LoadBalancerTypesResponse1">
        <xs:sequence>
          <xs:element minOccurs="0" name="load_balancer_type" type="schemas:LoadBalancerType" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="LoadBalancersResponse">
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="load_balancers" type="schemas:LoadBalancer" />
