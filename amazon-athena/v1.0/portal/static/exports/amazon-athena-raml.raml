- CalculationExecutionState: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "CalculationExecutionState",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "CREATING",
        "CREATED",
        "QUEUED",
        "RUNNING",
        "CANCELING",
        "CANCELED",
        "COMPLETED",
        "FAILED"
      ]
    }
- CalculationResult: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CalculationResult",
      "title": "CalculationResult",
      "description": "Contains information about an application-specific calculation result.",
      "type": "object",
      "properties": {
        "StdOutS3Uri": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
        },
        "StdErrorS3Uri": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
        },
        "ResultS3Uri": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^(https|s3|S3)://([^/]+)/?(.*)$"
        },
        "ResultType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "\\w+\\/[-+.\\w]+"
        }
      }
    }
- CalculationStatistics: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CalculationStatistics",
      "title": "CalculationStatistics",
      "description": "Contains statistics for a notebook calculation.",
      "type": "object",
      "properties": {
        "DpuExecutionInMillis": {
          "type": "integer",
          "format": "int32"
        },
        "Progress": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    }
- CalculationStatus: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CalculationStatus",
      "title": "CalculationStatus",
      "description": "Contains information about the status of a notebook calculation.",
      "type": "object",
      "properties": {
        "SubmissionDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "CompletionDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "State": {
          "title": "CalculationExecutionState1",
          "description": "<p>The state of the calculation execution. A description of each state follows.</p> <p> <code>CREATING</code> - The calculation is in the process of being created.</p> <p> <code>CREATED</code> - The calculation has been created and is ready to run.</p> <p> <code>QUEUED</code> - The calculation has been queued for processing.</p> <p> <code>RUNNING</code> - The calculation is running.</p> <p> <code>CANCELING</code> - A request to cancel the calculation has been received and the system is working to stop it.</p> <p> <code>CANCELED</code> - The calculation is no longer running as the result of a cancel request.</p> <p> <code>COMPLETED</code> - The calculation has completed without error.</p> <p> <code>FAILED</code> - The calculation failed and is no longer running.</p>",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "CREATING",
            "CREATED",
            "QUEUED",
            "RUNNING",
            "CANCELING",
            "CANCELED",
            "COMPLETED",
            "FAILED"
          ]
        },
        "StateChangeReason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    }
- CalculationSummary: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CalculationSummary",
      "title": "CalculationSummary",
      "description": "Summary information for a notebook calculation.",
      "type": "object",
      "properties": {
        "CalculationExecutionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 36
        },
        "Description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "Status": {
          "id": "Status1",
          "title": "Status1",
          "type": "object",
          "properties": {
            "SubmissionDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "CompletionDateTime": {
              "type": "string",
              "format": "date-time"
            },
            "State": {
              "title": "CalculationExecutionState1",
              "description": "<p>The state of the calculation execution. A description of each state follows.</p> <p> <code>CREATING</code> - The calculation is in the process of being created.</p> <p> <code>CREATED</code> - The calculation has been created and is ready to run.</p> <p> <code>QUEUED</code> - The calculation has been queued for processing.</p> <p> <code>RUNNING</code> - The calculation is running.</p> <p> <code>CANCELING</code> - A request to cancel the calculation has been received and the system is working to stop it.</p> <p> <code>CANCELED</code> - The calculation is no longer running as the result of a cancel request.</p> <p> <code>COMPLETED</code> - The calculation has completed without error.</p> <p> <code>FAILED</code> - The calculation failed and is no longer running.</p>",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "CREATING",
                "CREATED",
                "QUEUED",
                "RUNNING",
                "CANCELING",
                "CANCELED",
                "COMPLETED",
                "FAILED"
              ]
            },
            "StateChangeReason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1024
            }
          }
        }
      }
    }
- Column: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
