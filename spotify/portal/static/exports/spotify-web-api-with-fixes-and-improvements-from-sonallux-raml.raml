    get:
      securedBy:
      - oauth_2_0
      description: >
        Get Spotify catalog information for a single artist identified by their unique Spotify ID.
      responses:
        '200':
          description: An artist
          body:
            application/json:
              schema: |
                {
                  "id": "ArtistObject",
                  "title": "ArtistObject",
                  "type": "object",
                  "properties": {
                    "external_urls": {
                      "id": "ExternalUrlObject",
                      "title": "ExternalUrlObject",
                      "description": "Known external URLs for this artist.",
                      "type": "object",
                      "properties": {
                        "spotify": {
                          "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                          "type": "string"
                        }
                      }
                    },
                    "followers": {
                      "id": "FollowersObject",
                      "title": "FollowersObject",
                      "description": "Information about the followers of the artist.",
                      "type": "object",
                      "properties": {
                        "href": {
                          "description": "This will always be set to null, as the Web API does not support it at the moment.",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "total": {
                          "description": "The total number of followers.",
                          "type": "integer",
                          "format": "int32"
                        }
                      }
                    },
                    "genres": {
                      "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                      "example": [
                        "Prog rock",
                        "Grunge"
                      ],
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "href": {
                      "description": "A link to the Web API endpoint providing full details of the artist.",
                      "type": "string"
                    },
                    "id": {
                      "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                      "type": "string"
                    },
                    "images": {
                      "description": "Images of the artist in various sizes, widest first.",
                      "type": "array",
                      "items": {
                        "id": "ImageObject",
                        "title": "ImageObject",
                        "type": "object",
                        "properties": {
                          "url": {
                            "description": "The source URL of the image.",
                            "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                            "type": "string"
                          },
                          "height": {
                            "description": "The image height in pixels.",
                            "example": 300,
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "width": {
                            "description": "The image width in pixels.",
                            "example": 300,
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          }
                        },
                        "required": [
                          "url",
                          "height",
                          "width"
                        ]
                      }
                    },
                    "name": {
                      "description": "The name of the artist.",
                      "type": "string"
                    },
                    "popularity": {
                      "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                      "type": "integer",
                      "format": "int32"
                    },
                    "type": {
                      "title": "Type",
                      "description": "The object type.",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "artist"
                      ]
                    },
                    "uri": {
                      "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                      "type": "string"
                    }
                  }
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
  get:
    securedBy:
    - oauth_2_0
    description: >
      Get Spotify catalog information for several artists based on their Spotify IDs.
    queryParameters:
      ids:
        type: string
        example: 2CIMQHirSU0MQqyYHq0eOx,57dN52uHvrHOxijzpIgu3E,1vCWHaC5f2uS3yhpwWbIA6
        required: true
        displayName: ids
    responses:
      '200':
        description: A set of artists
        body:
          application/json:
            schema: |
              {
                "id": "ManyArtists",
                "title": "ManyArtists",
                "type": "object",
                "properties": {
                  "artists": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "ArtistObject",
                      "title": "ArtistObject",
                      "type": "object",
                      "properties": {
                        "external_urls": {
                          "id": "ExternalUrlObject",
                          "title": "ExternalUrlObject",
                          "description": "Known external URLs for this artist.",
                          "type": "object",
                          "properties": {
                            "spotify": {
                              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                              "type": "string"
                            }
                          }
                        },
                        "followers": {
                          "id": "FollowersObject",
                          "title": "FollowersObject",
                          "description": "Information about the followers of the artist.",
                          "type": "object",
                          "properties": {
                            "href": {
                              "description": "This will always be set to null, as the Web API does not support it at the moment.",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "total": {
                              "description": "The total number of followers.",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
                        },
                        "genres": {
                          "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                          "example": [
                            "Prog rock",
                            "Grunge"
                          ],
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the artist.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                          "type": "string"
                        },
                        "images": {
                          "description": "Images of the artist in various sizes, widest first.",
                          "type": "array",
                          "items": {
                            "id": "ImageObject",
                            "title": "ImageObject",
                            "type": "object",
                            "properties": {
                              "url": {
                                "description": "The source URL of the image.",
                                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                "type": "string"
                              },
                              "height": {
                                "description": "The image height in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              },
                              "width": {
                                "description": "The image width in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              }
                            },
                            "required": [
                              "url",
                              "height",
                              "width"
                            ]
                          }
                        },
                        "name": {
                          "description": "The name of the artist.",
                          "type": "string"
                        },
                        "popularity": {
                          "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "type": {
                          "title": "Type",
                          "description": "The object type.",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "artist"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "artists"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/audiobooks:
  /{id}:
    uriParameters:
      id:
        type: string
        example: 7iHfbu1YPACw6oZPAFJtqe
        required: true
        displayName: id
    /chapters:
      uriParameters: {}
      get:
        securedBy:
        - oauth_2_0
        description: >
          Get Spotify catalog information about an audiobook's chapters. Audiobooks are only available within the US, UK, Canada, Ireland, New Zealand and Australia markets.
        queryParameters:
          market:
            type: string
            example: ES
            required: false
            displayName: market
          limit:
            type: integer
            example: '10'
            default: '20'
            required: false
            displayName: limit
            minimum: '1'
            maximum: '50'
          offset:
            type: integer
            example: '5'
            default: '0'
            required: false
            displayName: offset
        responses:
          '200':
            description: Pages of chapters
            body:
              application/json:
                schema: |
                  {
                    "id": "PagingSimplifiedChapterObject",
                    "title": "PagingSimplifiedChapterObject",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "A link to the Web API endpoint returning the full result of the request",
                        "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                        "type": "string"
                      },
                      "limit": {
                        "description": "The maximum number of items in the response (as set in the query or by default).",
                        "example": 20,
                        "type": "integer",
                        "format": "int32"
                      },
                      "next": {
                        "description": "URL to the next page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "offset": {
                        "description": "The offset of the items returned (as set in the query or by default)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "previous": {
                        "description": "URL to the previous page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "total": {
                        "description": "The total number of items available to return.",
                        "example": 4,
                        "type": "integer",
                        "format": "int32"
                      },
                      "items": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "ChapterBase",
                          "title": "ChapterBase",
                          "type": "object",
                          "properties": {
                            "audio_preview_url": {
                              "description": "A URL to a 30 second preview (MP3 format) of the chapter. `null` if not available.",
                              "example": "https://p.scdn.co/mp3-preview/2f37da1d4221f40b9d1a98cd191f4d6f1646ad17",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "chapter_number": {
                              "description": "The number of the chapter",
                              "example": 1,
                              "type": "integer",
                              "format": "int32"
                            },
                            "description": {
                              "description": "A description of the chapter. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
                              "example": "We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.\n",
                              "type": "string"
                            },
                            "html_description": {
                              "description": "A description of the chapter. This field may contain HTML tags.",
                              "example": "<p>We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.</p>\n",
                              "type": "string"
                            },
                            "duration_ms": {
                              "description": "The chapter length in milliseconds.",
                              "example": 1686230,
                              "type": "integer",
                              "format": "int32"
                            },
                            "explicit": {
                              "description": "Whether or not the chapter has explicit content (true = yes it does; false = no it does not OR unknown).",
                              "type": "boolean"
                            },
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "External URLs for this chapter.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the chapter.",
                              "example": "https://api.spotify.com/v1/episodes/5Xt5DXGzch68nYYamXrNxZ",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
                              "example": "5Xt5DXGzch68nYYamXrNxZ",
                              "type": "string"
                            },
                            "images": {
                              "description": "The cover art for the chapter in various sizes, widest first.",
                              "type": "array",
                              "items": {
                                "id": "ImageObject",
                                "title": "ImageObject",
                                "type": "object",
                                "properties": {
                                  "url": {
                                    "description": "The source URL of the image.",
                                    "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                    "type": "string"
                                  },
                                  "height": {
                                    "description": "The image height in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  },
                                  "width": {
                                    "description": "The image width in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "url",
                                  "height",
                                  "width"
                                ]
                              }
                            },
                            "is_playable": {
                              "description": "True if the chapter is playable in the given market. Otherwise false.",
                              "type": "boolean"
                            },
                            "languages": {
                              "description": "A list of the languages used in the chapter, identified by their [ISO 639-1](https://en.wikipedia.org/wiki/ISO_639) code.",
                              "example": [
                                "fr",
                                "en"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "name": {
                              "description": "The name of the chapter.",
                              "example": "Starting Your Own Podcast: Tips, Tricks, and Advice From Anchor Creators\n",
                              "type": "string"
                            },
                            "release_date": {
                              "description": "The date the chapter was first released, for example `\"1981-12-15\"`. Depending on the precision, it might be shown as `\"1981\"` or `\"1981-12\"`.",
                              "example": "1981-12-15",
                              "type": "string"
                            },
                            "release_date_precision": {
                              "title": "ReleaseDatePrecision",
                              "description": "The precision with which `release_date` value is known.",
                              "example": "year",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "year",
                                "month",
                                "day"
                              ]
                            },
                            "type": {
                              "description": "The object type.",
                              "type": "string",
                              "enum": [
                                "episode"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
                              "example": "spotify:episode:0zLhl3WsOCQHbe1BPTiHgr",
                              "type": "string"
                            },
                            "available_markets": {
                              "description": "A list of the countries in which the chapter can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "resume_point": {
                              "id": "ResumePointObject",
                              "title": "ResumePointObject",
                              "description": "The user's most recent position in the chapter. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.",
                              "type": "object",
                              "properties": {
                                "fully_played": {
                                  "description": "Whether or not the episode has been fully played by the user.",
                                  "type": "boolean"
                                },
                                "resume_position_ms": {
                                  "description": "The user's most recent position in the episode in milliseconds.",
                                  "type": "integer",
                                  "format": "int32"
                                }
                              }
                            },
                            "restrictions": {
                              "id": "ChapterRestrictionObject",
                              "title": "ChapterRestrictionObject",
                              "description": "Included in the response when a content restriction is applied.",
                              "type": "object",
                              "properties": {
                                "reason": {
                                  "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n- `payment_required` - Payment is required to play the content item.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                                  "type": "string"
                                }
                              }
                            }
                          },
                          "required": [
                            "audio_preview_url",
                            "chapter_number",
                            "description",
                            "html_description",
                            "duration_ms",
                            "explicit",
                            "external_urls",
                            "href",
                            "id",
                            "images",
                            "is_playable",
                            "languages",
                            "name",
                            "release_date",
                            "release_date_precision",
                            "type",
                            "uri"
                          ]
                        }
                      }
                    },
                    "required": [
                      "href",
                      "limit",
                      "next",
                      "offset",
                      "previous",
                      "total",
                      "items"
                    ]
                  }
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                schema: |
                  {
                    "id": "Unauthorized1",
                    "title": "Unauthorized1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                schema: |
                  {
                    "id": "Forbidden1",
                    "title": "Forbidden1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
                    "id": "TooManyRequests1",
                    "title": "TooManyRequests1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
