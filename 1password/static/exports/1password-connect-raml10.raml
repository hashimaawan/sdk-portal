                              message: file {fileUuid} not found
                              status: 404
                          itemNotFound:
                            displayName: Item not found
                            value:
                              message: item {itemUuid} not found
                              status: 404
                          vaultNotFound:
                            displayName: Vault not found
                            value:
                              message: vault {vaultUuid} not found
                              status: 404
                        displayName: response404
                        description: ''
                        type: ErrorResponse
/activity:
  get:
    displayName: GetApiActivity
    description: ''
    securedBy:
    - ConnectToken
    queryParameters:
      limit:
        required: false
        default: '50'
        example:
          value: 10
        displayName: limit
        description: How many API Events should be retrieved in a single request.
        type: integer
        format: int32
      offset:
        required: false
        default: '0'
        example:
          value: 50
        displayName: offset
        description: How far into the collection of API Events should the response start
        type: integer
        format: int32
    responses:
      '200':
        description: OK
        headers:
          Content-Range:
            example:
              value: 1-50/1134
            displayName: Content-Range
            description: An decription of what part of the collection has been returned as well as the total size.
            type: string
        body:
          application/json:
            displayName: response200
            description: ''
            type: array
            items:
              type: APIRequest
      '401':
        description: Invalid or missing token
        body:
          application/json:
            example:
              value:
                message: Invalid token signature
                status: 401
            displayName: response401
            description: ''
            type: ErrorResponse
/health:
  get:
    displayName: GetServerHealth
    description: ''
    responses:
      '200':
        description: OK
        body:
          application/json:
            examples:
              WaitingForAPIRequest:
                displayName: API server waiting for first authenticated request
                value:
                  dependencies:
                  - service: sync
                    status: TOKEN_NEEDED
                  - message: Connected to./1password.sqlite
                    service: sqlite
                    status: ACTIVE
                  name: 1Password Connect API
                  version: 1.2.1
            displayName: response200
            description: ''
            type: HealthResponse
/heartbeat:
  get:
    displayName: GetHeartbeat
    description: ''
    responses:
      '200':
        description: OK
        body:
          text/plain:
            displayName: response200
            description: ''
            type: string
/metrics:
  get:
    displayName: GetPrometheusMetrics
    description: See Prometheus documentation for a complete data model.
    responses:
      '200':
        description: Successfully returned Prometheus metrics
        body:
          text/plain:
            displayName: response200
            description: ''
            type: string
