    description: The name of a prepared statement that could not be returned.
    type: object
    properties:
      StatementName:
        required: false
        displayName: StatementName
        type: string
        pattern: '[a-zA-Z_][a-zA-Z0-9_@:]{1,256}'
        minLength: 1
        maxLength: 256
      ErrorCode:
        required: false
        displayName: ErrorCode
        type: string
        minLength: 1
        maxLength: 256
      ErrorMessage:
        required: false
        displayName: ErrorMessage
        type: string
  QueryExecution:
    displayName: QueryExecution
    description: Information about a single instance of a query execution.
    type: object
    properties:
      QueryExecutionId:
        required: false
        displayName: QueryExecutionId
        type: string
        pattern: '\S+'
        minLength: 1
        maxLength: 128
      Query:
        required: false
        displayName: Query
        type: string
        minLength: 1
        maxLength: 262144
      StatementType:
        required: false
        displayName: StatementType
        type: string
        enum:
        - DDL
        - DML
        - UTILITY
      ResultConfiguration:
        required: false
        displayName: ResultConfiguration
        type: ResultConfiguration1
      ResultReuseConfiguration:
        required: false
        displayName: ResultReuseConfiguration
        type: ResultReuseConfiguration1
      QueryExecutionContext:
        required: false
        displayName: QueryExecutionContext
        type: QueryExecutionContext1
      Status:
        required: false
        displayName: Status
        type: Status
      Statistics:
        required: false
        displayName: Statistics
        type: Statistics
      WorkGroup:
        required: false
        displayName: WorkGroup
        type: string
        pattern: '[a-zA-Z0-9._-]{1,128}'
      EngineVersion:
        required: false
        displayName: EngineVersion
        type: EngineVersion1
      ExecutionParameters:
        required: false
        displayName: ExecutionParameters
        type: array
        uniqueItems: false
        minItems: 1
        items:
          type: string
          minLength: 1
          maxLength: 1024
      SubstatementType:
        required: false
        displayName: SubstatementType
        type: string
  UnprocessedQueryExecutionId:
    displayName: UnprocessedQueryExecutionId
    description: Describes a query execution that failed to process.
    type: object
    properties:
      QueryExecutionId:
        required: false
        displayName: QueryExecutionId
        type: string
        pattern: '\S+'
        minLength: 1
        maxLength: 128
      ErrorCode:
        required: false
        displayName: ErrorCode
        type: string
        minLength: 1
        maxLength: 256
      ErrorMessage:
        required: false
        displayName: ErrorMessage
        type: string
  CalculationConfiguration:
    displayName: CalculationConfiguration
    description: Contains configuration information for the calculation.
    type: object
    properties:
      CodeBlock:
        required: false
        displayName: CodeBlock
        type: string
        maxLength: 68000
  CalculationResult:
    displayName: CalculationResult
    description: Contains information about an application-specific calculation result.
    type: object
    properties:
      StdOutS3Uri:
        required: false
        displayName: StdOutS3Uri
        type: string
        pattern: ^(https|s3|S3)://([^/]+)/?(.*)$
        maxLength: 1024
      StdErrorS3Uri:
        required: false
        displayName: StdErrorS3Uri
        type: string
        pattern: ^(https|s3|S3)://([^/]+)/?(.*)$
        maxLength: 1024
      ResultS3Uri:
        required: false
        displayName: ResultS3Uri
        type: string
        pattern: ^(https|s3|S3)://([^/]+)/?(.*)$
        maxLength: 1024
      ResultType:
        required: false
        displayName: ResultType
        type: string
        pattern: '\w+\/[-+.\w]+'
        minLength: 1
        maxLength: 256
  CalculationStatistics:
    displayName: CalculationStatistics
    description: Contains statistics for a notebook calculation.
    type: object
    properties:
      DpuExecutionInMillis:
        required: false
        displayName: DpuExecutionInMillis
        type: integer
        format: int32
      Progress:
        required: false
        displayName: Progress
        type: string
        minLength: 1
        maxLength: 1024
  CalculationStatus:
    displayName: CalculationStatus
    description: Contains information about the status of a notebook calculation.
    type: object
    properties:
      SubmissionDateTime:
        required: false
        displayName: SubmissionDateTime
        type: datetime
      CompletionDateTime:
        required: false
        displayName: CompletionDateTime
        type: datetime
      State:
        required: false
        displayName: State
        type: string
        enum:
        - CREATING
        - CREATED
        - QUEUED
        - RUNNING
        - CANCELING
        - CANCELED
        - COMPLETED
        - FAILED
      StateChangeReason:
        required: false
        displayName: StateChangeReason
        type: string
        minLength: 1
        maxLength: 1024
  CalculationSummary:
    displayName: CalculationSummary
    description: Summary information for a notebook calculation.
    type: object
    properties:
      CalculationExecutionId:
        required: false
        displayName: CalculationExecutionId
        type: string
        minLength: 1
        maxLength: 36
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 1
        maxLength: 1024
      Status:
        required: false
        displayName: Status
        type: Status1
  Column:
    displayName: Column
    description: Contains metadata for a column in a table.
    type: object
    properties:
      Name:
        required: true
        displayName: Name
        type: string
        minLength: 1
        maxLength: 128
      Type:
        required: false
        displayName: Type
        type: string
        minLength: 0
        maxLength: 4096
      Comment:
        required: false
        displayName: Comment
        type: string
        minLength: 0
        maxLength: 255
  ColumnInfo:
    displayName: ColumnInfo
    description: Information about the columns in a query execution result.
    type: object
    properties:
      CatalogName:
        required: false
        displayName: CatalogName
        type: string
      SchemaName:
        required: false
        displayName: SchemaName
        type: string
      TableName:
        required: false
        displayName: TableName
        type: string
      Name:
        required: true
        displayName: Name
        type: string
      Label:
        required: false
        displayName: Label
        type: string
      Type:
        required: true
        displayName: Type
        type: string
      Precision:
        required: false
        displayName: Precision
        type: integer
        format: int32
      Scale:
        required: false
        displayName: Scale
        type: integer
        format: int32
      Nullable:
        required: false
        displayName: Nullable
        type: string
        enum:
        - NOT_NULL
        - NULLABLE
        - UNKNOWN
      CaseSensitive:
        required: false
        displayName: CaseSensitive
        type: boolean
  Tag:
    displayName: Tag
    description: 'A label that you assign to a resource. In Athena, a resource can be a workgroup or data catalog. Each tag consists of a key and an optional value, both of which you define. For example, you can use tags to categorize Athena workgroups or data catalogs by purpose, owner, or environment. Use a consistent set of tag keys to make it easier to search and filter workgroups or data catalogs in your account. For best practices, see <a href="https://docs.aws.amazon.com/whitepapers/latest/tagging-best-practices/tagging-best-practices.html">Tagging Best Practices</a>. Tag keys can be from 1 to 128 UTF-8 Unicode characters, and tag values can be from 0 to 256 UTF-8 Unicode characters. Tags can use letters and numbers representable in UTF-8, and the following characters: + - = . _ : / @. Tag keys and values are case-sensitive. Tag keys must be unique per resource. If you specify more than one tag, separate them by commas.'
    type: object
    properties:
      Key:
        required: false
        displayName: Key
        type: string
        minLength: 1
        maxLength: 128
      Value:
        required: false
        displayName: Value
        type: string
        minLength: 0
        maxLength: 256
  WorkGroupConfiguration:
    displayName: WorkGroupConfiguration
    description: The configuration of the workgroup, which includes the location in Amazon S3 where query and calculation results are stored, the encryption option, if any, used for query and calculation results, whether the Amazon CloudWatch Metrics are enabled for the workgroup and whether workgroup settings override query settings, and the data usage limits for the amount of data scanned per query or per workgroup. The workgroup settings override is specified in <code>EnforceWorkGroupConfiguration</code> (true/false) in the <code>WorkGroupConfiguration</code>. See <a>WorkGroupConfiguration$EnforceWorkGroupConfiguration</a>.
    type: object
    properties:
      ResultConfiguration:
        required: false
        displayName: ResultConfiguration
        type: ResultConfiguration1
      EnforceWorkGroupConfiguration:
        required: false
        displayName: EnforceWorkGroupConfiguration
        type: boolean
      PublishCloudWatchMetricsEnabled:
        required: false
        displayName: PublishCloudWatchMetricsEnabled
        type: boolean
      BytesScannedCutoffPerQuery:
        required: false
        displayName: BytesScannedCutoffPerQuery
        type: integer
        minimum: 10000000
        format: int32
      RequesterPaysEnabled:
        required: false
        displayName: RequesterPaysEnabled
        type: boolean
      EngineVersion:
        required: false
        displayName: EngineVersion
        type: EngineVersion1
      AdditionalConfiguration:
        required: false
        displayName: AdditionalConfiguration
        type: string
        minLength: 1
        maxLength: 128
      ExecutionRole:
        required: false
        displayName: ExecutionRole
        type: string
        pattern: ^arn:aws[a-z\-]*:iam::\d{12}:role/?[a-zA-Z_0-9+=,.@\-_/]+$
        minLength: 20
        maxLength: 2048
      CustomerContentEncryptionConfiguration:
        required: false
        displayName: CustomerContentEncryptionConfiguration
        type: CustomerContentEncryptionConfiguration2
      EnableMinimumEncryptionConfiguration:
        required: false
        displayName: EnableMinimumEncryptionConfiguration
        type: boolean
  CustomerContentEncryptionConfiguration:
    displayName: CustomerContentEncryptionConfiguration
    description: Specifies the KMS key that is used to encrypt the user's data stores in Athena.
    type: object
    properties:
      KmsKey:
        required: true
        displayName: KmsKey
        type: string
        pattern: ^arn:aws[a-z\-]*:kms:([a-z0-9\-]+):\d{12}:key/?[a-zA-Z_0-9+=,.@\-_/]+$|^arn:aws[a-z\-]*:kms:([a-z0-9\-]+):\d{12}:alias/?[a-zA-Z_0-9+=,.@\-_/]+$|^alias/[a-zA-Z0-9/_-]+$|[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}
        minLength: 1
        maxLength: 2048
  DataCatalog:
    displayName: DataCatalog
    description: <p>Contains information about a data catalog in an Amazon Web Services account.</p> <note> <p>In the Athena console, data catalogs are listed as "data sources" on the <b>Data sources</b> page under the <b>Data source name</b> column.</p> </note>
    type: object
    properties:
      Name:
        required: true
        displayName: Name
        type: string
        minLength: 1
        maxLength: 256
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 1
        maxLength: 1024
      Type:
        required: true
        displayName: Type
        type: string
        enum:
        - LAMBDA
        - GLUE
        - HIVE
      Parameters:
        required: false
        displayName: Parameters
        type: Parameters
  DataCatalogSummary:
    displayName: DataCatalogSummary
    description: The summary information for the data catalog, which includes its name and type.
    type: object
    properties:
      CatalogName:
        required: false
        displayName: CatalogName
        type: string
        minLength: 1
        maxLength: 256
      Type:
        required: false
        displayName: Type
        type: string
        enum:
        - LAMBDA
        - GLUE
        - HIVE
  Database:
    displayName: Database
    description: Contains metadata information for a database in a data catalog.
    type: object
    properties:
      Name:
        required: true
        displayName: Name
        type: string
        minLength: 1
        maxLength: 128
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 1
        maxLength: 1024
      Parameters:
        required: false
        displayName: Parameters
        type: Parameters
  Datum:
    displayName: Datum
    description: A piece of data (a field in the table).
    type: object
    properties:
      VarCharValue:
        required: false
        displayName: VarCharValue
        type: string
  EncryptionConfiguration:
    displayName: EncryptionConfiguration
    description: If query and calculation results are encrypted in Amazon S3, indicates the encryption option used (for example, <code>SSE_KMS</code> or <code>CSE_KMS</code>) and key information.
    type: object
    properties:
      EncryptionOption:
        required: true
        displayName: EncryptionOption
        type: string
        enum:
        - SSE_S3
        - SSE_KMS
        - CSE_KMS
      KmsKey:
        required: false
        displayName: KmsKey
        type: string
  EngineConfiguration:
    displayName: EngineConfiguration
    description: Contains data processing unit (DPU) configuration settings and parameter mappings for a notebook engine.
    type: object
    properties:
      CoordinatorDpuSize:
        required: false
        displayName: CoordinatorDpuSize
        type: integer
        minimum: 1
        maximum: 1
        format: int32
      MaxConcurrentDpus:
        required: true
        displayName: MaxConcurrentDpus
        type: integer
        minimum: 2
        maximum: 5000
        format: int32
      DefaultExecutorDpuSize:
        required: false
        displayName: DefaultExecutorDpuSize
        type: integer
        minimum: 1
        maximum: 1
        format: int32
      AdditionalConfigs:
        required: false
        displayName: AdditionalConfigs
        type: AdditionalConfigs
  EngineVersion:
    displayName: EngineVersion
    description: The Athena engine version for running queries, or the PySpark engine version for running sessions.
    type: object
    properties:
      SelectedEngineVersion:
        required: false
        displayName: SelectedEngineVersion
        type: string
        minLength: 1
        maxLength: 128
      EffectiveEngineVersion:
        required: false
        displayName: EffectiveEngineVersion
        type: string
        minLength: 1
        maxLength: 128
  ExecutorsSummary:
    displayName: ExecutorsSummary
    description: Contains summary information about an executor.
    type: object
    properties:
      ExecutorId:
        required: true
        displayName: ExecutorId
        type: string
        pattern: .*
        maxLength: 100000
      ExecutorType:
        required: false
        displayName: ExecutorType
        type: string
        enum:
        - COORDINATOR
        - GATEWAY
        - WORKER
      StartDateTime:
        required: false
        displayName: StartDateTime
        type: integer
        format: int32
      TerminationDateTime:
        required: false
        displayName: TerminationDateTime
        type: integer
        format: int32
      ExecutorState:
        required: false
        displayName: ExecutorState
        type: string
        enum:
        - CREATING
        - CREATED
        - REGISTERED
        - TERMINATING
        - TERMINATED
        - FAILED
      ExecutorSize:
        required: false
        displayName: ExecutorSize
        type: integer
        format: int32
  NotebookMetadata:
    displayName: NotebookMetadata
    description: Contains metadata for notebook, including the notebook name, ID, workgroup, and time created.
    type: object
    properties:
      NotebookId:
        required: false
        displayName: NotebookId
        type: string
        pattern: '[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}'
        minLength: 1
        maxLength: 36
      Name:
        required: false
        displayName: Name
        type: string
        minLength: 1
        maxLength: 255
      WorkGroup:
        required: false
        displayName: WorkGroup
        type: string
        pattern: '[a-zA-Z0-9._-]{1,128}'
      CreationTime:
        required: false
        displayName: CreationTime
        type: datetime
      Type:
        required: false
        displayName: Type
        type: string
        enum:
        - IPYNB
      LastModifiedTime:
        required: false
        displayName: LastModifiedTime
        type: datetime
  FilterDefinition:
    displayName: FilterDefinition
    description: A string for searching notebook names.
    type: object
    properties:
      Name:
        required: false
        displayName: Name
        type: string
        minLength: 1
        maxLength: 255
  ResultSet:
    displayName: ResultSet
    description: The metadata and rows that make up a query result set. The metadata describes the column structure and data types. To return a <code>ResultSet</code> object, use <a>GetQueryResults</a>.
    type: object
    properties:
      Rows:
        required: false
        displayName: Rows
        type: array
        items:
          type: Row
      ResultSetMetadata:
        required: false
        displayName: ResultSetMetadata
        type: ResultSetMetadata2
  QueryRuntimeStatistics:
    displayName: QueryRuntimeStatistics
    description: The query execution timeline, statistics on input and output rows and bytes, and the different query stages that form the query execution plan.
    type: object
    properties:
      Timeline:
        required: false
        displayName: Timeline
        description: Timeline statistics such as query queue time, planning time, execution time, service processing time, and total execution time.
        type: QueryRuntimeStatisticsTimeline
      Rows:
        required: false
        displayName: Rows
        description: Statistics such as input rows and bytes read by the query, rows and bytes output by the query, and the number of rows written by the query.
        type: QueryRuntimeStatisticsRows
      OutputStage:
        required: false
        displayName: OutputStage
        type: OutputStage
  SessionConfiguration:
    displayName: SessionConfiguration
    description: Contains session configuration information.
    type: object
    properties:
      ExecutionRole:
        required: false
        displayName: ExecutionRole
        type: string
        pattern: ^arn:aws[a-z\-]*:iam::\d{12}:role/?[a-zA-Z_0-9+=,.@\-_/]+$
        minLength: 20
        maxLength: 2048
      WorkingDirectory:
        required: false
        displayName: WorkingDirectory
        type: string
      IdleTimeoutSeconds:
        required: false
        displayName: IdleTimeoutSeconds
        type: integer
        format: int32
      EncryptionConfiguration:
        required: false
        displayName: EncryptionConfiguration
        description: If query and calculation results are encrypted in Amazon S3, indicates the encryption option used (for example, <code>SSE_KMS</code> or <code>CSE_KMS</code>) and key information.
        type: EncryptionConfiguration
  SessionStatus:
    displayName: SessionStatus
    description: Contains information about the status of a session.
    type: object
    properties:
      StartDateTime:
        required: false
        displayName: StartDateTime
        type: datetime
      LastModifiedDateTime:
        required: false
        displayName: LastModifiedDateTime
        type: datetime
      EndDateTime:
        required: false
        displayName: EndDateTime
        type: datetime
      IdleSinceDateTime:
        required: false
        displayName: IdleSinceDateTime
        type: datetime
      State:
        required: false
        displayName: State
        type: string
        enum:
        - CREATING
        - CREATED
        - IDLE
        - BUSY
        - TERMINATING
        - TERMINATED
        - DEGRADED
        - FAILED
      StateChangeReason:
        required: false
        displayName: StateChangeReason
        type: string
        minLength: 1
        maxLength: 1024
  SessionStatistics:
    displayName: SessionStatistics
    description: Contains statistics for a session.
    type: object
    properties:
      DpuExecutionInMillis:
        required: false
        displayName: DpuExecutionInMillis
        type: integer
        format: int32
  TableMetadata:
    displayName: TableMetadata
    description: Contains metadata for a table.
    type: object
    properties:
      Name:
        required: true
        displayName: Name
        type: string
        minLength: 1
        maxLength: 128
      CreateTime:
        required: false
        displayName: CreateTime
        type: datetime
      LastAccessTime:
        required: false
        displayName: LastAccessTime
        type: datetime
      TableType:
        required: false
        displayName: TableType
        type: string
        maxLength: 255
      Columns:
        required: false
        displayName: Columns
        type: array
        items:
          type: Column
      PartitionKeys:
        required: false
        displayName: PartitionKeys
        type: array
        items:
          type: Column
      Parameters:
        required: false
        displayName: Parameters
        type: Parameters
  WorkGroup:
    displayName: WorkGroup
    description: A workgroup, which contains a name, description, creation time, state, and other configuration, listed under <a>WorkGroup$Configuration</a>. Each workgroup enables you to isolate queries for you or your group of users from other queries in the same account, to configure the query results location and the encryption configuration (known as workgroup settings), to enable sending query metrics to Amazon CloudWatch, and to establish per-query data usage control limits for all queries in a workgroup. The workgroup settings override is specified in <code>EnforceWorkGroupConfiguration</code> (true/false) in the <code>WorkGroupConfiguration</code>. See <a>WorkGroupConfiguration$EnforceWorkGroupConfiguration</a>.
    type: object
    properties:
      Name:
        required: true
        displayName: Name
        type: string
        pattern: '[a-zA-Z0-9._-]{1,128}'
      State:
        required: false
        displayName: State
        type: string
        enum:
        - ENABLED
        - DISABLED
      Configuration:
        required: false
        displayName: Configuration
        type: Configuration
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 0
        maxLength: 1024
      CreationTime:
        required: false
        displayName: CreationTime
        type: datetime
  NotebookSessionSummary:
    displayName: NotebookSessionSummary
    description: Contains the notebook session ID and notebook session creation time.
    type: object
    properties:
      SessionId:
        required: false
        displayName: SessionId
        type: string
        minLength: 1
        maxLength: 256
      CreationTime:
        required: false
        displayName: CreationTime
        type: datetime
  PreparedStatementSummary:
    displayName: PreparedStatementSummary
    description: The name and last modified time of the prepared statement.
    type: object
    properties:
      StatementName:
        required: false
        displayName: StatementName
        type: string
        pattern: '[a-zA-Z_][a-zA-Z0-9_@:]{1,256}'
        minLength: 1
        maxLength: 256
      LastModifiedTime:
        required: false
        displayName: LastModifiedTime
        type: datetime
  SessionSummary:
    displayName: SessionSummary
    description: Contains summary information about a session.
    type: object
    properties:
      SessionId:
        required: false
        displayName: SessionId
        type: string
        minLength: 1
        maxLength: 256
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 1
        maxLength: 1024
      EngineVersion:
        required: false
        displayName: EngineVersion
        type: EngineVersion1
      NotebookVersion:
        required: false
        displayName: NotebookVersion
        type: string
        minLength: 1
        maxLength: 128
      Status:
        required: false
        displayName: Status
        type: Status3
  WorkGroupSummary:
    displayName: WorkGroupSummary
    description: The summary information for the workgroup, which includes its name, state, description, and the date and time it was created.
    type: object
    properties:
      Name:
        required: false
        displayName: Name
        type: string
        pattern: '[a-zA-Z0-9._-]{1,128}'
      State:
        required: false
        displayName: State
        type: string
        enum:
        - ENABLED
        - DISABLED
      Description:
        required: false
        displayName: Description
        type: string
        minLength: 0
        maxLength: 1024
      CreationTime:
        required: false
        displayName: CreationTime
        type: datetime
      EngineVersion:
        required: false
        displayName: EngineVersion
        type: EngineVersion1
  ResultConfiguration:
    displayName: ResultConfiguration
    description: The location in Amazon S3 where query and calculation results are stored and the encryption option, if any, used for query and calculation results. These are known as "client-side settings". If workgroup settings override client-side settings, then the query uses the workgroup settings.
    type: object
    properties:
      OutputLocation:
        required: false
        displayName: OutputLocation
        type: string
      EncryptionConfiguration:
        required: false
        displayName: EncryptionConfiguration
        type: EncryptionConfiguration2
      ExpectedBucketOwner:
        required: false
        displayName: ExpectedBucketOwner
        type: string
        pattern: ^[0-9]+$
        minLength: 12
        maxLength: 12
      AclConfiguration:
        required: false
        displayName: AclConfiguration
        type: AclConfiguration1
  ResultReuseConfiguration:
    displayName: ResultReuseConfiguration
    description: Specifies the query result reuse behavior for the query.
    type: object
    properties:
      ResultReuseByAgeConfiguration:
        required: false
        displayName: ResultReuseByAgeConfiguration
        type: ResultReuseByAgeConfiguration2
  QueryExecutionContext:
    displayName: QueryExecutionContext
    description: The database and data catalog context in which the query execution occurs.
    type: object
    properties:
      Database:
        required: false
        displayName: Database
        type: string
        minLength: 1
        maxLength: 255
      Catalog:
        required: false
        displayName: Catalog
        type: string
        minLength: 1
        maxLength: 256
  QueryExecutionStatus:
    displayName: QueryExecutionStatus
    description: The completion date, current state, submission time, and state change reason (if applicable) for the query execution.
    type: object
    properties:
      State:
        required: false
        displayName: State
        type: string
        enum:
        - QUEUED
        - RUNNING
        - SUCCEEDED
        - FAILED
        - CANCELLED
      StateChangeReason:
        required: false
        displayName: StateChangeReason
        type: string
      SubmissionDateTime:
        required: false
        displayName: SubmissionDateTime
        type: datetime
      CompletionDateTime:
        required: false
        displayName: CompletionDateTime
        type: datetime
      AthenaError:
        required: false
        displayName: AthenaError
        type: AthenaError2
  QueryExecutionStatistics:
    displayName: QueryExecutionStatistics
    description: The amount of data scanned during the query execution and the amount of time that it took to execute, and the type of statement that was run.
    type: object
    properties:
      EngineExecutionTimeInMillis:
        required: false
        displayName: EngineExecutionTimeInMillis
        type: integer
        format: int32
      DataScannedInBytes:
        required: false
        displayName: DataScannedInBytes
        type: integer
        format: int32
      DataManifestLocation:
        required: false
        displayName: DataManifestLocation
        type: string
      TotalExecutionTimeInMillis:
        required: false
        displayName: TotalExecutionTimeInMillis
        type: integer
        format: int32
      QueryQueueTimeInMillis:
        required: false
        displayName: QueryQueueTimeInMillis
        type: integer
        format: int32
      QueryPlanningTimeInMillis:
        required: false
        displayName: QueryPlanningTimeInMillis
        type: integer
        format: int32
      ServiceProcessingTimeInMillis:
        required: false
        displayName: ServiceProcessingTimeInMillis
        type: integer
        format: int32
      ResultReuseInformation:
        required: false
        displayName: ResultReuseInformation
        type: ResultReuseInformation2
  ResultReuseInformation:
    displayName: ResultReuseInformation
    description: Contains information about whether the result of a previous query was reused.
    type: object
    properties:
      ReusedPreviousResult:
        required: true
        displayName: ReusedPreviousResult
        type: boolean
  QueryRuntimeStatisticsTimeline:
    displayName: QueryRuntimeStatisticsTimeline
    description: Timeline statistics such as query queue time, planning time, execution time, service processing time, and total execution time.
    type: object
    properties:
      QueryQueueTimeInMillis:
        required: false
        displayName: QueryQueueTimeInMillis
        type: integer
        format: int32
      QueryPlanningTimeInMillis:
        required: false
        displayName: QueryPlanningTimeInMillis
        type: integer
        format: int32
      EngineExecutionTimeInMillis:
        required: false
        displayName: EngineExecutionTimeInMillis
        type: integer
        format: int32
      ServiceProcessingTimeInMillis:
        required: false
        displayName: ServiceProcessingTimeInMillis
        type: integer
        format: int32
      TotalExecutionTimeInMillis:
        required: false
        displayName: TotalExecutionTimeInMillis
        type: integer
        format: int32
  QueryRuntimeStatisticsRows:
    displayName: QueryRuntimeStatisticsRows
    description: Statistics such as input rows and bytes read by the query, rows and bytes output by the query, and the number of rows written by the query.
    type: object
    properties:
      InputRows:
        required: false
        displayName: InputRows
        type: integer
        format: int32
      InputBytes:
        required: false
        displayName: InputBytes
        type: integer
        format: int32
