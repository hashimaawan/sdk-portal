                    application/json:
                      examples:
                        fileTooLarge:
                          displayName: File too large
                          value:
                            message: File is too large to inline in request. Use the /v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content endpoint instead.
                            status: 413
                      displayName: response413
                      description: ''
                      type: ErrorResponse
            /content:
              get:
                displayName: DownloadFileByID
                description: ''
                securedBy:
                - ConnectToken
                responses:
                  '200':
                    description: Success
                    headers:
