          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the Server (must be unique per Project and a valid hostname as per RFC 1123)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="outgoing_traffic" nillable="true" type="xs:double">
            <xs:annotation>
              <xs:documentation>Outbound Traffic for the current billing period in bytes</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="placement_group" nillable="true" type="schemas:PlacementGroupNullable" />
          <xs:element minOccurs="1" name="primary_disk_size" type="xs:double">
            <xs:annotation>
              <xs:documentation>Size of the primary Disk</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="private_net" type="schemas:PrivateNet4">
            <xs:annotation>
              <xs:documentation>Private networks information</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="protection" type="schemas:Protection20">
            <xs:annotation>
              <xs:documentation>Protection configuration for the Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="public_net" type="schemas:PublicNet4">
            <xs:annotation>
              <xs:documentation>Public network information. The Server's IPv4 address can be found in `public_net-&gt;ipv4-&gt;ip`</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="rescue_enabled" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>True if rescue mode is enabled. Server will then boot into rescue system on next reboot</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="server_type" type="schemas:ServerType1">
            <xs:annotation>
              <xs:documentation>Type of Server - determines how much ram, disk and cpu a Server has</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="status" type="schemas:Status73">
            <xs:annotation>
              <xs:documentation>Status of the Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="volumes" type="xs:integer">
            <xs:annotation>
              <xs:documentation>IDs of Volumes assigned to this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Datacenter6">
        <xs:annotation>
          <xs:documentation>Datacenter this Resource is located at</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>Description of the Datacenter</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="location" type="schemas:Location" />
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique identifier of the Datacenter</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="server_types" type="schemas:ServerTypes">
            <xs:annotation>
              <xs:documentation>The Server types the Datacenter can handle</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Iso2">
        <xs:annotation>
          <xs:documentation>ISO Image that is attached to this Server. Null if no ISO is attached.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="deprecated" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>ISO 8601 timestamp of deprecation, null if ISO is still available. After the deprecation time it will no longer be possible to attach the ISO to Servers.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>Description of the ISO</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique identifier of the ISO. Only set for public ISOs</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="type" type="schemas:Type26">
            <xs:annotation>
              <xs:documentation>Type of the ISO</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PlacementGroupNullable">
        <xs:sequence>
          <xs:element minOccurs="1" name="created" type="xs:string">
            <xs:annotation>
              <xs:documentation>Point in time when the Resource was created (in ISO-8601 format)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="labels" type="xs:string">
            <xs:annotation>
              <xs:documentation>User-defined labels (key-value pairs)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the Resource. Must be unique per Project.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="servers" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Array of IDs of Servers that are part of this Placement Group</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" fixed="spread" name="type" type="xs:string">
            <xs:annotation>
              <xs:documentation>Type of the Placement Group</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PrivateNet4">
        <xs:sequence>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="alias_ips" type="xs:string" />
          <xs:element minOccurs="0" name="ip" type="xs:string" />
          <xs:element minOccurs="0" name="mac_address" type="xs:string" />
          <xs:element minOccurs="0" name="network" type="xs:integer" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Protection20">
        <xs:annotation>
          <xs:documentation>Protection configuration for the Server</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="delete" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>If true, prevents the Server from being deleted</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="rebuild" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>If true, prevents the Server from being rebuilt</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PublicNet4">
        <xs:annotation>
          <xs:documentation>Public network information. The Server's IPv4 address can be found in `public_net-&gt;ipv4-&gt;ip`</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="firewalls" type="schemas:ServerPublicNetFirewall">
            <xs:annotation>
              <xs:documentation>Firewalls applied to the public network interface of this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="floating_ips" type="xs:integer">
            <xs:annotation>
              <xs:documentation>IDs of Floating IPs assigned to this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ipv4" nillable="true" type="schemas:Ipv44">
            <xs:annotation>
              <xs:documentation>IP address (v4) and its reverse DNS entry of this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ipv6" nillable="true" type="schemas:Ipv64">
            <xs:annotation>
              <xs:documentation>IPv6 network assigned to this Server and its reverse DNS entry</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServerPublicNetFirewall">
        <xs:sequence>
          <xs:element minOccurs="0" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="status" type="schemas:Status72">
            <xs:annotation>
              <xs:documentation>Status of the Firewall on the Server</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="Status72">
        <xs:annotation>
          <xs:documentation>Status of the Firewall on the Server</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="applied" />
          <xs:enumeration value="pending" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="Ipv44">
        <xs:annotation>
          <xs:documentation>IP address (v4) and its reverse DNS entry of this Server</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="blocked" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>If the IP is blocked by our anti abuse dept</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="dns_ptr" type="xs:string">
            <xs:annotation>
              <xs:documentation>Reverse DNS PTR entry for the IPv4 addresses of this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ip" type="xs:string">
            <xs:annotation>
              <xs:documentation>IP address (v4) of this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Ipv64">
        <xs:annotation>
          <xs:documentation>IPv6 network assigned to this Server and its reverse DNS entry</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="blocked" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>If the IP is blocked by our anti abuse dept</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="dns_ptr" nillable="true" type="schemas:DnsPtr8">
            <xs:annotation>
              <xs:documentation>Reverse DNS PTR entries for the IPv6 addresses of this Server, `null` by default</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ip" type="xs:string">
            <xs:annotation>
              <xs:documentation>IP address (v6) of this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="DnsPtr8">
        <xs:sequence>
          <xs:element minOccurs="1" name="dns_ptr" type="xs:string">
            <xs:annotation>
              <xs:documentation>DNS pointer for the specific IP address</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ip" type="xs:string">
            <xs:annotation>
              <xs:documentation>Single IPv6 address of this Server for which the reverse DNS entry has been set up</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServerType1">
        <xs:annotation>
          <xs:documentation>Type of Server - determines how much ram, disk and cpu a Server has</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="cores" type="xs:double">
            <xs:annotation>
              <xs:documentation>Number of cpu cores a Server of this type will have</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="cpu_type" type="schemas:CpuType">
            <xs:annotation>
              <xs:documentation>Type of cpu</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="deprecated" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>True if Server type is deprecated</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>Description of the Server type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="disk" type="xs:double">
            <xs:annotation>
              <xs:documentation>Disk size a Server of this type will have in GB</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Server type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="memory" type="xs:double">
            <xs:annotation>
              <xs:documentation>Memory a Server of this type will have in GB</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique identifier of the Server type</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="prices" type="schemas:Price9">
            <xs:annotation>
              <xs:documentation>Prices in different Locations</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="storage_type" type="schemas:StorageType">
            <xs:annotation>
              <xs:documentation>Type of Server boot drive. Local has higher speed. Network has better availability.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="Status73">
        <xs:annotation>
          <xs:documentation>Status of the Server</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="running" />
          <xs:enumeration value="initializing" />
          <xs:enumeration value="starting" />
          <xs:enumeration value="stopping" />
          <xs:enumeration value="off" />
          <xs:enumeration value="deleting" />
          <xs:enumeration value="migrating" />
          <xs:enumeration value="rebuilding" />
          <xs:enumeration value="unknown" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="CreateServerRequest">
        <xs:sequence>
          <xs:element minOccurs="0" name="automount" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Auto-mount Volumes after attach</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="datacenter" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID or name of Datacenter to create Server in (must not be used together with location)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="firewalls" type="schemas:Firewall4">
            <xs:annotation>
              <xs:documentation>Firewalls which should be applied on the Server's public network interface at creation time</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="image" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID or name of the Image the Server is created from</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="labels">
            <xs:annotation>
              <xs:documentation>User-defined labels (key-value pairs)</xs:documentation>
            </xs:annotation>
            <xs:complexType>
              <xs:sequence>
                <xs:any />
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element minOccurs="0" name="location" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID or name of Location to create Server in (must not be used together with datacenter)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the Server to create (must be unique per Project and a valid hostname as per RFC 1123)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="networks" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Network IDs which should be attached to the Server private network interface at the creation time</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="placement_group" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Placement Group the server should be in</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="public_net" type="schemas:PublicNet5">
            <xs:annotation>
              <xs:documentation>Public Network options</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="server_type" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID or name of the Server type this Server should be created with</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="ssh_keys" type="xs:string">
            <xs:annotation>
              <xs:documentation>SSH key IDs (`integer`) or names (`string`) which should be injected into the Server at creation time</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="start_after_create" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Start Server right after creation. Defaults to true.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="user_data" type="xs:string">
            <xs:annotation>
              <xs:documentation>Cloud-Init user data to use during Server creation. This field is limited to 32KiB.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="volumes" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Volume IDs which should be attached to the Server at the creation time. Volumes must be in the same Location.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Firewall4">
        <xs:sequence>
          <xs:element minOccurs="0" name="firewall" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Firewall</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PublicNet5">
        <xs:annotation>
          <xs:documentation>Public Network options</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="enable_ipv4" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Attach an IPv4 on the public NIC. If false, no IPv4 address will be attached. Defaults to true.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="enable_ipv6" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Attach an IPv6 on the public NIC. If false, no IPv6 address will be attached. Defaults to true.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="ipv4" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the ipv4 Primary IP to use. If omitted and enable_ipv4 is true, a new ipv4 Primary IP will automatically be created.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="ipv6" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the ipv6 Primary IP to use. If omitted and enable_ipv6 is true, a new ipv6 Primary IP will automatically be created.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="CreateServerResponse">
        <xs:sequence>
          <xs:element minOccurs="1" name="action" type="schemas:Action" />
          <xs:element minOccurs="1" maxOccurs="unbounded" name="next_actions" type="schemas:Action" />
          <xs:element minOccurs="1" name="root_password" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Root password when no SSH keys have been specified</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="server" type="schemas:Server18" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServersResponse1">
        <xs:sequence>
          <xs:element minOccurs="0" name="action" type="schemas:Action" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServersResponse2">
        <xs:sequence>
          <xs:element minOccurs="0" name="server" type="schemas:Server18" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="UpdateServerRequest">
        <xs:sequence>
          <xs:element minOccurs="0" name="labels">
            <xs:annotation>
              <xs:documentation>User-defined labels (key-value pairs)</xs:documentation>
            </xs:annotation>
            <xs:complexType>
              <xs:sequence>
                <xs:any />
              </xs:sequence>
            </xs:complexType>
          </xs:element>
          <xs:element minOccurs="0" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>New name to set</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="AddToPlacementGroupRequest">
        <xs:sequence>
          <xs:element minOccurs="1" name="placement_group" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of Placement Group the Server should be added to</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServersActionsAttachIsoRequest">
        <xs:sequence>
          <xs:element minOccurs="1" name="iso" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID or name of ISO to attach to the Server as listed in GET `/isos`</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="AttachToNetworkRequest">
        <xs:sequence>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="alias_ips" type="xs:string">
            <xs:annotation>
              <xs:documentation>Additional IPs to be assigned to this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="ip" type="xs:string">
            <xs:annotation>
              <xs:documentation>IP to request to be assigned to this Server; if you do not provide this then you will be auto assigned an IP address</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="network" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of an existing network to attach the Server to</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServersActionsChangeAliasIpsRequest">
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="alias_ips" type="xs:string">
            <xs:annotation>
              <xs:documentation>New alias IPs to set for this Server</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="network" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of an existing Network already attached to the Server</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ServersActionsChangeDnsPtrRequest">
