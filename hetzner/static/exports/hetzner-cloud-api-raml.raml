                            "cpu_type": {
                              "title": "CpuType",
                              "description": "Type of cpu",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "shared",
                                "dedicated"
                              ]
                            },
                            "deprecated": {
                              "description": "True if Server type is deprecated",
                              "example": false,
                              "type": "boolean"
