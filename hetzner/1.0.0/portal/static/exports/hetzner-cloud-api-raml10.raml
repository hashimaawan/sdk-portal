    properties:
      placement_group:
        required: true
        displayName: placement_group
        type: PlacementGroup
  UpdatePlacementGroupRequest:
    displayName: UpdatePlacementGroupRequest
    type: object
    properties:
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: false
        example:
          value: my Placement Group
        displayName: name
        description: New PlacementGroup name
        type: string
  PricingResponse:
    displayName: PricingResponse
    type: object
    properties:
      pricing:
        required: true
        displayName: pricing
        type: Pricing
  Pricing:
    displayName: Pricing
    type: object
    properties:
      currency:
        required: true
        example:
          value: EUR
        displayName: currency
        description: Currency the returned prices are expressed in, coded according to ISO 4217
        type: string
      floating_ip:
        required: true
        displayName: floating_ip
        description: The cost of one Floating IP per month
        type: FloatingIp4
      floating_ips:
        required: true
        displayName: floating_ips
        description: Costs of Floating IPs types per Location and type
        type: array
        items:
          type: FloatingIp5
      image:
        required: true
        displayName: image
        description: The cost of Image per GB/month
        type: Image3
      load_balancer_types:
        required: true
        displayName: load_balancer_types
        description: Costs of Load Balancer types per Location and type
        type: array
        items:
          type: LoadBalancerType6
      primary_ips:
        required: true
        displayName: primary_ips
        description: Costs of Primary IPs types per Location
        type: array
        items:
          type: PrimaryIp
      server_backup:
        required: true
        displayName: server_backup
        description: Will increase base Server costs by specific percentage
        type: ServerBackup
      server_types:
        required: true
        displayName: server_types
        description: Costs of Server types per Location and type
        type: array
        items:
          type: ServerTypes2
      traffic:
        required: true
        displayName: traffic
        description: The cost of additional traffic per TB
        type: Traffic
      vat_rate:
        required: true
        example:
          value: '19.000000'
        displayName: vat_rate
        description: The VAT rate used for calculating prices with VAT
        type: string
      volume:
        required: true
        displayName: volume
        description: The cost of Volume per GB/month
        type: Volume
  FloatingIp4:
    displayName: FloatingIp4
    description: The cost of one Floating IP per month
    type: object
    properties:
      price_monthly:
        required: true
        displayName: price_monthly
        type: PriceMonthly6
  PriceMonthly6:
    displayName: PriceMonthly6
    type: object
    properties:
