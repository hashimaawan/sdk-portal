            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="resume_point" type="schemas:ResumePointObject">
            <xs:annotation>
              <xs:documentation>The user's most recent position in the episode. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" fixed="episode" name="type" type="xs:string">
            <xs:annotation>
              <xs:documentation>The object type.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="uri" type="xs:string">
            <xs:annotation>
