                "delete": {
                  "description": "If true, prevents the Resource from being deleted",
                  "example": false,
                  "type": "boolean"
                }
              },
              "required": [
                "delete"
              ]
            },
            "public_net": {
              "id": "PublicNet",
              "title": "PublicNet",
              "description": "Public network information",
