                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
