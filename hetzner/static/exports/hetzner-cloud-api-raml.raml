                            "started": {
                              "description": "Point in time when the Action was started (in ISO-8601 format)",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": "string"
                            },
                            "status": {
                              "title": "Status",
                              "description": "Status of the Action",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "success",
                                "running",
                                "error"
                              ]
                            }
                          },
                          "required": [
                            "command",
                            "error",
                            "finished",
                            "id",
                            "progress",
                            "resources",
                            "started",
                            "status"
                          ]
                        }
                      },
                      "required": [
                        "action"
                      ]
                    }
                  example: '{"action":{"command":"add_subnet","error":{"code":"action_failed","message":"Action failed"},"finished":"2016-01-30T23:56:00+00:00","id":13,"progress":100,"resources":[{"id":4711,"type":"network"}],"started":"2016-01-30T23:55:00+00:00","status":"success"}}'
      get:
        description: Returns all Action objects for a Network. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.
        queryParameters:
          sort:
            description: Can be used multiple times.
            required: false
            displayName: sort
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            required: false
            displayName: status
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                schema: |
                  {
                    "id": "ActionsResponse",
                    "title": "ActionsResponse",
                    "example": {
                      "actions": [
                        {
                          "command": "add_subnet",
                          "error": {
                            "code": "action_failed",
                            "message": "Action failed"
                          },
                          "finished": "2016-01-30T23:56:00+00:00",
                          "id": 13,
                          "progress": 100,
                          "resources": [
                            {
                              "id": 42,
                              "type": "server"
                            }
                          ],
                          "started": "2016-01-30T23:55:00+00:00",
                          "status": "success"
                        }
                      ]
                    },
                    "type": "object",
                    "properties": {
                      "actions": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "Action",
                          "title": "Action",
                          "type": "object",
                          "properties": {
                            "command": {
                              "description": "Command executed in the Action",
                              "example": "start_server",
                              "type": "string"
                            },
                            "error": {
                              "id": "Error",
                              "title": "Error",
                              "description": "Error message for the Action if error occurred, otherwise null",
                              "type": [
                                "object",
                                "null"
                              ],
                              "properties": {
                                "code": {
                                  "description": "Fixed machine readable code",
                                  "example": "action_failed",
                                  "type": "string"
                                },
                                "message": {
                                  "description": "Humanized error message",
                                  "example": "Action failed",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "code",
                                "message"
                              ]
                            },
                            "finished": {
                              "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "id": {
                              "description": "ID of the Resource",
                              "example": 42,
                              "type": "integer",
                              "format": "int32"
                            },
                            "progress": {
                              "description": "Progress of Action in percent",
                              "example": 100,
                              "type": "number"
                            },
                            "resources": {
                              "description": "Resources the Action relates to",
                              "type": "array",
                              "items": {
                                "id": "Resource",
                                "title": "Resource",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Resource",
                                    "example": 42,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "type": {
                                    "description": "Type of resource referenced",
                                    "example": "server",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "id",
                                  "type"
                                ]
                              }
                            },
                            "started": {
                              "description": "Point in time when the Action was started (in ISO-8601 format)",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": "string"
                            },
                            "status": {
                              "title": "Status",
                              "description": "Status of the Action",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "success",
                                "running",
                                "error"
                              ]
                            }
                          },
                          "required": [
                            "command",
                            "error",
                            "finished",
                            "id",
                            "progress",
                            "resources",
                            "started",
                            "status"
                          ]
                        }
                      },
                      "meta": {
                        "id": "Meta",
                        "title": "Meta",
                        "type": "object",
                        "properties": {
                          "pagination": {
                            "id": "Pagination",
                            "title": "Pagination",
                            "type": "object",
                            "properties": {
                              "last_page": {
                                "description": "ID of the last page available. Can be null if the current page is the last one.",
                                "example": 4,
