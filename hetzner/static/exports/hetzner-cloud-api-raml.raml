                        "longitude": 12.370071,
                        "name": "fsn1",
                        "network_zone": "eu-central"
                      },
                      "name": "database-storage",
                      "protection": {
                        "delete": false
                      },
                      "server": 12,
                      "size": 42,
                      "status": "available"
                    }
                  },
                  "type": "object",
                  "properties": {
                    "volume": {
                      "id": "Volume1",
