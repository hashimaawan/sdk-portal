                    "id": 42,
                    "ip": "131.232.99.1",
                    "labels": {
                      "labelkey": "value"
                    },
                    "name": "my-ip",
                    "protection": {
                      "delete": false
                    },
                    "type": "ipv4"
                  }
                },
                "type": "object",
                "properties": {
                  "primary_ip": {
                    "id": "PrimaryIP1",
