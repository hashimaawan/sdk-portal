  post:
    description: >
      Creates a new PlacementGroup.
    headers:
      Content-Type:
        example: application/json
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "CreatePlacementGroupRequest",
            "title": "CreatePlacementGroupRequest",
            "examples": [
              {
                "Id": "spread",
                "Name": "Creating a type `spread` Placement Group",
                "Value": "{\"name\":\"my Placement Group\",\"type\":\"spread\"}",
                "ExternalValue": null,
                "Description": null
              }
            ],
            "example": {
              "name": "my Placement Group",
              "type": "spread"
            },
            "type": "object",
            "properties": {
              "name": {
                "description": "Name of the PlacementGroup",
                "example": "my Placement Group",
                "type": "string"
              },
              "type": {
                "description": "Define the Placement Group Type.",
                "example": "spread",
                "type": "string",
                "enum": [
                  "spread"
                ]
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object"
              }
            },
            "required": [
              "name",
              "type"
            ]
          }
        example: '{"name":"my Placement Group","type":"spread"}'
    responses:
      '201':
        description: The `PlacementGroup` key contains the PlacementGroup that was just created.
        body:
          application/json:
            schema: |
              {
                "id": "CreatePlacementGroupResponse",
                "title": "CreatePlacementGroupResponse",
                "examples": [
                  {
                    "Id": "spread",
                    "Name": "Response when creating a type `spread` PlacementGroup",
                    "Value": "{\"placement_group\":{\"created\":\"2019-01-08T12:10:00+00:00\",\"id\":897,\"labels\":{\"key\":\"value\"},\"name\":\"my Placement Group\",\"servers\":[],\"type\":\"spread\"}}",
                    "ExternalValue": null,
                    "Description": null
                  }
                ],
                "example": {
                  "placement_group": {
                    "created": "2019-01-08T12:10:00+00:00",
                    "id": 897,
                    "labels": {
                      "key": "value"
                    },
                    "name": "my Placement Group",
                    "servers": [],
                    "type": "spread"
                  }
                },
                "type": "object",
                "properties": {
                  "placement_group": {
                    "id": "PlacementGroup",
                    "title": "PlacementGroup",
                    "type": "object",
                    "properties": {
                      "created": {
                        "description": "Point in time when the Resource was created (in ISO-8601 format)",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": "string"
                      },
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "labels": {
                        "description": "User-defined labels (key-value pairs)",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "name": {
                        "description": "Name of the Resource. Must be unique per Project.",
                        "example": "my-resource",
                        "type": "string"
                      },
                      "servers": {
                        "description": "Array of IDs of Servers that are part of this Placement Group",
                        "example": [
                          42
                        ],
                        "type": "array",
                        "items": {
                          "type": "integer",
                          "format": "int32"
                        }
                      },
                      "type": {
                        "description": "Type of the Placement Group",
                        "example": "spread",
                        "type": "string",
                        "enum": [
                          "spread"
                        ]
                      }
                    },
                    "required": [
                      "created",
                      "id",
                      "labels",
                      "name",
                      "servers",
                      "type"
                    ]
                  },
                  "action": {
                    "id": "NullableAction",
                    "title": "NullableAction",
                    "type": [
                      "object",
                      "null"
                    ],
                    "properties": {
                      "command": {
                        "description": "Command executed in the Action",
                        "example": "start_server",
                        "type": "string"
                      },
                      "error": {
                        "id": "Error",
                        "title": "Error",
                        "description": "Error message for the Action if error occurred, otherwise null",
                        "type": [
                          "object",
                          "null"
                        ],
                        "properties": {
                          "code": {
                            "description": "Fixed machine readable code",
                            "example": "action_failed",
                            "type": "string"
                          },
                          "message": {
                            "description": "Humanized error message",
                            "example": "Action failed",
                            "type": "string"
                          }
                        },
                        "required": [
                          "code",
                          "message"
                        ]
                      },
                      "finished": {
                        "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "progress": {
                        "description": "Progress of Action in percent",
                        "example": 100,
                        "type": "number"
                      },
                      "resources": {
                        "description": "Resources the Action relates to",
                        "type": "array",
                        "items": {
                          "id": "Resource",
                          "title": "Resource",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "ID of the Resource",
                              "example": 42,
                              "type": "integer",
                              "format": "int32"
                            },
                            "type": {
                              "description": "Type of resource referenced",
                              "example": "server",
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "type"
                          ]
                        }
                      },
                      "started": {
                        "description": "Point in time when the Action was started (in ISO-8601 format)",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": "string"
                      },
                      "status": {
                        "title": "Status",
                        "description": "Status of the Action",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "success",
                          "running",
                          "error"
                        ]
                      }
                    },
                    "required": [
                      "command",
                      "error",
                      "finished",
                      "id",
                      "progress",
                      "resources",
                      "started",
                      "status"
                    ]
                  }
                },
                "required": [
                  "placement_group"
                ]
              }
            example: '{"placement_group":{"created":"2019-01-08T12:10:00+00:00","id":897,"labels":{"key":"value"},"name":"my Placement Group","servers":[],"type":"spread"}}'
/pricing:
  get:
    description: >
      Returns prices for all resources available on the platform. VAT and currency of the Project owner are used for calculations.


      Both net and gross prices are included in the response.
    responses:
      '200':
        description: The `pricing` key in the reply contains an pricing object with this structure
        body:
          application/json:
            schema: |
              {
                "id": "PricingResponse",
                "title": "PricingResponse",
                "type": "object",
                "properties": {
                  "pricing": {
                    "id": "Pricing",
                    "title": "Pricing",
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "currency": {
                        "description": "Currency the returned prices are expressed in, coded according to ISO 4217",
                        "example": "EUR",
                        "type": "string"
                      },
                      "floating_ip": {
                        "id": "FloatingIp4",
                        "title": "FloatingIp4",
                        "description": "The cost of one Floating IP per month",
                        "type": "object",
                        "properties": {
                          "price_monthly": {
                            "id": "PriceMonthly6",
                            "title": "PriceMonthly6",
                            "type": "object",
                            "properties": {
                              "gross": {
                                "description": "Price with VAT added",
                                "example": "1.1900000000000000",
                                "type": "string"
                              },
                              "net": {
                                "description": "Price without VAT",
                                "example": "1.0000000000",
                                "type": "string"
                              }
                            },
                            "required": [
                              "gross",
                              "net"
                            ]
                          }
                        },
                        "required": [
                          "price_monthly"
                        ]
                      },
                      "floating_ips": {
                        "description": "Costs of Floating IPs types per Location and type",
                        "type": "array",
                        "items": {
                          "id": "FloatingIp5",
                          "title": "FloatingIp5",
                          "type": "object",
                          "properties": {
                            "prices": {
                              "description": "Floating IP type costs per Location",
                              "type": "array",
                              "items": {
                                "id": "Price6",
                                "title": "Price6",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly7",
                                    "title": "PriceMonthly7",
                                    "description": "Monthly costs for a Floating IP type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_monthly"
                                ]
                              }
                            },
                            "type": {
                              "title": "Type48",
                              "description": "The type of the Floating IP",
                              "example": "ipv4",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "ipv4",
                                "ipv6"
                              ]
                            }
                          },
                          "required": [
                            "prices",
                            "type"
                          ]
                        }
                      },
                      "image": {
                        "id": "Image3",
                        "title": "Image3",
                        "description": "The cost of Image per GB/month",
                        "type": "object",
                        "properties": {
                          "price_per_gb_month": {
                            "id": "PricePerGbMonth",
                            "title": "PricePerGbMonth",
                            "type": "object",
                            "properties": {
                              "gross": {
                                "description": "Price with VAT added",
                                "example": "1.1900000000000000",
                                "type": "string"
                              },
                              "net": {
                                "description": "Price without VAT",
                                "example": "1.0000000000",
                                "type": "string"
                              }
                            },
                            "required": [
                              "gross",
                              "net"
                            ]
                          }
                        },
                        "required": [
                          "price_per_gb_month"
                        ]
                      },
                      "load_balancer_types": {
                        "description": "Costs of Load Balancer types per Location and type",
                        "type": "array",
                        "items": {
                          "id": "LoadBalancerType6",
                          "title": "LoadBalancerType6",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "ID of the Load Balancer type the price is for",
                              "example": 1,
                              "type": "number"
                            },
                            "name": {
                              "description": "Name of the Load Balancer type the price is for",
                              "example": "lb11",
                              "type": "string"
                            },
                            "prices": {
                              "description": "Load Balancer type costs per Location",
                              "type": "array",
                              "items": {
                                "id": "Price7",
                                "title": "Price7",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly6",
                                    "title": "PriceHourly6",
                                    "description": "Hourly costs for a Load Balancer type in this network zone",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly8",
                                    "title": "PriceMonthly8",
                                    "description": "Monthly costs for a Load Balancer type in this network zone",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            }
                          },
                          "required": [
                            "id",
                            "name",
                            "prices"
                          ]
                        }
                      },
                      "primary_ips": {
                        "description": "Costs of Primary IPs types per Location",
                        "type": "array",
                        "items": {
                          "id": "PrimaryIp",
                          "title": "PrimaryIp",
                          "type": "object",
                          "properties": {
                            "prices": {
                              "description": "Primary IP type costs per Location",
                              "type": "array",
                              "items": {
                                "id": "Price8",
                                "title": "Price8",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly7",
                                    "title": "PriceHourly7",
                                    "description": "Hourly costs for a Primary IP type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly9",
                                    "title": "PriceMonthly9",
                                    "description": "Monthly costs for a Primary IP type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            },
                            "type": {
                              "title": "Type49",
                              "description": "The type of the Primary IP",
                              "example": "ipv4",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "ipv4",
                                "ipv6"
                              ]
                            }
                          },
                          "required": [
                            "prices",
                            "type"
                          ]
                        }
                      },
                      "server_backup": {
                        "id": "ServerBackup",
                        "title": "ServerBackup",
                        "description": "Will increase base Server costs by specific percentage",
                        "type": "object",
                        "properties": {
                          "percentage": {
                            "description": "Percentage by how much the base price will increase",
                            "example": "20.0000000000",
                            "type": "string"
                          }
                        },
                        "required": [
                          "percentage"
                        ]
                      },
                      "server_types": {
                        "description": "Costs of Server types per Location and type",
                        "type": "array",
                        "items": {
                          "id": "ServerTypes2",
                          "title": "ServerTypes2",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "ID of the Server type the price is for",
                              "example": 4,
                              "type": "number"
                            },
                            "name": {
                              "description": "Name of the Server type the price is for",
                              "example": "cx11",
                              "type": "string"
                            },
                            "prices": {
                              "description": "Server type costs per Location",
                              "type": "array",
                              "items": {
                                "id": "Price9",
                                "title": "Price9",
                                "type": "object",
                                "properties": {
                                  "location": {
                                    "description": "Name of the Location the price is for",
                                    "example": "fsn1",
                                    "type": "string"
                                  },
                                  "price_hourly": {
                                    "id": "PriceHourly8",
                                    "title": "PriceHourly8",
                                    "description": "Hourly costs for a Server type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  },
                                  "price_monthly": {
                                    "id": "PriceMonthly10",
                                    "title": "PriceMonthly10",
                                    "description": "Monthly costs for a Server type in this Location",
                                    "type": "object",
                                    "properties": {
                                      "gross": {
                                        "description": "Price with VAT added",
                                        "example": "1.1900000000000000",
                                        "type": "string"
                                      },
                                      "net": {
                                        "description": "Price without VAT",
                                        "example": "1.0000000000",
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "gross",
                                      "net"
                                    ]
                                  }
                                },
                                "required": [
                                  "location",
                                  "price_hourly",
                                  "price_monthly"
                                ]
                              }
                            }
                          },
                          "required": [
                            "id",
                            "name",
                            "prices"
                          ]
                        }
                      },
                      "traffic": {
                        "id": "Traffic",
                        "title": "Traffic",
                        "description": "The cost of additional traffic per TB",
                        "type": "object",
                        "properties": {
                          "price_per_tb": {
                            "id": "PricePerTb",
                            "title": "PricePerTb",
                            "type": "object",
                            "properties": {
                              "gross": {
                                "description": "Price with VAT added",
                                "example": "1.1900000000000000",
                                "type": "string"
                              },
                              "net": {
                                "description": "Price without VAT",
                                "example": "1.0000000000",
                                "type": "string"
                              }
                            },
                            "required": [
                              "gross",
                              "net"
                            ]
                          }
                        },
                        "required": [
                          "price_per_tb"
                        ]
                      },
                      "vat_rate": {
                        "description": "The VAT rate used for calculating prices with VAT",
                        "example": "19.000000",
                        "type": "string"
                      },
                      "volume": {
                        "id": "Volume",
                        "title": "Volume",
                        "description": "The cost of Volume per GB/month",
                        "type": "object",
                        "properties": {
                          "price_per_gb_month": {
                            "$ref": "PricePerGbMonth"
                          }
                        },
                        "required": [
                          "price_per_gb_month"
                        ]
                      }
                    },
                    "required": [
                      "currency",
                      "floating_ip",
                      "floating_ips",
                      "image",
                      "load_balancer_types",
                      "primary_ips",
                      "server_backup",
                      "server_types",
                      "traffic",
                      "vat_rate",
                      "volume"
                    ]
                  }
                },
                "required": [
                  "pricing"
                ]
              }
/servers:
  /{id}:
    uriParameters:
      id:
        description: ID of the Server
        type: integer
        required: true
        displayName: id
    /metrics:
      uriParameters: {}
      get:
        description: >
          Get Metrics for specified Server.


          You must specify the type of metric to get: cpu, disk or network. You can also specify more than one type by comma separation, e.g. cpu,disk.


          Depending on the type you will get different time series data


          | Type    | Timeseries              | Unit      | Description                                          |

          |---------|-------------------------|-----------|------------------------------------------------------|

          | cpu     | cpu                     | percent   | Percent CPU usage                                    |

          | disk    | disk.0.iops.read        | iop/s     | Number of read IO operations per second              |

          |         | disk.0.iops.write       | iop/s     | Number of write IO operations per second             |

          |         | disk.0.bandwidth.read   | bytes/s   | Bytes read per second                                |

          |         | disk.0.bandwidth.write  | bytes/s   | Bytes written per second                             |

          | network | network.0.pps.in        | packets/s | Public Network interface packets per second received |

          |         | network.0.pps.out       | packets/s | Public Network interface packets per second sent     |

          |         | network.0.bandwidth.in  | bytes/s   | Public Network interface bytes/s received            |

          |         | network.0.bandwidth.out | bytes/s   | Public Network interface bytes/s sent                |


          Metrics are available for the last 30 days only.


          If you do not provide the step argument we will automatically adjust it so that a maximum of 200 samples are returned.


          We limit the number of samples returned to a maximum of 500 and will adjust the step parameter accordingly.
        queryParameters:
          type:
            description: Type of metrics to get
            required: true
            displayName: type
            enum:
            - cpu
            - disk
            - network
          start:
            description: Start of period to get Metrics for (in ISO-8601 format)
            type: string
            required: true
            displayName: start
          end:
            description: End of period to get Metrics for (in ISO-8601 format)
            type: string
            required: true
            displayName: end
          step:
            description: Resolution of results in seconds
            type: string
            required: false
            displayName: step
        responses:
          '200':
            description: The `metrics` key in the reply contains a metrics object with this structure
            body:
              application/json:
                schema: |
                  {
                    "id": "ServersMetricsResponse",
                    "title": "ServersMetricsResponse",
                    "type": "object",
                    "properties": {
                      "metrics": {
                        "id": "Metrics",
                        "title": "Metrics",
                        "type": "object",
                        "properties": {
                          "end": {
                            "description": "End of period of metrics reported (in ISO-8601 format)",
                            "example": "2017-01-01T23:00:00+00:00",
                            "type": "string"
                          },
                          "start": {
                            "description": "Start of period of metrics reported (in ISO-8601 format)",
                            "example": "2017-01-01T00:00:00+00:00",
                            "type": "string"
                          },
                          "step": {
                            "description": "Resolution of results in seconds.",
                            "example": 60,
                            "type": "number"
                          },
                          "time_series": {
                            "title": "TimeSeries",
                            "description": "Hash with timeseries information, containing the name of timeseries as key",
                            "example": {
                              "name_of_timeseries": {
                                "values": [
                                  [
                                    1435781470.622,
                                    "42"
                                  ],
                                  [
                                    1435781471.622,
                                    "43"
                                  ]
                                ]
                              }
                            },
                            "type": "object",
                            "additionalProperties": {
                              "id": "TimeSeries",
                              "type": "object",
