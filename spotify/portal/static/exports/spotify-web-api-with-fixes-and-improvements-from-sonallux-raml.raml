- PagingObject: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PagingObject",
      "title": "PagingObject",
      "type": "object",
      "properties": {
        "href": {
          "description": "A link to the Web API endpoint returning the full result of the request",
