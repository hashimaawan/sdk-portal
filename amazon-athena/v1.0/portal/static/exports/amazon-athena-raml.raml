          "items": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    }
- AthenaError: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AthenaError",
      "title": "AthenaError",
      "description": "Provides information about an Athena query error. The <code>AthenaError</code> feature provides standardized error information to help you understand failed queries and take steps after a query failure occurs. <code>AthenaError</code> includes an <code>ErrorCategory</code> field that specifies whether the cause of the failed query is due to system error, user error, or other error.",
      "type": "object",
      "properties": {
        "ErrorCategory": {
          "type": "integer",
          "minimum": 1.0,
          "maximum": 3.0,
          "format": "int32"
        },
        "ErrorType": {
          "type": "integer",
          "minimum": 0.0,
          "maximum": 9999.0,
          "format": "int32"
        },
        "Retryable": {
          "type": "boolean"
        },
        "ErrorMessage": {
          "type": "string"
        }
      }
    }
- NamedQuery: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "NamedQuery",
      "title": "NamedQuery",
      "description": "A query, where <code>QueryString</code> contains the SQL statements that make up the query.",
      "type": "object",
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "Database": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "QueryString": {
          "type": "string",
          "minLength": 1,
          "maxLength": 262144
        },
        "Description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "NamedQueryId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "\\S+"
        },
        "WorkGroup": {
          "type": "string",
          "pattern": "[a-zA-Z0-9._-]{1,128}"
        }
      },
      "required": [
        "Name",
        "Database",
        "QueryString"
      ]
    }
- UnprocessedNamedQueryId: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "UnprocessedNamedQueryId",
