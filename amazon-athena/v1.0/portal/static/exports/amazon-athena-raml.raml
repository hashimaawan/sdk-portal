          "items": {
            "id": "CalculationSummary",
            "title": "CalculationSummary",
            "description": "Summary information for a notebook calculation.",
            "type": "object",
            "properties": {
              "CalculationExecutionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 36
              },
              "Description": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "Status": {
                "id": "Status1",
                "title": "Status1",
