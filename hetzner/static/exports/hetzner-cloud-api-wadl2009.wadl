    <resource id="_placement_groups" path="/placement_groups">
      <method id="GetallPlacementGroups" name="GET">
        <doc title="Get all PlacementGroups" xml:lang="en">Returns all PlacementGroup objects.</doc>
        <request>
          <param name="sort" style="query" default="">
            <doc title="sort" xml:lang="en">Can be used multiple times.</doc>
