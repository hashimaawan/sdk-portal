  /tracks:
    /contains:
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - user-library-read
        description: >
          Check if one or more tracks is already saved in the current Spotify user's 'Your Music' library.
        queryParameters:
          ids:
            type: string
            example: 7ouMYWpwJ422jRcDASZB7P,4VqPOruhp5EdPBeR92t6lQ,2takcwOaAZWiXQijPHIx7B
            required: true
            displayName: ids
        responses:
          '200':
            description: Array of booleans
            body:
              application/json:
                schema: |
                  {
                    "description": "",
                    "example": [
                      false,
                      true
                    ],
                    "type": "array",
                    "items": {
                      "type": "boolean"
                    }
                  }
                example: |
                  [
                    false,
                    true
