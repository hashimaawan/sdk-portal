            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="log_min_duration_statement">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>Log statements that take more than this number of milliseconds to run. If -1, disables.</xs:documentation>
              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="86400000" />
                <xs:minInclusive value="-1" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="0" name="max_files_per_process">
