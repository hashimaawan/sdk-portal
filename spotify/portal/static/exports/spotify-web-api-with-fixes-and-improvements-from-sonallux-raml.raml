                          "type": "object",
                          "properties": {
                            "isrc": {
                              "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                              "type": "string"
                            },
                            "ean": {
                              "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                              "type": "string"
                            },
                            "upc": {
                              "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                              "type": "string"
                            }
                          }
                        },
                        "genres": {
                          "description": "A list of the genres the album is associated with. If not yet classified, the array is empty.",
                          "example": [
                            "Egg punk",
                            "Noise rock"
                          ],
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "label": {
                          "description": "The label associated with the album.",
                          "type": "string"
                        },
                        "popularity": {
                          "description": "The popularity of the album. The value will be between 0 and 100, with 100 being the most popular.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "restrictions": {
                          "id": "AlbumRestrictionObject",
                          "title": "AlbumRestrictionObject",
                          "description": "Included in the response when a content restriction is applied.",
                          "type": "object",
                          "properties": {
                            "reason": {
                              "title": "Reason",
                              "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "market",
                                "product",
                                "explicit"
                              ]
                            }
                          }
                        }
                      },
                      "required": [
                        "album_type",
                        "total_tracks",
                        "available_markets",
                        "external_urls",
                        "href",
                        "id",
                        "images",
                        "name",
                        "release_date",
                        "release_date_precision",
                        "type",
                        "uri",
                        "artists",
                        "tracks",
                        "copyrights",
                        "external_ids",
                        "genres",
                        "label",
                        "popularity"
                      ]
                    }
                  }
                },
                "required": [
                  "albums"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/artists:
  /{id}:
    uriParameters:
      id:
        type: string
        example: 0TnOYISbd1XYRBk9myaseg
        required: true
        displayName: id
    /albums:
      uriParameters: {}
      get:
        securedBy:
        - oauth_2_0
        description: >
          Get Spotify catalog information about an artist's albums.
        queryParameters:
          include_groups:
            type: string
            example: single,appears_on
            required: false
            displayName: include_groups
          market:
            type: string
            example: ES
            required: false
            displayName: market
          limit:
            type: integer
            example: '10'
            default: '20'
            required: false
            displayName: limit
            minimum: '1'
            maximum: '50'
          offset:
            type: integer
            example: '5'
            default: '0'
            required: false
            displayName: offset
        responses:
          '200':
            description: Pages of albums
            body:
              application/json:
                schema: |
                  {
                    "id": "PagingArtistDiscographyAlbumObject",
                    "title": "PagingArtistDiscographyAlbumObject",
                    "type": "object",
                    "properties": {
                      "href": {
                        "description": "A link to the Web API endpoint returning the full result of the request",
                        "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                        "type": "string"
                      },
                      "limit": {
                        "description": "The maximum number of items in the response (as set in the query or by default).",
                        "example": 20,
                        "type": "integer",
                        "format": "int32"
                      },
                      "next": {
                        "description": "URL to the next page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "offset": {
                        "description": "The offset of the items returned (as set in the query or by default)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "previous": {
                        "description": "URL to the previous page of items. ( `null` if none)",
                        "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "total": {
                        "description": "The total number of items available to return.",
                        "example": 4,
                        "type": "integer",
                        "format": "int32"
                      },
                      "items": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "ArtistDiscographyAlbumObject",
                          "title": "ArtistDiscographyAlbumObject",
                          "type": "object",
                          "properties": {
                            "album_type": {
                              "title": "AlbumType",
                              "description": "The type of the album.",
                              "example": "compilation",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "album",
                                "single",
                                "compilation"
                              ]
                            },
                            "total_tracks": {
                              "description": "The number of tracks in the album.",
                              "example": 9,
                              "type": "integer",
                              "format": "int32"
                            },
                            "available_markets": {
                              "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                              "example": [
                                "CA",
                                "BR",
                                "IT"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "Known external URLs for this artist.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the album.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "images": {
                              "description": "The cover art for the album in various sizes, widest first.",
                              "type": "array",
                              "items": {
                                "id": "ImageObject",
                                "title": "ImageObject",
                                "type": "object",
                                "properties": {
                                  "url": {
                                    "description": "The source URL of the image.",
                                    "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                    "type": "string"
                                  },
                                  "height": {
                                    "description": "The image height in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  },
                                  "width": {
                                    "description": "The image width in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "url",
                                  "height",
                                  "width"
                                ]
                              }
                            },
                            "name": {
                              "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                              "type": "string"
                            },
                            "release_date": {
                              "description": "The date the album was first released.",
                              "example": "1981-12",
                              "type": "string"
                            },
                            "release_date_precision": {
                              "title": "ReleaseDatePrecision",
                              "description": "The precision with which `release_date` value is known.",
                              "example": "year",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "year",
                                "month",
                                "day"
                              ]
                            },
                            "type": {
                              "description": "The object type.",
                              "type": "string",
                              "enum": [
                                "album"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "artists": {
                              "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                              "type": "array",
                              "items": {
                                "id": "SimplifiedArtistObject",
                                "title": "SimplifiedArtistObject",
                                "type": "object",
                                "properties": {
                                  "external_urls": {
                                    "$ref": "ExternalUrlObject"
                                  },
                                  "href": {
                                    "description": "A link to the Web API endpoint providing full details of the artist.",
                                    "type": "string"
                                  },
                                  "id": {
                                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  },
                                  "name": {
                                    "description": "The name of the artist.",
                                    "type": "string"
                                  },
                                  "type": {
                                    "title": "Type",
                                    "description": "The object type.",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "artist"
                                    ]
                                  },
                                  "uri": {
                                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  }
                                }
                              }
                            },
                            "album_group": {
                              "title": "AlbumGroup",
                              "description": "This field describes the relationship between the artist and the album.",
                              "example": "compilation",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "album",
                                "single",
                                "compilation",
                                "appears_on"
                              ]
                            },
                            "restrictions": {
                              "id": "AlbumRestrictionObject",
                              "title": "AlbumRestrictionObject",
                              "description": "Included in the response when a content restriction is applied.",
                              "type": "object",
                              "properties": {
                                "reason": {
                                  "title": "Reason",
                                  "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "market",
                                    "product",
                                    "explicit"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "album_type",
                            "total_tracks",
                            "available_markets",
                            "external_urls",
                            "href",
                            "id",
                            "images",
                            "name",
                            "release_date",
                            "release_date_precision",
                            "type",
                            "uri",
                            "artists",
                            "album_group"
                          ]
                        }
                      }
                    },
                    "required": [
                      "href",
                      "limit",
                      "next",
                      "offset",
                      "previous",
                      "total",
                      "items"
                    ]
                  }
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                schema: |
                  {
                    "id": "Unauthorized1",
                    "title": "Unauthorized1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                schema: |
                  {
                    "id": "Forbidden1",
                    "title": "Forbidden1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
                    "id": "TooManyRequests1",
                    "title": "TooManyRequests1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
    /top-tracks:
      uriParameters: {}
      get:
        securedBy:
        - oauth_2_0
        description: >
          Get Spotify catalog information about an artist's top tracks by country.
