    properties:
      StageId:
        required: false
        displayName: StageId
        type: integer
        format: int32
      State:
        required: false
        displayName: State
        type: string
      OutputBytes:
        required: false
        displayName: OutputBytes
        type: integer
        format: int32
      OutputRows:
        required: false
        displayName: OutputRows
        type: integer
        format: int32
      InputBytes:
        required: false
        displayName: InputBytes
        type: integer
        format: int32
      InputRows:
        required: false
        displayName: InputRows
        type: integer
        format: int32
      ExecutionTime:
        required: false
