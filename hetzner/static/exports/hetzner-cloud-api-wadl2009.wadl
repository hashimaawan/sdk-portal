      </xs:complexType>
      <xs:complexType name="LoadBalancer">
        <xs:sequence>
          <xs:element minOccurs="1" name="algorithm" type="schemas:Algorithm">
            <xs:annotation>
              <xs:documentation>Algorithm of the Load Balancer</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="created" type="xs:string">
            <xs:annotation>
              <xs:documentation>Point in time when the Resource was created (in ISO-8601 format)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="included_traffic" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Free Traffic for the current billing period in bytes</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="ingoing_traffic" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Inbound Traffic for the current billing period in bytes</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="labels" type="xs:string">
            <xs:annotation>
              <xs:documentation>User-defined labels (key-value pairs)</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="load_balancer_type" type="schemas:LoadBalancerType" />
          <xs:element minOccurs="1" name="location" type="schemas:Location" />
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the Resource. Must be unique per Project.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="outgoing_traffic" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Outbound Traffic for the current billing period in bytes</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="private_net" type="schemas:PrivateNet">
            <xs:annotation>
              <xs:documentation>Private networks information</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="protection" type="schemas:Protection">
            <xs:annotation>
              <xs:documentation>Protection configuration for the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="public_net" type="schemas:PublicNet">
            <xs:annotation>
              <xs:documentation>Public network information</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="services" type="schemas:LoadBalancerService">
            <xs:annotation>
              <xs:documentation>List of services that belong to this Load Balancer</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="targets" type="schemas:LoadBalancerTarget">
            <xs:annotation>
              <xs:documentation>List of targets that belong to this Load Balancer</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Algorithm">
        <xs:annotation>
          <xs:documentation>Algorithm of the Load Balancer</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="type" type="schemas:Type28">
            <xs:annotation>
              <xs:documentation>Type of the algorithm</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
