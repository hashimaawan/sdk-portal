      "_id": "wrk_ca1dea1c44064b769ac7cb8aaa5574aa",
      "description": "Furkot provides Rest API to access user trip data.\nUsing Furkot API an application can list user trips and display stops for a specific trip.\nFurkot API uses OAuth2 protocol to authorize applications to access data on behalf of users.\n"
    },
    {
      "name": "production",
      "data": {
        "default": "https://trips.furkot.com/pub/api",
        "authserver": "https://trips.furkot.com/oauth"
      },
      "_type": "environment",
      "_id": "env_133e5655416747d29e455fc9683eaf48",
      "parentId": "wrk_ca1dea1c44064b769ac7cb8aaa5574aa"
    },
    {
      "name": "Trip_GET",
      "method": "GET",
      "url": "{{default}}/trip",
      "authentication": {
        "type": "oauth2",
        "accessTokenUrl": "https://trips.furkot.com/pub/api/access_token",
        "authorizationUrl": "https://trips.furkot.com/oauth/authorize",
        "grantType": "authorization_code"
      },
      "_type": "request",
