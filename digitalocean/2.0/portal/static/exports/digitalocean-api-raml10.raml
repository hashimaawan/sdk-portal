        required: true
        displayName: spec
        description: The desired configuration of an application.
        type: AppSpec
  V2CdnEndpointsResponse:
    example:
      value:
        endpoints:
        - certificate_id: 892071a0-bb95-49bc-8021-3afd67a210bf
          created_at: 2018-07-19T15:04:16Z
          custom_domain: static.example.com
          endpoint: static-images.nyc3.cdn.digitaloceanspaces.com
          id: 19f06b6a-3ace-4315-b086-499a0e521b76
          origin: static-images.nyc3.digitaloceanspaces.com
          ttl: 3600
        links: {}
        meta:
          total: 1
    displayName: V2CdnEndpointsResponse
    type: object
    properties:
      endpoints:
        required: false
        displayName: endpoints
        type: array
        items:
          type: Endpoint
      links:
        required: false
        displayName: links
        type: Links
      meta:
        required: true
        displayName: meta
        type: Meta
  Endpoint:
    displayName: Endpoint
    type: object
    properties:
      certificate_id:
        required: false
        example:
          value: 892071a0-bb95-49bc-8021-3afd67a210bf
        displayName: certificate_id
        description: The ID of a DigitalOcean managed TLS certificate used for SSL when a custom subdomain is provided.
        type: any
      created_at:
        required: false
        example:
          value: 2018-03-21T16:02:37Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format that represents when the CDN endpoint was created.
        type: datetime
      custom_domain:
        required: false
        example:
          value: static.example.com
        displayName: custom_domain
        description: The fully qualified domain name (FQDN) of the custom subdomain used with the CDN endpoint.
        type: string
      endpoint:
        required: false
        example:
          value: static-images.nyc3.cdn.digitaloceanspaces.com
        displayName: endpoint
        description: The fully qualified domain name (FQDN) from which the CDN-backed content is served.
        type: string
      id:
        required: false
        example:
          value: 892071a0-bb95-49bc-8021-3afd67a210bf
        displayName: id
        description: A unique ID that can be used to identify and reference a CDN endpoint.
        type: any
      origin:
        required: true
        example:
          value: static-images.nyc3.digitaloceanspaces.com
        displayName: origin
        description: The fully qualified domain name (FQDN) for the origin server which provides the content for the CDN. This is currently restricted to a Space.
        type: string
      ttl:
        required: false
        default: '3600'
        example:
          value: 3600
        displayName: ttl
        description: The amount of time the content is cached by the CDN's edge servers in seconds. TTL must be one of 60, 600, 3600, 86400, or 604800. Defaults to 3600 (one hour) when excluded.
        type: integer
        format: int32
        enum:
        - '60'
        - '600'
        - '3600'
        - '86400'
        - '604800'
  V2CdnEndpointsResponse1:
    displayName: V2CdnEndpointsResponse1
    type: object
    properties:
      endpoint:
        required: false
        displayName: endpoint
        type: Endpoint
  V2CdnEndpointsRequest:
    displayName: V2CdnEndpointsRequest
    type: object
    properties:
      certificate_id:
        required: false
        example:
          value: 892071a0-bb95-49bc-8021-3afd67a210bf
        displayName: certificate_id
        description: The ID of a DigitalOcean managed TLS certificate used for SSL when a custom subdomain is provided.
        type: any
      custom_domain:
        required: false
        example:
          value: static.example.com
        displayName: custom_domain
        description: The fully qualified domain name (FQDN) of the custom subdomain used with the CDN endpoint.
        type: string
      ttl:
        required: false
        default: '3600'
        example:
          value: 3600
        displayName: ttl
        description: The amount of time the content is cached by the CDN's edge servers in seconds. TTL must be one of 60, 600, 3600, 86400, or 604800. Defaults to 3600 (one hour) when excluded.
        type: integer
        format: int32
        enum:
        - '60'
        - '600'
        - '3600'
        - '86400'
        - '604800'
  V2CdnEndpointsCacheRequest:
    displayName: V2CdnEndpointsCacheRequest
    type: object
    properties:
      files:
        required: true
        example:
          value:
          - path/to/image.png
          - path/to/css/*
        displayName: files
        description: An array of strings containing the path to the content to be purged from the CDN cache.
        type: array
        items:
          type: string
  V2CertificatesResponse:
    displayName: V2CertificatesResponse
    type: object
    properties:
      certificates:
        required: false
        displayName: certificates
        type: array
        items:
          type: Certificate
      links:
        required: false
        displayName: links
        type: Links
      meta:
        required: true
        displayName: meta
        type: Meta
  Certificate:
    displayName: Certificate
    type: object
    properties:
      created_at:
        required: false
        example:
          value: 2017-02-08T16:02:37Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format that represents when the certificate was created.
        type: datetime
      dns_names:
        required: false
        example:
          value:
          - www.example.com
          - example.com
        displayName: dns_names
        description: An array of fully qualified domain names (FQDNs) for which the certificate was issued.
        type: array
        items:
          type: string
      id:
        required: false
        example:
          value: 892071a0-bb95-49bc-8021-3afd67a210bf
        displayName: id
        description: A unique ID that can be used to identify and reference a certificate.
        type: any
      name:
        required: false
        example:
          value: web-cert-01
        displayName: name
        description: A unique human-readable name referring to a certificate.
        type: string
      not_after:
        required: false
        example:
          value: 2017-02-22T00:23:00Z
        displayName: not_after
        description: A time value given in ISO8601 combined date and time format that represents the certificate's expiration date.
        type: datetime
      sha1_fingerprint:
        required: false
        example:
          value: dfcc9f57d86bf58e321c2c6c31c7a971be244ac7
        displayName: sha1_fingerprint
        description: A unique identifier generated from the SHA-1 fingerprint of the certificate.
        type: string
      state:
        required: false
        example:
          value: verified
        displayName: state
        description: A string representing the current state of the certificate. It may be `pending`, `verified`, or `error`.
        type: string
        enum:
        - pending
        - verified
        - error
      type:
        required: false
        example:
          value: lets_encrypt
        displayName: type
        description: A string representing the type of the certificate. The value will be `custom` for a user-uploaded certificate or `lets_encrypt` for one automatically generated with Let's Encrypt.
        type: string
        enum:
        - custom
        - lets_encrypt
  Let'sEncryptCertificateRequest:
    displayName: Let'sEncryptCertificateRequest
    type: object
    properties:
      name:
        required: true
        example:
          value: web-cert-01
        displayName: name
        description: A unique human-readable name referring to a certificate.
        type: string
      type:
        required: false
        example:
          value: lets_encrypt
        displayName: type
        description: A string representing the type of the certificate. The value will be `custom` for a user-uploaded certificate or `lets_encrypt` for one automatically generated with Let's Encrypt.
        type: string
        enum:
        - custom
        - lets_encrypt
      dns_names:
        required: true
        example:
          value:
          - www.example.com
          - example.com
        displayName: dns_names
        description: An array of fully qualified domain names (FQDNs) for which the certificate was issued. A certificate covering all subdomains can be issued using a wildcard (e.g. `*.example.com`).
        type: array
        items:
          type: string
