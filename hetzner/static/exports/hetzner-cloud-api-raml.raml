                                  "description": "Reverse DNS PTR entry for the IPv4 addresses of this Server",
                                  "example": "server01.example.com",
                                  "type": "string"
                                },
                                "ip": {
                                  "description": "IP address (v4) of this Server",
                                  "example": "1.2.3.4",
                                  "type": "string"
                                },
                                "id": {
                                  "description": "ID of the Resource",
                                  "example": 42,
