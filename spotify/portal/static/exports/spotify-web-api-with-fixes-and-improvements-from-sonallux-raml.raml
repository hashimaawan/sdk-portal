                    },
                    "items": {
                      "description": "",
                      "type": "array",
                      "items": {
                        "id": "SavedShowObject",
                        "title": "SavedShowObject",
                        "type": "object",
                        "properties": {
                          "added_at": {
                            "description": "The date and time the show was saved.\nTimestamps are returned in ISO 8601 format as Coordinated Universal Time (UTC) with a zero offset: YYYY-MM-DDTHH:MM:SSZ.\nIf the time is imprecise (for example, the date/time of an album release), an additional field indicates the precision; see for example, release_date in an album object.",
                            "type": "string",
                            "format": "date-time"
                          },
                          "show": {
                            "id": "ShowBase",
                            "title": "ShowBase",
                            "description": "Information about the show.",
                            "type": "object",
                            "properties": {
                              "available_markets": {
                                "description": "A list of the countries in which the show can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "copyrights": {
                                "description": "The copyright statements of the show.",
                                "type": "array",
                                "items": {
                                  "id": "CopyrightObject",
                                  "title": "CopyrightObject",
                                  "type": "object",
                                  "properties": {
                                    "text": {
                                      "description": "The copyright text for this content.",
                                      "type": "string"
                                    },
                                    "type": {
                                      "description": "The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.",
                                      "type": "string"
                                    }
                                  }
                                }
                              },
                              "description": {
                                "description": "A description of the show. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
                                "type": "string"
                              },
                              "html_description": {
                                "description": "A description of the show. This field may contain HTML tags.",
                                "type": "string"
                              },
                              "explicit": {
                                "description": "Whether or not the show has explicit content (true = yes it does; false = no it does not OR unknown).",
                                "type": "boolean"
                              },
                              "external_urls": {
                                "id": "ExternalUrlObject",
                                "title": "ExternalUrlObject",
                                "description": "External URLs for this show.",
                                "type": "object",
                                "properties": {
                                  "spotify": {
                                    "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                    "type": "string"
                                  }
                                }
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the show.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the show.",
                                "type": "string"
                              },
                              "images": {
                                "description": "The cover art for the show in various sizes, widest first.",
                                "type": "array",
                                "items": {
                                  "id": "ImageObject",
                                  "title": "ImageObject",
                                  "type": "object",
                                  "properties": {
                                    "url": {
                                      "description": "The source URL of the image.",
                                      "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                      "type": "string"
                                    },
                                    "height": {
                                      "description": "The image height in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    },
                                    "width": {
                                      "description": "The image width in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    }
                                  },
                                  "required": [
                                    "url",
                                    "height",
                                    "width"
                                  ]
                                }
                              },
                              "is_externally_hosted": {
                                "description": "True if all of the shows episodes are hosted outside of Spotify's CDN. This field might be `null` in some cases.",
                                "type": "boolean"
                              },
                              "languages": {
                                "description": "A list of the languages used in the show, identified by their [ISO 639](https://en.wikipedia.org/wiki/ISO_639) code.",
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "media_type": {
                                "description": "The media type of the show.",
                                "type": "string"
                              },
                              "name": {
                                "description": "The name of the episode.",
                                "type": "string"
                              },
                              "publisher": {
                                "description": "The publisher of the show.",
                                "type": "string"
                              },
                              "type": {
                                "description": "The object type.",
                                "type": "string",
                                "enum": [
                                  "show"
                                ]
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the show.",
                                "type": "string"
                              },
                              "total_episodes": {
                                "description": "The total number of episodes in the show.",
                                "type": "integer",
                                "format": "int32"
                              }
                            },
                            "required": [
                              "available_markets",
                              "copyrights",
                              "description",
                              "html_description",
                              "explicit",
                              "external_urls",
                              "href",
                              "id",
                              "images",
                              "is_externally_hosted",
                              "languages",
                              "media_type",
                              "name",
                              "publisher",
                              "type",
                              "uri",
                              "total_episodes"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "href",
                    "limit",
                    "next",
                    "offset",
                    "previous",
                    "total",
                    "items"
                  ]
                }
    put:
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-modify
      description: >
        Save one or more shows to current Spotify user's library.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      queryParameters:
        ids:
          type: string
          example: 5CfCWKI5pZ28U0uOzXkDHe,5as3aKmN2k11yfDDDSrvaZ
          required: true
          displayName: ids
      body:
        application/json:
          schema: |
            {
              "id": "MeShowsRequest",
              "title": "MeShowsRequest",
              "type": "object",
              "properties": {
                "ids": {
                  "description": "A JSON array of the [Spotify IDs](https://developer.spotify.com/documentation/web-api/#spotify-uris-and-ids).  \nA maximum of 50 items can be specified in one request. *Note: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored.*",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          example: ''
      responses:
        '200':
          description: Show saved
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
