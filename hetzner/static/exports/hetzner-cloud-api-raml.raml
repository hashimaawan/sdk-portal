- LoadBalancersMetricsResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LoadBalancersMetricsResponse",
      "title": "LoadBalancersMetricsResponse",
      "type": "object",
      "properties": {
        "metrics": {
          "id": "Metrics",
          "title": "Metrics",
          "type": "object",
          "properties": {
            "end": {
              "description": "End of period of metrics reported (in ISO-8601 format)",
              "example": "2017-01-01T23:00:00+00:00",
              "type": "string"
            },
            "start": {
              "description": "Start of period of metrics reported (in ISO-8601 format)",
              "example": "2017-01-01T00:00:00+00:00",
              "type": "string"
            },
            "step": {
              "description": "Resolution of results in seconds.",
              "example": 60,
              "type": "number"
            },
            "time_series": {
              "title": "TimeSeries",
              "description": "Hash with timeseries information, containing the name of timeseries as key",
              "example": {
                "name_of_timeseries": {
                  "values": [
                    [
                      1435781470.622,
                      "42"
                    ],
                    [
                      1435781471.622,
                      "43"
                    ]
                  ]
                }
              },
              "type": "object",
              "additionalProperties": {
                "id": "TimeSeries",
                "type": "object",
                "properties": {
                  "values": {
                    "description": "Metrics Timestamps with values",
                    "type": "array",
                    "items": {
                      "type": "array",
                      "items": {
                        "oneOf": [
                          {
                            "type": "number"
                          },
                          {
                            "type": "string"
                          }
                        ]
                      }
                    }
                  }
                },
                "required": [
                  "values"
                ]
              }
            }
          },
          "required": [
            "end",
            "start",
            "step",
            "time_series"
          ]
        }
      },
      "required": [
        "metrics"
      ]
    }
