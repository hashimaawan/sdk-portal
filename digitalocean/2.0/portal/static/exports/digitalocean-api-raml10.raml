/v2:
  /1-clicks:
    get:
      displayName: oneClicks_list
      description: >
        To list all available 1-Click applications, send a GET request to `/v2/1-clicks`. The `type` may

        be provided as query paramater in order to restrict results to a certain type of 1-Click, for

        example: `/v2/1-clicks?type=droplet`. Current supported types are `kubernetes` and `droplet`.


        The response will be a JSON object with a key called `1_clicks`. This will be set to an array of

        1-Click application data, each of which will contain the the slug and type for the 1-Click.
      securedBy:
      - bearer_auth
      queryParameters:
        type:
          required: false
          example:
            value: kubernetes
          displayName: type
          description: Restrict results to a certain type of 1-Click.
          type: string
          enum:
          - droplet
          - kubernetes
      responses:
        '200':
          description: A JSON object with a key of `1_clicks`.
          headers:
            ratelimit-limit:
              example:
                value: 5000
              displayName: ratelimit-limit
              description: The default limit on number of requests that can be made per hour and per minute. Current rate limits are 5000 requests per hour and 250 requests per minute.
              type: integer
              format: int32
            ratelimit-remaining:
              example:
                value: 4816
              displayName: ratelimit-remaining
              description: The number of requests in your hourly quota that remain before you hit your request limit. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
            ratelimit-reset:
              example:
                value: 1444931833
              displayName: ratelimit-reset
              description: The time when the oldest request will expire. The value is given in Unix epoch time. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
          body:
            application/json:
              examples:
                All 1-Click Applications:
                  value:
                    1_clicks:
                    - slug: monitoring
                      type: kubernetes
                    - slug: wordpress-18-04
                      type: droplet
              displayName: response200
              description: ''
              type: V21ClicksResponse
        '401':
          description: Unauthorized
          headers:
            ratelimit-limit:
              example:
                value: 5000
              displayName: ratelimit-limit
              description: The default limit on number of requests that can be made per hour and per minute. Current rate limits are 5000 requests per hour and 250 requests per minute.
              type: integer
              format: int32
            ratelimit-remaining:
              example:
                value: 4816
              displayName: ratelimit-remaining
              description: The number of requests in your hourly quota that remain before you hit your request limit. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
            ratelimit-reset:
              example:
                value: 1444931833
              displayName: ratelimit-reset
              description: The time when the oldest request will expire. The value is given in Unix epoch time. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
          body:
            application/json:
              example:
                value:
                  id: unauthorized
                  message: Unable to authenticate you.
              displayName: response401
              description: ''
              type: V21Clicks401Error1
        '429':
          description: API Rate limit exceeded
          headers:
            ratelimit-limit:
              example:
                value: 5000
              displayName: ratelimit-limit
              description: The default limit on number of requests that can be made per hour and per minute. Current rate limits are 5000 requests per hour and 250 requests per minute.
              type: integer
              format: int32
            ratelimit-remaining:
              example:
                value: 4816
              displayName: ratelimit-remaining
              description: The number of requests in your hourly quota that remain before you hit your request limit. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
            ratelimit-reset:
              example:
                value: 1444931833
              displayName: ratelimit-reset
              description: The time when the oldest request will expire. The value is given in Unix epoch time. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
          body:
            application/json:
              example:
                value:
                  id: too_many_requests
                  message: API Rate limit exceeded.
              displayName: response429
              description: ''
              type: V21Clicks401Error1
        '500':
          description: Server error.
          headers:
            ratelimit-limit:
              example:
                value: 5000
              displayName: ratelimit-limit
              description: The default limit on number of requests that can be made per hour and per minute. Current rate limits are 5000 requests per hour and 250 requests per minute.
              type: integer
              format: int32
            ratelimit-remaining:
              example:
                value: 4816
              displayName: ratelimit-remaining
              description: The number of requests in your hourly quota that remain before you hit your request limit. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
            ratelimit-reset:
              example:
                value: 1444931833
              displayName: ratelimit-reset
              description: The time when the oldest request will expire. The value is given in Unix epoch time. See https://developers.digitalocean.com/documentation/v2/#rate-limit for information about how requests expire.
              type: integer
              format: int32
          body:
