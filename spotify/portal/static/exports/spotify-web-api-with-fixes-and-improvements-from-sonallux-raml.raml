                            "chapter_number",
                            "description",
                            "html_description",
                            "duration_ms",
                            "explicit",
                            "external_urls",
                            "href",
                            "id",
                            "images",
                            "is_playable",
                            "languages",
                            "name",
                            "release_date",
                            "release_date_precision",
                            "type",
                            "uri"
                          ]
                        }
                      }
                    },
                    "required": [
                      "href",
                      "limit",
                      "next",
                      "offset",
                      "previous",
                      "total",
                      "items"
                    ]
                  },
                  "edition": {
                    "description": "The edition of the audiobook.",
                    "example": "Unabridged",
                    "type": "string"
                  }
                },
                "required": [
