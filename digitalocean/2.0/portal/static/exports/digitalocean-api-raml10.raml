          type: Anappdeployment
      links:
        required: false
        displayName: links
        type: Links
      meta:
        required: true
        displayName: meta
        type: Meta
  V2AppsDeploymentsRequest:
    displayName: V2AppsDeploymentsRequest
    type: object
    properties:
      force_build:
        required: false
        example:
          value: true
        displayName: force_build
        type: boolean
  V2AppsDeploymentsResponse1:
    displayName: V2AppsDeploymentsResponse1
    type: object
    properties:
      deployment:
        required: false
        displayName: deployment
        type: Anappdeployment
  V2AppsRollbackRequest:
    displayName: V2AppsRollbackRequest
    type: object
    properties:
      deployment_id:
        required: false
        example:
          value: 3aa4d20e-5527-4c00-b496-601fbd22520a
        displayName: deployment_id
        description: The ID of the deployment to rollback to.
        type: string
      skip_pin:
        required: false
        example:
          value: false
        displayName: skip_pin
        description: Whether to skip pinning the rollback deployment. If false, the rollback deployment will be pinned and any new deployments including Auto Deploy on Push hooks will be disabled until the rollback is either manually committed or reverted via the CommitAppRollback or RevertAppRollback endpoints respectively. If true, the rollback will be immediately committed and the app will remain unpinned.
        type: boolean
  V2AppsRollbackValidateResponse:
    displayName: V2AppsRollbackValidateResponse
    type: object
    properties:
      error:
        required: false
        displayName: error
        type: Error
      valid:
        required: false
        displayName: valid
        description: Indicates whether the app can be rolled back to the specified deployment.
        type: boolean
      warnings:
        required: false
        displayName: warnings
        description: Contains a list of warnings that may cause the rollback to run under unideal circumstances.
        type: array
        items:
          type: Warning
  Error:
    displayName: Error
    type: object
    properties:
      code:
        required: false
        example:
          value: exceeded_revision_limit
        displayName: code
        description: "A code identifier that represents the failing condition.\n\nFailing conditions:\n  - `incompatible_phase` - indicates that the deployment's phase is not suitable for rollback.\n  - `incompatible_result` - indicates that the deployment's result is not suitable for rollback.\n  - `exceeded_revision_limit` - indicates that the app has exceeded the rollback revision limits for its tier.\n  - `app_pinned` - indicates that there is already a rollback in progress and the app is pinned.\n  - `database_config_conflict` - indicates that the deployment's database config is different than the current config.\n  - `region_conflict` - indicates that the deployment's region differs from the current app region.\n  \nWarning conditions:\n  - `static_site_requires_rebuild` - indicates that the deployment contains at least one static site that will require a rebuild.\n  - `image_source_missing_digest` - indicates that the deployment contains at least one component with an image source that is missing a digest."
        type: string
        enum:
        - incompatible_phase
        - incompatible_result
        - exceeded_revision_limit
        - app_pinned
        - database_config_conflict
        - region_conflict
        - static_site_requires_rebuild
        - image_source_missing_digest
      components:
        required: false
        example:
          value:
          - www
        displayName: components
        type: array
        items:
          type: string
      message:
        required: false
        example:
          value: the deployment is past the maximum historical revision limit of 0 for the "starter" app tier
        displayName: message
        description: A human-readable message describing the failing condition.
        type: string
  Warning:
    displayName: Warning
    type: object
    properties:
      code:
        required: false
        example:
          value: exceeded_revision_limit
        displayName: code
        description: "A code identifier that represents the failing condition.\n\nFailing conditions:\n  - `incompatible_phase` - indicates that the deployment's phase is not suitable for rollback.\n  - `incompatible_result` - indicates that the deployment's result is not suitable for rollback.\n  - `exceeded_revision_limit` - indicates that the app has exceeded the rollback revision limits for its tier.\n  - `app_pinned` - indicates that there is already a rollback in progress and the app is pinned.\n  - `database_config_conflict` - indicates that the deployment's database config is different than the current config.\n  - `region_conflict` - indicates that the deployment's region differs from the current app region.\n  \nWarning conditions:\n  - `static_site_requires_rebuild` - indicates that the deployment contains at least one static site that will require a rebuild.\n  - `image_source_missing_digest` - indicates that the deployment contains at least one component with an image source that is missing a digest."
        type: string
        enum:
        - incompatible_phase
        - incompatible_result
        - exceeded_revision_limit
        - app_pinned
        - database_config_conflict
        - region_conflict
        - static_site_requires_rebuild
        - image_source_missing_digest
      components:
        required: false
        example:
          value:
          - www
        displayName: components
        type: array
        items:
          type: string
      message:
        required: false
        example:
          value: the deployment is past the maximum historical revision limit of 0 for the "starter" app tier
        displayName: message
        description: A human-readable message describing the failing condition.
        type: string
  V2AppsResponse2:
    displayName: V2AppsResponse2
    type: object
    properties:
      id:
        required: false
        example:
          value: 4f6c71e2-1e90-4762-9fee-6cc4a0a9f2cf
        displayName: id
        type: string
