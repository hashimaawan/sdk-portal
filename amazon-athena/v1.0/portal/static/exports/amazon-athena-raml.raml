        },
        "LastAccessTime": {
          "type": "string",
          "format": "date-time"
        },
        "TableType": {
          "type": "string",
          "maxLength": 255
        },
        "Columns": {
          "description": "",
          "type": "array",
          "items": {
            "id": "Column",
            "title": "Column",
            "description": "Contains metadata for a column in a table.",
            "type": "object",
            "properties": {
              "Name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "Type": {
                "type": "string",
                "minLength": 0,
                "maxLength": 4096
              },
              "Comment": {
                "type": "string",
                "minLength": 0,
                "maxLength": 255
              }
            },
