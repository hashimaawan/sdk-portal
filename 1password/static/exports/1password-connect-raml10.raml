                        value:
                          message: item {itemUuid} not found
                          status: 404
                      vaultNotFound:
                        displayName: Vault not found
                        value:
                          message: vault {vaultUuid} not found
                          status: 404
                    displayName: response404
                    description: ''
                    type: ErrorResponse
              '413':
                description: File content too large to display
                body:
                  application/json:
                    examples:
                      fileTooLarge:
                        displayName: File too large
                        value:
                          message: File is too large to inline in request. Use the /v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content endpoint instead.
                          status: 413
                    displayName: response413
                    description: ''
