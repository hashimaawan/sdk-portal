                            "id": "PrivateNet4",
                            "title": "PrivateNet4",
                            "type": "object",
                            "properties": {
                              "alias_ips": {
                                "description": "",
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "ip": {
                                "example": "10.0.0.2",
                                "type": "string"
                              },
                              "mac_address": {
                                "example": "86:00:ff:2a:7d:e1",
                                "type": "string"
                              },
                              "network": {
                                "example": 4711,
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          }
                        },
                        "protection": {
                          "id": "Protection20",
                          "title": "Protection20",
                          "description": "Protection configuration for the Server",
                          "type": "object",
                          "properties": {
                            "delete": {
                              "description": "If true, prevents the Server from being deleted",
                              "example": false,
                              "type": "boolean"
