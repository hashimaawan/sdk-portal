</doc>
        <request />
        <response status="201">
          <doc title="201" xml:lang="en">The `action` key contains the `disable_public_interface` Action</doc>
          <representation element="schemas:DisablethepublicinterfaceofaLoadBalancer201_Response0" mediaType="application/json" />
