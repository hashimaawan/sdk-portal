                                "pattern": "^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:key/?[a-zA-Z_0-9+=,.@\\-_/]+$|^arn:aws[a-z\\-]*:kms:([a-z0-9\\-]+):\\d{12}:alias/?[a-zA-Z_0-9+=,.@\\-_/]+$|^alias/[a-zA-Z0-9/_-]+$|[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}"
                              }
                            },
                            "required": [
                              "KmsKey"
                            ]
                          },
                          "EnableMinimumEncryptionConfiguration": {
                            "type": "boolean"
                          }
                        }
                      },
                      "Description": {
                        "type": "string",
                        "minLength": 0,
                        "maxLength": 1024
                      },
                      "CreationTime": {
                        "type": "string",
                        "format": "date-time"
                      }
                    },
                    "required": [
                      "Name"
                    ]
                  }
                }
              }
      '480':
