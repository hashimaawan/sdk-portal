              <xs:documentation>ID of the Resource</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique identifier of the ISO. Only set for public ISOs</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="type" type="schemas:Type26">
            <xs:annotation>
              <xs:documentation>Type of the ISO</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
