                    "type": "string"
                  },
                  "id": {
                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
                    "example": "5Xt5DXGzch68nYYamXrNxZ",
                    "type": "string"
                  },
                  "images": {
                    "description": "The cover art for the chapter in various sizes, widest first.",
                    "type": "array",
                    "items": {
                      "$ref": "ImageObject"
                    }
                  },
                  "is_playable": {
                    "description": "True if the chapter is playable in the given market. Otherwise false.",
                    "type": "boolean"
                  },
                  "languages": {
                    "description": "A list of the languages used in the chapter, identified by their [ISO 639-1](https://en.wikipedia.org/wiki/ISO_639) code.",
                    "example": [
                      "fr",
                      "en"
                    ],
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "name": {
                    "description": "The name of the chapter.",
                    "example": "Starting Your Own Podcast: Tips, Tricks, and Advice From Anchor Creators\n",
                    "type": "string"
                  },
                  "release_date": {
                    "description": "The date the chapter was first released, for example `\"1981-12-15\"`. Depending on the precision, it might be shown as `\"1981\"` or `\"1981-12\"`.",
                    "example": "1981-12-15",
                    "type": "string"
                  },
                  "release_date_precision": {
                    "title": "ReleaseDatePrecision",
                    "description": "The precision with which `release_date` value is known.",
                    "example": "year",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "year",
                      "month",
                      "day"
                    ]
                  },
                  "type": {
                    "description": "The object type.",
                    "type": "string",
                    "enum": [
                      "episode"
                    ]
                  },
                  "uri": {
                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.",
                    "example": "spotify:episode:0zLhl3WsOCQHbe1BPTiHgr",
                    "type": "string"
                  },
                  "available_markets": {
                    "description": "A list of the countries in which the chapter can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "resume_point": {
                    "id": "ResumePointObject",
                    "title": "ResumePointObject",
                    "description": "The user's most recent position in the chapter. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.",
                    "type": "object",
                    "properties": {
                      "fully_played": {
                        "description": "Whether or not the episode has been fully played by the user.",
                        "type": "boolean"
                      },
                      "resume_position_ms": {
                        "description": "The user's most recent position in the episode in milliseconds.",
                        "type": "integer",
                        "format": "int32"
                      }
                    }
                  },
                  "restrictions": {
                    "id": "ChapterRestrictionObject",
                    "title": "ChapterRestrictionObject",
                    "description": "Included in the response when a content restriction is applied.",
                    "type": "object",
                    "properties": {
                      "reason": {
                        "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n- `payment_required` - Payment is required to play the content item.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                        "type": "string"
                      }
                    }
                  }
                },
                "required": [
                  "audio_preview_url",
                  "chapter_number",
                  "description",
                  "html_description",
                  "duration_ms",
                  "explicit",
                  "external_urls",
                  "href",
                  "id",
                  "images",
                  "is_playable",
                  "languages",
                  "name",
                  "release_date",
                  "release_date_precision",
                  "type",
                  "uri"
                ]
              }
            }
          },
          "required": [
            "href",
            "limit",
            "next",
            "offset",
            "previous",
            "total",
            "items"
          ]
        },
        "edition": {
          "description": "The edition of the audiobook.",
          "example": "Unabridged",
          "type": "string"
        }
      },
      "required": [
        "authors",
        "available_markets",
        "copyrights",
        "description",
        "html_description",
        "explicit",
        "external_urls",
        "href",
        "id",
        "images",
        "languages",
        "media_type",
        "name",
        "narrators",
        "publisher",
        "type",
        "uri",
        "total_chapters",
        "chapters"
      ]
    }
- AlbumBase: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AlbumBase",
      "title": "AlbumBase",
      "type": "object",
      "properties": {
        "album_type": {
          "title": "AlbumType",
          "description": "The type of the album.",
          "example": "compilation",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "album",
            "single",
            "compilation"
          ]
        },
        "total_tracks": {
          "description": "The number of tracks in the album.",
          "example": 9,
          "type": "integer",
          "format": "int32"
        },
        "available_markets": {
          "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
          "example": [
            "CA",
            "BR",
            "IT"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_urls": {
          "id": "ExternalUrlObject",
          "title": "ExternalUrlObject",
          "description": "Known external URLs for this album.",
          "type": "object",
          "properties": {
            "spotify": {
              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
              "type": "string"
            }
          }
        },
        "href": {
          "description": "A link to the Web API endpoint providing full details of the album.",
          "type": "string"
        },
        "id": {
          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
          "example": "2up3OPMp9Tb4dAKM2erWXQ",
          "type": "string"
        },
        "images": {
          "description": "The cover art for the album in various sizes, widest first.",
          "type": "array",
          "items": {
            "id": "ImageObject",
            "title": "ImageObject",
            "type": "object",
            "properties": {
              "url": {
                "description": "The source URL of the image.",
                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                "type": "string"
              },
              "height": {
                "description": "The image height in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "width": {
                "description": "The image width in pixels.",
                "example": 300,
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              }
            },
            "required": [
              "url",
              "height",
              "width"
            ]
          }
        },
        "name": {
          "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
          "type": "string"
        },
        "release_date": {
          "description": "The date the album was first released.",
          "example": "1981-12",
          "type": "string"
        },
        "release_date_precision": {
          "title": "ReleaseDatePrecision",
          "description": "The precision with which `release_date` value is known.",
          "example": "year",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "year",
            "month",
            "day"
          ]
        },
        "type": {
          "description": "The object type.",
          "type": "string",
          "enum": [
            "album"
          ]
        },
        "uri": {
          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
          "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
          "type": "string"
        },
        "restrictions": {
          "id": "AlbumRestrictionObject",
          "title": "AlbumRestrictionObject",
          "description": "Included in the response when a content restriction is applied.",
          "type": "object",
          "properties": {
            "reason": {
              "title": "Reason",
              "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "market",
                "product",
                "explicit"
              ]
            }
          }
        }
      },
      "required": [
        "album_type",
        "total_tracks",
        "available_markets",
        "external_urls",
        "href",
        "id",
        "images",
        "name",
        "release_date",
        "release_date_precision",
        "type",
        "uri"
      ]
    }
