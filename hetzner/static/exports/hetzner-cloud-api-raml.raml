          ],
          "format": "int32"
        }
      }
    }
- CreateServerResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CreateServerResponse",
      "title": "CreateServerResponse",
      "type": "object",
      "properties": {
        "action": {
          "id": "Action",
          "title": "Action",
          "type": "object",
          "properties": {
            "command": {
              "description": "Command executed in the Action",
              "example": "start_server",
              "type": "string"
            },
            "error": {
              "id": "Error",
              "title": "Error",
              "description": "Error message for the Action if error occurred, otherwise null",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "code": {
                  "description": "Fixed machine readable code",
                  "example": "action_failed",
                  "type": "string"
                },
                "message": {
                  "description": "Humanized error message",
                  "example": "Action failed",
                  "type": "string"
                }
              },
              "required": [
                "code",
                "message"
              ]
            },
            "finished": {
              "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
              "example": "2016-01-30T23:55:00+00:00",
              "type": [
                "string",
                "null"
              ]
            },
            "id": {
              "description": "ID of the Resource",
              "example": 42,
              "type": "integer",
              "format": "int32"
            },
            "progress": {
              "description": "Progress of Action in percent",
              "example": 100,
              "type": "number"
            },
            "resources": {
              "description": "Resources the Action relates to",
              "type": "array",
              "items": {
                "id": "Resource",
                "title": "Resource",
                "type": "object",
                "properties": {
                  "id": {
                    "description": "ID of the Resource",
                    "example": 42,
                    "type": "integer",
                    "format": "int32"
                  },
                  "type": {
                    "description": "Type of resource referenced",
                    "example": "server",
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "type"
                ]
              }
            },
            "started": {
              "description": "Point in time when the Action was started (in ISO-8601 format)",
              "example": "2016-01-30T23:55:00+00:00",
              "type": "string"
            },
            "status": {
              "title": "Status",
              "description": "Status of the Action",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "success",
                "running",
                "error"
              ]
            }
          },
          "required": [
            "command",
            "error",
            "finished",
            "id",
            "progress",
            "resources",
            "started",
            "status"
          ]
        },
        "next_actions": {
          "description": "",
          "type": "array",
          "items": {
            "$ref": "Action"
          }
        },
        "root_password": {
          "description": "Root password when no SSH keys have been specified",
          "example": "YItygq1v3GYjjMomLaKc",
          "type": [
            "string",
            "null"
          ]
        },
        "server": {
          "id": "Server18",
          "title": "Server18",
          "type": "object",
          "properties": {
            "backup_window": {
              "description": "Time window (UTC) in which the backup will run, or null if the backups are not enabled",
              "example": "22-02",
              "type": [
                "string",
                "null"
              ]
            },
            "created": {
              "description": "Point in time when the Resource was created (in ISO-8601 format)",
              "example": "2016-01-30T23:55:00+00:00",
              "type": "string"
            },
            "datacenter": {
              "id": "Datacenter6",
              "title": "Datacenter6",
              "description": "Datacenter this Resource is located at",
              "type": "object",
              "properties": {
                "description": {
                  "description": "Description of the Datacenter",
                  "example": "Falkenstein DC Park 8",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "location": {
                  "id": "Location",
                  "title": "Location",
                  "type": "object",
                  "properties": {
                    "city": {
                      "description": "City the Location is closest to",
                      "example": "Falkenstein",
                      "type": "string"
                    },
                    "country": {
                      "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                      "example": "DE",
                      "type": "string"
                    },
                    "description": {
                      "description": "Description of the Location",
                      "example": "Falkenstein DC Park 1",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Location",
                      "example": 1,
                      "type": "number"
                    },
                    "latitude": {
                      "description": "Latitude of the city closest to the Location",
                      "example": 50.47612,
                      "type": "number"
                    },
                    "longitude": {
                      "description": "Longitude of the city closest to the Location",
                      "example": 12.370071,
                      "type": "number"
                    },
                    "name": {
                      "description": "Unique identifier of the Location",
                      "example": "fsn1",
                      "type": "string"
                    },
                    "network_zone": {
                      "description": "Name of network zone this Location resides in",
                      "example": "eu-central",
                      "type": "string"
                    }
                  },
                  "required": [
                    "city",
                    "country",
                    "description",
                    "id",
                    "latitude",
                    "longitude",
                    "name",
                    "network_zone"
                  ]
                },
                "name": {
                  "description": "Unique identifier of the Datacenter",
                  "example": "fsn1-dc8",
                  "type": "string"
                },
                "server_types": {
                  "id": "ServerTypes",
                  "title": "ServerTypes",
                  "description": "The Server types the Datacenter can handle",
                  "type": "object",
                  "properties": {
                    "available": {
                      "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    },
                    "available_for_migration": {
                      "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    },
                    "supported": {
                      "description": "IDs of Server types that are supported in the Datacenter",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  },
                  "required": [
                    "available",
                    "available_for_migration",
                    "supported"
                  ]
                }
              },
              "required": [
                "description",
                "id",
                "location",
                "name",
                "server_types"
              ]
            },
            "id": {
              "description": "ID of the Resource",
              "example": 42,
              "type": "integer",
              "format": "int32"
            },
            "image": {
              "id": "Image",
              "title": "Image",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "bound_to": {
                  "description": "ID of Server the Image is bound to. Only set for Images of type `backup`.",
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int32"
                },
                "created": {
                  "description": "Point in time when the Resource was created (in ISO-8601 format)",
                  "example": "2016-01-30T23:55:00+00:00",
                  "type": "string"
                },
                "created_from": {
                  "id": "CreatedFrom",
                  "title": "CreatedFrom",
                  "description": "Information about the Server the Image was created from",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "id": {
                      "description": "ID of the Server the Image was created from",
                      "example": 1,
                      "type": "integer",
                      "format": "int32"
                    },
                    "name": {
                      "description": "Server name at the time the Image was created",
                      "example": "Server",
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                },
                "deleted": {
                  "description": "Point in time where the Image was deleted (in ISO-8601 format)",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "deprecated": {
                  "description": "Point in time when the Image is considered to be deprecated (in ISO-8601 format)",
                  "example": "2018-02-28T00:00:00+00:00",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "description": {
                  "description": "Description of the Image",
                  "example": "Ubuntu 20.04 Standard 64 bit",
                  "type": "string"
                },
                "disk_size": {
                  "description": "Size of the disk contained in the Image in GB",
                  "example": 10,
                  "type": "number"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "image_size": {
                  "description": "Size of the Image file in our storage in GB. For snapshot Images this is the value relevant for calculating costs for the Image.",
                  "example": 2.3,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "name": {
                  "description": "Unique identifier of the Image. This value is only set for system Images.",
                  "example": "ubuntu-20.04",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "os_flavor": {
                  "title": "OsFlavor",
                  "description": "Flavor of operating system contained in the Image",
                  "example": "ubuntu",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "ubuntu",
                    "centos",
                    "debian",
                    "fedora",
                    "unknown"
                  ]
                },
                "os_version": {
                  "description": "Operating system version",
                  "example": "20.04",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "protection": {
                  "id": "Protection",
                  "title": "Protection",
                  "description": "Protection configuration for the Resource",
                  "type": "object",
                  "properties": {
                    "delete": {
                      "description": "If true, prevents the Resource from being deleted",
                      "example": false,
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "delete"
                  ]
                },
                "status": {
                  "title": "Status24",
                  "description": "Whether the Image can be used or if it's still being created or unavailable",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "available",
                    "creating",
                    "unavailable"
                  ]
                },
                "type": {
                  "title": "Type22",
                  "description": "Type of the Image",
                  "example": "snapshot",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "system",
                    "app",
                    "snapshot",
                    "backup",
                    "temporary"
                  ]
                },
                "rapid_deploy": {
                  "description": "Indicates that rapid deploy of the Image is available",
                  "example": false,
                  "type": "boolean"
                }
              },
              "required": [
                "bound_to",
                "created",
                "created_from",
                "deleted",
                "deprecated",
                "description",
                "disk_size",
                "id",
                "image_size",
                "labels",
                "name",
                "os_flavor",
                "os_version",
                "protection",
                "status",
                "type"
              ]
            },
            "included_traffic": {
              "description": "Free Traffic for the current billing period in bytes",
              "example": 654321,
              "type": [
                "number",
                "null"
              ]
            },
            "ingoing_traffic": {
              "description": "Inbound Traffic for the current billing period in bytes",
              "example": 123456,
              "type": [
                "number",
                "null"
              ]
            },
            "iso": {
              "id": "Iso2",
              "title": "Iso2",
              "description": "ISO Image that is attached to this Server. Null if no ISO is attached.",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "deprecated": {
                  "description": "ISO 8601 timestamp of deprecation, null if ISO is still available. After the deprecation time it will no longer be possible to attach the ISO to Servers.",
                  "example": "2018-02-28T00:00:00+00:00",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "description": {
                  "description": "Description of the ISO",
                  "example": "FreeBSD 11.0 x64",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "name": {
                  "description": "Unique identifier of the ISO. Only set for public ISOs",
                  "example": "FreeBSD-11.0-RELEASE-amd64-dvd1",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "type": {
                  "title": "Type26",
                  "description": "Type of the ISO",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "public",
                    "private"
                  ]
                }
              },
              "required": [
                "deprecated",
                "description",
                "id",
                "name",
                "type"
              ]
            },
            "labels": {
              "description": "User-defined labels (key-value pairs)",
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "locked": {
              "description": "True if Server has been locked and is not available to user",
              "example": false,
              "type": "boolean"
            },
            "name": {
              "description": "Name of the Server (must be unique per Project and a valid hostname as per RFC 1123)",
              "example": "my-resource",
              "type": "string"
            },
            "outgoing_traffic": {
              "description": "Outbound Traffic for the current billing period in bytes",
              "example": 123456,
              "type": [
                "number",
                "null"
              ]
            },
            "primary_disk_size": {
              "description": "Size of the primary Disk",
              "example": 50,
              "type": "number"
            },
            "private_net": {
              "description": "Private networks information",
              "type": "array",
              "items": {
                "id": "PrivateNet4",
                "title": "PrivateNet4",
                "type": "object",
                "properties": {
                  "alias_ips": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "ip": {
                    "example": "10.0.0.2",
                    "type": "string"
                  },
                  "mac_address": {
                    "example": "86:00:ff:2a:7d:e1",
                    "type": "string"
                  },
                  "network": {
                    "example": 4711,
                    "type": "integer",
                    "format": "int32"
                  }
                }
              }
            },
            "protection": {
              "id": "Protection20",
              "title": "Protection20",
              "description": "Protection configuration for the Server",
              "type": "object",
              "properties": {
                "delete": {
                  "description": "If true, prevents the Server from being deleted",
                  "example": false,
                  "type": "boolean"
                },
                "rebuild": {
                  "description": "If true, prevents the Server from being rebuilt",
                  "example": false,
                  "type": "boolean"
                }
              },
              "required": [
                "delete",
                "rebuild"
              ]
            },
            "public_net": {
              "id": "PublicNet4",
              "title": "PublicNet4",
              "description": "Public network information. The Server's IPv4 address can be found in `public_net->ipv4->ip`",
              "type": "object",
              "properties": {
                "floating_ips": {
                  "description": "IDs of Floating IPs assigned to this Server",
                  "example": [
                    478
                  ],
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                },
                "ipv4": {
                  "id": "Ipv44",
                  "title": "Ipv44",
                  "description": "IP address (v4) and its reverse DNS entry of this Server",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "blocked": {
                      "description": "If the IP is blocked by our anti abuse dept",
                      "example": false,
                      "type": "boolean"
                    },
                    "dns_ptr": {
                      "description": "Reverse DNS PTR entry for the IPv4 addresses of this Server",
                      "example": "server01.example.com",
                      "type": "string"
                    },
                    "ip": {
                      "description": "IP address (v4) of this Server",
                      "example": "1.2.3.4",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Resource",
                      "example": 42,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "blocked",
                    "dns_ptr",
                    "ip"
                  ]
                },
                "ipv6": {
                  "id": "Ipv64",
                  "title": "Ipv64",
                  "description": "IPv6 network assigned to this Server and its reverse DNS entry",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "blocked": {
                      "description": "If the IP is blocked by our anti abuse dept",
                      "example": false,
                      "type": "boolean"
                    },
                    "dns_ptr": {
                      "description": "Reverse DNS PTR entries for the IPv6 addresses of this Server, `null` by default",
                      "type": [
                        "array",
                        "null"
                      ],
                      "items": {
                        "id": "DnsPtr8",
                        "title": "DnsPtr8",
                        "type": "object",
                        "properties": {
                          "dns_ptr": {
                            "description": "DNS pointer for the specific IP address",
                            "example": "server.example.com",
                            "type": "string"
                          },
                          "ip": {
                            "description": "Single IPv6 address of this Server for which the reverse DNS entry has been set up",
                            "example": "2001:db8::1",
                            "type": "string"
                          }
                        },
                        "required": [
                          "dns_ptr",
                          "ip"
                        ]
                      }
                    },
                    "ip": {
                      "description": "IP address (v6) of this Server",
                      "example": "2001:db8::/64",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Resource",
                      "example": 42,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "blocked",
                    "dns_ptr",
                    "ip"
                  ]
                },
                "firewalls": {
                  "description": "Firewalls applied to the public network interface of this Server",
                  "type": "array",
                  "items": {
                    "id": "ServerPublicNetFirewall",
                    "title": "ServerPublicNetFirewall",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "status": {
                        "title": "Status72",
                        "description": "Status of the Firewall on the Server",
                        "example": "applied",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "applied",
                          "pending"
                        ]
                      }
                    }
                  }
                }
              },
              "required": [
                "floating_ips",
                "ipv4",
                "ipv6"
              ]
            },
            "rescue_enabled": {
              "description": "True if rescue mode is enabled. Server will then boot into rescue system on next reboot",
              "example": false,
              "type": "boolean"
            },
            "server_type": {
              "id": "ServerType1",
              "title": "ServerType1",
              "description": "Type of Server - determines how much ram, disk and cpu a Server has",
              "type": "object",
              "properties": {
                "cores": {
                  "description": "Number of cpu cores a Server of this type will have",
                  "example": 1,
                  "type": "number"
                },
                "cpu_type": {
                  "title": "CpuType",
                  "description": "Type of cpu",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "shared",
                    "dedicated"
                  ]
                },
                "deprecated": {
                  "description": "True if Server type is deprecated",
                  "example": false,
                  "type": "boolean"
                },
                "description": {
                  "description": "Description of the Server type",
                  "example": "CX11",
                  "type": "string"
                },
                "disk": {
                  "description": "Disk size a Server of this type will have in GB",
                  "example": 25,
                  "type": "number"
                },
                "id": {
                  "description": "ID of the Server type",
                  "example": 1,
                  "type": "integer",
                  "format": "int32"
                },
                "memory": {
                  "description": "Memory a Server of this type will have in GB",
                  "example": 1,
                  "type": "number"
                },
                "name": {
                  "description": "Unique identifier of the Server type",
                  "example": "cx11",
                  "type": "string"
                },
                "prices": {
                  "description": "Prices in different Locations",
                  "type": "array",
                  "items": {
                    "id": "Price9",
                    "title": "Price9",
                    "type": "object",
                    "properties": {
                      "location": {
                        "description": "Name of the Location the price is for",
                        "example": "fsn1",
                        "type": "string"
                      },
                      "price_hourly": {
                        "id": "PriceHourly8",
                        "title": "PriceHourly8",
                        "description": "Hourly costs for a Server type in this Location",
                        "type": "object",
                        "properties": {
                          "gross": {
                            "description": "Price with VAT added",
                            "example": "1.1900000000000000",
                            "type": "string"
                          },
                          "net": {
                            "description": "Price without VAT",
                            "example": "1.0000000000",
                            "type": "string"
                          }
                        },
                        "required": [
                          "gross",
                          "net"
                        ]
                      },
                      "price_monthly": {
                        "id": "PriceMonthly10",
                        "title": "PriceMonthly10",
                        "description": "Monthly costs for a Server type in this Location",
                        "type": "object",
                        "properties": {
                          "gross": {
                            "description": "Price with VAT added",
                            "example": "1.1900000000000000",
                            "type": "string"
                          },
                          "net": {
                            "description": "Price without VAT",
                            "example": "1.0000000000",
                            "type": "string"
                          }
                        },
                        "required": [
                          "gross",
                          "net"
                        ]
                      }
                    },
                    "required": [
                      "location",
                      "price_hourly",
                      "price_monthly"
                    ]
                  }
                },
                "storage_type": {
                  "title": "StorageType",
                  "description": "Type of Server boot drive. Local has higher speed. Network has better availability.",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "local",
                    "network"
                  ]
                }
              },
              "required": [
                "cores",
                "cpu_type",
                "deprecated",
                "description",
                "disk",
                "id",
                "memory",
                "name",
                "prices",
                "storage_type"
              ]
            },
            "status": {
              "title": "Status73",
              "description": "Status of the Server",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "running",
                "initializing",
                "starting",
                "stopping",
                "off",
                "deleting",
                "migrating",
                "rebuilding",
                "unknown"
              ]
            },
            "load_balancers": {
              "description": "",
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            },
            "placement_group": {
              "id": "PlacementGroupNullable",
              "title": "PlacementGroupNullable",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "created": {
                  "description": "Point in time when the Resource was created (in ISO-8601 format)",
                  "example": "2016-01-30T23:55:00+00:00",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "name": {
                  "description": "Name of the Resource. Must be unique per Project.",
                  "example": "my-resource",
                  "type": "string"
                },
                "servers": {
                  "description": "Array of IDs of Servers that are part of this Placement Group",
                  "example": [
                    42
                  ],
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                },
                "type": {
                  "description": "Type of the Placement Group",
                  "example": "spread",
                  "type": "string",
                  "enum": [
                    "spread"
                  ]
                }
              },
              "required": [
                "created",
                "id",
                "labels",
                "name",
                "servers",
                "type"
              ]
            },
            "volumes": {
              "description": "IDs of Volumes assigned to this Server",
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            }
          },
          "required": [
            "backup_window",
            "created",
            "datacenter",
            "id",
            "image",
            "included_traffic",
            "ingoing_traffic",
            "iso",
            "labels",
            "locked",
            "name",
            "outgoing_traffic",
            "primary_disk_size",
            "private_net",
            "protection",
            "public_net",
            "rescue_enabled",
            "server_type",
            "status"
          ]
        }
      },
      "required": [
        "action",
        "next_actions",
        "root_password",
        "server"
      ]
    }
- ServersResponse1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ServersResponse1",
      "title": "ServersResponse1",
      "type": "object",
      "properties": {
        "action": {
          "id": "Action",
          "title": "Action",
          "type": "object",
          "properties": {
            "command": {
              "description": "Command executed in the Action",
              "example": "start_server",
              "type": "string"
            },
            "error": {
              "id": "Error",
              "title": "Error",
              "description": "Error message for the Action if error occurred, otherwise null",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "code": {
                  "description": "Fixed machine readable code",
                  "example": "action_failed",
                  "type": "string"
                },
                "message": {
                  "description": "Humanized error message",
                  "example": "Action failed",
                  "type": "string"
                }
              },
              "required": [
                "code",
                "message"
              ]
            },
            "finished": {
              "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
              "example": "2016-01-30T23:55:00+00:00",
              "type": [
                "string",
                "null"
              ]
            },
            "id": {
              "description": "ID of the Resource",
              "example": 42,
              "type": "integer",
              "format": "int32"
            },
            "progress": {
              "description": "Progress of Action in percent",
              "example": 100,
              "type": "number"
            },
            "resources": {
              "description": "Resources the Action relates to",
              "type": "array",
              "items": {
                "id": "Resource",
                "title": "Resource",
                "type": "object",
                "properties": {
                  "id": {
                    "description": "ID of the Resource",
                    "example": 42,
                    "type": "integer",
                    "format": "int32"
                  },
                  "type": {
                    "description": "Type of resource referenced",
                    "example": "server",
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "type"
                ]
              }
            },
            "started": {
              "description": "Point in time when the Action was started (in ISO-8601 format)",
              "example": "2016-01-30T23:55:00+00:00",
              "type": "string"
            },
            "status": {
              "title": "Status",
              "description": "Status of the Action",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "success",
                "running",
                "error"
              ]
            }
          },
          "required": [
            "command",
            "error",
            "finished",
            "id",
            "progress",
            "resources",
            "started",
            "status"
          ]
        }
      }
    }
- ServersResponse2: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ServersResponse2",
      "title": "ServersResponse2",
      "type": "object",
      "properties": {
        "server": {
          "id": "Server18",
          "title": "Server18",
          "type": "object",
          "properties": {
            "backup_window": {
              "description": "Time window (UTC) in which the backup will run, or null if the backups are not enabled",
              "example": "22-02",
              "type": [
                "string",
                "null"
              ]
            },
            "created": {
              "description": "Point in time when the Resource was created (in ISO-8601 format)",
              "example": "2016-01-30T23:55:00+00:00",
              "type": "string"
            },
            "datacenter": {
              "id": "Datacenter6",
              "title": "Datacenter6",
              "description": "Datacenter this Resource is located at",
              "type": "object",
              "properties": {
                "description": {
                  "description": "Description of the Datacenter",
                  "example": "Falkenstein DC Park 8",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "location": {
                  "id": "Location",
                  "title": "Location",
                  "type": "object",
                  "properties": {
                    "city": {
                      "description": "City the Location is closest to",
                      "example": "Falkenstein",
                      "type": "string"
                    },
                    "country": {
                      "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                      "example": "DE",
                      "type": "string"
                    },
                    "description": {
                      "description": "Description of the Location",
                      "example": "Falkenstein DC Park 1",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Location",
                      "example": 1,
                      "type": "number"
                    },
                    "latitude": {
                      "description": "Latitude of the city closest to the Location",
                      "example": 50.47612,
                      "type": "number"
                    },
                    "longitude": {
                      "description": "Longitude of the city closest to the Location",
                      "example": 12.370071,
                      "type": "number"
                    },
                    "name": {
                      "description": "Unique identifier of the Location",
                      "example": "fsn1",
                      "type": "string"
                    },
                    "network_zone": {
                      "description": "Name of network zone this Location resides in",
                      "example": "eu-central",
                      "type": "string"
                    }
                  },
                  "required": [
                    "city",
                    "country",
                    "description",
                    "id",
                    "latitude",
                    "longitude",
                    "name",
                    "network_zone"
                  ]
                },
                "name": {
                  "description": "Unique identifier of the Datacenter",
                  "example": "fsn1-dc8",
                  "type": "string"
                },
                "server_types": {
                  "id": "ServerTypes",
                  "title": "ServerTypes",
                  "description": "The Server types the Datacenter can handle",
                  "type": "object",
                  "properties": {
                    "available": {
                      "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    },
                    "available_for_migration": {
                      "description": "IDs of Server types that are supported and for which the Datacenter has enough resources left",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    },
                    "supported": {
                      "description": "IDs of Server types that are supported in the Datacenter",
                      "example": [
                        1,
                        2,
                        3
                      ],
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  },
                  "required": [
                    "available",
                    "available_for_migration",
                    "supported"
                  ]
                }
              },
              "required": [
                "description",
                "id",
                "location",
                "name",
                "server_types"
              ]
            },
            "id": {
              "description": "ID of the Resource",
              "example": 42,
              "type": "integer",
              "format": "int32"
            },
            "image": {
              "id": "Image",
              "title": "Image",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "bound_to": {
                  "description": "ID of Server the Image is bound to. Only set for Images of type `backup`.",
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int32"
                },
                "created": {
                  "description": "Point in time when the Resource was created (in ISO-8601 format)",
                  "example": "2016-01-30T23:55:00+00:00",
                  "type": "string"
                },
                "created_from": {
                  "id": "CreatedFrom",
                  "title": "CreatedFrom",
                  "description": "Information about the Server the Image was created from",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "id": {
                      "description": "ID of the Server the Image was created from",
                      "example": 1,
                      "type": "integer",
                      "format": "int32"
                    },
                    "name": {
                      "description": "Server name at the time the Image was created",
                      "example": "Server",
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                },
                "deleted": {
                  "description": "Point in time where the Image was deleted (in ISO-8601 format)",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "deprecated": {
                  "description": "Point in time when the Image is considered to be deprecated (in ISO-8601 format)",
                  "example": "2018-02-28T00:00:00+00:00",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "description": {
                  "description": "Description of the Image",
                  "example": "Ubuntu 20.04 Standard 64 bit",
                  "type": "string"
                },
                "disk_size": {
                  "description": "Size of the disk contained in the Image in GB",
                  "example": 10,
                  "type": "number"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "image_size": {
                  "description": "Size of the Image file in our storage in GB. For snapshot Images this is the value relevant for calculating costs for the Image.",
                  "example": 2.3,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "name": {
                  "description": "Unique identifier of the Image. This value is only set for system Images.",
                  "example": "ubuntu-20.04",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "os_flavor": {
                  "title": "OsFlavor",
                  "description": "Flavor of operating system contained in the Image",
                  "example": "ubuntu",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "ubuntu",
                    "centos",
                    "debian",
                    "fedora",
                    "unknown"
                  ]
                },
                "os_version": {
                  "description": "Operating system version",
                  "example": "20.04",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "protection": {
                  "id": "Protection",
                  "title": "Protection",
                  "description": "Protection configuration for the Resource",
                  "type": "object",
                  "properties": {
                    "delete": {
                      "description": "If true, prevents the Resource from being deleted",
                      "example": false,
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "delete"
                  ]
                },
                "status": {
                  "title": "Status24",
                  "description": "Whether the Image can be used or if it's still being created or unavailable",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "available",
                    "creating",
                    "unavailable"
                  ]
                },
                "type": {
                  "title": "Type22",
                  "description": "Type of the Image",
                  "example": "snapshot",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "system",
                    "app",
                    "snapshot",
                    "backup",
                    "temporary"
                  ]
                },
                "rapid_deploy": {
                  "description": "Indicates that rapid deploy of the Image is available",
                  "example": false,
                  "type": "boolean"
                }
              },
              "required": [
                "bound_to",
                "created",
                "created_from",
                "deleted",
                "deprecated",
                "description",
                "disk_size",
                "id",
                "image_size",
                "labels",
                "name",
                "os_flavor",
                "os_version",
                "protection",
                "status",
                "type"
              ]
            },
            "included_traffic": {
              "description": "Free Traffic for the current billing period in bytes",
              "example": 654321,
              "type": [
                "number",
                "null"
              ]
            },
            "ingoing_traffic": {
              "description": "Inbound Traffic for the current billing period in bytes",
              "example": 123456,
              "type": [
                "number",
                "null"
              ]
            },
            "iso": {
              "id": "Iso2",
              "title": "Iso2",
              "description": "ISO Image that is attached to this Server. Null if no ISO is attached.",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "deprecated": {
                  "description": "ISO 8601 timestamp of deprecation, null if ISO is still available. After the deprecation time it will no longer be possible to attach the ISO to Servers.",
                  "example": "2018-02-28T00:00:00+00:00",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "description": {
                  "description": "Description of the ISO",
                  "example": "FreeBSD 11.0 x64",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "name": {
                  "description": "Unique identifier of the ISO. Only set for public ISOs",
                  "example": "FreeBSD-11.0-RELEASE-amd64-dvd1",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "type": {
                  "title": "Type26",
                  "description": "Type of the ISO",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "public",
                    "private"
                  ]
                }
              },
              "required": [
                "deprecated",
                "description",
                "id",
                "name",
                "type"
              ]
            },
            "labels": {
              "description": "User-defined labels (key-value pairs)",
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "locked": {
              "description": "True if Server has been locked and is not available to user",
              "example": false,
              "type": "boolean"
            },
            "name": {
              "description": "Name of the Server (must be unique per Project and a valid hostname as per RFC 1123)",
              "example": "my-resource",
              "type": "string"
            },
            "outgoing_traffic": {
              "description": "Outbound Traffic for the current billing period in bytes",
              "example": 123456,
              "type": [
                "number",
                "null"
              ]
            },
            "primary_disk_size": {
              "description": "Size of the primary Disk",
              "example": 50,
              "type": "number"
            },
            "private_net": {
              "description": "Private networks information",
              "type": "array",
              "items": {
                "id": "PrivateNet4",
                "title": "PrivateNet4",
                "type": "object",
                "properties": {
                  "alias_ips": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "ip": {
                    "example": "10.0.0.2",
                    "type": "string"
                  },
                  "mac_address": {
                    "example": "86:00:ff:2a:7d:e1",
                    "type": "string"
                  },
                  "network": {
                    "example": 4711,
                    "type": "integer",
                    "format": "int32"
                  }
                }
              }
            },
            "protection": {
              "id": "Protection20",
              "title": "Protection20",
              "description": "Protection configuration for the Server",
              "type": "object",
              "properties": {
                "delete": {
                  "description": "If true, prevents the Server from being deleted",
                  "example": false,
                  "type": "boolean"
                },
                "rebuild": {
                  "description": "If true, prevents the Server from being rebuilt",
                  "example": false,
                  "type": "boolean"
                }
              },
              "required": [
                "delete",
                "rebuild"
              ]
            },
            "public_net": {
              "id": "PublicNet4",
              "title": "PublicNet4",
              "description": "Public network information. The Server's IPv4 address can be found in `public_net->ipv4->ip`",
              "type": "object",
              "properties": {
                "floating_ips": {
                  "description": "IDs of Floating IPs assigned to this Server",
                  "example": [
                    478
                  ],
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                },
                "ipv4": {
                  "id": "Ipv44",
                  "title": "Ipv44",
                  "description": "IP address (v4) and its reverse DNS entry of this Server",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "blocked": {
                      "description": "If the IP is blocked by our anti abuse dept",
                      "example": false,
                      "type": "boolean"
                    },
                    "dns_ptr": {
                      "description": "Reverse DNS PTR entry for the IPv4 addresses of this Server",
                      "example": "server01.example.com",
                      "type": "string"
                    },
                    "ip": {
                      "description": "IP address (v4) of this Server",
                      "example": "1.2.3.4",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Resource",
                      "example": 42,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "blocked",
                    "dns_ptr",
                    "ip"
                  ]
                },
                "ipv6": {
                  "id": "Ipv64",
                  "title": "Ipv64",
                  "description": "IPv6 network assigned to this Server and its reverse DNS entry",
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "blocked": {
                      "description": "If the IP is blocked by our anti abuse dept",
                      "example": false,
                      "type": "boolean"
                    },
                    "dns_ptr": {
                      "description": "Reverse DNS PTR entries for the IPv6 addresses of this Server, `null` by default",
                      "type": [
                        "array",
                        "null"
                      ],
                      "items": {
                        "id": "DnsPtr8",
                        "title": "DnsPtr8",
                        "type": "object",
                        "properties": {
                          "dns_ptr": {
                            "description": "DNS pointer for the specific IP address",
                            "example": "server.example.com",
                            "type": "string"
                          },
                          "ip": {
                            "description": "Single IPv6 address of this Server for which the reverse DNS entry has been set up",
                            "example": "2001:db8::1",
                            "type": "string"
                          }
                        },
                        "required": [
                          "dns_ptr",
                          "ip"
                        ]
                      }
                    },
                    "ip": {
                      "description": "IP address (v6) of this Server",
                      "example": "2001:db8::/64",
                      "type": "string"
                    },
                    "id": {
                      "description": "ID of the Resource",
                      "example": 42,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "blocked",
                    "dns_ptr",
                    "ip"
                  ]
                },
                "firewalls": {
                  "description": "Firewalls applied to the public network interface of this Server",
                  "type": "array",
                  "items": {
                    "id": "ServerPublicNetFirewall",
                    "title": "ServerPublicNetFirewall",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "status": {
                        "title": "Status72",
                        "description": "Status of the Firewall on the Server",
                        "example": "applied",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "applied",
                          "pending"
                        ]
                      }
                    }
                  }
                }
              },
              "required": [
                "floating_ips",
                "ipv4",
                "ipv6"
              ]
            },
            "rescue_enabled": {
              "description": "True if rescue mode is enabled. Server will then boot into rescue system on next reboot",
              "example": false,
              "type": "boolean"
            },
            "server_type": {
              "id": "ServerType1",
              "title": "ServerType1",
              "description": "Type of Server - determines how much ram, disk and cpu a Server has",
              "type": "object",
              "properties": {
                "cores": {
                  "description": "Number of cpu cores a Server of this type will have",
                  "example": 1,
                  "type": "number"
                },
                "cpu_type": {
                  "title": "CpuType",
                  "description": "Type of cpu",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "shared",
                    "dedicated"
                  ]
                },
                "deprecated": {
                  "description": "True if Server type is deprecated",
                  "example": false,
                  "type": "boolean"
                },
                "description": {
                  "description": "Description of the Server type",
                  "example": "CX11",
                  "type": "string"
                },
                "disk": {
                  "description": "Disk size a Server of this type will have in GB",
                  "example": 25,
                  "type": "number"
                },
                "id": {
                  "description": "ID of the Server type",
                  "example": 1,
                  "type": "integer",
                  "format": "int32"
                },
                "memory": {
                  "description": "Memory a Server of this type will have in GB",
                  "example": 1,
                  "type": "number"
                },
                "name": {
                  "description": "Unique identifier of the Server type",
                  "example": "cx11",
                  "type": "string"
                },
                "prices": {
                  "description": "Prices in different Locations",
                  "type": "array",
                  "items": {
                    "id": "Price9",
                    "title": "Price9",
                    "type": "object",
                    "properties": {
                      "location": {
                        "description": "Name of the Location the price is for",
                        "example": "fsn1",
                        "type": "string"
                      },
                      "price_hourly": {
                        "id": "PriceHourly8",
                        "title": "PriceHourly8",
                        "description": "Hourly costs for a Server type in this Location",
                        "type": "object",
                        "properties": {
                          "gross": {
                            "description": "Price with VAT added",
                            "example": "1.1900000000000000",
                            "type": "string"
                          },
                          "net": {
                            "description": "Price without VAT",
                            "example": "1.0000000000",
                            "type": "string"
                          }
                        },
                        "required": [
                          "gross",
                          "net"
                        ]
                      },
                      "price_monthly": {
                        "id": "PriceMonthly10",
                        "title": "PriceMonthly10",
                        "description": "Monthly costs for a Server type in this Location",
                        "type": "object",
                        "properties": {
                          "gross": {
                            "description": "Price with VAT added",
                            "example": "1.1900000000000000",
                            "type": "string"
                          },
                          "net": {
                            "description": "Price without VAT",
                            "example": "1.0000000000",
                            "type": "string"
                          }
                        },
                        "required": [
                          "gross",
                          "net"
                        ]
                      }
                    },
                    "required": [
                      "location",
                      "price_hourly",
                      "price_monthly"
                    ]
                  }
                },
                "storage_type": {
                  "title": "StorageType",
                  "description": "Type of Server boot drive. Local has higher speed. Network has better availability.",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "local",
                    "network"
                  ]
                }
              },
              "required": [
                "cores",
                "cpu_type",
                "deprecated",
                "description",
                "disk",
                "id",
                "memory",
                "name",
                "prices",
                "storage_type"
              ]
            },
            "status": {
              "title": "Status73",
              "description": "Status of the Server",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "running",
                "initializing",
                "starting",
                "stopping",
                "off",
                "deleting",
                "migrating",
                "rebuilding",
                "unknown"
              ]
            },
            "load_balancers": {
              "description": "",
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            },
            "placement_group": {
              "id": "PlacementGroupNullable",
              "title": "PlacementGroupNullable",
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "created": {
                  "description": "Point in time when the Resource was created (in ISO-8601 format)",
                  "example": "2016-01-30T23:55:00+00:00",
                  "type": "string"
                },
                "id": {
                  "description": "ID of the Resource",
                  "example": 42,
                  "type": "integer",
                  "format": "int32"
                },
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "name": {
                  "description": "Name of the Resource. Must be unique per Project.",
                  "example": "my-resource",
                  "type": "string"
                },
                "servers": {
                  "description": "Array of IDs of Servers that are part of this Placement Group",
                  "example": [
                    42
                  ],
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                },
                "type": {
                  "description": "Type of the Placement Group",
                  "example": "spread",
                  "type": "string",
                  "enum": [
                    "spread"
                  ]
                }
              },
              "required": [
                "created",
                "id",
                "labels",
                "name",
                "servers",
                "type"
              ]
            },
            "volumes": {
              "description": "IDs of Volumes assigned to this Server",
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            }
          },
          "required": [
            "backup_window",
            "created",
            "datacenter",
            "id",
            "image",
            "included_traffic",
            "ingoing_traffic",
            "iso",
            "labels",
            "locked",
            "name",
            "outgoing_traffic",
            "primary_disk_size",
            "private_net",
            "protection",
            "public_net",
            "rescue_enabled",
            "server_type",
            "status"
          ]
        }
      }
    }
- UpdateServerRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "UpdateServerRequest",
      "title": "UpdateServerRequest",
      "type": "object",
      "properties": {
        "labels": {
          "description": "User-defined labels (key-value pairs)",
          "example": {
            "labelkey": "value"
          },
          "type": "object"
        },
        "name": {
          "description": "New name to set",
          "example": "my-server",
          "type": "string"
        }
      }
    }
- AddToPlacementGroupRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AddToPlacementGroupRequest",
      "title": "AddToPlacementGroupRequest",
      "type": "object",
      "properties": {
        "placement_group": {
          "description": "ID of Placement Group the Server should be added to",
          "example": 1,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "placement_group"
      ]
    }
- ServersActionsAttachIsoRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ServersActionsAttachIsoRequest",
      "title": "ServersActionsAttachIsoRequest",
      "type": "object",
      "properties": {
        "iso": {
          "description": "ID or name of ISO to attach to the Server as listed in GET `/isos`",
          "example": "FreeBSD-11.0-RELEASE-amd64-dvd1",
          "type": "string"
        }
      },
      "required": [
        "iso"
      ]
    }
- AttachToNetworkRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AttachToNetworkRequest",
      "title": "AttachToNetworkRequest",
      "type": "object",
      "properties": {
        "network": {
          "description": "ID of an existing network to attach the Server to",
          "example": 4711,
          "type": "integer",
          "format": "int32"
        },
        "alias_ips": {
