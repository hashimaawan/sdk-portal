                            "status": 404
                          },
                          "type": "object",
                          "properties": {
                            "message": {
                              "description": "A message detailing the error",
                              "type": "string"
                            },
                            "status": {
                              "description": "HTTP Status Code",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
                        }
                      example: '{"message":"file {fileUuid} not found","status":404}'
                '413':
                  description: File content too large to display
                  body:
                    application/json:
                      schema: |
                        {
                          "id": "ErrorResponse",
                          "title": "ErrorResponse",
                          "examples": [
                            {
                              "Id": "fileTooLarge",
                              "Name": "File too large",
                              "Value": "{\"message\":\"File is too large to inline in request. Use the /v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content endpoint instead.\",\"status\":413}",
                              "ExternalValue": null,
                              "Description": null
                            }
                          ],
                          "example": {
                            "message": "File is too large to inline in request. Use the /v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content endpoint instead.",
                            "status": 413
                          },
                          "type": "object",
                          "properties": {
                            "message": {
                              "description": "A message detailing the error",
                              "type": "string"
                            },
                            "status": {
                              "description": "HTTP Status Code",
                              "type": "integer",
                              "format": "int32"
                            }
                          }
                        }
                      example: '{"message":"File is too large to inline in request. Use the /v1/vaults/{vaultUUID}/items/{itemUUID}/files/{fileUUID}/content endpoint instead.","status":413}'
          get:
            securedBy:
            - ConnectToken
            queryParameters:
              inline_files:
                description: Tells server to return the base64-encoded file contents in the response.
                type: boolean
                example: 'true'
                required: false
