                  "ip": {
                    "example": "10.0.0.2",
                    "type": "string"
                  },
                  "network": {
                    "example": 4711,
                    "type": "integer",
                    "format": "int32"
                  }
                }
              }
            },
            "protection": {
              "id": "Protection",
              "title": "Protection",
              "description": "Protection configuration for the Resource",
              "type": "object",
