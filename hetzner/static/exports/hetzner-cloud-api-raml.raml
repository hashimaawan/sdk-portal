      /attach_to_network:
        uriParameters: {}
        post:
          description: >
            Attach a Load Balancer to a Network.


            **Call specific error codes**


            | Code                             | Description                                                           |

            |----------------------------------|-----------------------------------------------------------------------|

            | `load_balancer_already_attached` | The Load Balancer is already attached to a network                    |

            | `ip_not_available`               | The provided Network IP is not available                              |

            | `no_subnet_available`            | No Subnet or IP is available for the Load Balancer within the network |
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              enum:
              - application/json
          body:
            application/json:
              schema: |
                {
                  "id": "LoadBalancersActionsAttachToNetworkRequest",
                  "title": "LoadBalancersActionsAttachToNetworkRequest",
                  "type": "object",
                  "properties": {
                    "network": {
                      "description": "ID of an existing network to attach the Load Balancer to",
                      "example": 4711,
                      "type": "number"
                    },
                    "ip": {
                      "description": "IP to request to be assigned to this Load Balancer; if you do not provide this then you will be auto assigned an IP address",
                      "example": "10.0.1.1",
                      "type": "string"
                    }
                  },
                  "required": [
                    "network"
                  ]
                }
              example: ''
          responses:
            '201':
