        required: false
        example:
          value: 6
        displayName: max_nodes
        description: The maximum number of nodes that this node pool can be auto-scaled to. The value will be `0` if `auto_scale` is set to `false`.
        type: integer
        format: int32
      min_nodes:
        required: false
        example:
          value: 3
        displayName: min_nodes
        description: The minimum number of nodes that this node pool can be auto-scaled to. The value will be `0` if `auto_scale` is set to `false`.
        type: integer
        format: int32
      name:
        required: false
        example:
          value: frontend-pool
        displayName: name
        description: A human-readable name for the node pool.
        type: string
      nodes:
        required: false
        displayName: nodes
        description: An object specifying the details of a specific worker node in a node pool.
        type: array
        items:
          type: Node
      tags:
        required: false
        example:
          value:
          - k8s
          - k8s:bd5f5959-5e1e-4205-a714-a914373942af
          - k8s-worker
          - production
          - web-team
        displayName: tags
        description: An array containing the tags applied to the node pool. All node pools are automatically tagged `k8s`, `k8s-worker`, and `k8s:$K8S_CLUSTER_ID`.
        type: array
        items:
          type: string
      taints:
        required: false
        displayName: taints
        description: An array of taints to apply to all nodes in a pool. Taints will automatically be applied to all existing nodes and any subsequent nodes added to the pool. When a taint is removed, it is removed from all nodes in the pool.
        type: array
        items:
          type: Taint
  V2KubernetesClustersNodePoolsRecycleRequest:
    displayName: V2KubernetesClustersNodePoolsRecycleRequest
    type: object
    properties:
      nodes:
        required: false
        example:
          value:
          - d8db5e1a-6103-43b5-a7b3-8a948210a9fc
        displayName: nodes
        type: array
        items:
          type: string
  V2KubernetesClustersUpgradeRequest:
    displayName: V2KubernetesClustersUpgradeRequest
    type: object
    properties:
      version:
        required: false
        example:
          value: 1.16.13-do.0
        displayName: version
        description: The slug identifier for the version of Kubernetes that the cluster will be upgraded to.
        type: string
  V2KubernetesClustersUpgradesResponse:
    displayName: V2KubernetesClustersUpgradesResponse
    type: object
    properties:
      available_upgrade_versions:
        required: false
        displayName: available_upgrade_versions
        type:
        - array
        - nil
        items:
          type: AvailableUpgradeVersion
  AvailableUpgradeVersion:
    displayName: AvailableUpgradeVersion
    type: object
    properties:
      kubernetes_version:
        required: false
        example:
          value: 1.16.13
        displayName: kubernetes_version
        description: The upstream version string for the version of Kubernetes provided by a given slug.
        type: string
      slug:
        required: false
        example:
          value: 1.16.13-do.0
        displayName: slug
        description: The slug identifier for an available version of Kubernetes for use when creating or updating a cluster. The string contains both the upstream version of Kubernetes as well as the DigitalOcean revision.
        type: string
      supported_features:
        required: false
        example:
          value:
          - cluster-autoscaler
          - docr-integration
          - token-authentication
        displayName: supported_features
        description: The features available with the version of Kubernetes provided by a given slug.
        type: array
        items:
          type: string
  V2KubernetesClustersUserResponse:
    displayName: V2KubernetesClustersUserResponse
    type: object
    properties:
      kubernetes_cluster_user:
        required: false
        displayName: kubernetes_cluster_user
        type: KubernetesClusterUser
  KubernetesClusterUser:
    displayName: KubernetesClusterUser
    type: object
    properties:
      groups:
        required: false
        example:
          value:
          - k8saas:authenticated
        displayName: groups
        description: A list of in-cluster groups that the user belongs to.
        type: array
        items:
          type: string
      username:
        required: false
        example:
          value: sammy@digitalocean.com
        displayName: username
        description: The username for the cluster admin user.
        type: string
  V2KubernetesOptionsResponse:
    displayName: V2KubernetesOptionsResponse
    type: object
    properties:
      options:
        required: false
        displayName: options
        type: Options1
  Options1:
    displayName: Options1
    type: object
    properties:
      regions:
        required: false
        displayName: regions
        type: array
        items:
          type: Region4
      sizes:
        required: false
        displayName: sizes
        type: array
        items:
          type: Size1
      versions:
        required: false
        displayName: versions
        type: array
        items:
          type: AvailableUpgradeVersion
  Region4:
    displayName: Region4
    type: object
    properties:
      name:
        required: false
        example:
          value: New York 3
        displayName: name
        description: A DigitalOcean region where Kubernetes is available.
        type: string
      slug:
        required: false
        example:
          value: nyc3
        displayName: slug
        description: The identifier for a region for use when creating a new cluster.
        type: string
  Size1:
    displayName: Size1
    type: object
    properties:
      name:
        required: false
        example:
          value: s-1vcpu-2gb
        displayName: name
        description: A Droplet size available for use in a Kubernetes node pool.
        type: string
      slug:
        required: false
        example:
          value: s-1vcpu-2gb
        displayName: slug
        description: The identifier for a size for use when creating a new cluster.
        type: string
  V2KubernetesRegistryRequest:
    displayName: V2KubernetesRegistryRequest
    type: object
    properties:
      cluster_uuids:
        required: false
        example:
          value:
          - bd5f5959-5e1e-4205-a714-a914373942af
          - 50c2f44c-011d-493e-aee5-361a4a0d1844
        displayName: cluster_uuids
        description: An array containing the UUIDs of Kubernetes clusters.
        type: array
        items:
          type: string
  V2LoadBalancersResponse:
    displayName: V2LoadBalancersResponse
    type: object
    properties:
      load_balancers:
        required: false
        displayName: load_balancers
        type: array
        items:
          type: LoadBalancer1
      links:
        required: false
        displayName: links
        type: Links
      meta:
        required: true
        displayName: meta
        type: Meta
  LoadBalancer1:
    displayName: LoadBalancer1
    type: object
    properties:
      algorithm:
        required: false
        default: round_robin
        example:
          value: round_robin
        displayName: algorithm
        description: This field has been deprecated. You can no longer specify an algorithm for load balancers.
        type: string
        enum:
        - round_robin
        - least_connections
      created_at:
        required: false
        example:
          value: 2017-02-01T22:22:58Z
        displayName: created_at
        description: A time value given in ISO8601 combined date and time format that represents when the load balancer was created.
        type: datetime
      disable_lets_encrypt_dns_records:
        required: false
        default: 'false'
        example:
          value: true
        displayName: disable_lets_encrypt_dns_records
        description: A boolean value indicating whether to disable automatic DNS record creation for Let's Encrypt certificates that are added to the load balancer.
        type: boolean
      enable_backend_keepalive:
        required: false
        default: 'false'
        example:
          value: true
        displayName: enable_backend_keepalive
        description: A boolean value indicating whether HTTP keepalive connections are maintained to target Droplets.
        type: boolean
      enable_proxy_protocol:
        required: false
        default: 'false'
        example:
          value: true
        displayName: enable_proxy_protocol
        description: A boolean value indicating whether PROXY Protocol is in use.
        type: boolean
      firewall:
        required: false
        displayName: firewall
        description: An object specifying allow and deny rules to control traffic to the load balancer.
        type: Firewall1
      forwarding_rules:
        required: true
        displayName: forwarding_rules
        description: An array of objects specifying the forwarding rules for a load balancer.
        type: array
        uniqueItems: false
        minItems: 1
        items:
          type: ForwardingRule
      health_check:
        required: false
        displayName: health_check
        description: An object specifying health check settings for the load balancer.
        type: HealthCheck1
      http_idle_timeout_seconds:
        required: false
        default: '60'
        example:
          value: 90
        displayName: http_idle_timeout_seconds
        description: An integer value which configures the idle timeout for HTTP requests to the target droplets.
        type: integer
        minimum: 30
        maximum: 600
        format: int32
      id:
        required: false
        example:
          value: 4de7ac8b-495b-4884-9a69-1050c6793cd6
        displayName: id
        description: A unique ID that can be used to identify and reference a load balancer.
        type: any
      ip:
        required: false
        example:
          value: 104.131.186.241
        displayName: ip
        description: An attribute containing the public-facing IP address of the load balancer.
        type: string
        pattern: ^$|^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$
      name:
        required: false
        example:
          value: example-lb-01
        displayName: name
        description: A human-readable name for a load balancer instance.
        type: string
      project_id:
        required: false
        example:
          value: 4de7ac8b-495b-4884-9a69-1050c6793cd6
        displayName: project_id
        description: The ID of the project that the load balancer is associated with. If no ID is provided at creation, the load balancer associates with the user's default project. If an invalid project ID is provided, the load balancer will not be created.
        type: string
      redirect_http_to_https:
        required: false
        default: 'false'
        example:
          value: true
        displayName: redirect_http_to_https
        description: A boolean value indicating whether HTTP requests to the load balancer on port 80 will be redirected to HTTPS on port 443.
        type: boolean
      size:
        required: false
        default: lb-small
        example:
          value: lb-small
        displayName: size
        description: |
          This field has been replaced by the `size_unit` field for all regions except in AMS2, NYC2, and SFO1. Each available load balancer size now equates to the load balancer having a set number of nodes.

          * `lb-small` = 1 node

          * `lb-medium` = 3 nodes

          * `lb-large` = 6 nodes


          You can resize load balancers after creation up to once per hour. You cannot resize a load balancer within the first hour of its creation.
        type: string
        enum:
        - lb-small
        - lb-medium
        - lb-large
      size_unit:
        required: false
        default: '1'
        example:
          value: 3
        displayName: size_unit
        description: How many nodes the load balancer contains. Each additional node increases the load balancer's ability to manage more connections. Load balancers can be scaled up or down, and you can change the number of nodes after creation up to once per hour. This field is currently not available in the AMS2, NYC2, or SFO1 regions. Use the `size` field to scale load balancers that reside in these regions.
        type: integer
        minimum: 1
        maximum: 100
        format: int32
      status:
        required: false
        example:
          value: new
        displayName: status
        description: A status string indicating the current state of the load balancer. This can be `new`, `active`, or `errored`.
        type: string
        enum:
        - new
        - active
        - errored
      sticky_sessions:
        required: false
        displayName: sticky_sessions
        description: An object specifying sticky sessions settings for the load balancer.
        type: StickySessions
      vpc_uuid:
        required: false
        example:
          value: c33931f2-a26a-4e61-b85c-4e95a2ec431b
        displayName: vpc_uuid
        description: A string specifying the UUID of the VPC to which the load balancer is assigned.
        type: any
      region:
        required: false
        displayName: region
        type: Region
      droplet_ids:
        required: false
        example:
          value:
          - 3164444
          - 3164445
        displayName: droplet_ids
        description: An array containing the IDs of the Droplets assigned to the load balancer.
        type: array
        items:
          type: integer
          format: int32
      tag:
        required: false
        example:
          value: prod:web
        displayName: tag
        description: The name of a Droplet tag corresponding to Droplets assigned to the load balancer.
        type: string
  Firewall1:
    displayName: Firewall1
    description: An object specifying allow and deny rules to control traffic to the load balancer.
    type: object
    properties:
      allow:
        required: false
        default: '[]'
        example:
          value:
          - ip:1.2.3.4
          - cidr:2.3.0.0/16
        displayName: allow
        description: the rules for allowing traffic to the load balancer (in the form 'ip:1.2.3.4' or 'cidr:1.2.0.0/16')
        type: array
        items:
          type: string
      deny:
        required: false
        default: '[]'
        example:
          value:
          - ip:1.2.3.4
          - cidr:2.3.0.0/16
        displayName: deny
        description: the rules for denying traffic to the load balancer (in the form 'ip:1.2.3.4' or 'cidr:1.2.0.0/16')
        type: array
        items:
          type: string
  ForwardingRule:
    displayName: ForwardingRule
    description: An object specifying a forwarding rule for a load balancer.
    type: object
    properties:
      certificate_id:
        required: false
        example:
          value: 892071a0-bb95-49bc-8021-3afd67a210bf
        displayName: certificate_id
        description: The ID of the TLS certificate used for SSL termination if enabled.
        type: string
      entry_port:
        required: true
        example:
          value: 443
        displayName: entry_port
        description: An integer representing the port on which the load balancer instance will listen.
        type: integer
        format: int32
      entry_protocol:
        required: true
        example:
          value: https
        displayName: entry_protocol
        description: 'The protocol used for traffic to the load balancer. The possible values are: `http`, `https`, `http2`, `http3`, `tcp`, or `udp`. If you set the  `entry_protocol` to `udp`, the `target_protocol` must be set to `udp`.  When using UDP, the load balancer requires that you set up a health  check with a port that uses TCP, HTTP, or HTTPS to work properly.'
        type: string
        enum:
        - http
        - https
        - http2
        - http3
        - tcp
        - udp
      target_port:
        required: true
        example:
          value: 80
        displayName: target_port
        description: An integer representing the port on the backend Droplets to which the load balancer will send traffic.
        type: integer
        format: int32
      target_protocol:
        required: true
        example:
          value: http
        displayName: target_protocol
        description: 'The protocol used for traffic from the load balancer to the backend Droplets. The possible values are: `http`, `https`, `http2`, `tcp`, or `udp`. If you set the `target_protocol` to `udp`, the `entry_protocol` must be set to  `udp`. When using UDP, the load balancer requires that you set up a health  check with a port that uses TCP, HTTP, or HTTPS to work properly.'
        type: string
        enum:
        - http
        - https
        - http2
        - tcp
        - udp
      tls_passthrough:
        required: false
        example:
          value: false
        displayName: tls_passthrough
        description: A boolean value indicating whether SSL encrypted traffic will be passed through to the backend Droplets.
        type: boolean
  HealthCheck1:
    displayName: HealthCheck1
    description: An object specifying health check settings for the load balancer.
    type: object
    properties:
      check_interval_seconds:
        required: false
        default: '10'
        example:
          value: 10
        displayName: check_interval_seconds
        description: The number of seconds between between two consecutive health checks.
        type: integer
        format: int32
      healthy_threshold:
        required: false
        default: '3'
        example:
          value: 3
        displayName: healthy_threshold
        description: The number of times a health check must pass for a backend Droplet to be marked "healthy" and be re-added to the pool.
        type: integer
        format: int32
      path:
        required: false
        default: /
        example:
          value: /
        displayName: path
        description: The path on the backend Droplets to which the load balancer instance will send a request.
        type: string
      port:
        required: false
        default: '80'
        example:
          value: 80
        displayName: port
        description: An integer representing the port on the backend Droplets on which the health check will attempt a connection.
        type: integer
        format: int32
      protocol:
        required: false
        default: http
        example:
          value: http
        displayName: protocol
        description: The protocol used for health checks sent to the backend Droplets. The possible values are `http`, `https`, or `tcp`.
        type: string
        enum:
        - http
        - https
        - tcp
      response_timeout_seconds:
        required: false
        default: '5'
        example:
          value: 5
        displayName: response_timeout_seconds
        description: The number of seconds the load balancer instance will wait for a response until marking a health check as failed.
        type: integer
        format: int32
      unhealthy_threshold:
        required: false
        default: '5'
        example:
          value: 5
        displayName: unhealthy_threshold
        description: The number of times a health check must fail for a backend Droplet to be marked "unhealthy" and be removed from the pool.
        type: integer
        format: int32
  StickySessions:
    displayName: StickySessions
    description: An object specifying sticky sessions settings for the load balancer.
    type: object
    properties:
      cookie_name:
        required: false
        example:
          value: DO-LB
        displayName: cookie_name
        description: The name of the cookie sent to the client. This attribute is only returned when using `cookies` for the sticky sessions type.
        type: string
      cookie_ttl_seconds:
        required: false
        example:
          value: 300
        displayName: cookie_ttl_seconds
        description: The number of seconds until the cookie set by the load balancer expires. This attribute is only returned when using `cookies` for the sticky sessions type.
        type: integer
        format: int32
      type:
        required: false
        default: none
        example:
          value: cookies
        displayName: type
        description: An attribute indicating how and if requests from a client will be persistently served by the same backend Droplet. The possible values are `cookies` or `none`.
        type: string
        enum:
        - cookies
        - none
