        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
