          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">OK</doc>
          <representation element="schemas:GetVaultItems200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Invalid or missing token</doc>
          <representation element="schemas:GetVaultItems401_Response0" mediaType="application/json" />
        </response>
        <response status="404">
          <doc title="404" xml:lang="en">Vault not found</doc>
          <representation element="schemas:GetVaultItems404_Response0" mediaType="application/json" />
        </response>
