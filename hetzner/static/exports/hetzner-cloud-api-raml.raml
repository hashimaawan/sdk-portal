- LoadBalancersResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LoadBalancersResponse",
      "title": "LoadBalancersResponse",
      "type": "object",
      "properties": {
        "load_balancers": {
          "description": "",
          "type": "array",
          "items": {
            "id": "LoadBalancer",
            "title": "LoadBalancer",
            "type": "object",
            "properties": {
              "algorithm": {
                "id": "Algorithm",
                "title": "Algorithm",
                "description": "Algorithm of the Load Balancer",
                "type": "object",
                "properties": {
                  "type": {
                    "title": "Type28",
                    "description": "Type of the algorithm",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "round_robin",
                      "least_connections"
                    ]
                  }
                },
                "required": [
                  "type"
                ]
              },
              "created": {
                "description": "Point in time when the Resource was created (in ISO-8601 format)",
                "example": "2016-01-30T23:55:00+00:00",
