  /following:
    /contains:
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - user-follow-read
        description: >
          Check to see if the current user is following one or more artists or other Spotify users.
        queryParameters:
          type:
            example: artist
            required: true
            displayName: type
            enum:
            - artist
            - user
          ids:
            type: string
