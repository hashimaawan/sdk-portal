/ssh_keys:
  /{id}:
    uriParameters:
      id:
        description: ID of the SSH key
        type: string
        required: true
        displayName: id
    delete:
      description: Deletes an SSH key. It cannot be used anymore.
      responses:
        '204':
          description: SSH key deleted
    get:
      description: Returns a specific SSH key object.
      responses:
        '200':
          description: The `ssh_key` key in the reply contains an SSH key object with this structure
          body:
            application/json:
              schema: |
                {
                  "id": "SshKeysResponse1",
                  "title": "SshKeysResponse1",
                  "type": "object",
                  "properties": {
                    "ssh_key": {
                      "id": "SshKey",
                      "title": "SshKey",
                      "type": "object",
                      "properties": {
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "fingerprint": {
                          "description": "Fingerprint of public key",
                          "example": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "public_key": {
                          "description": "Public key",
                          "example": "ssh-rsa AAAjjk76kgf...Xt",
                          "type": "string"
                        }
                      },
                      "required": [
                        "created",
                        "fingerprint",
                        "id",
                        "labels",
                        "name",
                        "public_key"
                      ]
                    }
                  },
                  "required": [
                    "ssh_key"
                  ]
                }
    put:
      description: >
        Updates an SSH key. You can update an SSH key name and an SSH key labels.


        Please note that when updating labels, the SSH key current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "SshKeysRequest1",
              "title": "SshKeysRequest1",
              "type": "object",
              "properties": {
                "labels": {
                  "description": "User-defined labels (key-value pairs)",
                  "example": {
                    "labelkey": "value"
                  },
                  "type": "object"
                },
                "name": {
                  "description": "New name Name to set",
                  "example": "My ssh key",
                  "type": "string"
                }
              }
            }
          example: ''
      responses:
        '200':
          description: The `ssh_key` key in the reply contains the modified SSH key object with the new description
          body:
            application/json:
              schema: |
                {
                  "id": "SshKeysResponse1",
                  "title": "SshKeysResponse1",
                  "example": {
                    "ssh_key": {
                      "created": "2016-01-30T23:50:00+00:00",
                      "fingerprint": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                      "id": 2323,
                      "labels": {
                        "labelkey": "value"
                      },
                      "name": "My ssh key",
                      "public_key": "ssh-rsa AAAjjk76kgf...Xt"
                    }
                  },
                  "type": "object",
                  "properties": {
                    "ssh_key": {
                      "id": "SshKey",
                      "title": "SshKey",
                      "type": "object",
                      "properties": {
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "fingerprint": {
                          "description": "Fingerprint of public key",
                          "example": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
                          "example": "my-resource",
                          "type": "string"
                        },
                        "public_key": {
                          "description": "Public key",
                          "example": "ssh-rsa AAAjjk76kgf...Xt",
                          "type": "string"
                        }
                      },
                      "required": [
                        "created",
                        "fingerprint",
                        "id",
                        "labels",
                        "name",
                        "public_key"
                      ]
                    }
                  },
                  "required": [
                    "ssh_key"
                  ]
                }
              example: '{"ssh_key":{"created":"2016-01-30T23:50:00+00:00","fingerprint":"b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f","id":2323,"labels":{"labelkey":"value"},"name":"My ssh key","public_key":"ssh-rsa AAAjjk76kgf...Xt"}}'
  get:
    description: Returns all SSH key objects.
    queryParameters:
      sort:
        description: Can be used multiple times.
        required: false
        displayName: sort
        enum:
        - id
        - id:asc
        - id:desc
        - name
        - name:asc
        - name:desc
      name:
        description: Can be used to filter resources by their name. The response will only contain the resources matching the specified name
        type: string
        required: false
        displayName: name
      fingerprint:
        description: Can be used to filter SSH keys by their fingerprint. The response will only contain the SSH key matching the specified fingerprint.
        type: string
        required: false
        displayName: fingerprint
      label_selector:
        description: Can be used to filter resources by labels. The response will only contain resources matching the label selector.
        type: string
        required: false
        displayName: label_selector
    responses:
      '200':
        description: The `ssh_keys` key in the reply contains an array of SSH key objects with this structure
        body:
          application/json:
            schema: |
              {
                "id": "SshKeysResponse",
                "title": "SshKeysResponse",
                "type": "object",
                "properties": {
                  "ssh_keys": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "SshKey",
                      "title": "SshKey",
                      "type": "object",
                      "properties": {
                        "created": {
                          "description": "Point in time when the Resource was created (in ISO-8601 format)",
                          "example": "2016-01-30T23:55:00+00:00",
                          "type": "string"
                        },
                        "fingerprint": {
                          "description": "Fingerprint of public key",
                          "example": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                          "type": "string"
                        },
                        "id": {
                          "description": "ID of the Resource",
                          "example": 42,
                          "type": "integer",
                          "format": "int32"
                        },
                        "labels": {
                          "description": "User-defined labels (key-value pairs)",
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        },
                        "name": {
                          "description": "Name of the Resource. Must be unique per Project.",
