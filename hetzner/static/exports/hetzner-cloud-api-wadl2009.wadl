      </xs:complexType>
      <xs:complexType name="LoadBalancerServiceHealthCheck">
        <xs:annotation>
          <xs:documentation>Service health check</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="http" type="schemas:Http">
            <xs:annotation>
              <xs:documentation>Additional configuration for protocol http</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="interval" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Time interval in seconds health checks are performed</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="port" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Port the health check will be performed on</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="protocol" type="schemas:Protocol6">
            <xs:annotation>
              <xs:documentation>Type of the health check</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="retries" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timeout" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Time in seconds after an attempt is considered a timeout</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Http">
        <xs:annotation>
          <xs:documentation>Additional configuration for protocol http</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="domain" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="path" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="response" type="xs:string">
            <xs:annotation>
              <xs:documentation>String that must be contained in HTTP response in order to pass the health check</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="status_codes" type="xs:string">
            <xs:annotation>
              <xs:documentation>List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="tls" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Use HTTPS for health check</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="Protocol6">
        <xs:annotation>
          <xs:documentation>Type of the health check</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="tcp" />
          <xs:enumeration value="http" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="LoadBalancerServiceHTTP">
        <xs:annotation>
          <xs:documentation>Configuration option for protocols http and https</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="certificates" type="xs:integer">
            <xs:annotation>
              <xs:documentation>IDs of the Certificates to use for TLS/SSL termination by the Load Balancer; empty for TLS/SSL passthrough or if `protocol` is "http"</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="cookie_lifetime" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Lifetime of the cookie used for sticky sessions</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="cookie_name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the cookie used for sticky sessions</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="redirect_http" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Redirect HTTP requests to HTTPS. Only available if protocol is "https". Default `false`</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="sticky_sessions" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Use sticky sessions. Only available if protocol is "http" or "https". Default `false`</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="Protocol7">
        <xs:annotation>
          <xs:documentation>Protocol of the Load Balancer</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="tcp" />
          <xs:enumeration value="http" />
          <xs:enumeration value="https" />
        </xs:restriction>
      </xs:simpleType>
