      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        additionalProperties: true
        properties:
          //:
            type: string
      name:
        required: true
        example:
          value: ubuntu-20.04
        displayName: name
        description: Unique identifier of the Image. This value is only set for system Images.
        type:
        - string
        - nil
      os_flavor:
        required: true
        example:
          value: ubuntu
        displayName: os_flavor
        description: Flavor of operating system contained in the Image
        type: string
        enum:
        - ubuntu
        - centos
        - debian
        - fedora
        - unknown
      os_version:
        required: true
        example:
          value: '20.04'
        displayName: os_version
        description: Operating system version
        type:
        - string
        - nil
      protection:
        required: true
        displayName: protection
        description: Protection configuration for the Resource
        type: Protection
      rapid_deploy:
        required: false
        example:
          value: false
        displayName: rapid_deploy
        description: Indicates that rapid deploy of the Image is available
        type: boolean
      status:
        required: true
        displayName: status
        description: Whether the Image can be used or if it's still being created or unavailable
        type: string
        enum:
        - available
        - creating
        - unavailable
      type:
        required: true
        example:
          value: snapshot
        displayName: type
        description: Type of the Image
        type: string
        enum:
        - system
        - app
        - snapshot
        - backup
        - temporary
  CreatedFrom:
    displayName: CreatedFrom
    description: Information about the Server the Image was created from
    type: object
    properties:
      id:
        required: true
        example:
          value: 1
        displayName: id
        description: ID of the Server the Image was created from
        type: integer
        format: int32
      name:
        required: true
        example:
          value: Server
        displayName: name
        description: Server name at the time the Image was created
        type: string
  ImagesResponse1:
    displayName: ImagesResponse1
    type: object
    properties:
      image:
        required: false
        displayName: image
        type: Image
  UpdateImageRequest:
    displayName: UpdateImageRequest
    type: object
    properties:
      description:
        required: false
        example:
          value: My new Image description
        displayName: description
        description: New description of Image
        type: string
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      type:
        required: false
        displayName: type
        description: Destination Image type to convert to
        type: string
        enum:
        - snapshot
  ImagesActionsChangeProtectionRequest:
    displayName: ImagesActionsChangeProtectionRequest
    type: object
    properties:
      delete:
        required: false
        example:
          value: true
        displayName: delete
        description: If true, prevents the snapshot from being deleted
        type: boolean
  IsosResponse:
    displayName: IsosResponse
    type: object
    properties:
      isos:
        required: true
        displayName: isos
        type: array
        items:
          type: Iso
      meta:
        required: false
        displayName: meta
        type: Meta
  Iso:
    displayName: Iso
    type: object
    properties:
      deprecated:
        required: true
        example:
          value: 2018-02-28T00:00:00+00:00
        displayName: deprecated
        description: ISO 8601 timestamp of deprecation, null if ISO is still available. After the deprecation time it will no longer be possible to attach the ISO to Servers.
        type:
        - string
        - nil
      description:
        required: true
        example:
          value: FreeBSD 11.0 x64
        displayName: description
        description: Description of the ISO
        type: string
      id:
        required: true
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      name:
        required: true
        example:
          value: FreeBSD-11.0-RELEASE-amd64-dvd1
        displayName: name
        description: Unique identifier of the ISO. Only set for public ISOs
        type:
        - string
        - nil
      type:
        required: true
        displayName: type
        description: Type of the ISO
        type: string
        enum:
        - public
        - private
  IsosResponse1:
    displayName: IsosResponse1
    type: object
    properties:
      iso:
        required: true
        displayName: iso
        type: Iso
  LoadBalancerTypesResponse:
    displayName: LoadBalancerTypesResponse
    type: object
    properties:
      load_balancer_types:
        required: true
        displayName: load_balancer_types
        type: array
        items:
          type: LoadBalancerType
  LoadBalancerType:
    displayName: LoadBalancerType
    type: object
    properties:
      deprecated:
        required: true
        example:
          value: 2016-01-30T23:50:00+00:00
        displayName: deprecated
        description: Point in time when the Load Balancer type is deprecated (in ISO-8601 format)
        type:
        - string
        - nil
      description:
        required: true
        example:
          value: LB11
        displayName: description
        description: Description of the Load Balancer type
        type: string
      id:
        required: true
        example:
          value: 1
        displayName: id
        description: ID of the Load Balancer type
        type: number
        format: double
      max_assigned_certificates:
        required: true
        example:
          value: 10
        displayName: max_assigned_certificates
        description: Number of SSL Certificates that can be assigned to a single Load Balancer
        type: number
        format: double
      max_connections:
        required: true
        example:
          value: 20000
        displayName: max_connections
        description: Number of maximum simultaneous open connections
        type: number
        format: double
      max_services:
        required: true
        example:
          value: 5
        displayName: max_services
        description: Number of services a Load Balancer of this type can have
        type: number
        format: double
      max_targets:
        required: true
        example:
          value: 25
        displayName: max_targets
        description: Number of targets a single Load Balancer can have
        type: number
        format: double
      name:
        required: true
        example:
          value: lb11
        displayName: name
        description: Unique identifier of the Load Balancer type
        type: string
      prices:
        required: true
        displayName: prices
        description: Prices in different network zones
        type: array
        items:
          type: Price
  Price:
    displayName: Price
    type: object
    properties:
      location:
        required: true
        example:
          value: fsn1
        displayName: location
        description: Name of the Location the price is for
        type: string
      price_hourly:
        required: true
        displayName: price_hourly
        description: Hourly costs for a Resource in this Location
        type: PriceHourly
      price_monthly:
        required: true
        displayName: price_monthly
        description: Monthly costs for a Resource in this Location
        type: PriceMonthly
  PriceHourly:
    displayName: PriceHourly
    description: Hourly costs for a Resource in this Location
    type: object
    properties:
      gross:
        required: true
        example:
          value: '1.1900000000000000'
        displayName: gross
        description: Price with VAT added
        type: string
      net:
        required: true
        example:
          value: '1.0000000000'
        displayName: net
        description: Price without VAT
        type: string
  PriceMonthly:
    displayName: PriceMonthly
    description: Monthly costs for a Resource in this Location
    type: object
    properties:
      gross:
        required: true
        example:
          value: '1.1900000000000000'
        displayName: gross
        description: Price with VAT added
        type: string
      net:
        required: true
        example:
          value: '1.0000000000'
        displayName: net
        description: Price without VAT
        type: string
  LoadBalancerTypesResponse1:
    displayName: LoadBalancerTypesResponse1
    type: object
    properties:
      load_balancer_type:
        required: false
        displayName: load_balancer_type
        type: LoadBalancerType
  LoadBalancersResponse:
    displayName: LoadBalancersResponse
    type: object
    properties:
      load_balancers:
        required: true
        displayName: load_balancers
        type: array
        items:
          type: LoadBalancer
      meta:
        required: false
        displayName: meta
        type: Meta
  LoadBalancer:
    displayName: LoadBalancer
    type: object
    properties:
      algorithm:
        required: true
        displayName: algorithm
        description: Algorithm of the Load Balancer
        type: Algorithm
      created:
        required: true
        example:
          value: 2016-01-30T23:55:00+00:00
        displayName: created
        description: Point in time when the Resource was created (in ISO-8601 format)
        type: string
      id:
        required: true
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      included_traffic:
        required: true
        example:
          value: 10000
        displayName: included_traffic
        description: Free Traffic for the current billing period in bytes
        type: integer
        format: int32
      ingoing_traffic:
        required: true
        displayName: ingoing_traffic
        description: Inbound Traffic for the current billing period in bytes
        type:
        - integer
        - nil
        format: int32
      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        additionalProperties: true
        properties:
          //:
            type: string
      load_balancer_type:
        required: true
        displayName: load_balancer_type
        type: LoadBalancerType
      location:
        required: true
        displayName: location
        type: Location
      name:
        required: true
        example:
          value: my-resource
        displayName: name
        description: Name of the Resource. Must be unique per Project.
        type: string
      outgoing_traffic:
        required: true
        displayName: outgoing_traffic
        description: Outbound Traffic for the current billing period in bytes
        type:
        - integer
        - nil
        format: int32
      private_net:
        required: true
        displayName: private_net
        description: Private networks information
        type: array
        items:
          type: PrivateNet
      protection:
        required: true
        displayName: protection
        description: Protection configuration for the Resource
        type: Protection
      public_net:
        required: true
        displayName: public_net
        description: Public network information
        type: PublicNet
      services:
        required: true
        displayName: services
        description: List of services that belong to this Load Balancer
        type: array
        items:
          type: LoadBalancerService
      targets:
        required: true
        displayName: targets
        description: List of targets that belong to this Load Balancer
        type: array
        items:
          type: LoadBalancerTarget
  Algorithm:
    displayName: Algorithm
    description: Algorithm of the Load Balancer
    type: object
    properties:
      type:
        required: true
        displayName: type
        description: Type of the algorithm
        type: string
        enum:
        - round_robin
        - least_connections
  PrivateNet:
    displayName: PrivateNet
    type: object
    properties:
      ip:
        required: false
        example:
          value: 10.0.0.2
        displayName: ip
        type: string
      network:
        required: false
        example:
          value: 4711
        displayName: network
        type: integer
        format: int32
  PublicNet:
    displayName: PublicNet
    description: Public network information
    type: object
    properties:
      enabled:
        required: true
        displayName: enabled
        description: Public Interface enabled or not
        type: boolean
      ipv4:
        required: true
        displayName: ipv4
        description: IP address (v4)
        type: Ipv4
      ipv6:
        required: true
        displayName: ipv6
        description: IP address (v6)
        type: Ipv6
  Ipv4:
    displayName: Ipv4
    description: IP address (v4)
    type: object
    properties:
      dns_ptr:
        required: false
        example:
          value: lb1.example.com
        displayName: dns_ptr
        description: Reverse DNS PTR entry for the IPv4 address of this Load Balancer
        type:
        - string
        - nil
      ip:
        required: false
        example:
          value: 1.2.3.4
        displayName: ip
        description: IP address (v4) of this Load Balancer
        type:
        - string
        - nil
  Ipv6:
    displayName: Ipv6
    description: IP address (v6)
    type: object
    properties:
      dns_ptr:
        required: false
        example:
          value: lb1.example.com
        displayName: dns_ptr
        description: Reverse DNS PTR entry for the IPv6 address of this Load Balancer
        type:
        - string
        - nil
      ip:
        required: false
        example:
          value: 2001:db8::1
        displayName: ip
        description: IP address (v6) of this Load Balancer
        type:
        - string
        - nil
  LoadBalancerService:
    displayName: LoadBalancerService
    type: object
    properties:
      destination_port:
        required: true
        example:
          value: 80
        displayName: destination_port
        description: Port the Load Balancer will balance to
        type: integer
        format: int32
      health_check:
        required: true
        displayName: health_check
        description: Service health check
        type: LoadBalancerServiceHealthCheck
      http:
        required: false
        displayName: http
        description: Configuration option for protocols http and https
        type: LoadBalancerServiceHTTP
      listen_port:
        required: true
        example:
          value: 443
        displayName: listen_port
        description: Port the Load Balancer listens on
        type: integer
        format: int32
      protocol:
        required: true
        example:
          value: https
        displayName: protocol
        description: Protocol of the Load Balancer
        type: string
        enum:
        - tcp
        - http
        - https
      proxyprotocol:
        required: true
        example:
          value: false
        displayName: proxyprotocol
        description: Is Proxyprotocol enabled or not
        type: boolean
  LoadBalancerServiceHealthCheck:
    displayName: LoadBalancerServiceHealthCheck
    description: Service health check
    type: object
    properties:
      http:
        required: false
        displayName: http
        description: Additional configuration for protocol http
        type: Http
      interval:
        required: true
        example:
          value: 15
        displayName: interval
        description: Time interval in seconds health checks are performed
        type: integer
        format: int32
      port:
        required: true
        example:
          value: 4711
        displayName: port
        description: Port the health check will be performed on
        type: integer
        format: int32
      protocol:
        required: true
        example:
          value: http
        displayName: protocol
        description: Type of the health check
        type: string
        enum:
        - tcp
        - http
      retries:
        required: true
        example:
          value: 3
        displayName: retries
        description: Unsuccessful retries needed until a target is considered unhealthy; an unhealthy target needs the same number of successful retries to become healthy again
        type: integer
        format: int32
      timeout:
        required: true
        example:
          value: 10
        displayName: timeout
        description: Time in seconds after an attempt is considered a timeout
        type: integer
        format: int32
  Http:
    displayName: Http
    description: Additional configuration for protocol http
    type: object
    properties:
      domain:
        required: true
        example:
          value: example.com
        displayName: domain
        description: Host header to send in the HTTP request. May not contain spaces, percent or backslash symbols. Can be null, in that case no host header is sent.
        type:
        - string
        - nil
      path:
        required: true
        example:
          value: /
        displayName: path
        description: HTTP path to use for health checks. May not contain literal spaces, use percent-encoding instead.
        type: string
      response:
        required: false
        example:
          value:
            status: ok
        displayName: response
        description: String that must be contained in HTTP response in order to pass the health check
        type: string
      status_codes:
        required: false
        example:
          value:
          - 2??
          - 3??
        displayName: status_codes
        description: List of returned HTTP status codes in order to pass the health check. Supports the wildcards `?` for exactly one character and `*` for multiple ones. The default is to pass the health check for any status code between 2?? and 3??.
        type: array
        items:
          type: string
      tls:
        required: false
        example:
          value: false
        displayName: tls
        description: Use HTTPS for health check
        type: boolean
  LoadBalancerServiceHTTP:
    displayName: LoadBalancerServiceHTTP
    description: Configuration option for protocols http and https
    type: object
    properties:
      certificates:
        required: false
        example:
          value:
          - 897
        displayName: certificates
        description: IDs of the Certificates to use for TLS/SSL termination by the Load Balancer; empty for TLS/SSL passthrough or if `protocol` is "http"
        type: array
        items:
          type: integer
          format: int32
      cookie_lifetime:
        required: false
        example:
          value: 300
        displayName: cookie_lifetime
        description: Lifetime of the cookie used for sticky sessions
        type: integer
        format: int32
      cookie_name:
        required: false
        example:
          value: HCLBSTICKY
        displayName: cookie_name
        description: Name of the cookie used for sticky sessions
        type: string
      redirect_http:
        required: false
        example:
          value: true
        displayName: redirect_http
        description: Redirect HTTP requests to HTTPS. Only available if protocol is "https". Default `false`
        type: boolean
      sticky_sessions:
        required: false
        example:
          value: true
        displayName: sticky_sessions
        description: Use sticky sessions. Only available if protocol is "http" or "https". Default `false`
        type: boolean
  LoadBalancerTarget:
    displayName: LoadBalancerTarget
    type: object
    properties:
      health_status:
        required: false
        displayName: health_status
        description: List of health statuses of the services on this target
        type: array
        items:
          type: HealthStatus
      ip:
        required: false
        displayName: ip
        description: IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.
        type: Ip
      label_selector:
        required: false
        displayName: label_selector
        description: Label selector and a list of selected targets
        type: LabelSelector7
      server:
        required: false
        displayName: server
        description: Server where the traffic should be routed through
        type: LoadBalancerTargetServer
      targets:
        required: false
        displayName: targets
        description: List of selected targets
        type: array
        items:
          type: Target
      type:
        required: true
        displayName: type
        description: Type of the resource
        type: string
        enum:
        - server
        - label_selector
        - ip
      use_private_ip:
        required: false
        displayName: use_private_ip
        description: Use the private network IP instead of the public IP. Default value is false.
        type: boolean
  HealthStatus:
    displayName: HealthStatus
    type: object
    properties:
      listen_port:
        required: false
        example:
          value: 443
        displayName: listen_port
        type: integer
        format: int32
      status:
        required: false
        example:
          value: healthy
        displayName: status
        type: string
        enum:
        - healthy
        - unhealthy
        - unknown
  Ip:
    displayName: Ip
    description: IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.
    type: object
    properties:
      ip:
        required: true
        example:
          value: 203.0.113.1
        displayName: ip
        description: IP of a server that belongs to the same customer (public IPv4/IPv6) or private IP in a Subnetwork type vswitch.
        type: string
  LabelSelector7:
    displayName: LabelSelector7
    description: Label selector and a list of selected targets
    type: object
    properties:
      selector:
        required: true
        example:
          value: env=prod
        displayName: selector
        description: Label selector
        type: string
  LoadBalancerTargetServer:
    displayName: LoadBalancerTargetServer
    description: Server where the traffic should be routed through
    type: object
    properties:
      id:
        required: true
        example:
          value: 80
        displayName: id
        description: ID of the Server
        type: integer
        format: int32
  Target:
    displayName: Target
    type: object
    properties:
      health_status:
        required: false
        displayName: health_status
        type: array
        items:
          type: HealthStatus
      server:
        required: false
        displayName: server
        type: Server11
      type:
        required: false
        example:
          value: server
        displayName: type
        type: string
      use_private_ip:
        required: false
        example:
          value: false
        displayName: use_private_ip
        type: boolean
  Server11:
    displayName: Server11
    type: object
    properties:
      id:
        required: true
        example:
          value: 85
        displayName: id
        description: ID of the Server
        type: integer
        format: int32
  CreateLoadBalancerRequest:
    displayName: CreateLoadBalancerRequest
    type: object
    properties:
      algorithm:
        required: true
        displayName: algorithm
        description: Algorithm of the Load Balancer
        type: LoadBalancerAlgorithm
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: Labels
      load_balancer_type:
        required: true
        example:
          value: lb11
        displayName: load_balancer_type
        description: ID or name of the Load Balancer type this Load Balancer should be created with
        type: string
      location:
        required: false
        displayName: location
        description: ID or name of Location to create Load Balancer in
        type: string
      name:
        required: true
        example:
          value: Web Frontend
        displayName: name
        description: Name of the Load Balancer
        type: string
      network:
        required: false
        example:
          value: 123
        displayName: network
        description: ID of the network the Load Balancer should be attached to on creation
        type: integer
        format: int32
      network_zone:
        required: false
        example:
          value: eu-central
        displayName: network_zone
        description: Name of network zone
        type: string
      public_interface:
        required: false
        example:
          value: true
        displayName: public_interface
        description: Enable or disable the public interface of the Load Balancer
        type: boolean
      services:
        required: false
        displayName: services
        description: Array of services
        type: array
        items:
          type: LoadBalancerService
      targets:
        required: false
        displayName: targets
        description: Array of targets
        type: array
        items:
          type: LoadBalancerTarget
  LoadBalancerAlgorithm:
    displayName: LoadBalancerAlgorithm
    description: Algorithm of the Load Balancer
    type: object
    properties:
      type:
        required: true
        displayName: type
        description: Type of the algorithm
        type: string
        enum:
        - round_robin
        - least_connections
  Labels:
    displayName: Labels
    description: User-defined labels (key-value pairs)
    type: object
    properties:
      labelkey:
        required: false
        example:
          value: value
        displayName: labelkey
        description: New label
        type: string
  LoadBalancersResponse1:
    displayName: LoadBalancersResponse1
    type: object
    properties:
      action:
        required: true
        displayName: action
        type: Action
      load_balancer:
        required: true
        displayName: load_balancer
        type: LoadBalancer
  LoadBalancersResponse2:
    displayName: LoadBalancersResponse2
    type: object
    properties:
      load_balancer:
        required: true
        displayName: load_balancer
        type: LoadBalancer
  LoadBalancersRequest:
    displayName: LoadBalancersRequest
    type: object
    properties:
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: false
        example:
          value: new-name
        displayName: name
        description: New Load Balancer name
        type: string
  AddTargetRequest:
    displayName: AddTargetRequest
    type: object
    properties:
      ip:
        required: false
        displayName: ip
        description: IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.
        type: Ip
      label_selector:
        required: false
        displayName: label_selector
        description: Configuration for label selector targets, required if type is `label_selector`
        type: LabelSelector12
      server:
        required: false
        displayName: server
        description: Configuration for type Server, required if type is `server`
        type: Server16
      type:
        required: true
        displayName: type
        description: Type of the resource
        type: string
        enum:
        - server
        - label_selector
        - ip
      use_private_ip:
        required: false
        example:
          value: true
        displayName: use_private_ip
        description: Use the private network IP instead of the public IP of the Server, requires the Server and Load Balancer to be in the same network. Default value is false.
        type: boolean
  LabelSelector12:
    displayName: LabelSelector12
    description: Configuration for label selector targets, required if type is `label_selector`
    type: object
    properties:
      selector:
        required: true
        example:
          value: env=prod
        displayName: selector
        description: Label selector
        type: string
  Server16:
    displayName: Server16
    description: Configuration for type Server, required if type is `server`
    type: object
    properties:
      id:
        required: true
        example:
          value: 80
        displayName: id
        description: ID of the Server
        type: number
        format: double
  LoadBalancersActionsAttachToNetworkRequest:
    displayName: LoadBalancersActionsAttachToNetworkRequest
    type: object
    properties:
      ip:
        required: false
        example:
          value: 10.0.1.1
        displayName: ip
        description: IP to request to be assigned to this Load Balancer; if you do not provide this then you will be auto assigned an IP address
        type: string
      network:
        required: true
        example:
          value: 4711
        displayName: network
        description: ID of an existing network to attach the Load Balancer to
        type: number
        format: double
  LoadBalancersActionsChangeAlgorithmRequest:
    displayName: LoadBalancersActionsChangeAlgorithmRequest
    type: object
    properties:
      type:
        required: true
        displayName: type
        description: Algorithm of the Load Balancer
        type: string
        enum:
        - round_robin
        - least_connections
  ChangeLoadbalancerDnsPtrRequest:
    displayName: ChangeLoadbalancerDnsPtrRequest
    type: object
    properties:
      dns_ptr:
        required: true
        example:
          value: lb1.example.com
        displayName: dns_ptr
        description: Hostname to set as a reverse DNS PTR entry
        type:
        - string
        - nil
      ip:
        required: true
        example:
          value: 1.2.3.4
        displayName: ip
        description: Public IP address for which the reverse DNS entry should be set
        type: string
  LoadBalancersActionsChangeProtectionRequest:
    displayName: LoadBalancersActionsChangeProtectionRequest
    type: object
    properties:
      delete:
        required: false
        example:
          value: true
        displayName: delete
        description: If true, prevents the Load Balancer from being deleted
        type: boolean
  ChangeTypeRequest:
    displayName: ChangeTypeRequest
    type: object
    properties:
      load_balancer_type:
        required: true
        example:
          value: lb21
        displayName: load_balancer_type
        description: ID or name of Load Balancer type the Load Balancer should migrate to
        type: string
  LoadBalancersActionsDeleteServiceRequest:
    displayName: LoadBalancersActionsDeleteServiceRequest
    type: object
    properties:
      listen_port:
        required: true
        example:
          value: 4711
        displayName: listen_port
        description: The listen port of the service you want to delete
        type: number
        format: double
  LoadBalancersActionsDetachFromNetworkRequest:
    displayName: LoadBalancersActionsDetachFromNetworkRequest
    type: object
    properties:
      network:
        required: true
        example:
          value: 4711
        displayName: network
        description: ID of an existing network to detach the Load Balancer from
        type: number
        format: double
  RemoveTargetRequest:
    displayName: RemoveTargetRequest
    type: object
    properties:
      ip:
        required: false
        displayName: ip
        description: IP targets where the traffic should be routed through. It is only possible to use the (Public or vSwitch) IPs of Hetzner Online Root Servers belonging to the project owner. IPs belonging to other users are blocked. Additionally IPs belonging to services provided by Hetzner Cloud (Servers, Load Balancers, ...) are blocked as well.
        type: Ip
      label_selector:
        required: false
        displayName: label_selector
        description: Configuration for label selector targets, required if type is `label_selector`
        type: LabelSelector12
      server:
        required: false
        displayName: server
        description: Configuration for type Server, required if type is `server`
        type: Server16
      type:
        required: true
        displayName: type
        description: Type of the resource
        type: string
        enum:
        - server
        - label_selector
        - ip
  LoadBalancersMetricsResponse:
    displayName: LoadBalancersMetricsResponse
    type: object
    properties:
      metrics:
        required: true
        displayName: metrics
        type: Metrics
  Metrics:
    displayName: Metrics
    type: object
    properties:
      end:
        required: true
        example:
          value: 2017-01-01T23:00:00+00:00
        displayName: end
        description: End of period of metrics reported (in ISO-8601 format)
        type: string
      start:
        required: true
        example:
          value: 2017-01-01T00:00:00+00:00
        displayName: start
        description: Start of period of metrics reported (in ISO-8601 format)
        type: string
      step:
        required: true
        example:
          value: 60
        displayName: step
        description: Resolution of results in seconds.
        type: number
        format: double
      time_series:
        required: true
        example:
          value:
            name_of_timeseries:
              values:
              - - 1435781470.622
                - '42'
              - - 1435781471.622
                - '43'
        displayName: time_series
        description: Hash with timeseries information, containing the name of timeseries as key
        type: object
        additionalProperties: true
        properties:
          //:
            type: TimeSeries
  TimeSeries:
    displayName: TimeSeries
    type: object
    properties:
      values:
        required: true
        displayName: values
        description: Metrics Timestamps with values
        type: (number | string)[][]
  LocationsResponse:
    displayName: LocationsResponse
    type: object
    properties:
      locations:
        required: true
        displayName: locations
        type: array
        items:
          type: Location
  LocationsResponse1:
    displayName: LocationsResponse1
    type: object
    properties:
      location:
        required: true
        displayName: location
        type: Location
  NetworksResponse:
    displayName: NetworksResponse
    type: object
    properties:
      meta:
        required: false
        displayName: meta
        type: Meta
      networks:
        required: true
        displayName: networks
        type: array
        items:
          type: Network
  Network:
    displayName: Network
    type: object
    properties:
      created:
        required: true
        example:
          value: 2016-01-30T23:50:00+00:00
        displayName: created
        description: Point in time when the Network was created (in ISO-8601 format)
        type: string
      id:
        required: true
        example:
          value: 4711
        displayName: id
        description: ID of the Network
        type: integer
        format: int32
      ip_range:
        required: true
        example:
          value: 10.0.0.0/16
        displayName: ip_range
        description: IPv4 prefix of the whole Network
        type: string
      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      load_balancers:
        required: false
        example:
          value:
          - 42
        displayName: load_balancers
        description: Array of IDs of Load Balancers attached to this Network
        type: array
        items:
          type: integer
          format: int32
      name:
        required: true
        example:
          value: mynet
        displayName: name
        description: Name of the Network
        type: string
      protection:
        required: true
        displayName: protection
        description: Protection configuration for the Network
        type: Protection11
      routes:
        required: true
        displayName: routes
        description: Array of routes set in this Network
        type: array
        items:
          type: Route
      servers:
        required: true
        example:
          value:
          - 42
        displayName: servers
        description: Array of IDs of Servers attached to this Network
        type: array
        items:
          type: integer
          format: int32
      subnets:
        required: true
        displayName: subnets
        description: Array subnets allocated in this Network
        type: array
        items:
          type: Subnet
  Protection11:
    displayName: Protection11
    description: Protection configuration for the Network
    type: object
    properties:
      delete:
        required: true
        example:
          value: false
        displayName: delete
        description: If true, prevents the Network from being deleted
        type: boolean
  Route:
    displayName: Route
    type: object
    properties:
      destination:
        required: true
        example:
          value: 10.100.1.0/24
        displayName: destination
        description: Destination network or host of this route. Must not overlap with an existing ip_range in any subnets or with any destinations in other routes or with the first IP of the networks ip_range or with 172.31.1.1. Must be one of the private IPv4 ranges of RFC1918.
        type: string
      gateway:
        required: true
        example:
          value: 10.0.1.1
        displayName: gateway
        description: Gateway for the route. Cannot be the first IP of the networks ip_range and also cannot be 172.31.1.1 as this IP is being used as a gateway for the public network interface of Servers.
        type: string
  Subnet:
    displayName: Subnet
    type: object
    properties:
      gateway:
        required: true
        example:
          value: 10.0.0.1
        displayName: gateway
        description: Gateway for Servers attached to this subnet. For subnets of type Server this is always the first IP of the network IP range.
        type: string
      ip_range:
        required: false
        example:
          value: 10.0.1.0/24
        displayName: ip_range
        description: Range to allocate IPs from. Must be a Subnet of the ip_range of the parent network object and must not overlap with any other subnets or with any destinations in routes. Minimum Network size is /30. We suggest that you pick a bigger Network with a /24 netmask.
        type: string
      network_zone:
        required: true
        example:
          value: eu-central
        displayName: network_zone
        description: Name of Network zone. The Location object contains the `network_zone` property each Location belongs to.
        type: string
      type:
        required: true
        displayName: type
        description: Type of Subnetwork
        type: string
        enum:
        - cloud
        - server
        - vswitch
  CreateNetworkRequest:
    displayName: CreateNetworkRequest
    type: object
    properties:
      ip_range:
        required: true
        example:
          value: 10.0.0.0/16
        displayName: ip_range
        description: IP range of the whole network which must span all included subnets. Must be one of the private IPv4 ranges of RFC1918. Minimum network size is /24. We highly recommend that you pick a larger network with a /16 netmask.
        type: string
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: Labels
      name:
        required: true
        example:
          value: mynet
        displayName: name
        description: Name of the network
        type: string
      routes:
        required: false
        displayName: routes
        description: Array of routes set in this network. The destination of the route must be one of the private IPv4 ranges of RFC1918. The gateway must be a subnet/IP of the ip_range of the network object. The destination must not overlap with an existing ip_range in any subnets or with any destinations in other routes or with the first IP of the networks ip_range or with 172.31.1.1. The gateway cannot be the first IP of the networks ip_range and also cannot be 172.31.1.1.
        type: array
        items:
          type: Route
      subnets:
        required: false
        displayName: subnets
        description: Array of subnets allocated.
        type: array
        items:
          type: Subnet1
  Subnet1:
    displayName: Subnet1
    type: object
    properties:
      ip_range:
        required: false
        example:
          value: 10.0.1.0/24
        displayName: ip_range
        description: Range to allocate IPs from. Must be a Subnet of the ip_range of the parent network object and must not overlap with any other subnets or with any destinations in routes. Minimum Network size is /30. We suggest that you pick a bigger Network with a /24 netmask.
        type: string
      network_zone:
        required: true
        example:
          value: eu-central
        displayName: network_zone
        description: Name of Network zone. The Location object contains the `network_zone` property each Location belongs to.
        type: string
      type:
        required: true
        displayName: type
        description: Type of Subnetwork
        type: string
        enum:
        - cloud
        - server
        - vswitch
  NetworksResponse1:
    displayName: NetworksResponse1
    type: object
    properties:
      network:
        required: false
        displayName: network
        type: Network
  UpdateNetworkRequest:
    displayName: UpdateNetworkRequest
    type: object
    properties:
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: Labels2
      name:
        required: false
        example:
          value: new-name
        displayName: name
        description: New network name
        type: string
  Labels2:
    displayName: Labels2
    description: User-defined labels (key-value pairs)
    type: object
    properties:
      labelkey:
        required: false
        example:
          value: value
        displayName: labelkey
        type: string
  AddDeleteRouteRequest:
    displayName: AddDeleteRouteRequest
    type: object
    properties:
      destination:
        required: true
        example:
          value: 10.100.1.0/24
        displayName: destination
        description: Destination network or host of this route. Must not overlap with an existing ip_range in any subnets or with any destinations in other routes or with the first IP of the networks ip_range or with 172.31.1.1. Must be one of the private IPv4 ranges of RFC1918.
        type: string
      gateway:
        required: true
        example:
          value: 10.0.1.1
        displayName: gateway
        description: Gateway for the route. Cannot be the first IP of the networks ip_range, an IP behind a vSwitch or 172.31.1.1, as this IP is being used as a gateway for the public network interface of Servers.
        type: string
  AddSubnetRequest:
    displayName: AddSubnetRequest
    type: object
    properties:
      ip_range:
        required: false
        example:
          value: 10.0.1.0/24
        displayName: ip_range
        description: Range to allocate IPs from. Must be a Subnet of the ip_range of the parent network object and must not overlap with any other subnets or with any destinations in routes. If the Subnet is of type vSwitch, it also can not overlap with any gateway in routes. Minimum Network size is /30. We suggest that you pick a bigger Network with a /24 netmask.
        type: string
      network_zone:
        required: true
        example:
          value: eu-central
        displayName: network_zone
        description: Name of Network zone. The Location object contains the `network_zone` property each Location belongs to.
        type: string
      type:
        required: true
        displayName: type
        description: Type of Subnetwork
        type: string
        enum:
        - cloud
        - server
        - vswitch
      vswitch_id:
        required: false
        example:
          value: 1000
        displayName: vswitch_id
        description: ID of the robot vSwitch. Must be supplied if the subnet is of type vswitch.
        type: integer
        format: int32
  ChangeIPRangeRequest:
    displayName: ChangeIPRangeRequest
    type: object
    properties:
      ip_range:
        required: true
        example:
          value: 10.0.0.0/12
        displayName: ip_range
        description: The new prefix for the whole Network
        type: string
  ChangeProtectionRequest1:
    displayName: ChangeProtectionRequest1
    type: object
    properties:
      delete:
        required: false
        example:
          value: true
        displayName: delete
        description: If true, prevents the Network from being deleted
        type: boolean
  DeleteSubnetRequest:
    displayName: DeleteSubnetRequest
    type: object
    properties:
      ip_range:
        required: true
        example:
          value: 10.0.1.0/24
        displayName: ip_range
        description: IP range of subnet to delete
        type: string
  PlacementGroupsResponse:
    displayName: PlacementGroupsResponse
    type: object
    properties:
      meta:
        required: false
