          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
- MeFollowingRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MeFollowingRequest",
      "title": "MeFollowingRequest",
      "type": "object",
      "properties": {
        "ids": {
          "description": "A JSON array of the artist or user [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids).\nFor example: `{ids:[\"74ASZWbe4lXaubB36ztrGX\", \"08td7MxkoHQkXnWAYD8d6Q\"]}`. A maximum of 50 IDs can be sent in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ids"
      ]
    }
- MeFollowingRequest1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MeFollowingRequest1",
      "title": "MeFollowingRequest1",
      "type": "object",
      "properties": {
        "ids": {
          "description": "A JSON array of the artist or user [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `{ids:[\"74ASZWbe4lXaubB36ztrGX\", \"08td7MxkoHQkXnWAYD8d6Q\"]}`. A maximum of 50 IDs can be sent in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
- MePlayerPlayRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MePlayerPlayRequest",
      "title": "MePlayerPlayRequest",
      "example": {
        "context_uri": "spotify:album:5ht7ItJgpBH7W6vJ5BqpPr",
        "offset": {
          "position": 5
        },
        "position_ms": 0
      },
      "type": "object",
      "properties": {
        "context_uri": {
          "description": "Optional. Spotify URI of the context to play.\nValid contexts are albums, artists & playlists.\n`{context_uri:\"spotify:album:1Je1IMUlBXcx1Fz0WE7oPT\"}`",
          "type": "string"
        },
        "uris": {
          "description": "Optional. A JSON array of the Spotify track URIs to play.\nFor example: `{\"uris\": [\"spotify:track:4iV5W9uYEdYUVa79Axb7Rh\", \"spotify:track:1301WleyT98MSxVHPZCA6M\"]}`",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "offset": {
          "description": "Optional. Indicates from where in the context playback should start. Only available when context_uri corresponds to an album or playlist object\n\"position\" is zero based and can’t be negative. Example: `\"offset\": {\"position\": 5}`\n\"uri\" is a string representing the uri of the item to start at. Example: `\"offset\": {\"uri\": \"spotify:track:1301WleyT98MSxVHPZCA6M\"}`",
          "type": "object"
        },
        "position_ms": {
          "description": "Indicates from what position to start playback. Must be a positive number. Passing in a position that is greater than the length of the track will cause the player to start playing the next song.",
          "type": "integer",
          "format": "int32"
        }
      }
    }
- MePlayerRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MePlayerRequest",
      "title": "MePlayerRequest",
      "example": {
        "device_ids": [
          "74ASZWbe4lXaubB36ztrGX"
        ]
      },
      "type": "object",
      "properties": {
        "device_ids": {
          "description": "A JSON array containing the ID of the device on which playback should be started/transferred.<br/>For example:`{device_ids:[\"74ASZWbe4lXaubB36ztrGX\"]}`<br/>_**Note**: Although an array is accepted, only a single device_id is currently supported. Supplying more than one will return `400 Bad Request`_",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "play": {
          "description": "**true**: ensure playback happens on new device.<br/>**false** or not provided: keep the current playback state.",
          "type": "boolean"
        }
      },
      "required": [
        "device_ids"
      ]
    }
- MeShowsRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MeShowsRequest",
      "title": "MeShowsRequest",
      "type": "object",
      "properties": {
        "ids": {
          "description": "A JSON array of the [Spotify IDs](https://developer.spotify.com/documentation/web-api/#spotify-uris-and-ids).  \nA maximum of 50 items can be specified in one request. *Note: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored.*",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
- MeTracksRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MeTracksRequest",
      "title": "MeTracksRequest",
      "type": "object",
      "properties": {
        "ids": {
          "description": "A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `[\"4iV5W9uYEdYUVa79Axb7Rh\", \"1301WleyT98MSxVHPZCA6M\"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ids"
      ]
    }
- MeTracksRequest1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MeTracksRequest1",
      "title": "MeTracksRequest1",
      "type": "object",
      "properties": {
        "ids": {
          "description": "A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `[\"4iV5W9uYEdYUVa79Axb7Rh\", \"1301WleyT98MSxVHPZCA6M\"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
- Meta: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Meta",
      "title": "Meta",
      "type": "object",
      "properties": {
        "analyzer_version": {
          "description": "The version of the Analyzer used to analyze this track.",
          "example": "4.0.0",
          "type": "string"
        },
        "platform": {
          "description": "The platform used to read the track's audio data.",
          "example": "Linux",
          "type": "string"
        },
        "detailed_status": {
          "description": "A detailed status code for this track. If analysis data is missing, this code may explain why.",
          "example": "OK",
          "type": "string"
        },
        "status_code": {
          "description": "The return code of the analyzer process. 0 if successful, 1 if any errors occurred.",
          "example": 0,
          "type": "integer",
          "format": "int32"
        },
        "timestamp": {
          "description": "The Unix timestamp (in seconds) at which this track was analyzed.",
          "example": 1495193577,
          "type": "integer",
          "format": "int64"
        },
        "analysis_time": {
          "description": "The amount of time taken to analyze this track.",
          "example": 6.93906,
          "type": "number"
        },
        "input_process": {
          "description": "The method used to read the track's audio data.",
          "example": "libvorbisfile L+R 44100->22050",
          "type": "string"
        }
      }
    }
- Mode: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "Mode",
      "description": "Indicates the modality (major or minor) of a section, the type of scale from which its melodic content is derived. This field will contain a 0 for \"minor\", a 1 for \"major\", or a -1 for no result. Note that the major key (e.g. C major) could more likely be confused with the minor key at 3 semitones lower (e.g. A minor) as both keys carry the same pitches.",
      "type": "integer",
      "additionalProperties": false,
      "enum": [
        -1,
        0,
        1
      ]
    }
- NotFound1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "NotFound1",
      "title": "NotFound1",
      "type": "object",
      "properties": {
        "error": {
          "id": "ErrorObject",
          "title": "ErrorObject",
          "type": "object",
          "properties": {
            "status": {
              "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
              "type": "integer",
              "minimum": 400.0,
              "maximum": 599.0,
              "format": "int32"
            },
            "message": {
              "description": "A short description of the cause of the error.",
              "type": "string"
            }
          },
          "required": [
            "status",
            "message"
          ]
        }
      },
      "required": [
        "error"
      ]
    }
- PagedAlbums: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PagedAlbums",
      "title": "PagedAlbums",
      "type": "object",
      "properties": {
        "albums": {
          "id": "PagingSimplifiedAlbumObject",
          "title": "PagingSimplifiedAlbumObject",
          "type": "object",
          "properties": {
            "href": {
              "description": "A link to the Web API endpoint returning the full result of the request",
              "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
              "type": "string"
            },
            "limit": {
              "description": "The maximum number of items in the response (as set in the query or by default).",
              "example": 20,
              "type": "integer",
              "format": "int32"
            },
            "next": {
              "description": "URL to the next page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "offset": {
              "description": "The offset of the items returned (as set in the query or by default)",
              "example": 0,
              "type": "integer",
              "format": "int32"
            },
            "previous": {
              "description": "URL to the previous page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "total": {
              "description": "The total number of items available to return.",
              "example": 4,
              "type": "integer",
              "format": "int32"
            },
            "items": {
              "description": "",
              "type": "array",
              "items": {
                "id": "SimplifiedAlbumObject",
                "title": "SimplifiedAlbumObject",
                "description": "The album on which the track appears. The album object includes a link in `href` to full information about the album.",
                "type": "object",
                "properties": {
                  "album_type": {
                    "title": "AlbumType",
                    "description": "The type of the album.",
                    "example": "compilation",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "album",
                      "single",
                      "compilation"
                    ]
                  },
                  "total_tracks": {
                    "description": "The number of tracks in the album.",
                    "example": 9,
                    "type": "integer",
                    "format": "int32"
                  },
                  "available_markets": {
                    "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                    "example": [
                      "CA",
                      "BR",
                      "IT"
                    ],
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "external_urls": {
                    "id": "ExternalUrlObject",
                    "title": "ExternalUrlObject",
                    "description": "External URLs for this chapter.",
                    "type": "object",
                    "properties": {
                      "spotify": {
                        "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                        "type": "string"
                      }
                    }
                  },
                  "href": {
                    "description": "A link to the Web API endpoint providing full details of the album.",
                    "type": "string"
                  },
                  "id": {
                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                    "example": "2up3OPMp9Tb4dAKM2erWXQ",
                    "type": "string"
                  },
                  "images": {
                    "description": "The cover art for the album in various sizes, widest first.",
                    "type": "array",
                    "items": {
                      "id": "ImageObject",
                      "title": "ImageObject",
                      "type": "object",
                      "properties": {
                        "url": {
                          "description": "The source URL of the image.",
                          "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                          "type": "string"
                        },
                        "height": {
                          "description": "The image height in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "width": {
                          "description": "The image width in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        }
                      },
                      "required": [
                        "url",
                        "height",
                        "width"
                      ]
                    }
                  },
                  "name": {
                    "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                    "type": "string"
                  },
                  "release_date": {
                    "description": "The date the album was first released.",
                    "example": "1981-12",
                    "type": "string"
                  },
                  "release_date_precision": {
                    "title": "ReleaseDatePrecision",
                    "description": "The precision with which `release_date` value is known.",
                    "example": "year",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "year",
                      "month",
                      "day"
                    ]
                  },
                  "type": {
                    "description": "The object type.",
                    "type": "string",
                    "enum": [
                      "album"
                    ]
                  },
                  "uri": {
                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                    "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                    "type": "string"
                  },
                  "artists": {
                    "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                    "type": "array",
                    "items": {
                      "id": "SimplifiedArtistObject",
                      "title": "SimplifiedArtistObject",
                      "type": "object",
                      "properties": {
                        "external_urls": {
                          "$ref": "ExternalUrlObject"
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the artist.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                          "type": "string"
                        },
                        "name": {
                          "description": "The name of the artist.",
                          "type": "string"
                        },
                        "type": {
                          "title": "Type",
                          "description": "The object type.",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "artist"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                          "type": "string"
                        }
                      }
                    }
                  },
                  "restrictions": {
                    "id": "AlbumRestrictionObject",
                    "title": "AlbumRestrictionObject",
                    "description": "Included in the response when a content restriction is applied.",
                    "type": "object",
                    "properties": {
                      "reason": {
                        "title": "Reason",
                        "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "market",
                          "product",
                          "explicit"
                        ]
                      }
                    }
                  }
                },
                "required": [
                  "album_type",
                  "total_tracks",
                  "available_markets",
                  "external_urls",
                  "href",
                  "id",
                  "images",
                  "name",
                  "release_date",
                  "release_date_precision",
                  "type",
                  "uri",
                  "artists"
                ]
              }
            }
          },
          "required": [
            "href",
            "limit",
            "next",
            "offset",
            "previous",
            "total",
            "items"
          ]
        }
      },
      "required": [
        "albums"
      ]
    }
- PagedCategories: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PagedCategories",
      "title": "PagedCategories",
      "type": "object",
      "properties": {
        "categories": {
          "id": "Categories",
          "title": "Categories",
          "type": "object",
          "properties": {
            "href": {
              "description": "A link to the Web API endpoint returning the full result of the request",
              "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
              "type": "string"
            },
            "limit": {
              "description": "The maximum number of items in the response (as set in the query or by default).",
              "example": 20,
              "type": "integer",
              "format": "int32"
            },
            "next": {
              "description": "URL to the next page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "offset": {
              "description": "The offset of the items returned (as set in the query or by default)",
              "example": 0,
              "type": "integer",
              "format": "int32"
            },
            "previous": {
              "description": "URL to the previous page of items. ( `null` if none)",
              "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
              "type": [
                "string",
                "null"
              ]
            },
            "total": {
              "description": "The total number of items available to return.",
              "example": 4,
              "type": "integer",
              "format": "int32"
            },
            "items": {
              "description": "",
              "type": "array",
              "items": {
                "id": "CategoryObject",
                "title": "CategoryObject",
                "type": "object",
                "properties": {
                  "href": {
                    "description": "A link to the Web API endpoint returning full details of the category.",
                    "type": "string"
                  },
                  "icons": {
                    "description": "The category icon, in various sizes.",
                    "type": "array",
                    "items": {
                      "id": "ImageObject",
                      "title": "ImageObject",
                      "type": "object",
                      "properties": {
                        "url": {
                          "description": "The source URL of the image.",
                          "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                          "type": "string"
                        },
                        "height": {
                          "description": "The image height in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        },
                        "width": {
                          "description": "The image width in pixels.",
                          "example": 300,
                          "type": [
                            "integer",
                            "null"
                          ],
                          "format": "int32"
                        }
                      },
                      "required": [
                        "url",
                        "height",
                        "width"
                      ]
                    }
                  },
                  "id": {
                    "description": "The [Spotify category ID](/documentation/web-api/concepts/spotify-uris-ids) of the category.",
                    "example": "equal",
                    "type": "string"
                  },
                  "name": {
                    "description": "The name of the category.",
                    "example": "EQUAL",
                    "type": "string"
                  }
                },
                "required": [
                  "href",
                  "icons",
                  "id",
                  "name"
                ]
              }
            }
          },
          "required": [
            "href",
            "limit",
            "next",
            "offset",
            "previous",
            "total",
            "items"
          ]
        }
      },
      "required": [
        "categories"
      ]
    }
- PlaylistsFollowersRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistsFollowersRequest",
      "title": "PlaylistsFollowersRequest",
      "example": {
        "public": false
      },
      "type": "object",
      "properties": {
        "public": {
          "description": "Defaults to `true`. If `true` the playlist will be included in user's public playlists, if `false` it will remain private.",
          "type": "boolean"
        }
      }
    }
- PlaylistsRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistsRequest",
      "title": "PlaylistsRequest",
      "example": {
        "name": "Updated Playlist Name",
        "description": "Updated playlist description",
        "public": false
      },
      "type": "object",
      "properties": {
        "name": {
          "description": "The new name for the playlist, for example `\"My New Playlist Title\"`",
          "type": "string"
        },
        "public": {
          "description": "If `true` the playlist will be public, if `false` it will be private.",
          "type": "boolean"
        },
        "collaborative": {
          "description": "If `true`, the playlist will become collaborative and other users will be able to modify the playlist in their Spotify client. <br/>\n_**Note**: You can only set `collaborative` to `true` on non-public playlists._",
          "type": "boolean"
        },
        "description": {
          "description": "Value for playlist description as displayed in Spotify Clients and in the Web API.",
          "type": "string"
        }
      }
    }
- PlaylistsTracksRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistsTracksRequest",
      "title": "PlaylistsTracksRequest",
      "type": "object",
      "properties": {
        "uris": {
          "description": "A JSON array of the [Spotify URIs](/documentation/web-api/concepts/spotify-uris-ids) to add. For example: `{\"uris\": [\"spotify:track:4iV5W9uYEdYUVa79Axb7Rh\",\"spotify:track:1301WleyT98MSxVHPZCA6M\", \"spotify:episode:512ojhOuo1ktJprKbVcKyQ\"]}`<br/>A maximum of 100 items can be added in one request. _**Note**: if the `uris` parameter is present in the query string, any URIs listed here in the body will be ignored._",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "position": {
          "description": "The position to insert the items, a zero-based index. For example, to insert the items in the first position: `position=0` ; to insert the items in the third position: `position=2`. If omitted, the items will be appended to the playlist. Items are added in the order they appear in the uris array. For example: `{\"uris\": [\"spotify:track:4iV5W9uYEdYUVa79Axb7Rh\",\"spotify:track:1301WleyT98MSxVHPZCA6M\"], \"position\": 3}`",
          "type": "integer",
          "format": "int32"
        }
      }
    }
- PlaylistsTracksRequest1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistsTracksRequest1",
      "title": "PlaylistsTracksRequest1",
      "example": {
        "range_start": 1,
        "insert_before": 3,
        "range_length": 2
      },
      "type": "object",
      "properties": {
        "uris": {
          "description": "",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "range_start": {
          "description": "The position of the first item to be reordered.",
          "type": "integer",
          "format": "int32"
        },
        "insert_before": {
          "description": "The position where the items should be inserted.<br/>To reorder the items to the end of the playlist, simply set _insert_before_ to the position after the last item.<br/>Examples:<br/>To reorder the first item to the last position in a playlist with 10 items, set _range_start_ to 0, and _insert_before_ to 10.<br/>To reorder the last item in a playlist with 10 items to the start of the playlist, set _range_start_ to 9, and _insert_before_ to 0.",
          "type": "integer",
          "format": "int32"
        },
        "range_length": {
          "description": "The amount of items to be reordered. Defaults to 1 if not set.<br/>The range of items to be reordered begins from the _range_start_ position, and includes the _range_length_ subsequent items.<br/>Example:<br/>To move the items at index 9-10 to the start of the playlist, _range_start_ is set to 9, and _range_length_ is set to 2.",
          "type": "integer",
          "format": "int32"
        },
        "snapshot_id": {
          "description": "The playlist's snapshot ID against which you want to make the changes.",
          "type": "string"
        }
      }
    }
- PlaylistsTracksRequest2: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistsTracksRequest2",
      "title": "PlaylistsTracksRequest2",
      "type": "object",
      "properties": {
        "tracks": {
          "description": "An array of objects containing [Spotify URIs](/documentation/web-api/concepts/spotify-uris-ids) of the tracks or episodes to remove.\nFor example: `{ \"tracks\": [{ \"uri\": \"spotify:track:4iV5W9uYEdYUVa79Axb7Rh\" },{ \"uri\": \"spotify:track:1301WleyT98MSxVHPZCA6M\" }] }`. A maximum of 100 objects can be sent at once.",
          "type": "array",
          "items": {
            "id": "Track1",
            "title": "Track1",
            "type": "object",
            "properties": {
              "uri": {
                "description": "Spotify URI",
                "type": "string"
              }
            }
          }
        },
        "snapshot_id": {
          "description": "The playlist's snapshot ID against which you want to make the changes.\nThe API will validate that the specified items exist and in the specified positions and make the changes,\neven if more recent changes have been made to the playlist.",
          "type": "string"
        }
      },
      "required": [
        "tracks"
      ]
    }
- PlaylistSnapshotId: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "PlaylistSnapshotId",
      "title": "PlaylistSnapshotId",
      "type": "object",
      "properties": {
        "snapshot_id": {
          "example": "abc",
          "type": "string"
        }
      }
    }
- Reason: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "Reason",
      "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "market",
        "product",
        "explicit"
      ]
    }
- ReleaseDatePrecision: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "ReleaseDatePrecision",
      "description": "The precision with which `release_date` value is known.",
      "example": "year",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "year",
        "month",
        "day"
      ]
    }
- SearchItems: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SearchItems",
      "title": "SearchItems",
      "type": "object",
      "properties": {
        "tracks": {
          "id": "PagingTrackObject",
          "title": "PagingTrackObject",
          "type": "object",
          "properties": {
            "href": {
              "description": "A link to the Web API endpoint returning the full result of the request",
              "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
              "type": "string"
            },
            "limit": {
