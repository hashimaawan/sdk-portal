  <resources base="https://api.spotify.com/v1">
    <resource id="_albumsid" path="/albums/{id}">
      <param name="id" style="template" type="xsd:string" required="true">
        <doc title="id" xml:lang="en" />
      </param>
      <method id="get-an-album" name="GET">
        <doc title="get-an-album" xml:lang="en">Get Spotify catalog information for a single album.
</doc>
        <request>
          <param name="market" style="query" type="xsd:string">
            <doc title="market" xml:lang="en" />
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">An album</doc>
          <representation element="schemas:get-an-album200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Bad or expired token. This can happen if the user revoked a token or
the access token has expired. You should re-authenticate the user.</doc>
          <representation element="schemas:get-an-album401_Response0" mediaType="application/json" />
        </response>
        <response status="403">
          <doc title="403" xml:lang="en">Bad OAuth request (wrong consumer key, bad nonce, expired
timestamp...). Unfortunately, re-authenticating the user won't help here.</doc>
          <representation element="schemas:get-an-album403_Response0" mediaType="application/json" />
        </response>
        <response status="429">
          <doc title="429" xml:lang="en">The app has exceeded its rate limits.</doc>
          <representation element="schemas:get-an-album429_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
    <resource id="_albums" path="/albums">
      <method id="get-multiple-albums" name="GET">
        <doc title="get-multiple-albums" xml:lang="en">Get Spotify catalog information for multiple albums identified by their Spotify IDs.
</doc>
        <request>
          <param name="ids" style="query" type="xsd:string" required="true">
            <doc title="ids" xml:lang="en" />
          </param>
          <param name="market" style="query" type="xsd:string">
            <doc title="market" xml:lang="en" />
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">A set of albums</doc>
          <representation element="schemas:get-multiple-albums200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Bad or expired token. This can happen if the user revoked a token or
the access token has expired. You should re-authenticate the user.</doc>
          <representation element="schemas:get-multiple-albums401_Response0" mediaType="application/json" />
        </response>
        <response status="403">
          <doc title="403" xml:lang="en">Bad OAuth request (wrong consumer key, bad nonce, expired
timestamp...). Unfortunately, re-authenticating the user won't help here.</doc>
          <representation element="schemas:get-multiple-albums403_Response0" mediaType="application/json" />
        </response>
        <response status="429">
          <doc title="429" xml:lang="en">The app has exceeded its rate limits.</doc>
          <representation element="schemas:get-multiple-albums429_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
    <resource id="_albumsidtracks" path="/albums/{id}/tracks">
      <param name="id" style="template" type="xsd:string" required="true">
        <doc title="id" xml:lang="en" />
      </param>
      <method id="get-an-albums-tracks" name="GET">
        <doc title="get-an-albums-tracks" xml:lang="en">Get Spotify catalog information about an album’s tracks.
Optional parameters can be used to limit the number of tracks returned.
</doc>
        <request>
          <param name="market" style="query" type="xsd:string">
            <doc title="market" xml:lang="en" />
          </param>
          <param name="limit" style="query" type="xsd:integer" default="20">
            <doc title="limit" xml:lang="en" />
          </param>
          <param name="offset" style="query" type="xsd:integer" default="0">
            <doc title="offset" xml:lang="en" />
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">Pages of tracks</doc>
          <representation element="schemas:get-an-albums-tracks200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Bad or expired token. This can happen if the user revoked a token or
the access token has expired. You should re-authenticate the user.</doc>
          <representation element="schemas:get-an-albums-tracks401_Response0" mediaType="application/json" />
        </response>
        <response status="403">
          <doc title="403" xml:lang="en">Bad OAuth request (wrong consumer key, bad nonce, expired
timestamp...). Unfortunately, re-authenticating the user won't help here.</doc>
          <representation element="schemas:get-an-albums-tracks403_Response0" mediaType="application/json" />
        </response>
        <response status="429">
          <doc title="429" xml:lang="en">The app has exceeded its rate limits.</doc>
          <representation element="schemas:get-an-albums-tracks429_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
    <resource id="_mealbums" path="/me/albums">
      <method id="get-users-saved-albums" name="GET">
        <doc title="get-users-saved-albums" xml:lang="en">Get a list of the albums saved in the current Spotify user's 'Your Music' library.
</doc>
        <request>
          <param name="limit" style="query" type="xsd:integer" default="20">
            <doc title="limit" xml:lang="en" />
          </param>
          <param name="offset" style="query" type="xsd:integer" default="0">
            <doc title="offset" xml:lang="en" />
          </param>
          <param name="market" style="query" type="xsd:string">
            <doc title="market" xml:lang="en" />
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">Pages of albums</doc>
          <representation element="schemas:get-users-saved-albums200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
