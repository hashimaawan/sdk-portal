                      }
                    },
                    "required": [
                      "KmsKey"
                    ]
                  },
                  "EnableMinimumEncryptionConfiguration": {
                    "type": "boolean"
                  }
                }
              },
              "State": {
                "title": "WorkGroupState2",
                "description": "The workgroup state that will be updated for the given workgroup.",
