                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
