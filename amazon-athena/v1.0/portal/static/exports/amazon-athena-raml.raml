/#X-Amz-Target=AmazonAthena.GetQueryResults:
  post:
    description: <p>Streams the results of a single query execution specified by <code>QueryExecutionId</code> from the Athena query results location in Amazon S3. For more information, see <a href="https://docs.aws.amazon.com/athena/latest/ug/querying.html">Working with query results, recent queries, and output files</a> in the <i>Amazon Athena User Guide</i>. This request does not execute the query but returns results. Use <a>StartQueryExecution</a> to run a query.</p> <p>To stream query results successfully, the IAM principal with permission to call <code>GetQueryResults</code> also must have permissions to the Amazon S3 <code>GetObject</code> action for the Athena query results location.</p> <important> <p>IAM principals with permission to the Amazon S3 <code>GetObject</code> action for the query results location are able to retrieve query results from Amazon S3 even if permission to the <code>GetQueryResults</code> action is denied. To restrict user or role access, ensure that Amazon S3 permissions to the Athena query location are denied.</p> </important>
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.GetQueryResults
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    queryParameters:
      MaxResults:
        description: Pagination limit
        type: string
        required: false
        displayName: MaxResults
      NextToken:
        description: Pagination token
        type: string
        required: false
        displayName: NextToken
    body:
      application/json:
        schema: |
          {
            "id": "GetQueryResultsInput",
            "title": "GetQueryResultsInput",
            "type": "object",
            "properties": {
              "QueryExecutionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "\\S+"
              },
              "NextToken": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "MaxResults": {
                "type": "integer",
                "minimum": 1.0,
                "maximum": 1000.0,
                "format": "int32"
              }
            },
            "required": [
              "QueryExecutionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "GetQueryResultsOutput",
                "title": "GetQueryResultsOutput",
                "type": "object",
                "properties": {
                  "UpdateCount": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "ResultSet": {
                    "id": "ResultSet2",
                    "title": "ResultSet2",
                    "type": "object",
                    "properties": {
                      "Rows": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "id": "Row",
                          "title": "Row",
                          "description": "The rows that make up a query result table.",
                          "type": "object",
                          "properties": {
                            "Data": {
                              "description": "",
                              "type": "array",
                              "items": {
                                "id": "Datum",
                                "title": "Datum",
                                "description": "A piece of data (a field in the table).",
                                "type": "object",
                                "properties": {
                                  "VarCharValue": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        }
                      },
                      "ResultSetMetadata": {
                        "id": "ResultSetMetadata2",
                        "title": "ResultSetMetadata2",
                        "type": "object",
                        "properties": {
                          "ColumnInfo": {
                            "description": "",
                            "type": "array",
                            "items": {
                              "id": "ColumnInfo",
                              "title": "ColumnInfo",
                              "description": "Information about the columns in a query execution result.",
                              "type": "object",
                              "properties": {
                                "Name": {
                                  "type": "string"
                                },
                                "Type": {
                                  "type": "string"
                                },
                                "CatalogName": {
                                  "type": "string"
                                },
                                "SchemaName": {
                                  "type": "string"
                                },
                                "TableName": {
                                  "type": "string"
                                },
                                "Label": {
                                  "type": "string"
                                },
                                "Precision": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "Scale": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "Nullable": {
                                  "title": "ColumnNullable2",
                                  "description": "Indicates the column's nullable status.",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "NOT_NULL",
                                    "NULLABLE",
                                    "UNKNOWN"
                                  ]
                                },
                                "CaseSensitive": {
                                  "type": "boolean"
                                }
                              },
                              "required": [
                                "Name",
                                "Type"
                              ]
                            }
                          }
                        }
                      }
                    }
                  },
                  "NextToken": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: TooManyRequestsException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.GetQueryRuntimeStatistics:
  post:
    description: Returns query execution runtime statistics related to a single execution of a query if you have access to the workgroup in which the query ran. Query execution runtime statistics are returned only when <a>QueryExecutionStatus$State</a> is in a SUCCEEDED or FAILED state. Stage-level input and output row count and data size statistics are not shown when a query has row-level filters defined in Lake Formation.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.GetQueryRuntimeStatistics
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "GetQueryRuntimeStatisticsInput",
            "title": "GetQueryRuntimeStatisticsInput",
            "type": "object",
            "properties": {
              "QueryExecutionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "\\S+"
              }
            },
            "required": [
              "QueryExecutionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "GetQueryRuntimeStatisticsOutput",
                "title": "GetQueryRuntimeStatisticsOutput",
                "type": "object",
                "properties": {
                  "QueryRuntimeStatistics": {
                    "id": "QueryRuntimeStatistics2",
                    "title": "QueryRuntimeStatistics2",
                    "type": "object",
                    "properties": {
                      "Timeline": {
                        "id": "QueryRuntimeStatisticsTimeline",
                        "title": "QueryRuntimeStatisticsTimeline",
                        "description": "Timeline statistics such as query queue time, planning time, execution time, service processing time, and total execution time.",
                        "type": "object",
                        "properties": {
                          "QueryQueueTimeInMillis": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "QueryPlanningTimeInMillis": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "EngineExecutionTimeInMillis": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "ServiceProcessingTimeInMillis": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "TotalExecutionTimeInMillis": {
                            "type": "integer",
                            "format": "int32"
                          }
                        }
                      },
                      "Rows": {
                        "id": "QueryRuntimeStatisticsRows",
                        "title": "QueryRuntimeStatisticsRows",
                        "description": "Statistics such as input rows and bytes read by the query, rows and bytes output by the query, and the number of rows written by the query.",
                        "type": "object",
                        "properties": {
                          "InputRows": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "InputBytes": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "OutputBytes": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "OutputRows": {
                            "type": "integer",
                            "format": "int32"
                          }
                        }
                      },
                      "OutputStage": {
                        "id": "OutputStage",
                        "title": "OutputStage",
                        "type": "object",
                        "properties": {
                          "StageId": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "State": {
                            "type": "string"
                          },
                          "OutputBytes": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "OutputRows": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "InputBytes": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "InputRows": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "ExecutionTime": {
                            "type": "integer",
                            "format": "int32"
                          },
                          "QueryStagePlan": {
                            "id": "QueryStagePlan",
                            "title": "QueryStagePlan",
                            "type": "object",
                            "properties": {
                              "Name": {
                                "type": "string"
                              },
                              "Identifier": {
                                "type": "string"
                              },
                              "Children": {
                                "description": "",
                                "type": "array",
                                "items": {
                                  "id": "QueryStagePlanNode",
                                  "title": "QueryStagePlanNode",
                                  "description": "Stage plan information such as name, identifier, sub plans, and remote sources.",
                                  "type": "object",
                                  "properties": {
                                    "Name": {
                                      "type": "string"
                                    },
                                    "Identifier": {
                                      "type": "string"
                                    },
                                    "Children": {
                                      "description": "",
                                      "type": "array",
                                      "items": {
                                        "$ref": "QueryStagePlanNode"
                                      }
                                    },
                                    "RemoteSources": {
                                      "description": "",
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  }
                                }
                              },
                              "RemoteSources": {
                                "description": "",
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            }
                          },
                          "SubStages": {
                            "description": "",
                            "type": "array",
                            "items": {
                              "id": "QueryStage",
                              "title": "QueryStage",
                              "description": "Stage statistics such as input and output rows and bytes, execution time and stage state. This information also includes substages and the query stage plan.",
                              "type": "object",
                              "properties": {
                                "StageId": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "State": {
                                  "type": "string"
                                },
                                "OutputBytes": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "OutputRows": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "InputBytes": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "InputRows": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "ExecutionTime": {
                                  "type": "integer",
                                  "format": "int32"
                                },
                                "QueryStagePlan": {
                                  "$ref": "QueryStagePlan"
                                },
                                "SubStages": {
                                  "description": "",
                                  "type": "array",
                                  "items": {
                                    "$ref": "QueryStage"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.GetSession:
  post:
    description: Gets the full details of a previously created session, including the session status and configuration.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.GetSession
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "GetSessionRequest",
            "title": "GetSessionRequest",
            "type": "object",
            "properties": {
              "SessionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              }
            },
            "required": [
              "SessionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "GetSessionResponse",
                "title": "GetSessionResponse",
                "type": "object",
                "properties": {
                  "SessionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "Description": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                  },
                  "WorkGroup": {
                    "type": "string",
                    "pattern": "[a-zA-Z0-9._-]{1,128}"
                  },
                  "EngineVersion": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "EngineConfiguration": {
                    "id": "EngineConfiguration1",
                    "title": "EngineConfiguration1",
                    "type": "object",
                    "properties": {
                      "MaxConcurrentDpus": {
                        "type": "integer",
                        "minimum": 2.0,
                        "maximum": 5000.0,
                        "format": "int32"
                      },
                      "CoordinatorDpuSize": {
                        "type": "integer",
                        "minimum": 1.0,
                        "maximum": 1.0,
                        "format": "int32"
                      },
                      "DefaultExecutorDpuSize": {
                        "type": "integer",
                        "minimum": 1.0,
                        "maximum": 1.0,
                        "format": "int32"
                      },
                      "AdditionalConfigs": {
                        "id": "AdditionalConfigs",
                        "title": "AdditionalConfigs",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string",
                          "maxLength": 51200
                        }
                      }
                    },
                    "required": [
                      "MaxConcurrentDpus"
                    ]
                  },
                  "NotebookVersion": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "SessionConfiguration": {
                    "id": "SessionConfiguration2",
                    "title": "SessionConfiguration2",
                    "type": "object",
                    "properties": {
                      "ExecutionRole": {
                        "type": "string",
                        "minLength": 20,
                        "maxLength": 2048,
                        "pattern": "^arn:aws[a-z\\-]*:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$"
                      },
                      "WorkingDirectory": {
                        "type": "string"
                      },
                      "IdleTimeoutSeconds": {
                        "type": "integer",
                        "format": "int32"
                      },
                      "EncryptionConfiguration": {
                        "id": "EncryptionConfiguration",
                        "title": "EncryptionConfiguration",
                        "description": "If query and calculation results are encrypted in Amazon S3, indicates the encryption option used (for example, <code>SSE_KMS</code> or <code>CSE_KMS</code>) and key information.",
                        "type": "object",
                        "properties": {
                          "EncryptionOption": {
                            "title": "EncryptionOption1",
                            "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "SSE_S3",
                              "SSE_KMS",
                              "CSE_KMS"
                            ]
                          },
                          "KmsKey": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "EncryptionOption"
                        ]
                      }
                    }
                  },
                  "Status": {
                    "id": "Status3",
                    "title": "Status3",
                    "type": "object",
                    "properties": {
                      "StartDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "LastModifiedDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "EndDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "IdleSinceDateTime": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "State": {
                        "title": "SessionState1",
                        "description": "<p>The state of the session. A description of each state follows.</p> <p> <code>CREATING</code> - The session is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The session has been started.</p> <p> <code>IDLE</code> - The session is able to accept a calculation.</p> <p> <code>BUSY</code> - The session is processing another task and is unable to accept a calculation.</p> <p> <code>TERMINATING</code> - The session is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The session and its resources are no longer running.</p> <p> <code>DEGRADED</code> - The session has no healthy coordinators.</p> <p> <code>FAILED</code> - Due to a failure, the session and its resources are no longer running.</p>",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "CREATING",
                          "CREATED",
                          "IDLE",
                          "BUSY",
                          "TERMINATING",
                          "TERMINATED",
                          "DEGRADED",
                          "FAILED"
                        ]
                      },
                      "StateChangeReason": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                      }
                    }
                  },
                  "Statistics": {
                    "id": "Statistics3",
                    "title": "Statistics3",
                    "type": "object",
                    "properties": {
                      "DpuExecutionInMillis": {
                        "type": "integer",
                        "format": "int32"
                      }
                    }
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.GetSessionStatus:
