          </param>
          <param name="step" style="query" type="xsd:string">
            <doc title="step" xml:lang="en">Resolution of results in seconds</doc>
          </param>
        </request>
        <response status="200">
          <doc title="200" xml:lang="en">The `metrics` key in the reply contains a metrics object with this structure</doc>
          <representation element="schemas:GetMetricsforaLoadBalancer200_Response0" mediaType="application/json" />
        </response>
      </method>
    </resource>
