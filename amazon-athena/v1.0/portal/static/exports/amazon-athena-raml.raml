          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "[a-zA-Z_][a-zA-Z0-9_@:]{1,256}"
        },
        "QueryStatement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 262144
        },
