                        "description",
                        "html_description",
                        "explicit",
                        "external_urls",
                        "href",
                        "id",
                        "images",
                        "is_externally_hosted",
                        "languages",
                        "media_type",
                        "name",
                        "publisher",
                        "type",
                        "uri",
