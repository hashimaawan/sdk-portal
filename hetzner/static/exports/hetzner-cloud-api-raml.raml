/firewalls:
  /{id}:
    uriParameters:
      id:
        description: ID of the resource
        type: integer
        required: true
        displayName: id
    /actions:
      uriParameters: {}
      /apply_to_resources:
        uriParameters: {}
        post:
          description: >
            Applies one Firewall to multiple resources.


            Currently servers (public network interface) and label selectors are supported.


            #### Call specific error codes


            | Code                          | Description                                                   |

            |-------------------------------|---------------------------------------------------------------|

            | `firewall_already_applied`    | Firewall was already applied on resource                      |

            | `incompatible_network_type`   | The Network type is incompatible for the given resource       |

            | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              enum:
              - application/json
          body:
            application/json:
              schema: |
                {
                  "id": "ApplyToResourcesRequest",
                  "title": "ApplyToResourcesRequest",
                  "example": {
                    "apply_to": [
                      {
                        "server": {
                          "id": 42
                        },
                        "type": "server"
                      }
                    ]
                  },
                  "type": "object",
                  "properties": {
                    "apply_to": {
                      "description": "Resources the Firewall should be applied to",
                      "type": "array",
                      "items": {
                        "id": "FirewallApplyToResources",
                        "title": "FirewallApplyToResources",
                        "type": "object",
                        "properties": {
                          "label_selector": {
                            "id": "LabelSelector5",
                            "title": "LabelSelector5",
                            "description": "Configuration for type label_selector, required if type is `label_selector`",
                            "type": "object",
                            "properties": {
                              "selector": {
                                "description": "Label selector",
                                "example": "env=prod",
                                "type": "string"
                              }
                            },
                            "required": [
                              "selector"
                            ]
                          },
                          "server": {
                            "id": "Server9",
                            "title": "Server9",
                            "description": "Configuration for type server, required if type is `server`",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "ID of the Server",
                                "type": "integer",
                                "format": "int32"
                              }
                            },
                            "required": [
                              "id"
                            ]
                          },
                          "type": {
                            "title": "Type7",
                            "description": "Type of the resource",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "server",
                              "label_selector"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "apply_to"
                  ]
                }
              example: '{"apply_to":[{"server":{"id":42},"type":"server"}]}'
          responses:
            '201':
              description: The `actions` key contains multiple `apply_firewall` Actions
              body:
                application/json:
                  schema: |
                    {
                      "id": "ActionsResponse",
                      "title": "ActionsResponse",
                      "example": {
                        "actions": [
                          {
                            "command": "apply_firewall",
                            "error": {
                              "code": "action_failed",
                              "message": "Action failed"
                            },
                            "finished": "2016-01-30T23:56:00+00:00",
                            "id": 14,
                            "progress": 100,
                            "resources": [
                              {
                                "id": 42,
                                "type": "server"
                              },
                              {
                                "id": 38,
                                "type": "firewall"
                              }
                            ],
                            "started": "2016-01-30T23:55:00+00:00",
                            "status": "success"
                          }
                        ]
                      },
                      "type": "object",
                      "properties": {
                        "actions": {
                          "description": "",
                          "type": "array",
                          "items": {
                            "id": "Action",
                            "title": "Action",
                            "type": "object",
                            "properties": {
                              "command": {
                                "description": "Command executed in the Action",
                                "example": "start_server",
                                "type": "string"
                              },
                              "error": {
                                "id": "Error",
                                "title": "Error",
                                "description": "Error message for the Action if error occurred, otherwise null",
                                "type": [
                                  "object",
                                  "null"
                                ],
                                "properties": {
                                  "code": {
                                    "description": "Fixed machine readable code",
                                    "example": "action_failed",
                                    "type": "string"
                                  },
                                  "message": {
                                    "description": "Humanized error message",
                                    "example": "Action failed",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "code",
                                  "message"
                                ]
                              },
                              "finished": {
                                "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
                                "example": "2016-01-30T23:55:00+00:00",
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "id": {
                                "description": "ID of the Resource",
                                "example": 42,
                                "type": "integer",
                                "format": "int32"
                              },
                              "progress": {
                                "description": "Progress of Action in percent",
                                "example": 100,
                                "type": "number"
                              },
                              "resources": {
                                "description": "Resources the Action relates to",
                                "type": "array",
                                "items": {
                                  "id": "Resource",
                                  "title": "Resource",
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "description": "ID of the Resource",
                                      "example": 42,
                                      "type": "integer",
                                      "format": "int32"
                                    },
                                    "type": {
                                      "description": "Type of resource referenced",
                                      "example": "server",
                                      "type": "string"
                                    }
                                  },
                                  "required": [
                                    "id",
                                    "type"
                                  ]
                                }
                              },
                              "started": {
                                "description": "Point in time when the Action was started (in ISO-8601 format)",
                                "example": "2016-01-30T23:55:00+00:00",
                                "type": "string"
                              },
                              "status": {
                                "title": "Status",
                                "description": "Status of the Action",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "success",
                                  "running",
                                  "error"
                                ]
                              }
                            },
                            "required": [
                              "command",
                              "error",
                              "finished",
                              "id",
                              "progress",
                              "resources",
                              "started",
                              "status"
                            ]
                          }
                        },
                        "meta": {
                          "id": "Meta",
                          "title": "Meta",
                          "type": "object",
                          "properties": {
                            "pagination": {
                              "id": "Pagination",
                              "title": "Pagination",
                              "type": "object",
                              "properties": {
                                "last_page": {
                                  "description": "ID of the last page available. Can be null if the current page is the last one.",
                                  "example": 4,
                                  "type": [
                                    "number",
                                    "null"
                                  ]
                                },
                                "next_page": {
                                  "description": "ID of the next page. Can be null if the current page is the last one.",
                                  "example": 4,
                                  "type": [
                                    "number",
                                    "null"
                                  ]
                                },
                                "page": {
                                  "description": "Current page number",
                                  "example": 3,
                                  "type": "number"
                                },
                                "per_page": {
                                  "description": "Maximum number of items shown per page in the response",
                                  "example": 25,
                                  "type": "number"
                                },
                                "previous_page": {
                                  "description": "ID of the previous page. Can be null if the current page is the first one.",
                                  "example": 2,
                                  "type": [
                                    "number",
                                    "null"
                                  ]
                                },
                                "total_entries": {
                                  "description": "The total number of entries that exist in the database for this query. Nullable if unknown.",
                                  "example": 100,
                                  "type": [
                                    "number",
                                    "null"
                                  ]
                                }
                              },
                              "required": [
                                "last_page",
                                "next_page",
                                "page",
                                "per_page",
                                "previous_page",
                                "total_entries"
                              ]
                            }
                          },
                          "required": [
                            "pagination"
                          ]
                        }
                      },
                      "required": [
                        "actions"
                      ]
                    }
