    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.ListWorkGroups
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    queryParameters:
      MaxResults:
        description: Pagination limit
        type: string
        required: false
        displayName: MaxResults
      NextToken:
        description: Pagination token
        type: string
        required: false
        displayName: NextToken
    body:
      application/json:
        schema: |
          {
            "id": "ListWorkGroupsInput",
            "title": "ListWorkGroupsInput",
            "type": "object",
            "properties": {
              "NextToken": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "MaxResults": {
                "type": "integer",
                "minimum": 1.0,
                "maximum": 50.0,
                "format": "int32"
              }
            }
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "ListWorkGroupsOutput",
                "title": "ListWorkGroupsOutput",
                "type": "object",
                "properties": {
                  "WorkGroups": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "WorkGroupSummary",
                      "title": "WorkGroupSummary",
                      "description": "The summary information for the workgroup, which includes its name, state, description, and the date and time it was created.",
                      "type": "object",
                      "properties": {
                        "Name": {
                          "type": "string",
                          "pattern": "[a-zA-Z0-9._-]{1,128}"
                        },
                        "State": {
                          "title": "WorkGroupState1",
                          "description": "The state of the workgroup.",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "ENABLED",
                            "DISABLED"
                          ]
                        },
                        "Description": {
                          "type": "string",
                          "minLength": 0,
                          "maxLength": 1024
                        },
                        "CreationTime": {
                          "type": "string",
                          "format": "date-time"
                        },
                        "EngineVersion": {
                          "id": "EngineVersion1",
                          "title": "EngineVersion1",
                          "type": "object",
                          "properties": {
                            "SelectedEngineVersion": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 128
                            },
                            "EffectiveEngineVersion": {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 128
                            }
                          }
                        }
                      }
                    },
                    "minItems": 0,
                    "maxItems": 50
                  },
                  "NextToken": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.StartCalculationExecution:
  post:
    description: Submits calculations for execution within a session. You can supply the code to run as an inline code block within the request.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.StartCalculationExecution
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "StartCalculationExecutionRequest",
            "title": "StartCalculationExecutionRequest",
            "type": "object",
            "properties": {
              "SessionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "Description": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "CalculationConfiguration": {
                "id": "GetCalculationExecutionCodeResponse",
                "title": "GetCalculationExecutionCodeResponse",
                "type": "object",
                "properties": {
                  "CodeBlock": {
                    "type": "string",
                    "maxLength": 68000
                  }
                }
              },
              "CodeBlock": {
                "type": "string",
                "maxLength": 68000
              },
              "ClientRequestToken": {
                "type": "string",
                "minLength": 32,
                "maxLength": 128
              }
            },
            "required": [
              "SessionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "StartCalculationExecutionResponse",
                "title": "StartCalculationExecutionResponse",
                "type": "object",
                "properties": {
                  "CalculationExecutionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 36
                  },
                  "State": {
                    "title": "CalculationExecutionState4",
                    "description": "<p> <code>CREATING</code> - The calculation is in the process of being created.</p> <p> <code>CREATED</code> - The calculation has been created and is ready to run.</p> <p> <code>QUEUED</code> - The calculation has been queued for processing.</p> <p> <code>RUNNING</code> - The calculation is running.</p> <p> <code>CANCELING</code> - A request to cancel the calculation has been received and the system is working to stop it.</p> <p> <code>CANCELED</code> - The calculation is no longer running as the result of a cancel request.</p> <p> <code>COMPLETED</code> - The calculation has completed without error.</p> <p> <code>FAILED</code> - The calculation failed and is no longer running.</p>",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "CREATING",
                      "CREATED",
                      "QUEUED",
                      "RUNNING",
                      "CANCELING",
                      "CANCELED",
                      "COMPLETED",
                      "FAILED"
                    ]
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.StartQueryExecution:
  post:
    description: Runs the SQL query statements contained in the <code>Query</code>. Requires you to have access to the workgroup in which the query ran. Running queries against an external catalog requires <a>GetDataCatalog</a> permission to the catalog. For code samples using the Amazon Web Services SDK for Java, see <a href="http://docs.aws.amazon.com/athena/latest/ug/code-samples.html">Examples and Code Samples</a> in the <i>Amazon Athena User Guide</i>.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.StartQueryExecution
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "StartQueryExecutionInput",
            "title": "StartQueryExecutionInput",
            "type": "object",
            "properties": {
              "QueryString": {
                "type": "string",
                "minLength": 1,
                "maxLength": 262144
              },
              "ClientRequestToken": {
                "type": "string",
                "minLength": 32,
                "maxLength": 128
              },
              "QueryExecutionContext": {
                "id": "QueryExecutionContext1",
                "title": "QueryExecutionContext1",
                "type": "object",
                "properties": {
                  "Database": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                  },
                  "Catalog": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  }
                }
              },
              "ResultConfiguration": {
                "id": "ResultConfiguration1",
                "title": "ResultConfiguration1",
                "type": "object",
                "properties": {
                  "OutputLocation": {
                    "type": "string"
                  },
                  "EncryptionConfiguration": {
                    "id": "EncryptionConfiguration2",
                    "title": "EncryptionConfiguration2",
                    "type": "object",
                    "properties": {
                      "EncryptionOption": {
                        "title": "EncryptionOption1",
                        "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "SSE_S3",
                          "SSE_KMS",
                          "CSE_KMS"
                        ]
                      },
                      "KmsKey": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "EncryptionOption"
                    ]
                  },
                  "ExpectedBucketOwner": {
                    "type": "string",
                    "minLength": 12,
                    "maxLength": 12,
                    "pattern": "^[0-9]+$"
                  },
                  "AclConfiguration": {
                    "id": "AclConfiguration1",
                    "title": "AclConfiguration1",
                    "type": "object",
                    "properties": {
                      "S3AclOption": {
                        "title": "S3AclOption1",
                        "description": "The Amazon S3 canned ACL that Athena should specify when storing query results. Currently the only supported canned ACL is <code>BUCKET_OWNER_FULL_CONTROL</code>. If a query runs in a workgroup and the workgroup overrides client-side settings, then the Amazon S3 canned ACL specified in the workgroup's settings is used for all queries that run in the workgroup. For more information about Amazon S3 canned ACLs, see <a href=\"https://docs.aws.amazon.com/AmazonS3/latest/userguide/acl-overview.html#canned-acl\">Canned ACL</a> in the <i>Amazon S3 User Guide</i>.",
                        "type": "string",
                        "additionalProperties": false,
                        "enum": [
                          "BUCKET_OWNER_FULL_CONTROL"
                        ]
                      }
                    },
                    "required": [
                      "S3AclOption"
                    ]
                  }
                }
              },
              "WorkGroup": {
                "type": "string",
                "pattern": "[a-zA-Z0-9._-]{1,128}"
              },
              "ExecutionParameters": {
                "description": "",
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 1024
                },
                "minItems": 1
              },
              "ResultReuseConfiguration": {
                "id": "ResultReuseConfiguration1",
                "title": "ResultReuseConfiguration1",
                "type": "object",
                "properties": {
                  "ResultReuseByAgeConfiguration": {
                    "id": "ResultReuseByAgeConfiguration2",
                    "title": "ResultReuseByAgeConfiguration2",
                    "type": "object",
                    "properties": {
                      "Enabled": {
                        "type": "boolean"
                      },
                      "MaxAgeInMinutes": {
                        "type": "integer",
                        "minimum": 0.0,
                        "maximum": 10080.0,
                        "format": "int32"
                      }
                    },
                    "required": [
                      "Enabled"
                    ]
                  }
                }
              }
            },
            "required": [
              "QueryString"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "StartQueryExecutionOutput",
                "title": "StartQueryExecutionOutput",
                "type": "object",
                "properties": {
                  "QueryExecutionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "\\S+"
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: TooManyRequestsException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.StartSession:
  post:
    description: Creates a session for running calculations within a workgroup. The session is ready when it reaches an <code>IDLE</code> state.
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.StartSession
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "StartSessionRequest",
            "title": "StartSessionRequest",
            "type": "object",
            "properties": {
              "WorkGroup": {
                "type": "string",
                "pattern": "[a-zA-Z0-9._-]{1,128}"
              },
              "EngineConfiguration": {
                "id": "EngineConfiguration1",
                "title": "EngineConfiguration1",
                "type": "object",
                "properties": {
                  "MaxConcurrentDpus": {
                    "type": "integer",
                    "minimum": 2.0,
                    "maximum": 5000.0,
                    "format": "int32"
                  },
                  "CoordinatorDpuSize": {
                    "type": "integer",
                    "minimum": 1.0,
                    "maximum": 1.0,
                    "format": "int32"
                  },
                  "DefaultExecutorDpuSize": {
                    "type": "integer",
                    "minimum": 1.0,
                    "maximum": 1.0,
                    "format": "int32"
                  },
                  "AdditionalConfigs": {
                    "id": "AdditionalConfigs",
                    "title": "AdditionalConfigs",
                    "type": "object",
                    "additionalProperties": {
                      "type": "string",
                      "maxLength": 51200
                    }
                  }
                },
                "required": [
                  "MaxConcurrentDpus"
                ]
              },
              "Description": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024
              },
              "NotebookVersion": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "SessionIdleTimeoutInMinutes": {
                "type": "integer",
                "minimum": 1.0,
                "maximum": 480.0,
                "format": "int32"
              },
              "ClientRequestToken": {
                "type": "string",
                "minLength": 32,
                "maxLength": 128
              }
            },
            "required": [
              "WorkGroup",
              "EngineConfiguration"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "StartSessionResponse",
                "title": "StartSessionResponse",
                "type": "object",
                "properties": {
                  "SessionId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "State": {
                    "title": "SessionState1",
                    "description": "<p>The state of the session. A description of each state follows.</p> <p> <code>CREATING</code> - The session is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The session has been started.</p> <p> <code>IDLE</code> - The session is able to accept a calculation.</p> <p> <code>BUSY</code> - The session is processing another task and is unable to accept a calculation.</p> <p> <code>TERMINATING</code> - The session is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The session and its resources are no longer running.</p> <p> <code>DEGRADED</code> - The session has no healthy coordinators.</p> <p> <code>FAILED</code> - Due to a failure, the session and its resources are no longer running.</p>",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "CREATING",
                      "CREATED",
                      "IDLE",
                      "BUSY",
                      "TERMINATING",
                      "TERMINATED",
                      "DEGRADED",
                      "FAILED"
                    ]
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
      '483':
        description: SessionAlreadyExistsException
        body:
          application/json:
            schema: '{}'
      '484':
        description: TooManyRequestsException
        body:
          application/json:
            schema: '{}'
/#X-Amz-Target=AmazonAthena.StopCalculationExecution:
  post:
    description: <p>Requests the cancellation of a calculation. A <code>StopCalculationExecution</code> call on a calculation that is already in a terminal state (for example, <code>STOPPED</code>, <code>FAILED</code>, or <code>COMPLETED</code>) succeeds but has no effect.</p> <note> <p>Cancelling a calculation is done on a best effort basis. If a calculation cannot be cancelled, you can be charged for its completion. If you are concerned about being charged for a calculation that cannot be cancelled, consider terminating the session in which the calculation is running.</p> </note>
    headers:
      X-Amz-Target:
        required: true
        displayName: X-Amz-Target
        enum:
        - AmazonAthena.StopCalculationExecution
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
      X-Amz-Content-Sha256:
        type: string
        required: false
        displayName: X-Amz-Content-Sha256
      X-Amz-Date:
        type: string
        required: false
        displayName: X-Amz-Date
      X-Amz-Algorithm:
        type: string
        required: false
        displayName: X-Amz-Algorithm
      X-Amz-Credential:
        type: string
        required: false
        displayName: X-Amz-Credential
      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
      application/json:
        schema: |
          {
            "id": "StopCalculationExecutionRequest",
            "title": "StopCalculationExecutionRequest",
            "type": "object",
            "properties": {
              "CalculationExecutionId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 36
              }
            },
            "required": [
              "CalculationExecutionId"
            ]
          }
        example: ''
    responses:
      '200':
        description: Success
        body:
          application/json:
            schema: |
              {
                "id": "StopCalculationExecutionResponse",
                "title": "StopCalculationExecutionResponse",
                "type": "object",
                "properties": {
                  "State": {
                    "title": "CalculationExecutionState4",
                    "description": "<p> <code>CREATING</code> - The calculation is in the process of being created.</p> <p> <code>CREATED</code> - The calculation has been created and is ready to run.</p> <p> <code>QUEUED</code> - The calculation has been queued for processing.</p> <p> <code>RUNNING</code> - The calculation is running.</p> <p> <code>CANCELING</code> - A request to cancel the calculation has been received and the system is working to stop it.</p> <p> <code>CANCELED</code> - The calculation is no longer running as the result of a cancel request.</p> <p> <code>COMPLETED</code> - The calculation has completed without error.</p> <p> <code>FAILED</code> - The calculation failed and is no longer running.</p>",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "CREATING",
                      "CREATED",
                      "QUEUED",
                      "RUNNING",
                      "CANCELING",
                      "CANCELED",
                      "COMPLETED",
                      "FAILED"
                    ]
                  }
                }
              }
      '480':
        description: InternalServerException
        body:
          application/json:
            schema: '{}'
      '481':
        description: InvalidRequestException
        body:
          application/json:
            schema: '{}'
      '482':
        description: ResourceNotFoundException
        body:
          application/json:
            schema: '{}'
