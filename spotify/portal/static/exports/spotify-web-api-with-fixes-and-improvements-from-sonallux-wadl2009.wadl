      <xs:element name="unfollow-artists-users_Request" type="schemas:unfollow-artists-users_Request" />
      <xs:element name="unfollow-artists-users401_Response0" type="schemas:unfollow-artists-users401_Response0" />
      <xs:element name="unfollow-artists-users403_Response0" type="schemas:unfollow-artists-users403_Response0" />
      <xs:element name="unfollow-artists-users429_Response0" type="schemas:unfollow-artists-users429_Response0" />
      <xs:element name="check-current-user-follows200_Response0" type="schemas:check-current-user-follows200_Response0" />
      <xs:element name="check-current-user-follows401_Response0" type="schemas:check-current-user-follows401_Response0" />
      <xs:element name="check-current-user-follows403_Response0" type="schemas:check-current-user-follows403_Response0" />
      <xs:element name="check-current-user-follows429_Response0" type="schemas:check-current-user-follows429_Response0" />
      <xs:element name="check-if-user-follows-playlist200_Response0" type="schemas:check-if-user-follows-playlist200_Response0" />
      <xs:element name="check-if-user-follows-playlist401_Response0" type="schemas:check-if-user-follows-playlist401_Response0" />
      <xs:element name="check-if-user-follows-playlist403_Response0" type="schemas:check-if-user-follows-playlist403_Response0" />
      <xs:element name="check-if-user-follows-playlist429_Response0" type="schemas:check-if-user-follows-playlist429_Response0" />
      <xs:element name="get-users-top-artists200_Response0" type="schemas:get-users-top-artists200_Response0" />
      <xs:element name="get-users-top-artists401_Response0" type="schemas:get-users-top-artists401_Response0" />
      <xs:element name="get-users-top-artists403_Response0" type="schemas:get-users-top-artists403_Response0" />
      <xs:element name="get-users-top-artists429_Response0" type="schemas:get-users-top-artists429_Response0" />
      <xs:element name="get-users-top-tracks200_Response0" type="schemas:get-users-top-tracks200_Response0" />
      <xs:element name="get-users-top-tracks401_Response0" type="schemas:get-users-top-tracks401_Response0" />
      <xs:element name="get-users-top-tracks403_Response0" type="schemas:get-users-top-tracks403_Response0" />
