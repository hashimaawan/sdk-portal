                            "created",
                            "created_from",
                            "deleted",
                            "deprecated",
                            "description",
                            "disk_size",
                            "id",
                            "image_size",
                            "labels",
                            "name",
                            "os_flavor",
                            "os_version",
                            "protection",
                            "status",
                            "type"
                          ]
                        },
                        "included_traffic": {
