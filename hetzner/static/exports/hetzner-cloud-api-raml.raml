                "integer",
                "null"
              ],
              "format": "int32"
            },
            "size": {
              "description": "Size in GB of the Volume",
              "example": 42,
              "type": "number"
            },
            "status": {
              "title": "Status113",
              "description": "Current status of the Volume",
