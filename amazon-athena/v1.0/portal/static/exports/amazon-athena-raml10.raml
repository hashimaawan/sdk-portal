#%RAML 1.0
title: Amazon Athena
version: 2017-05-18
baseUri: http://athena.us-east-1.amazonaws.com
baseUriParameters:
  region:
    required: false
    default: us-east-1
    displayName: region
    description: The AWS region
    type: string
    enum:
    - us-east-1
    - us-east-2
    - us-west-1
    - us-west-2
    - us-gov-west-1
    - us-gov-east-1
    - ca-central-1
    - eu-north-1
    - eu-west-1
    - eu-west-2
    - eu-west-3
    - eu-central-1
    - eu-south-1
    - af-south-1
    - ap-northeast-1
    - ap-northeast-2
    - ap-northeast-3
    - ap-southeast-1
    - ap-southeast-2
    - ap-east-1
    - ap-south-1
    - sa-east-1
    - me-south-1
protocols:
- HTTP
- HTTPS
documentation:
- title: Amazon Athena
  content: <p>Amazon Athena is an interactive query service that lets you use standard SQL to analyze data directly in Amazon S3. You can point Athena at your data in Amazon S3 and run ad-hoc queries and get results in seconds. Athena is serverless, so there is no infrastructure to set up or manage. You pay only for the queries you run. Athena scales automatically—executing queries in parallel—so results are fast, even with large datasets and complex queries. For more information, see <a href="http://docs.aws.amazon.com/athena/latest/ug/what-is.html">What is Amazon Athena</a> in the <i>Amazon Athena User Guide</i>.</p> <p>If you connect to Athena using the JDBC driver, use version 1.1.0 of the driver or later with the Amazon Athena API. Earlier version drivers do not support the API. For more information and to download the driver, see <a href="https://docs.aws.amazon.com/athena/latest/ug/connect-with-jdbc.html">Accessing Amazon Athena with JDBC</a>.</p> <p>For code samples using the Amazon Web Services SDK for Java, see <a href="https://docs.aws.amazon.com/athena/latest/ug/code-samples.html">Examples and Code Samples</a> in the <i>Amazon Athena User Guide</i>.</p>
securitySchemes:
  hmac:
    type: Pass Through
    description: Amazon Signature authorization v4
    describedBy:
      headers:
        Authorization:
          required: true
          displayName: Authorization
          description: Amazon Signature authorization v4
          type: string
securedBy:
- hmac
types:
  BatchGetNamedQueryOutput:
    displayName: BatchGetNamedQueryOutput
    type: object
    properties:
      NamedQueries:
        required: false
        displayName: NamedQueries
        type: array
        items:
          type: NamedQuery
      UnprocessedNamedQueryIds:
        required: false
        displayName: UnprocessedNamedQueryIds
        type: array
        items:
          type: UnprocessedNamedQueryId
  BatchGetNamedQueryInput:
    displayName: BatchGetNamedQueryInput
    description: Contains an array of named query IDs.
    type: object
    properties:
      NamedQueryIds:
        required: true
        displayName: NamedQueryIds
        type: array
        uniqueItems: false
        minItems: 1
        maxItems: 50
        items:
          type: string
          pattern: '\S+'
          minLength: 1
          maxLength: 128
  BatchGetPreparedStatementOutput:
    displayName: BatchGetPreparedStatementOutput
    type: object
    properties:
      PreparedStatements:
        required: false
        displayName: PreparedStatements
        type: array
        items:
          type: PreparedStatement
      UnprocessedPreparedStatementNames:
        required: false
        displayName: UnprocessedPreparedStatementNames
        type: array
        items:
          type: UnprocessedPreparedStatementName
  BatchGetPreparedStatementInput:
    displayName: BatchGetPreparedStatementInput
    type: object
    properties:
      PreparedStatementNames:
        required: true
        displayName: PreparedStatementNames
        type: array
