                              "format": "int32"
                            },
                            "QueryPlanningTimeInMillis": {
                              "type": "integer",
                              "format": "int32"
                            },
                            "ServiceProcessingTimeInMillis": {
                              "type": "integer",
                              "format": "int32"
                            },
                            "ResultReuseInformation": {
                              "id": "ResultReuseInformation2",
