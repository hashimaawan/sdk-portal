        type: number
        minimum: 0
        maximum: 1
        format: double
      max_instrumentalness:
        required: false
        displayName: max_instrumentalness
        type: number
        minimum: 0
        maximum: 1
        format: double
      target_instrumentalness:
        required: false
        displayName: target_instrumentalness
        type: number
        minimum: 0
        maximum: 1
        format: double
      min_key:
        required: false
        displayName: min_key
        type: integer
        minimum: 0
        maximum: 11
        format: int32
      max_key:
        required: false
        displayName: max_key
        type: integer
        minimum: 0
        maximum: 11
        format: int32
      target_key:
        required: false
