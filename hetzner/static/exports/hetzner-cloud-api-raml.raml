- NetworksResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "NetworksResponse",
      "title": "NetworksResponse",
      "type": "object",
      "properties": {
        "networks": {
          "description": "",
          "type": "array",
          "items": {
            "id": "Network",
            "title": "Network",
            "type": "object",
            "properties": {
              "created": {
                "description": "Point in time when the Network was created (in ISO-8601 format)",
                "example": "2016-01-30T23:50:00+00:00",
                "type": "string"
              },
              "id": {
                "description": "ID of the Network",
                "example": 4711,
                "type": "integer",
                "format": "int32"
              },
              "ip_range": {
                "description": "IPv4 prefix of the whole Network",
                "example": "10.0.0.0/16",
                "type": "string"
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object"
              },
              "name": {
                "description": "Name of the Network",
                "example": "mynet",
                "type": "string"
              },
              "protection": {
                "id": "Protection11",
                "title": "Protection11",
                "description": "Protection configuration for the Network",
                "type": "object",
                "properties": {
                  "delete": {
                    "description": "If true, prevents the Network from being deleted",
                    "example": false,
                    "type": "boolean"
                  }
                },
                "required": [
                  "delete"
                ]
              },
              "routes": {
                "description": "Array of routes set in this Network",
                "type": "array",
                "items": {
                  "id": "Route",
                  "title": "Route",
                  "type": "object",
                  "properties": {
                    "destination": {
                      "description": "Destination network or host of this route. Must not overlap with an existing ip_range in any subnets or with any destinations in other routes or with the first IP of the networks ip_range or with 172.31.1.1. Must be one of the private IPv4 ranges of RFC1918.",
                      "example": "10.100.1.0/24",
                      "type": "string"
                    },
                    "gateway": {
                      "description": "Gateway for the route. Cannot be the first IP of the networks ip_range and also cannot be 172.31.1.1 as this IP is being used as a gateway for the public network interface of Servers.",
                      "example": "10.0.1.1",
                      "type": "string"
                    }
                  },
                  "required": [
                    "destination",
                    "gateway"
                  ]
                }
              },
              "servers": {
                "description": "Array of IDs of Servers attached to this Network",
                "example": [
                  42
                ],
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int32"
                }
              },
              "subnets": {
                "description": "Array subnets allocated in this Network",
                "type": "array",
                "items": {
                  "id": "Subnet",
                  "title": "Subnet",
                  "type": "object",
                  "properties": {
                    "gateway": {
                      "description": "Gateway for Servers attached to this subnet. For subnets of type Server this is always the first IP of the network IP range.",
                      "example": "10.0.0.1",
                      "type": "string"
                    },
                    "network_zone": {
                      "description": "Name of Network zone. The Location object contains the `network_zone` property each Location belongs to.",
                      "example": "eu-central",
                      "type": "string"
                    },
                    "type": {
                      "title": "Type42",
                      "description": "Type of Subnetwork",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "cloud",
                        "server",
                        "vswitch"
                      ]
                    },
                    "ip_range": {
                      "description": "Range to allocate IPs from. Must be a Subnet of the ip_range of the parent network object and must not overlap with any other subnets or with any destinations in routes. Minimum Network size is /30. We suggest that you pick a bigger Network with a /24 netmask.",
                      "example": "10.0.1.0/24",
                      "type": "string"
                    }
                  },
                  "required": [
                    "gateway",
                    "network_zone",
                    "type"
                  ]
                }
              },
              "load_balancers": {
                "description": "Array of IDs of Load Balancers attached to this Network",
                "example": [
                  42
                ],
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            },
            "required": [
              "created",
              "id",
              "ip_range",
              "labels",
              "name",
              "protection",
              "routes",
              "servers",
              "subnets"
            ]
          }
        },
        "meta": {
          "id": "Meta",
          "title": "Meta",
          "type": "object",
          "properties": {
            "pagination": {
              "id": "Pagination",
              "title": "Pagination",
              "type": "object",
              "properties": {
                "last_page": {
                  "description": "ID of the last page available. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "next_page": {
                  "description": "ID of the next page. Can be null if the current page is the last one.",
                  "example": 4,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "page": {
                  "description": "Current page number",
                  "example": 3,
                  "type": "number"
                },
                "per_page": {
                  "description": "Maximum number of items shown per page in the response",
                  "example": 25,
                  "type": "number"
                },
                "previous_page": {
                  "description": "ID of the previous page. Can be null if the current page is the first one.",
                  "example": 2,
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "total_entries": {
                  "description": "The total number of entries that exist in the database for this query. Nullable if unknown.",
                  "example": 100,
                  "type": [
                    "number",
                    "null"
                  ]
                }
              },
              "required": [
                "last_page",
                "next_page",
                "page",
                "per_page",
                "previous_page",
                "total_entries"
              ]
            }
          },
          "required": [
            "pagination"
          ]
        }
      },
      "required": [
        "networks"
      ]
    }
- Network: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Network",
      "title": "Network",
      "type": "object",
      "properties": {
        "created": {
          "description": "Point in time when the Network was created (in ISO-8601 format)",
          "example": "2016-01-30T23:50:00+00:00",
          "type": "string"
        },
        "id": {
          "description": "ID of the Network",
          "example": 4711,
          "type": "integer",
          "format": "int32"
        },
        "ip_range": {
          "description": "IPv4 prefix of the whole Network",
          "example": "10.0.0.0/16",
          "type": "string"
        },
        "labels": {
          "description": "User-defined labels (key-value pairs)",
          "type": "object"
        },
        "name": {
          "description": "Name of the Network",
          "example": "mynet",
          "type": "string"
        },
        "protection": {
          "id": "Protection11",
          "title": "Protection11",
          "description": "Protection configuration for the Network",
          "type": "object",
          "properties": {
            "delete": {
              "description": "If true, prevents the Network from being deleted",
              "example": false,
              "type": "boolean"
            }
          },
          "required": [
            "delete"
          ]
        },
        "routes": {
          "description": "Array of routes set in this Network",
          "type": "array",
          "items": {
            "id": "Route",
            "title": "Route",
            "type": "object",
            "properties": {
              "destination": {
                "description": "Destination network or host of this route. Must not overlap with an existing ip_range in any subnets or with any destinations in other routes or with the first IP of the networks ip_range or with 172.31.1.1. Must be one of the private IPv4 ranges of RFC1918.",
                "example": "10.100.1.0/24",
                "type": "string"
              },
              "gateway": {
                "description": "Gateway for the route. Cannot be the first IP of the networks ip_range and also cannot be 172.31.1.1 as this IP is being used as a gateway for the public network interface of Servers.",
                "example": "10.0.1.1",
                "type": "string"
              }
            },
            "required": [
              "destination",
              "gateway"
            ]
          }
        },
        "servers": {
          "description": "Array of IDs of Servers attached to this Network",
          "example": [
            42
          ],
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "subnets": {
          "description": "Array subnets allocated in this Network",
          "type": "array",
          "items": {
            "id": "Subnet",
            "title": "Subnet",
            "type": "object",
            "properties": {
              "gateway": {
                "description": "Gateway for Servers attached to this subnet. For subnets of type Server this is always the first IP of the network IP range.",
                "example": "10.0.0.1",
                "type": "string"
              },
              "network_zone": {
                "description": "Name of Network zone. The Location object contains the `network_zone` property each Location belongs to.",
                "example": "eu-central",
                "type": "string"
              },
              "type": {
                "title": "Type42",
                "description": "Type of Subnetwork",
                "type": "string",
                "additionalProperties": false,
                "enum": [
                  "cloud",
                  "server",
                  "vswitch"
                ]
              },
              "ip_range": {
                "description": "Range to allocate IPs from. Must be a Subnet of the ip_range of the parent network object and must not overlap with any other subnets or with any destinations in routes. Minimum Network size is /30. We suggest that you pick a bigger Network with a /24 netmask.",
                "example": "10.0.1.0/24",
                "type": "string"
              }
            },
            "required": [
              "gateway",
              "network_zone",
              "type"
            ]
          }
        },
        "load_balancers": {
          "description": "Array of IDs of Load Balancers attached to this Network",
          "example": [
            42
          ],
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "required": [
        "created",
        "id",
        "ip_range",
        "labels",
        "name",
        "protection",
        "routes",
        "servers",
        "subnets"
      ]
    }
