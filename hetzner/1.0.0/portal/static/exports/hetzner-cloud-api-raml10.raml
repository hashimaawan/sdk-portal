/certificates:
  get:
    displayName: GetallCertificates
    description: Returns all Certificate objects.
    queryParameters:
      sort:
        required: false
        displayName: sort
        description: Can be used multiple times.
        type: string
        enum:
        - id
        - id:asc
        - id:desc
        - name
        - name:asc
        - name:desc
        - created
        - created:asc
        - created:desc
      name:
        required: false
        displayName: name
        description: Can be used to filter resources by their name. The response will only contain the resources matching the specified name
        type: string
      label_selector:
        required: false
        displayName: label_selector
        description: Can be used to filter resources by labels. The response will only contain resources matching the label selector.
        type: string
      type:
        required: false
        displayName: type
        description: Can be used multiple times. The response will only contain Certificates matching the type.
        type: string
        enum:
        - uploaded
        - managed
    responses:
      '200':
        description: The `certificates` key contains an array of Certificate objects
        body:
          application/json:
            example:
              value:
                certificates:
                - certificate: |
                    -----BEGIN CERTIFICATE-----

                    ...
                  created: 2019-01-08T12:10:00+00:00
                  domain_names:
                  - example.com
                  - webmail.example.com
                  - www.example.com
                  fingerprint: 03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f
                  id: 897
                  labels:
                    env: dev
                  name: my website cert
                  not_valid_after: 2019-07-08T09:59:59+00:00
                  not_valid_before: 2019-01-08T10:00:00+00:00
                  status: null
                  type: uploaded
                  used_by:
                  - id: 4711
                    type: load_balancer
            displayName: response200
            description: ''
            type: CertificatesResponse
  post:
    displayName: CreateaCertificate
    description: >
      Creates a new Certificate.


      The default type **uploaded** allows for uploading your existing `certificate` and `private_key` in PEM format. You have to monitor its expiration date and handle renewal yourself.


      In contrast, type **managed** requests a new Certificate from *Let's Encrypt* for the specified `domain_names`. Only domains managed by *Hetzner DNS* are supported. We handle renewal and timely alert the project owner via email if problems occur.


      For type `managed` Certificates the `action` key of the response contains the Action that allows for tracking the issuance process. For type `uploaded` Certificates the `action` is always null.
    body:
      application/json:
        examples:
          managed:
            displayName: Creating a type `managed` Certificate
            value:
              domain_names:
              - example.com
              - webmail.example.com
              - www.example.com
              name: my website cert
              type: managed
          uploaded:
            displayName: Creating a type `uploaded` Certificate
            value:
              certificate: |
                -----BEGIN CERTIFICATE-----

                ...
              name: my website cert
              private_key: |
                -----BEGIN PRIVATE KEY-----

                ...
              type: uploaded
        displayName: body
        type: CreateCertificateRequest
    headers:
      Content-Type:
        required: true
        example:
          value: application/json
        displayName: Content-Type
        type: string
        enum:
        - application/json
    responses:
      '201':
        description: The `certificate` key contains the Certificate that was just created. For type `managed` Certificates the `action` key contains the Action that allows for tracking the issuance process. For type `uploaded` Certificates the `action` is always null.
        body:
          application/json:
            examples:
              managed:
                displayName: Response when creating a type `managed` Certificate
                value:
                  action:
                    command: create_certificate
                    error:
                      code: action_failed
                      message: Action failed
                    finished: null
                    id: 13
                    progress: 0
                    resources:
                    - id: 879
                      type: certificate
                    started: 2019-01-08T12:10:00+00:00
                    status: running
                  certificate:
                    certificate: null
                    created: 2019-01-08T12:10:00+00:00
                    domain_names:
                    - example.com
                    - webmail.example.com
                    - www.example.com
                    fingerprint: null
                    id: 897
                    labels:
                      env: dev
                    name: my website cert
                    not_valid_after: null
                    not_valid_before: null
                    status:
                      error: null
                      issuance: pending
                      renewal: unavailable
                    type: managed
                    used_by:
                    - id: 4711
                      type: load_balancer
              uploaded:
                displayName: Response when creating a type `uploaded` Certificate
                value:
                  action: null
                  certificate:
                    certificate: |
                      -----BEGIN CERTIFICATE-----

                      ...
                    created: 2019-01-08T12:10:00+00:00
                    domain_names:
                    - example.com
                    - webmail.example.com
                    - www.example.com
                    fingerprint: 03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f
                    id: 897
                    labels:
                      env: dev
                    name: my website cert
                    not_valid_after: 2019-07-08T09:59:59+00:00
                    not_valid_before: 2019-01-08T10:00:00+00:00
                    status: null
                    type: uploaded
                    used_by:
                    - id: 4711
                      type: load_balancer
            displayName: response201
            description: ''
            type: CreateCertificateResponse
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of the resource
        type: integer
        format: int32
    delete:
      displayName: DeleteaCertificate
      description: Deletes a Certificate.
      responses:
        '204':
          description: Certificate deleted
          body: {}
    get:
      displayName: GetaCertificate
      description: Gets a specific Certificate object.
      responses:
        '200':
          description: The `certificate` key contains a Certificate object
          body:
            application/json:
              example:
                value:
                  certificate:
                    certificate: |
                      -----BEGIN CERTIFICATE-----

                      ...
                    created: 2019-01-08T12:10:00+00:00
                    domain_names:
                    - example.com
                    - webmail.example.com
                    - www.example.com
                    fingerprint: 03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f
                    id: 897
                    labels:
                      env: dev
                    name: my website cert
                    not_valid_after: 2019-07-08T09:59:59+00:00
                    not_valid_before: 2019-01-08T10:00:00+00:00
                    status: null
                    type: uploaded
                    used_by:
                    - id: 4711
                      type: load_balancer
              displayName: response200
              description: ''
              type: CertificateResponse
    put:
      displayName: UpdateaCertificate
      description: >
        Updates the Certificate properties.


        Note that when updating labels, the Certificate’s current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.


        Note: if the Certificate object changes during the request, the response will be a “conflict” error.
      body:
        application/json:
          displayName: body
          type: UpdateCertificateRequest
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: The `certificate` key contains the Certificate that was just updated
          body:
            application/json:
              example:
                value:
                  certificate:
                    certificate: |
                      -----BEGIN CERTIFICATE-----

                      ...
                    created: 2019-01-08T12:10:00+00:00
                    domain_names:
                    - example.com
                    - webmail.example.com
                    - www.example.com
                    fingerprint: 03:c7:55:9b:2a:d1:04:17:09:f6:d0:7f:18:34:63:d4:3e:5f
                    id: 897
                    labels:
                      labelkey: value
                    name: my website cert
                    not_valid_after: 2019-07-08T09:59:59+00:00
                    not_valid_before: 2019-01-08T10:00:00+00:00
                    status: null
                    type: uploaded
                    used_by:
                    - id: 4711
                      type: load_balancer
              displayName: response200
              description: ''
              type: CertificateResponse
    /actions:
      get:
        displayName: GetallActionsforaCertificate
        description: >
          Returns all Action objects for a Certificate. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.


          Only type `managed` Certificates can have Actions. For type `uploaded` Certificates the `actions` key will always contain an empty array.
        queryParameters:
          sort:
            required: false
            displayName: sort
            description: Can be used multiple times.
            type: string
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            required: false
            displayName: status
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            type: string
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                example:
                  value:
                    actions:
                    - command: issue_certificate
                      error:
                        code: action_failed
                        message: Action failed
                      finished: 2021-01-30T23:57:00+00:00
                      id: 14
                      progress: 100
                      resources:
                      - id: 896
                        type: certificate
                      started: 2021-01-30T23:55:00+00:00
                      status: success
                displayName: response200
                description: ''
                type: ActionsResponse
      /retry:
        post:
          displayName: RetryIssuanceorRenewal
          description: >
            Retry a failed Certificate issuance or renewal.


            Only applicable if the type of the Certificate is `managed` and the issuance or renewal status is `failed`.


            #### Call specific error codes


            | Code                                                    | Description                                                               |

            |---------------------------------------------------------|---------------------------------------------------------------------------|

            | `caa_record_does_not_allow_ca`                          | CAA record does not allow certificate authority                           |

            | `ca_dns_validation_failed`                              | Certificate Authority: DNS validation failed                              |

            | `ca_too_many_authorizations_failed_recently`            | Certificate Authority: Too many authorizations failed recently            |

            | `ca_too_many_certificates_issued_for_registered_domain` | Certificate Authority: Too many certificates issued for registered domain |

            | `ca_too_many_duplicate_certificates`                    | Certificate Authority: Too many duplicate certificates                    |

            | `could_not_verify_domain_delegated_to_zone`             | Could not verify domain delegated to zone                                 |

            | `dns_zone_not_found`                                    | DNS zone not found                                                        |

            | `dns_zone_is_secondary_zone`                            | DNS zone is a secondary zone                                              |
          responses:
            '201':
              description: The `action` key contains the resulting Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: issue_certificate
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2021-01-30T23:57:00+00:00
                        id: 14
                        progress: 100
                        resources:
                        - id: 896
                          type: certificate
                        started: 2021-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /{action_id}:
        uriParameters:
          action_id:
            required: true
            displayName: action_id
            description: ID of the Action
            type: integer
            format: int32
        get:
          displayName: GetanActionforaCertificate
          description: Returns a specific Action for a Certificate. Only type `managed` Certificates have Actions.
          responses:
            '200':
              description: The `action` key contains the Certificate Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: issue_certificate
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2021-01-30T23:57:00+00:00
                        id: 14
                        progress: 100
                        resources:
                        - id: 896
                          type: certificate
                        started: 2021-01-30T23:55:00+00:00
                        status: success
                  displayName: response200
                  description: ''
                  type: ActionResponse
/datacenters:
  get:
    displayName: GetallDatacenters
    description: Returns all Datacenter objects.
    queryParameters:
      name:
        required: false
        displayName: name
        description: Can be used to filter Datacenters by their name. The response will only contain the Datacenter matching the specified name. When the name does not match the Datacenter name format, an `invalid_input` error is returned.
        type: string
    responses:
      '200':
        description: The reply contains the `datacenters` and `recommendation` keys
        body:
          application/json:
            displayName: response200
            description: ''
            type: DatacentersResponse
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of Datacenter
        type: integer
        format: int32
    get:
      displayName: GetaDatacenter
      description: Returns a specific Datacenter object.
      responses:
        '200':
          description: The `datacenter` key in the reply contains a Datacenter object with this structure
          body:
            application/json:
              displayName: response200
              description: ''
              type: DatacentersResponse1
/firewalls:
  get:
    displayName: GetallFirewalls
    description: Returns all Firewall objects.
    queryParameters:
      sort:
        required: false
        displayName: sort
        description: Can be used multiple times.
        type: string
        enum:
        - id
        - id:asc
        - id:desc
        - name
        - name:asc
        - name:desc
        - created
        - created:asc
        - created:desc
      name:
        required: false
        displayName: name
        description: Can be used to filter resources by their name. The response will only contain the resources matching the specified name
        type: string
      label_selector:
        required: false
        displayName: label_selector
        description: Can be used to filter resources by labels. The response will only contain resources matching the label selector.
        type: string
    responses:
      '200':
        description: The `firewalls` key contains an array of Firewall objects
        body:
          application/json:
            displayName: response200
            description: ''
            type: FirewallsResponse
  post:
    displayName: CreateaFirewall
    description: >
      Creates a new Firewall.


      #### Call specific error codes


      | Code                          | Description                                                   |

      |------------------------------ |-------------------------------------------------------------- |

      | `server_already_added`        | Server added more than one time to resource                   |

      | `incompatible_network_type`   | The Network type is incompatible for the given resource       |

      | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
    body:
      application/json:
        examples:
          request:
            value:
              apply_to:
              - server:
                  id: 42
                type: server
              labels:
                env: dev
              name: Corporate Intranet Protection
              rules:
              - description: Allow port 80
                direction: in
                port: '80'
                protocol: tcp
                source_ips:
                - 28.239.13.1/32
                - 28.239.14.0/24
                - ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128
        displayName: body
        type: CreateFirewallRequest
    headers:
      Content-Type:
        required: true
        example:
          value: application/json
        displayName: Content-Type
        type: string
        enum:
        - application/json
    responses:
      '201':
        description: The `firewall` key contains the Firewall that was just created
        body:
          application/json:
            displayName: response201
            description: ''
            type: CreateFirewallResponse
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of the resource
        type: integer
        format: int32
    delete:
      displayName: DeleteaFirewall
      description: >
        Deletes a Firewall.


        #### Call specific error codes


        | Code                 | Description                               |

        |--------------------- |-------------------------------------------|

        | `resource_in_use`    | Firewall must not be in use to be deleted |
      responses:
        '204':
          description: Firewall deleted
          body: {}
    get:
      displayName: GetaFirewall
      description: Gets a specific Firewall object.
      responses:
        '200':
          description: The `firewall` key contains a Firewall object
          body:
            application/json:
              displayName: response200
              description: ''
              type: FirewallResponse
    put:
      displayName: UpdateaFirewall
      description: >
        Updates the Firewall.


        Note that when updating labels, the Firewall's current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.


        Note: if the Firewall object changes during the request, the response will be a “conflict” error.
      body:
        application/json:
          displayName: body
          type: UpdateFirewallRequest
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: The `firewall` key contains the Firewall that was just updated
          body:
            application/json:
              displayName: response200
              description: ''
              type: FirewallResponse
    /actions:
      get:
        displayName: GetallActionsforaFirewall
        description: Returns all Action objects for a Firewall. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.
        queryParameters:
          sort:
            required: false
            displayName: sort
            description: Can be used multiple times.
            type: string
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            required: false
            displayName: status
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            type: string
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                example:
                  value:
                    actions:
                    - command: set_firewall_rules
                      error:
                        code: action_failed
                        message: Action failed
                      finished: 2016-01-30T23:56:00+00:00
                      id: 13
                      progress: 100
                      resources:
                      - id: 38
                        type: firewall
                      started: 2016-01-30T23:55:00+00:00
                      status: success
                displayName: response200
                description: ''
                type: ActionsResponse
      /apply_to_resources:
        post:
          displayName: ApplytoResources
          description: >
            Applies one Firewall to multiple resources.


            Currently servers (public network interface) and label selectors are supported.


            #### Call specific error codes


            | Code                          | Description                                                   |

            |-------------------------------|---------------------------------------------------------------|

            | `firewall_already_applied`    | Firewall was already applied on resource                      |

            | `incompatible_network_type`   | The Network type is incompatible for the given resource       |

            | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
          body:
            application/json:
              example:
                value:
                  apply_to:
                  - server:
                      id: 42
                    type: server
              displayName: body
              type: ApplyToResourcesRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `actions` key contains multiple `apply_firewall` Actions
              body:
                application/json:
                  example:
                    value:
                      actions:
                      - command: apply_firewall
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 14
                        progress: 100
                        resources:
                        - id: 42
                          type: server
                        - id: 38
                          type: firewall
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionsResponse
      /remove_from_resources:
        post:
          displayName: RemovefromResources
          description: >
            Removes one Firewall from multiple resources.


            Currently only Servers (and their public network interfaces) are supported.


            #### Call specific error codes


            | Code                                  | Description                                                            |

            |---------------------------------------|------------------------------------------------------------------------|

            | `firewall_already_removed`            | Firewall was already removed from the resource                         |

            | `firewall_resource_not_found`         | The resource the Firewall should be attached to was not found          |

            | `firewall_managed_by_label_selector`  | Firewall was applied via label selector and cannot be removed manually |
          body:
            application/json:
              example:
                value:
                  remove_from:
                  - server:
                      id: 42
                    type: server
              displayName: body
              type: RemoveFromResourcesRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `actions` key contains multiple `remove_firewall` Actions
              body:
                application/json:
                  example:
                    value:
                      actions:
                      - command: remove_firewall
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 14
                        progress: 100
                        resources:
                        - id: 42
                          type: server
                        - id: 38
                          type: firewall
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionsResponse
      /set_rules:
        post:
          displayName: SetRules
          description: >
            Sets the rules of a Firewall.


            All existing rules will be overwritten. Pass an empty `rules` array to remove all rules.

            The maximum amount of rules that can be defined is 50.


            #### Call specific error codes


            | Code                          | Description                                                   |

            |-------------------------------|---------------------------------------------------------------|

            | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
          body:
            application/json:
              examples:
                rules:
                  value:
                    rules:
                    - description: Allow port 80
                      direction: in
                      port: '80'
                      protocol: tcp
                      source_ips:
                      - 28.239.13.1/32
                      - 28.239.14.0/24
                      - ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128
              displayName: body
              type: SetRulesRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `action` key contains one `set_firewall_rules` Action plus one `apply_firewall` Action per resource where the Firewall is active
              body:
                application/json:
                  example:
                    value:
                      actions:
                      - command: set_firewall_rules
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 38
                          type: firewall
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                      - command: apply_firewall
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 14
                        progress: 100
                        resources:
                        - id: 38
                          type: firewall
                        - id: 42
                          type: server
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionsResponse
      /{action_id}:
        uriParameters:
          action_id:
            required: true
            displayName: action_id
            description: ID of the Action
            type: integer
            format: int32
        get:
          displayName: GetanActionforaFirewall
          description: Returns a specific Action for a Firewall.
          responses:
            '200':
              description: The `action` key contains the Firewall Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: set_firewall_rules
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 38
                          type: firewall
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response200
                  description: ''
                  type: ActionResponse
/floating_ips:
  get:
    displayName: GetallFloatingIPs
    description: Returns all Floating IP objects.
    queryParameters:
      name:
        required: false
        displayName: name
        description: Can be used to filter Floating IPs by their name. The response will only contain the Floating IP matching the specified name.
        type: string
      label_selector:
        required: false
        displayName: label_selector
        description: Can be used to filter Floating IPs by labels. The response will only contain Floating IPs matching the label selector.
        type: string
      sort:
        required: false
        displayName: sort
        description: Can be used multiple times. Choices id id:asc id:desc created created:asc created:desc
        type: string
        enum:
        - id
        - id:asc
        - id:desc
        - created
        - created:asc
        - created:desc
    responses:
      '200':
        description: The `floating_ips` key in the reply contains an array of Floating IP objects with this structure
        body:
          application/json:
            displayName: response200
            description: ''
            type: FloatingIpsResponse
  post:
    displayName: CreateaFloatingIP
    description: Creates a new Floating IP assigned to a Server. If you want to create a Floating IP that is not bound to a Server, you need to provide the `home_location` key instead of `server`. This can be either the ID or the name of the Location this IP shall be created in. Note that a Floating IP can be assigned to a Server in any Location later on. For optimal routing it is advised to use the Floating IP in the same Location it was created in.
    body:
      application/json:
        displayName: body
        description: The `type` argument is required while `home_location` and `server` are mutually exclusive.
        type: CreateFloatingIPRequest
    headers:
      Content-Type:
        required: true
        example:
          value: application/json
        displayName: Content-Type
        type: string
        enum:
        - application/json
    responses:
      '201':
        description: The `floating_ip` key in the reply contains the object that was just created
        body:
          application/json:
            example:
              value:
                action:
                  command: create_floating_ip
                  error:
                    code: action_failed
                    message: Action failed
                  finished: null
                  id: 13
                  progress: 0
                  resources:
                  - id: 42
                    type: server
                  started: 2016-01-30T23:50:00+00:00
                  status: running
                floating_ip:
                  blocked: false
                  created: 2016-01-30T23:50:00+00:00
                  description: Web Frontend
                  dns_ptr:
                  - dns_ptr: server.example.com
                    ip: 2001:db8::1
                  home_location:
                    city: Falkenstein
                    country: DE
                    description: Falkenstein DC Park 1
                    id: 1
                    latitude: 50.47612
                    longitude: 12.370071
                    name: fsn1
                    network_zone: eu-central
                  id: 4711
                  ip: 131.232.99.1
                  labels:
                    env: dev
                  name: Web Frontend
                  protection:
                    delete: false
                  server: 42
                  type: ipv4
            displayName: response201
            description: ''
            type: FloatingIpsResponse1
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of the Floating IP
        type: integer
        format: int32
    delete:
      displayName: DeleteaFloatingIP
      description: Deletes a Floating IP. If it is currently assigned to a Server it will automatically get unassigned.
      responses:
        '204':
          description: Floating IP deleted
          body: {}
    get:
      displayName: GetaFloatingIP
      description: Returns a specific Floating IP object.
      responses:
        '200':
          description: The `floating_ip` key in the reply contains a Floating IP object with this structure
          body:
            application/json:
              displayName: response200
              description: ''
              type: FloatingIpsResponse2
    put:
      displayName: UpdateaFloatingIP
      description: |
        Updates the description or labels of a Floating IP.

        Also note that when updating labels, the Floating IP’s current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.
      body:
        application/json:
          displayName: body
          type: UpdateFloatingIPRequest
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: The `floating_ip` key in the reply contains the modified Floating IP object with the new description
          body:
            application/json:
              example:
                value:
                  floating_ip:
                    blocked: false
                    created: 2016-01-30T23:50:00+00:00
                    description: Web Frontend
                    dns_ptr:
                    - dns_ptr: server.example.com
                      ip: 2001:db8::1
                    home_location:
                      city: Falkenstein
                      country: DE
                      description: Falkenstein DC Park 1
                      id: 1
                      latitude: 50.47612
                      longitude: 12.370071
                      name: fsn1
                      network_zone: eu-central
                    id: 4711
                    ip: 131.232.99.1
                    labels:
                      labelkey: value
                    name: Web Frontend
                    protection:
                      delete: false
                    server: 42
                    type: ipv4
              displayName: response200
              description: ''
              type: FloatingIpsResponse2
    /actions:
      get:
        displayName: GetallActionsforaFloatingIP
        description: Returns all Action objects for a Floating IP. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.
        queryParameters:
          sort:
            required: false
            displayName: sort
            description: Can be used multiple times.
            type: string
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            required: false
            displayName: status
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            type: string
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                example:
                  value:
                    actions:
                    - command: assign_floating_ip
                      error:
                        code: action_failed
                        message: Action failed
                      finished: 2016-01-30T23:56:00+00:00
                      id: 13
                      progress: 100
                      resources:
                      - id: 4711
                        type: server
                      - id: 4712
                        type: floating_ip
                      started: 2016-01-30T23:55:00+00:00
                      status: success
                displayName: response200
                description: ''
                type: FloatingIpsActionsResponse
      /assign:
        post:
          displayName: AssignaFloatingIPtoaServer
          description: Assigns a Floating IP to a Server.
          body:
            application/json:
              displayName: body
              type: AssignFloatingIPRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `action` key contains the `assign` Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: assign_floating_ip
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 42
                          type: server
                        - id: 4711
                          type: floating_ip
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /change_dns_ptr:
        post:
          displayName: ChangereverseDNSentryforaFloatingIP
          description: Changes the hostname that will appear when getting the hostname belonging to this Floating IP.
          body:
            application/json:
              displayName: body
              description: |
                Select the IP address for which to change the DNS entry by passing `ip`. For a Floating IP of type `ipv4` this must exactly match the IP address of the Floating IP. For a Floating IP of type `ipv6` this must be a single IP within the IPv6 /64 range that belongs to this Floating IP.


                The target hostname is set by passing `dns_ptr`.
              type: ChangeDNSPTRRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `action` key contains the `change_dns_ptr` Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: change_dns_ptr
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 4711
                          type: floating_ip
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /change_protection:
        post:
          displayName: ChangeFloatingIPProtection
          description: Changes the protection configuration of the Floating IP.
          body:
            application/json:
              displayName: body
              type: ChangeProtectionRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `action` key contains the `change_protection` Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: change_protection
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 4711
                          type: floating_ip
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /unassign:
        post:
          displayName: UnassignaFloatingIP
          description: Unassigns a Floating IP, resulting in it being unreachable. You may assign it to a Server again at a later time.
          responses:
            '201':
              description: The `action` key contains the `unassign` Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: unassign_floating_ip
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 42
                          type: server
                        - id: 4711
                          type: floating_ip
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /{action_id}:
        uriParameters:
          action_id:
            required: true
            displayName: action_id
            description: ID of the Action
            type: integer
            format: int32
        get:
          displayName: GetanActionforaFloatingIP
          description: Returns a specific Action object for a Floating IP.
          responses:
            '200':
              description: The `action` key in the reply has this structure
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: assign_floating_ip
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 42
                          type: server
                        - id: 4711
                          type: floating_ip
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response200
                  description: ''
                  type: ActionResponse
/images:
  get:
    displayName: GetallImages
    description: Returns all Image objects. You can select specific Image types only and sort the results by using URI parameters.
    queryParameters:
      sort:
        required: false
        displayName: sort
        description: Can be used multiple times.
        type: string
        enum:
        - id
        - id:asc
        - id:desc
        - name
        - name:asc
        - name:desc
        - created
        - created:asc
        - created:desc
      type:
        required: false
        displayName: type
        description: Can be used multiple times.
        type: string
        enum:
        - system
        - snapshot
        - backup
        - app
      status:
        required: false
        displayName: status
        description: Can be used multiple times. The response will only contain Images matching the status.
        type: string
        enum:
        - available
        - creating
      bound_to:
        required: false
        displayName: bound_to
        description: Can be used multiple times. Server ID linked to the Image. Only available for Images of type `backup`
        type: string
      include_deprecated:
        required: false
        displayName: include_deprecated
        description: Can be used multiple times.
        type: boolean
      name:
        required: false
        displayName: name
        description: Can be used to filter resources by their name. The response will only contain the resources matching the specified name
        type: string
      label_selector:
        required: false
        displayName: label_selector
        description: Can be used to filter resources by labels. The response will only contain resources matching the label selector.
        type: string
    responses:
      '200':
        description: The `images` key in the reply contains an array of Image objects with this structure
        body:
          application/json:
            displayName: response200
            description: ''
            type: ImagesResponse
  /{id}:
    uriParameters:
      id:
        required: true
        displayName: id
        description: ID of the Image
        type: integer
        format: int32
    delete:
      displayName: DeleteanImage
      description: Deletes an Image. Only Images of type `snapshot` and `backup` can be deleted.
      responses:
        '204':
          description: Image deleted
          body: {}
    get:
      displayName: GetanImage
      description: Returns a specific Image object.
      responses:
        '200':
          description: The `image` key in the reply contains an Image object with this structure
          body:
            application/json:
              displayName: response200
              description: ''
              type: ImagesResponse1
    put:
      displayName: UpdateanImage
      description: >
        Updates the Image. You may change the description, convert a Backup Image to a Snapshot Image or change the Image labels. Only Images of type `snapshot` and `backup` can be updated.


        Note that when updating labels, the current set of labels will be replaced with the labels provided in the request body. So, for example, if you want to add a new label, you have to provide all existing labels plus the new label in the request body.
      body:
        application/json:
          displayName: body
          type: UpdateImageRequest
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: The image key in the reply contains the modified Image object
          body:
            application/json:
              example:
                value:
                  image:
                    bound_to: null
                    build_id: c313fe40383af26094a5a92026054320ab55abc7
                    created: 2016-01-30T23:50:00+00:00
                    created_from:
                      id: 1
                      name: Server
                    deleted: null
                    deprecated: 2018-02-28T00:00:00+00:00
                    description: My new Image description
                    disk_size: 10
                    id: 4711
                    image_size: 2.3
                    labels:
                      labelkey: value
                    name: null
                    os_flavor: ubuntu
                    os_version: '20.04'
                    protection:
                      delete: false
                    rapid_deploy: false
                    status: available
                    type: snapshot
              displayName: response200
              description: ''
              type: ImagesResponse1
    /actions:
      get:
        displayName: GetallActionsforanImage
        description: Returns all Action objects for an Image. You can sort the results by using the `sort` URI parameter, and filter them with the `status` parameter.
        queryParameters:
          sort:
            required: false
            displayName: sort
            description: Can be used multiple times.
            type: string
            enum:
            - id
            - id:asc
            - id:desc
            - command
            - command:asc
            - command:desc
            - status
            - status:asc
            - status:desc
            - progress
            - progress:asc
            - progress:desc
            - started
            - started:asc
            - started:desc
            - finished
            - finished:asc
            - finished:desc
          status:
            required: false
            displayName: status
            description: Can be used multiple times, the response will contain only Actions with specified statuses
            type: string
            enum:
            - running
            - success
            - error
        responses:
          '200':
            description: The `actions` key contains a list of Actions
            body:
              application/json:
                example:
                  value:
                    actions:
                    - command: change_protection
                      error:
                        code: action_failed
                        message: Action failed
                      finished: 2016-01-30T23:56:00+00:00
                      id: 13
                      progress: 100
                      resources:
                      - id: 4711
                        type: image
                      started: 2016-01-30T23:55:00+00:00
                      status: success
                displayName: response200
                description: ''
                type: ActionsResponse
      /change_protection:
        post:
          displayName: ChangeImageProtection
          description: Changes the protection configuration of the Image. Can only be used on snapshots.
          body:
            application/json:
              displayName: body
              type: ImagesActionsChangeProtectionRequest
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              type: string
              enum:
              - application/json
          responses:
            '201':
              description: The `action` key contains the `change_protection` Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: change_protection
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 4711
                          type: image
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response201
                  description: ''
                  type: ActionResponse
      /{action_id}:
        uriParameters:
          action_id:
            required: true
            displayName: action_id
            description: ID of the Action
            type: integer
            format: int32
        get:
          displayName: GetanActionforanImage
          description: Returns a specific Action for an Image.
          responses:
            '200':
              description: The `action` key contains the Image Action
              body:
                application/json:
                  example:
                    value:
                      action:
                        command: change_protection
                        error:
                          code: action_failed
                          message: Action failed
                        finished: 2016-01-30T23:56:00+00:00
                        id: 13
                        progress: 100
                        resources:
                        - id: 4711
                          type: image
                        started: 2016-01-30T23:55:00+00:00
                        status: success
                  displayName: response200
                  description: ''
                  type: ActionResponse
