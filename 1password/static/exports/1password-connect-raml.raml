                          "title": "Vault3",
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "pattern": "^[\\da-z]{26}$"
                            }
                          }
                        }
                      }
                    },
                    "result": {
                      "title": "Result",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "SUCCESS",
                        "DENY"
                      ]
                    },
                    "timestamp": {
                      "description": "The time at which the request was processed by the server.",
                      "readOnly": true,
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
      '401':
        description: Invalid or missing token
        body:
          application/json:
            schema: |
              {
                "id": "ErrorResponse",
                "title": "ErrorResponse",
                "example": {
                  "message": "Invalid token signature",
                  "status": 401
                },
                "type": "object",
                "properties": {
                  "message": {
                    "description": "A message detailing the error",
                    "type": "string"
                  },
                  "status": {
                    "description": "HTTP Status Code",
                    "type": "integer",
                    "format": "int32"
                  }
                }
              }
            example: '{"message":"Invalid token signature","status":401}'
/health:
  get:
    responses:
      '200':
        description: OK
        body:
          application/json:
            schema: |
              {
                "id": "HealthResponse",
                "title": "HealthResponse",
                "examples": [
                  {
                    "Id": "WaitingForAPIRequest",
                    "Name": "API server waiting for first authenticated request",
                    "Value": "{\"dependencies\":[{\"service\":\"sync\",\"status\":\"TOKEN_NEEDED\"},{\"message\":\"Connected to./1password.sqlite\",\"service\":\"sqlite\",\"status\":\"ACTIVE\"}],\"name\":\"1Password Connect API\",\"version\":\"1.2.1\"}",
                    "ExternalValue": null,
                    "Description": null
                  }
                ],
                "example": {
                  "dependencies": [
                    {
                      "service": "sync",
                      "status": "TOKEN_NEEDED"
                    },
                    {
                      "message": "Connected to./1password.sqlite",
                      "service": "sqlite",
                      "status": "ACTIVE"
                    }
                  ],
                  "name": "1Password Connect API",
                  "version": "1.2.1"
                },
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "description": "The Connect server's version",
                    "type": "string"
                  },
                  "dependencies": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "ServiceDependency",
                      "title": "ServiceDependency",
                      "description": "The state of a registered server dependency.",
                      "type": "object",
                      "properties": {
                        "message": {
                          "description": "Human-readable message for explaining the current state.",
                          "type": "string"
                        },
                        "service": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "name",
                  "version"
                ]
              }
            example: '{"dependencies":[{"service":"sync","status":"TOKEN_NEEDED"},{"message":"Connected to./1password.sqlite","service":"sqlite","status":"ACTIVE"}],"name":"1Password Connect API","version":"1.2.1"}'
/heartbeat:
  get:
    responses:
      '200':
        description: OK
        body:
          text/plain:
            schema: |
              {
                "type": "string"
              }
/metrics:
  get:
    description: See Prometheus documentation for a complete data model.
    responses:
      '200':
        description: Successfully returned Prometheus metrics
        body:
          text/plain:
            schema: |
              {
                "type": "string"
              }
