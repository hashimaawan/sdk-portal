        </request>
        <response status="200">
          <doc title="200" xml:lang="en">OK - Item updated. If no Patch operations were provided, Item is unmodified.</doc>
          <representation element="schemas:PatchVaultItem200_Response0" mediaType="application/json" />
        </response>
        <response status="401">
          <doc title="401" xml:lang="en">Invalid or missing token</doc>
          <representation element="schemas:PatchVaultItem401_Response0" mediaType="application/json" />
        </response>
