    put:
      securedBy:
      - oauth_2_0:
          scopes:
          - user-follow-modify
      description: >
        Add the current user as a follower of one or more artists or other Spotify users.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      queryParameters:
        type:
          example: artist
          required: true
          displayName: type
          enum:
          - artist
          - user
        ids:
          type: string
          example: 2CIMQHirSU0MQqyYHq0eOx,57dN52uHvrHOxijzpIgu3E,1vCWHaC5f2uS3yhpwWbIA6
          required: true
          displayName: ids
      body:
        application/json:
          schema: |
            {
              "id": "MeFollowingRequest",
              "title": "MeFollowingRequest",
              "type": "object",
              "properties": {
                "ids": {
                  "description": "A JSON array of the artist or user [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids).\nFor example: `{ids:[\"74ASZWbe4lXaubB36ztrGX\", \"08td7MxkoHQkXnWAYD8d6Q\"]}`. A maximum of 50 IDs can be sent in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "ids"
              ]
            }
          example: ''
      responses:
        '204':
          description: Artist or user followed
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
