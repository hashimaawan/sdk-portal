  <resources base="https://api.giphy.com/v1">
    <resource id="_gifs" path="/gifs">
      <method id="getGifsById" name="GET">
        <doc title="getGifsById" xml:lang="en">A multiget version of the get GIF by ID endpoint.
</doc>
        <request>
          <param name="ids" style="query" type="xsd:string">
            <doc title="ids" xml:lang="en">Filters results by specified GIF IDs, separated by commas.</doc>
          </param>
        </request>
        <response status="200">
