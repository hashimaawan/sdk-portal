      "title": "NamedQuery1",
      "type": "object",
      "properties": {
        "Name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "Database": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "QueryString": {
          "type": "string",
          "minLength": 1,
          "maxLength": 262144
        },
        "Description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "NamedQueryId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "\\S+"
        },
        "WorkGroup": {
          "type": "string",
          "pattern": "[a-zA-Z0-9._-]{1,128}"
        }
      },
      "required": [
