              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="1800000" />
                <xs:minInclusive value="500" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="0" name="default_toast_compression" type="schemas:DefaultToastCompression">
