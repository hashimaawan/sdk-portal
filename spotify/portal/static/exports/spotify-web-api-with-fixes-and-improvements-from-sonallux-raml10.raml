  ChapterObject:
    displayName: ChapterObject
    type: object
    properties:
      audio_preview_url:
        required: true
        example:
          value: https://p.scdn.co/mp3-preview/2f37da1d4221f40b9d1a98cd191f4d6f1646ad17
        displayName: audio_preview_url
        description: A URL to a 30 second preview (MP3 format) of the chapter. `null` if not available.
        type:
        - string
        - nil
      available_markets:
        required: false
        displayName: available_markets
        description: A list of the countries in which the chapter can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.
        type: array
        items:
          type: string
      chapter_number:
        required: true
        example:
          value: 1
        displayName: chapter_number
        description: The number of the chapter
        type: integer
        format: int32
      description:
        required: true
        example:
          value: >
            We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.
        displayName: description
        description: A description of the chapter. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.
        type: string
      html_description:
        required: true
        example:
          value: >
            <p>We kept on ascending, with occasional periods of quick descent, but in the main always ascending. Suddenly, I became conscious of the fact that the driver was in the act of pulling up the horses in the courtyard of a vast ruined castle, from whose tall black windows came no ray of light, and whose broken battlements showed a jagged line against the moonlit sky.</p>
        displayName: html_description
        description: A description of the chapter. This field may contain HTML tags.
        type: string
      duration_ms:
        required: true
        example:
          value: 1686230
        displayName: duration_ms
        description: The chapter length in milliseconds.
        type: integer
        format: int32
      explicit:
        required: true
        displayName: explicit
        description: Whether or not the chapter has explicit content (true = yes it does; false = no it does not OR unknown).
        type: boolean
      external_urls:
        required: true
        displayName: external_urls
        description: External URLs for this chapter.
        type: ExternalUrlObject
      href:
        required: true
        example:
          value: https://api.spotify.com/v1/episodes/5Xt5DXGzch68nYYamXrNxZ
        displayName: href
        description: A link to the Web API endpoint providing full details of the chapter.
        type: string
      id:
        required: true
        example:
          value: 5Xt5DXGzch68nYYamXrNxZ
        displayName: id
        description: The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.
        type: string
      images:
        required: true
        displayName: images
        description: The cover art for the chapter in various sizes, widest first.
        type: array
        items:
          type: ImageObject
      is_playable:
        required: true
        displayName: is_playable
        description: True if the chapter is playable in the given market. Otherwise false.
        type: boolean
      languages:
        required: true
        example:
          value:
          - fr
          - en
        displayName: languages
        description: A list of the languages used in the chapter, identified by their [ISO 639-1](https://en.wikipedia.org/wiki/ISO_639) code.
        type: array
        items:
          type: string
      name:
        required: true
        example:
          value: >
            Starting Your Own Podcast: Tips, Tricks, and Advice From Anchor Creators
        displayName: name
        description: The name of the chapter.
        type: string
      release_date:
        required: true
        example:
          value: 1981-12-15
        displayName: release_date
        description: The date the chapter was first released, for example `"1981-12-15"`. Depending on the precision, it might be shown as `"1981"` or `"1981-12"`.
        type: string
      release_date_precision:
        required: true
        example:
          value: day
        displayName: release_date_precision
        description: The precision with which `release_date` value is known.
        type: string
        enum:
        - year
        - month
        - day
      resume_point:
        required: false
        displayName: resume_point
        description: The user's most recent position in the chapter. Set if the supplied access token is a user token and has the scope 'user-read-playback-position'.
        type: ResumePointObject
      type:
        required: true
        displayName: type
        description: The object type.
        type: string
        enum:
        - episode
      uri:
        required: true
        example:
          value: spotify:episode:0zLhl3WsOCQHbe1BPTiHgr
        displayName: uri
        description: The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the chapter.
        type: string
      restrictions:
        required: false
        displayName: restrictions
        description: Included in the response when a content restriction is applied.
        type: ChapterRestrictionObject
      audiobook:
        required: true
        displayName: audiobook
        description: The audiobook for which the chapter belongs.
        type: AudiobookBase
