      /remove_from_resources:
        uriParameters: {}
        post:
          description: >
            Removes one Firewall from multiple resources.


            Currently only Servers (and their public network interfaces) are supported.


            #### Call specific error codes


            | Code                                  | Description                                                            |

            |---------------------------------------|------------------------------------------------------------------------|

            | `firewall_already_removed`            | Firewall was already removed from the resource                         |

            | `firewall_resource_not_found`         | The resource the Firewall should be attached to was not found          |

            | `firewall_managed_by_label_selector`  | Firewall was applied via label selector and cannot be removed manually |
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              enum:
              - application/json
          body:
            application/json:
              schema: |
                {
                  "id": "RemoveFromResourcesRequest",
                  "title": "RemoveFromResourcesRequest",
                  "example": {
                    "remove_from": [
                      {
                        "server": {
                          "id": 42
                        },
                        "type": "server"
                      }
                    ]
                  },
                  "type": "object",
                  "properties": {
                    "remove_from": {
                      "description": "Resources the Firewall should be removed from",
                      "type": "array",
                      "items": {
                        "id": "FirewallRemoveFromResources",
                        "title": "FirewallRemoveFromResources",
                        "type": "object",
                        "properties": {
                          "label_selector": {
                            "id": "LabelSelector5",
                            "title": "LabelSelector5",
                            "description": "Configuration for type label_selector, required if type is `label_selector`",
                            "type": "object",
                            "properties": {
                              "selector": {
                                "description": "Label selector",
                                "example": "env=prod",
                                "type": "string"
                              }
                            },
                            "required": [
                              "selector"
                            ]
                          },
                          "server": {
                            "id": "Server9",
                            "title": "Server9",
                            "description": "Configuration for type server, required if type is `server`",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "ID of the Server",
                                "type": "integer",
                                "format": "int32"
                              }
                            },
                            "required": [
                              "id"
                            ]
                          },
                          "type": {
                            "title": "Type7",
                            "description": "Type of the resource",
                            "type": "string",
                            "additionalProperties": false,
                            "enum": [
                              "server",
                              "label_selector"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "remove_from"
                  ]
                }
              example: '{"remove_from":[{"server":{"id":42},"type":"server"}]}'
          responses:
            '201':
              description: The `actions` key contains multiple `remove_firewall` Actions
              body:
                application/json:
                  schema: |
                    {
                      "id": "ActionsResponse",
                      "title": "ActionsResponse",
                      "example": {
                        "actions": [
                          {
                            "command": "remove_firewall",
                            "error": {
                              "code": "action_failed",
                              "message": "Action failed"
                            },
                            "finished": "2016-01-30T23:56:00+00:00",
                            "id": 14,
                            "progress": 100,
                            "resources": [
                              {
                                "id": 42,
                                "type": "server"
                              },
                              {
                                "id": 38,
                                "type": "firewall"
                              }
                            ],
                            "started": "2016-01-30T23:55:00+00:00",
                            "status": "success"
                          }
                        ]
                      },
                      "type": "object",
                      "properties": {
                        "actions": {
                          "description": "",
                          "type": "array",
                          "items": {
                            "id": "Action",
                            "title": "Action",
                            "type": "object",
                            "properties": {
                              "command": {
                                "description": "Command executed in the Action",
