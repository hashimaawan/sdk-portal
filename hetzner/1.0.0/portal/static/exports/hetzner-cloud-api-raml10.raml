          value: server01.example.com
        displayName: dns_ptr
        description: Reverse DNS PTR entry for the IPv4 addresses of this Server
        type: string
      id:
        required: false
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      ip:
        required: true
        example:
          value: 1.2.3.4
        displayName: ip
        description: IP address (v4) of this Server
        type: string
  Ipv64:
    displayName: Ipv64
    description: IPv6 network assigned to this Server and its reverse DNS entry
    type: object
    properties:
      blocked:
        required: true
        example:
          value: false
        displayName: blocked
        description: If the IP is blocked by our anti abuse dept
        type: boolean
      dns_ptr:
        required: true
        displayName: dns_ptr
        description: Reverse DNS PTR entries for the IPv6 addresses of this Server, `null` by default
        type:
        - array
        - nil
        items:
          type: DnsPtr8
      id:
        required: false
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      ip:
        required: true
        example:
          value: 2001:db8::/64
        displayName: ip
        description: IP address (v6) of this Server
        type: string
  DnsPtr8:
    displayName: DnsPtr8
    type: object
    properties:
      dns_ptr:
        required: true
        example:
          value: server.example.com
        displayName: dns_ptr
        description: DNS pointer for the specific IP address
        type: string
      ip:
        required: true
        example:
          value: 2001:db8::1
        displayName: ip
        description: Single IPv6 address of this Server for which the reverse DNS entry has been set up
        type: string
  ServerType1:
    displayName: ServerType1
    description: Type of Server - determines how much ram, disk and cpu a Server has
    type: object
    properties:
      cores:
        required: true
        example:
          value: 1
        displayName: cores
        description: Number of cpu cores a Server of this type will have
        type: number
        format: double
      cpu_type:
        required: true
        displayName: cpu_type
        description: Type of cpu
        type: string
        enum:
        - shared
        - dedicated
      deprecated:
        required: true
        example:
          value: false
        displayName: deprecated
        description: True if Server type is deprecated
        type: boolean
      description:
        required: true
        example:
          value: CX11
        displayName: description
        description: Description of the Server type
        type: string
      disk:
        required: true
        example:
          value: 25
        displayName: disk
        description: Disk size a Server of this type will have in GB
        type: number
        format: double
      id:
        required: true
        example:
          value: 1
        displayName: id
        description: ID of the Server type
        type: integer
        format: int32
      memory:
        required: true
        example:
          value: 1
        displayName: memory
        description: Memory a Server of this type will have in GB
        type: number
        format: double
      name:
        required: true
        example:
          value: cx11
        displayName: name
        description: Unique identifier of the Server type
        type: string
      prices:
        required: true
        displayName: prices
        description: Prices in different Locations
        type: array
        items:
          type: Price9
      storage_type:
        required: true
        displayName: storage_type
        description: Type of Server boot drive. Local has higher speed. Network has better availability.
        type: string
        enum:
        - local
        - network
  CreateServerRequest:
    displayName: CreateServerRequest
    type: object
    properties:
      automount:
        required: false
        example:
          value: false
        displayName: automount
        description: Auto-mount Volumes after attach
        type: boolean
      datacenter:
        required: false
        example:
          value: nbg1-dc3
        displayName: datacenter
        description: ID or name of Datacenter to create Server in (must not be used together with location)
        type: string
      firewalls:
        required: false
        example:
          value:
          - firewall: 38
        displayName: firewalls
        description: Firewalls which should be applied on the Server's public network interface at creation time
        type: array
        items:
          type: Firewall4
      image:
        required: true
        example:
          value: ubuntu-20.04
        displayName: image
        description: ID or name of the Image the Server is created from
        type: string
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      location:
        required: false
        example:
          value: nbg1
        displayName: location
        description: ID or name of Location to create Server in (must not be used together with datacenter)
        type: string
      name:
        required: true
        example:
          value: my-server
        displayName: name
        description: Name of the Server to create (must be unique per Project and a valid hostname as per RFC 1123)
        type: string
      networks:
        required: false
        example:
          value:
          - 456
        displayName: networks
        description: Network IDs which should be attached to the Server private network interface at the creation time
        type: array
        items:
          type: integer
          format: int32
      placement_group:
        required: false
        example:
          value: 1
        displayName: placement_group
        description: ID of the Placement Group the server should be in
        type: integer
        format: int32
      public_net:
        required: false
        displayName: public_net
        description: Public Network options
        type: PublicNet5
      server_type:
        required: true
        example:
          value: cx11
        displayName: server_type
        description: ID or name of the Server type this Server should be created with
        type: string
      ssh_keys:
        required: false
        example:
          value:
          - my-ssh-key
        displayName: ssh_keys
        description: SSH key IDs (`integer`) or names (`string`) which should be injected into the Server at creation time
        type: array
        items:
          type: string
      start_after_create:
        required: false
        example:
          value: true
        displayName: start_after_create
        description: Start Server right after creation. Defaults to true.
        type: boolean
      user_data:
        required: false
        example:
          value: >
            #cloud-config

            runcmd:

            - [touch, /root/cloud-init-worked]
        displayName: user_data
        description: Cloud-Init user data to use during Server creation. This field is limited to 32KiB.
        type: string
      volumes:
        required: false
        example:
          value:
          - 123
        displayName: volumes
        description: Volume IDs which should be attached to the Server at the creation time. Volumes must be in the same Location.
        type: array
        items:
          type: integer
          format: int32
  Firewall4:
    displayName: Firewall4
    type: object
    properties:
      firewall:
        required: false
        displayName: firewall
        description: ID of the Firewall
        type: integer
        format: int32
  PublicNet5:
    displayName: PublicNet5
    description: Public Network options
    type: object
    properties:
      enable_ipv4:
        required: false
        displayName: enable_ipv4
        description: Attach an IPv4 on the public NIC. If false, no IPv4 address will be attached. Defaults to true.
        type: boolean
      enable_ipv6:
        required: false
        displayName: enable_ipv6
        description: Attach an IPv6 on the public NIC. If false, no IPv6 address will be attached. Defaults to true.
        type: boolean
      ipv4:
        required: false
        displayName: ipv4
        description: ID of the ipv4 Primary IP to use. If omitted and enable_ipv4 is true, a new ipv4 Primary IP will automatically be created.
        type:
        - integer
        - nil
        format: int32
      ipv6:
        required: false
        displayName: ipv6
        description: ID of the ipv6 Primary IP to use. If omitted and enable_ipv6 is true, a new ipv6 Primary IP will automatically be created.
        type:
        - integer
        - nil
        format: int32
  CreateServerResponse:
    displayName: CreateServerResponse
    type: object
    properties:
      action:
        required: true
        displayName: action
        type: Action
      next_actions:
        required: true
        displayName: next_actions
        type: array
        items:
          type: Action
      root_password:
        required: true
        example:
          value: YItygq1v3GYjjMomLaKc
        displayName: root_password
        description: Root password when no SSH keys have been specified
        type:
        - string
        - nil
      server:
        required: true
        displayName: server
        type: Server18
  ServersResponse1:
    displayName: ServersResponse1
    type: object
    properties:
      action:
        required: false
        displayName: action
        type: Action
  ServersResponse2:
    displayName: ServersResponse2
    type: object
    properties:
      server:
        required: false
        displayName: server
        type: Server18
  UpdateServerRequest:
    displayName: UpdateServerRequest
    type: object
    properties:
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: false
        example:
          value: my-server
        displayName: name
        description: New name to set
        type: string
  AddToPlacementGroupRequest:
    displayName: AddToPlacementGroupRequest
    type: object
    properties:
      placement_group:
        required: true
        example:
          value: 1
        displayName: placement_group
        description: ID of Placement Group the Server should be added to
        type: integer
        format: int32
  ServersActionsAttachIsoRequest:
    displayName: ServersActionsAttachIsoRequest
    type: object
    properties:
      iso:
        required: true
        example:
          value: FreeBSD-11.0-RELEASE-amd64-dvd1
        displayName: iso
        description: ID or name of ISO to attach to the Server as listed in GET `/isos`
        type: string
  AttachToNetworkRequest:
    displayName: AttachToNetworkRequest
    type: object
    properties:
      alias_ips:
        required: false
        example:
          value:
          - 10.0.1.2
        displayName: alias_ips
        description: Additional IPs to be assigned to this Server
        type: array
        items:
          type: string
      ip:
        required: false
        example:
          value: 10.0.1.1
        displayName: ip
        description: IP to request to be assigned to this Server; if you do not provide this then you will be auto assigned an IP address
        type: string
      network:
        required: true
        example:
          value: 4711
        displayName: network
        description: ID of an existing network to attach the Server to
        type: integer
        format: int32
  ServersActionsChangeAliasIpsRequest:
    displayName: ServersActionsChangeAliasIpsRequest
    type: object
    properties:
      alias_ips:
        required: true
        example:
          value:
          - 10.0.1.2
        displayName: alias_ips
        description: New alias IPs to set for this Server
        type: array
        items:
          type: string
      network:
        required: true
        example:
          value: 4711
        displayName: network
        description: ID of an existing Network already attached to the Server
        type: integer
        format: int32
  ServersActionsChangeDnsPtrRequest:
    displayName: ServersActionsChangeDnsPtrRequest
    type: object
    properties:
      dns_ptr:
        required: true
        example:
          value: server01.example.com
        displayName: dns_ptr
        description: Hostname to set as a reverse DNS PTR entry, reset to original value if `null`
        type:
        - string
        - nil
      ip:
        required: true
        example:
          value: 1.2.3.4
        displayName: ip
        description: Primary IP address for which the reverse DNS entry should be set
        type: string
  ServersActionsChangeProtectionRequest:
    displayName: ServersActionsChangeProtectionRequest
    type: object
    properties:
      delete:
        required: false
        example:
          value: true
        displayName: delete
        description: If true, prevents the Server from being deleted (currently delete and rebuild attribute needs to have the same value)
        type: boolean
      rebuild:
        required: false
        example:
          value: true
        displayName: rebuild
        description: If true, prevents the Server from being rebuilt (currently delete and rebuild attribute needs to have the same value)
        type: boolean
  ServersActionsChangeTypeRequest:
    displayName: ServersActionsChangeTypeRequest
    type: object
    properties:
      server_type:
        required: true
        example:
          value: cx11
        displayName: server_type
        description: ID or name of Server type the Server should migrate to
        type: string
      upgrade_disk:
        required: true
        example:
          value: true
        displayName: upgrade_disk
        description: If false, do not upgrade the disk (this allows downgrading the Server type later)
        type: boolean
  CreateImageRequest:
    displayName: CreateImageRequest
    type: object
    properties:
      description:
        required: false
        example:
          value: my image
        displayName: description
        description: Description of the Image, will be auto-generated if not set
        type: string
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: Labels
      type:
        required: false
        example:
          value: snapshot
        displayName: type
        description: 'Type of Image to create (default: `snapshot`)'
        type: string
        enum:
        - snapshot
        - backup
  ServersActionsCreateImageResponse:
    displayName: ServersActionsCreateImageResponse
    type: object
    properties:
      action:
        required: false
        displayName: action
        type: Action
      image:
        required: false
        displayName: image
        type: Image
  DetachFromNetworkRequest:
    displayName: DetachFromNetworkRequest
    type: object
    properties:
      network:
        required: true
        example:
          value: 4711
        displayName: network
        description: ID of an existing network to detach the Server from
        type: integer
        format: int32
  ServersActionsEnableRescueRequest:
    displayName: ServersActionsEnableRescueRequest
    type: object
    properties:
      ssh_keys:
        required: false
        example:
          value:
          - 2323
        displayName: ssh_keys
        description: Array of SSH key IDs which should be injected into the rescue system.
        type: array
        items:
          type: integer
          format: int32
      type:
        required: false
        displayName: type
        description: 'Type of rescue system to boot (default: `linux64`)'
        type: string
        enum:
        - linux64
        - linux32
  ServersActionsEnableRescueResponse:
    displayName: ServersActionsEnableRescueResponse
    type: object
    properties:
      action:
        required: false
        displayName: action
        type: Action
      root_password:
        required: false
        example:
          value: zCWbFhnu950dUTko5f40
        displayName: root_password
        description: Password that will be set for this Server once the Action succeeds
        type: string
  RebuildServerRequest:
    displayName: RebuildServerRequest
    type: object
    properties:
      image:
        required: true
        example:
          value: ubuntu-20.04
        displayName: image
        description: ID or name of Image to rebuilt from.
        type: string
  ServersActionsRebuildResponse:
    displayName: ServersActionsRebuildResponse
    type: object
    properties:
      action:
        required: false
        displayName: action
        type: Action
      root_password:
        required: false
        displayName: root_password
        description: New root password when not using SSH keys
        type:
        - string
        - nil
  ServersActionsRequestConsoleResponse:
    displayName: ServersActionsRequestConsoleResponse
    type: object
    properties:
      action:
        required: true
        displayName: action
        type: Action
      password:
        required: true
        example:
          value: 9MQaTg2VAGI0FIpc10k3UpRXcHj2wQ6x
        displayName: password
        description: VNC password to use for this connection (this password only works in combination with a wss_url with valid token)
        type: string
      wss_url:
        required: true
        example:
          value: wss://console.hetzner.cloud/?server_id=1&token=3db32d15-af2f-459c-8bf8-dee1fd05f49c
        displayName: wss_url
        description: URL of websocket proxy to use; this includes a token which is valid for a limited time only
        type: string
  ServersActionsResetPasswordResponse:
    displayName: ServersActionsResetPasswordResponse
    type: object
    properties:
      action:
        required: false
        displayName: action
        type: Action
      root_password:
        required: false
        example:
          value: zCWbFhnu950dUTko5f40
        displayName: root_password
        description: Password that will be set for this Server once the Action succeeds
        type: string
  ServersMetricsResponse:
    displayName: ServersMetricsResponse
    type: object
    properties:
      metrics:
        required: true
        displayName: metrics
        type: Metrics
  SshKeysResponse:
    displayName: SshKeysResponse
    type: object
    properties:
      meta:
        required: false
        displayName: meta
        type: Meta
      ssh_keys:
        required: true
        displayName: ssh_keys
        type: array
        items:
          type: SshKey
  SshKey:
    displayName: SshKey
    type: object
    properties:
      created:
        required: true
        example:
          value: 2016-01-30T23:55:00+00:00
        displayName: created
        description: Point in time when the Resource was created (in ISO-8601 format)
        type: string
      fingerprint:
        required: true
        example:
          value: b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f
        displayName: fingerprint
        description: Fingerprint of public key
        type: string
      id:
        required: true
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        additionalProperties: true
        properties:
          //:
            type: string
      name:
        required: true
        example:
          value: my-resource
        displayName: name
        description: Name of the Resource. Must be unique per Project.
        type: string
      public_key:
        required: true
        example:
          value: ssh-rsa AAAjjk76kgf...Xt
        displayName: public_key
        description: Public key
        type: string
  SshKeysRequest:
    displayName: SshKeysRequest
    type: object
    properties:
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: true
        example:
          value: My ssh key
        displayName: name
        description: Name of the SSH key
        type: string
      public_key:
        required: true
        example:
          value: ssh-rsa AAAjjk76kgf...Xt
        displayName: public_key
        description: Public key
        type: string
  SshKeysResponse1:
    displayName: SshKeysResponse1
    type: object
    properties:
      ssh_key:
        required: true
        displayName: ssh_key
        type: SshKey
  SshKeysRequest1:
    displayName: SshKeysRequest1
    type: object
    properties:
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      name:
        required: false
        example:
          value: My ssh key
        displayName: name
        description: New name Name to set
        type: string
  VolumesResponse:
    displayName: VolumesResponse
    type: object
    properties:
      meta:
        required: false
        displayName: meta
        type: Meta
      volumes:
        required: true
        displayName: volumes
        type: array
        items:
          type: Volume1
  Volume1:
    displayName: Volume1
    type: object
    properties:
      created:
        required: true
        example:
          value: 2016-01-30T23:55:00+00:00
        displayName: created
        description: Point in time when the Resource was created (in ISO-8601 format)
        type: string
      format:
        required: true
        example:
          value: xfs
        displayName: format
        description: Filesystem of the Volume if formatted on creation, null if not formatted on creation
        type:
        - string
        - nil
      id:
        required: true
        example:
          value: 42
        displayName: id
        description: ID of the Resource
        type: integer
        format: int32
      labels:
        required: true
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        additionalProperties: true
        properties:
          //:
            type: string
      linux_device:
        required: true
        example:
          value: /dev/disk/by-id/scsi-0HC_Volume_4711
        displayName: linux_device
        description: Device path on the file system for the Volume
        type: string
      location:
        required: true
        displayName: location
        description: Location of the Volume. Volume can only be attached to Servers in the same Location.
        type: Location16
      name:
        required: true
        example:
          value: my-resource
        displayName: name
        description: Name of the Resource. Must be unique per Project.
        type: string
      protection:
        required: true
        displayName: protection
        description: Protection configuration for the Resource
        type: Protection
      server:
        required: true
        example:
          value: 12
        displayName: server
        description: ID of the Server the Volume is attached to, null if it is not attached at all
        type:
        - integer
        - nil
        format: int32
      size:
        required: true
        example:
          value: 42
        displayName: size
        description: Size in GB of the Volume
        type: number
        format: double
      status:
        required: true
        example:
          value: available
        displayName: status
        description: Current status of the Volume
        type: string
        enum:
        - creating
        - available
  Location16:
    displayName: Location16
    description: Location of the Volume. Volume can only be attached to Servers in the same Location.
    type: object
    properties:
      city:
        required: true
        example:
          value: Falkenstein
        displayName: city
        description: City the Location is closest to
        type: string
      country:
        required: true
        example:
          value: DE
        displayName: country
        description: ISO 3166-1 alpha-2 code of the country the Location resides in
        type: string
      description:
        required: true
        example:
          value: Falkenstein DC Park 1
        displayName: description
        description: Description of the Location
        type: string
      id:
        required: true
        example:
          value: 1
        displayName: id
        description: ID of the Location
        type: number
        format: double
      latitude:
        required: true
        example:
          value: 50.47612
        displayName: latitude
        description: Latitude of the city closest to the Location
        type: number
        format: double
      longitude:
        required: true
        example:
          value: 12.370071
        displayName: longitude
        description: Longitude of the city closest to the Location
        type: number
        format: double
      name:
        required: true
        example:
          value: fsn1
        displayName: name
        description: Unique identifier of the Location
        type: string
      network_zone:
        required: true
        example:
          value: eu-central
        displayName: network_zone
        description: Name of network zone this Location resides in
        type: string
  CreateVolumeRequest:
    displayName: CreateVolumeRequest
    type: object
    properties:
      automount:
        required: false
        example:
          value: false
        displayName: automount
        description: Auto-mount Volume after attach. `server` must be provided.
        type: boolean
      format:
        required: false
        example:
          value: xfs
        displayName: format
        description: 'Format Volume after creation. One of: `xfs`, `ext4`'
        type: string
      labels:
        required: false
        example:
          value:
            labelkey: value
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: object
        properties: {}
      location:
        required: false
        example:
          value: nbg1
        displayName: location
        description: Location to create the Volume in (can be omitted if Server is specified)
        type: string
      name:
        required: true
        example:
          value: databases-storage
        displayName: name
        description: Name of the volume
        type: string
      server:
        required: false
        displayName: server
        description: Server to which to attach the Volume once it's created (Volume will be created in the same Location as the server)
        type: integer
        format: int32
      size:
        required: true
        example:
          value: 42
        displayName: size
        description: Size of the Volume in GB
        type: integer
        format: int32
  VolumesResponse1:
    displayName: VolumesResponse1
    type: object
    properties:
      action:
        required: true
        displayName: action
        type: Action
      next_actions:
        required: true
        displayName: next_actions
        type: array
        items:
          type: Action
      volume:
        required: true
        displayName: volume
        type: Volume1
  VolumesResponse2:
    displayName: VolumesResponse2
    type: object
    properties:
      volume:
        required: true
        displayName: volume
        type: Volume1
  UpdateVolumeRequest:
    displayName: UpdateVolumeRequest
    type: object
    properties:
      labels:
        required: false
        displayName: labels
        description: User-defined labels (key-value pairs)
        type: Labels2
      name:
        required: true
        example:
          value: database-storage
        displayName: name
        description: New Volume name
        type: string
  AttachVolumeRequest:
    displayName: AttachVolumeRequest
    type: object
    properties:
      automount:
        required: false
        example:
          value: false
        displayName: automount
        description: Auto-mount the Volume after attaching it
        type: boolean
      server:
        required: true
        example:
          value: 43
        displayName: server
        description: ID of the Server the Volume will be attached to
        type: integer
        format: int32
  VolumesActionsChangeProtectionRequest:
    displayName: VolumesActionsChangeProtectionRequest
    type: object
    properties:
      delete:
        required: false
        example:
          value: true
        displayName: delete
        description: If true, prevents the Volume from being deleted
        type: boolean
  VolumesActionsResizeRequest:
    displayName: VolumesActionsResizeRequest
    type: object
    properties:
      size:
        required: true
        example:
          value: 50
        displayName: size
        description: New Volume size in GB (must be greater than current size)
        type: number
        format: double
/actions:
  get:
