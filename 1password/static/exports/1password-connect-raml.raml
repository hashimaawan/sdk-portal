- ServiceDependency: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "ServiceDependency",
      "title": "ServiceDependency",
      "description": "The state of a registered server dependency.",
      "type": "object",
      "properties": {
        "message": {
          "description": "Human-readable message for explaining the current state.",
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    }
- Vault: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Vault",
      "title": "Vault",
      "type": "object",
      "properties": {
        "attributeVersion": {
          "description": "The vault version",
          "type": "integer",
          "format": "int32"
        },
        "contentVersion": {
          "description": "The version of the vault contents",
          "type": "integer",
          "format": "int32"
        },
        "createdAt": {
          "readOnly": true,
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string",
          "pattern": "^[\\da-z]{26}$"
        },
        "items": {
          "description": "Number of active items in the vault",
          "type": "integer",
          "format": "int32"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "title": "Type2",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "USER_CREATED",
            "PERSONAL",
            "EVERYONE",
            "TRANSFER"
          ]
        },
        "updatedAt": {
          "readOnly": true,
          "type": "string",
          "format": "date-time"
        }
      }
    }
