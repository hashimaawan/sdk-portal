/activity:
  get:
    securedBy:
    - ConnectToken
    queryParameters:
      limit:
        description: How many API Events should be retrieved in a single request.
        type: integer
        example: '10'
        default: '50'
        required: false
        displayName: limit
      offset:
        description: How far into the collection of API Events should the response start
        type: integer
        example: '50'
        default: '0'
        required: false
        displayName: offset
    responses:
      '200':
        description: OK
        headers:
          Content-Range:
            required: false
        body:
          application/json:
            schema: |
              {
                "description": "",
                "type": "array",
