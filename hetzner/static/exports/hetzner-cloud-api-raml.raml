                    ]
                  }
                },
                "required": [
                  "ssh_keys"
                ]
              }
  post:
    description: Creates a new SSH key with the given `name` and `public_key`. Once an SSH key is created, it can be used in other calls such as creating Servers.
    headers:
      Content-Type:
        example: application/json
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "SshKeysRequest",
            "title": "SshKeysRequest",
            "type": "object",
            "properties": {
              "name": {
                "description": "Name of the SSH key",
                "example": "My ssh key",
                "type": "string"
              },
              "public_key": {
                "description": "Public key",
                "example": "ssh-rsa AAAjjk76kgf...Xt",
                "type": "string"
              },
              "labels": {
                "description": "User-defined labels (key-value pairs)",
                "type": "object"
              }
            },
            "required": [
              "name",
              "public_key"
            ]
          }
        example: ''
    responses:
      '201':
        description: The `ssh_key` key in the reply contains the object that was just created
        body:
          application/json:
            schema: |
              {
                "id": "SshKeysResponse1",
                "title": "SshKeysResponse1",
                "type": "object",
                "properties": {
                  "ssh_key": {
                    "id": "SshKey",
                    "title": "SshKey",
                    "type": "object",
                    "properties": {
                      "created": {
                        "description": "Point in time when the Resource was created (in ISO-8601 format)",
                        "example": "2016-01-30T23:55:00+00:00",
                        "type": "string"
                      },
                      "fingerprint": {
                        "description": "Fingerprint of public key",
                        "example": "b7:2f:30:a0:2f:6c:58:6c:21:04:58:61:ba:06:3b:2f",
                        "type": "string"
                      },
                      "id": {
                        "description": "ID of the Resource",
                        "example": 42,
                        "type": "integer",
                        "format": "int32"
                      },
                      "labels": {
                        "description": "User-defined labels (key-value pairs)",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "name": {
                        "description": "Name of the Resource. Must be unique per Project.",
                        "example": "my-resource",
                        "type": "string"
                      },
                      "public_key": {
                        "description": "Public key",
                        "example": "ssh-rsa AAAjjk76kgf...Xt",
                        "type": "string"
                      }
                    },
                    "required": [
                      "created",
                      "fingerprint",
                      "id",
                      "labels",
                      "name",
                      "public_key"
                    ]
                  }
                },
                "required": [
                  "ssh_key"
                ]
              }
/volumes:
  /{id}:
    uriParameters:
      id:
        description: ID of the Volume
        type: string
        required: true
        displayName: id
    /actions:
      uriParameters: {}
      /attach:
        uriParameters: {}
        post:
          description: Attaches a Volume to a Server. Works only if the Server is in the same Location as the Volume.
          headers:
            Content-Type:
              required: true
              displayName: Content-Type
              enum:
              - application/json
          body:
            application/json:
              schema: |
                {
                  "id": "AttachVolumeRequest",
                  "title": "AttachVolumeRequest",
                  "type": "object",
                  "properties": {
                    "server": {
                      "description": "ID of the Server the Volume will be attached to",
                      "example": 43,
                      "type": "integer",
                      "format": "int32"
                    },
                    "automount": {
                      "description": "Auto-mount the Volume after attaching it",
                      "example": false,
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "server"
                  ]
                }
              example: ''
          responses:
            '201':
              description: The `action` key contains the `attach_volume` Action
              body:
                application/json:
                  schema: |
                    {
                      "id": "ActionResponse",
                      "title": "ActionResponse",
                      "example": {
                        "action": {
                          "command": "attach_volume",
                          "error": {
                            "code": "action_failed",
                            "message": "Action failed"
                          },
                          "finished": null,
                          "id": 13,
                          "progress": 0,
                          "resources": [
                            {
                              "id": 43,
                              "type": "server"
                            },
                            {
                              "id": 554,
                              "type": "volume"
                            }
                          ],
                          "started": "2016-01-30T23:50:00+00:00",
                          "status": "running"
                        }
                      },
                      "type": "object",
                      "properties": {
                        "action": {
                          "id": "Action",
                          "title": "Action",
                          "type": "object",
                          "properties": {
                            "command": {
                              "description": "Command executed in the Action",
                              "example": "start_server",
                              "type": "string"
                            },
                            "error": {
                              "id": "Error",
                              "title": "Error",
                              "description": "Error message for the Action if error occurred, otherwise null",
                              "type": [
                                "object",
                                "null"
                              ],
                              "properties": {
                                "code": {
                                  "description": "Fixed machine readable code",
                                  "example": "action_failed",
                                  "type": "string"
                                },
                                "message": {
                                  "description": "Humanized error message",
                                  "example": "Action failed",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "code",
                                "message"
                              ]
                            },
                            "finished": {
                              "description": "Point in time when the Action was finished (in ISO-8601 format). Only set if the Action is finished otherwise null.",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "id": {
                              "description": "ID of the Resource",
                              "example": 42,
                              "type": "integer",
                              "format": "int32"
                            },
                            "progress": {
                              "description": "Progress of Action in percent",
                              "example": 100,
                              "type": "number"
                            },
                            "resources": {
                              "description": "Resources the Action relates to",
                              "type": "array",
                              "items": {
                                "id": "Resource",
                                "title": "Resource",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Resource",
                                    "example": 42,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "type": {
                                    "description": "Type of resource referenced",
                                    "example": "server",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "id",
                                  "type"
                                ]
                              }
                            },
                            "started": {
                              "description": "Point in time when the Action was started (in ISO-8601 format)",
                              "example": "2016-01-30T23:55:00+00:00",
                              "type": "string"
                            },
                            "status": {
                              "title": "Status",
                              "description": "Status of the Action",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "success",
                                "running",
                                "error"
                              ]
                            }
                          },
                          "required": [
                            "command",
                            "error",
                            "finished",
                            "id",
                            "progress",
                            "resources",
                            "started",
                            "status"
                          ]
                        }
                      },
                      "required": [
                        "action"
                      ]
                    }
                  example: '{"action":{"command":"attach_volume","error":{"code":"action_failed","message":"Action failed"},"finished":null,"id":13,"progress":0,"resources":[{"id":43,"type":"server"},{"id":554,"type":"volume"}],"started":"2016-01-30T23:50:00+00:00","status":"running"}}'
