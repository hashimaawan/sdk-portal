/locations:
  /{id}:
    uriParameters:
      id:
        description: ID of Location
        type: integer
        required: true
        displayName: id
    get:
      description: Returns a specific Location object.
      responses:
        '200':
          description: The `location` key in the reply contains a Location object with this structure
          body:
            application/json:
              schema: |
                {
                  "id": "LocationsResponse1",
