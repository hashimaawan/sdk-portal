                                "app",
                                "snapshot",
                                "backup",
                                "temporary"
                              ]
                            },
                            "rapid_deploy": {
                              "description": "Indicates that rapid deploy of the Image is available",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
