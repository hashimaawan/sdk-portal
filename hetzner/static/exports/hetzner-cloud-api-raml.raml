                                "id": "Resource",
                                "title": "Resource",
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "description": "ID of the Resource",
                                    "example": 42,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "type": {
                                    "description": "Type of resource referenced",
                                    "example": "server",
                                    "type": "string"
                                  }
                                },
                                "required": [
