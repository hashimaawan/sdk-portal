                            "rebuild": {
                              "description": "If true, prevents the Server from being rebuilt",
                              "example": false,
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "delete",
                            "rebuild"
                          ]
                        },
                        "public_net": {
                          "id": "PublicNet4",
