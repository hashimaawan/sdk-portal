  get:
    securedBy:
    - oauth_2_0
    description: >
      Get Spotify catalog information for several shows based on their Spotify IDs.
    queryParameters:
      ids:
        type: string
        example: 5CfCWKI5pZ28U0uOzXkDHe,5as3aKmN2k11yfDDDSrvaZ
        required: true
        displayName: ids
      market:
        type: string
        example: ES
        required: false
        displayName: market
    responses:
      '200':
        description: A set of shows
        body:
          application/json:
            schema: |
              {
                "id": "ManySimplifiedShows",
                "title": "ManySimplifiedShows",
                "type": "object",
                "properties": {
                  "shows": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "ShowBase",
                      "title": "ShowBase",
                      "type": "object",
                      "properties": {
                        "available_markets": {
                          "description": "A list of the countries in which the show can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "copyrights": {
                          "description": "The copyright statements of the show.",
                          "type": "array",
                          "items": {
                            "id": "CopyrightObject",
                            "title": "CopyrightObject",
                            "type": "object",
                            "properties": {
                              "text": {
                                "description": "The copyright text for this content.",
                                "type": "string"
                              },
                              "type": {
                                "description": "The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.",
                                "type": "string"
                              }
                            }
                          }
                        },
                        "description": {
                          "description": "A description of the show. HTML tags are stripped away from this field, use `html_description` field in case HTML tags are needed.",
                          "type": "string"
                        },
                        "html_description": {
                          "description": "A description of the show. This field may contain HTML tags.",
                          "type": "string"
                        },
                        "explicit": {
                          "description": "Whether or not the show has explicit content (true = yes it does; false = no it does not OR unknown).",
                          "type": "boolean"
                        },
                        "external_urls": {
                          "id": "ExternalUrlObject",
                          "title": "ExternalUrlObject",
                          "description": "External URLs for this show.",
                          "type": "object",
                          "properties": {
                            "spotify": {
                              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                              "type": "string"
                            }
                          }
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the show.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the show.",
                          "type": "string"
                        },
                        "images": {
                          "description": "The cover art for the show in various sizes, widest first.",
                          "type": "array",
                          "items": {
                            "id": "ImageObject",
                            "title": "ImageObject",
                            "type": "object",
                            "properties": {
                              "url": {
                                "description": "The source URL of the image.",
                                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                "type": "string"
                              },
                              "height": {
                                "description": "The image height in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              },
                              "width": {
                                "description": "The image width in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              }
                            },
                            "required": [
                              "url",
                              "height",
                              "width"
                            ]
                          }
                        },
                        "is_externally_hosted": {
                          "description": "True if all of the shows episodes are hosted outside of Spotify's CDN. This field might be `null` in some cases.",
                          "type": "boolean"
                        },
                        "languages": {
                          "description": "A list of the languages used in the show, identified by their [ISO 639](https://en.wikipedia.org/wiki/ISO_639) code.",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "media_type": {
                          "description": "The media type of the show.",
                          "type": "string"
                        },
                        "name": {
                          "description": "The name of the episode.",
                          "type": "string"
                        },
                        "publisher": {
                          "description": "The publisher of the show.",
                          "type": "string"
                        },
                        "type": {
                          "description": "The object type.",
                          "type": "string",
                          "enum": [
                            "show"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the show.",
                          "type": "string"
                        },
                        "total_episodes": {
                          "description": "The total number of episodes in the show.",
                          "type": "integer",
                          "format": "int32"
                        }
                      },
                      "required": [
                        "available_markets",
                        "copyrights",
                        "description",
                        "html_description",
                        "explicit",
                        "external_urls",
                        "href",
                        "id",
                        "images",
                        "is_externally_hosted",
                        "languages",
                        "media_type",
                        "name",
                        "publisher",
                        "type",
                        "uri",
                        "total_episodes"
                      ]
                    }
                  }
                },
                "required": [
                  "shows"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/tracks:
  /{id}:
    uriParameters:
      id:
        type: string
        example: 11dFghVXANMlKmJXsNCbNl
        required: true
        displayName: id
    get:
      securedBy:
      - oauth_2_0
      description: >
        Get Spotify catalog information for a single track identified by its

        unique Spotify ID.
      queryParameters:
        market:
          type: string
          example: ES
          required: false
          displayName: market
      responses:
        '200':
          description: A track
          body:
            application/json:
              schema: |
                {
                  "id": "TrackObject",
                  "title": "TrackObject",
                  "type": "object",
                  "properties": {
                    "album": {
                      "id": "SimplifiedAlbumObject",
                      "title": "SimplifiedAlbumObject",
                      "description": "The album on which the track appears. The album object includes a link in `href` to full information about the album.",
                      "type": "object",
                      "properties": {
                        "album_type": {
                          "title": "AlbumType",
                          "description": "The type of the album.",
                          "example": "compilation",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "album",
                            "single",
                            "compilation"
                          ]
                        },
                        "total_tracks": {
                          "description": "The number of tracks in the album.",
                          "example": 9,
                          "type": "integer",
                          "format": "int32"
                        },
                        "available_markets": {
                          "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                          "example": [
                            "CA",
                            "BR",
                            "IT"
                          ],
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "external_urls": {
                          "id": "ExternalUrlObject",
                          "title": "ExternalUrlObject",
                          "description": "Known external URLs for this track.",
                          "type": "object",
                          "properties": {
                            "spotify": {
                              "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                              "type": "string"
                            }
                          }
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the album.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                          "example": "2up3OPMp9Tb4dAKM2erWXQ",
                          "type": "string"
                        },
                        "images": {
                          "description": "The cover art for the album in various sizes, widest first.",
                          "type": "array",
                          "items": {
                            "id": "ImageObject",
                            "title": "ImageObject",
                            "type": "object",
                            "properties": {
                              "url": {
                                "description": "The source URL of the image.",
                                "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                "type": "string"
                              },
                              "height": {
                                "description": "The image height in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              },
                              "width": {
                                "description": "The image width in pixels.",
                                "example": 300,
                                "type": [
                                  "integer",
                                  "null"
                                ],
                                "format": "int32"
                              }
                            },
                            "required": [
                              "url",
                              "height",
                              "width"
                            ]
                          }
                        },
                        "name": {
                          "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                          "type": "string"
                        },
                        "release_date": {
                          "description": "The date the album was first released.",
                          "example": "1981-12",
                          "type": "string"
                        },
                        "release_date_precision": {
                          "title": "ReleaseDatePrecision",
                          "description": "The precision with which `release_date` value is known.",
                          "example": "year",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "year",
                            "month",
                            "day"
                          ]
                        },
                        "type": {
                          "description": "The object type.",
                          "type": "string",
                          "enum": [
                            "album"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                          "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                          "type": "string"
                        },
                        "artists": {
                          "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                          "type": "array",
                          "items": {
                            "id": "SimplifiedArtistObject",
                            "title": "SimplifiedArtistObject",
                            "type": "object",
                            "properties": {
                              "external_urls": {
                                "$ref": "ExternalUrlObject"
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the artist.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              },
                              "name": {
                                "description": "The name of the artist.",
                                "type": "string"
                              },
                              "type": {
                                "title": "Type",
                                "description": "The object type.",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "artist"
                                ]
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              }
                            }
                          }
                        },
                        "restrictions": {
                          "id": "AlbumRestrictionObject",
                          "title": "AlbumRestrictionObject",
                          "description": "Included in the response when a content restriction is applied.",
                          "type": "object",
                          "properties": {
                            "reason": {
                              "title": "Reason",
                              "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "market",
                                "product",
                                "explicit"
                              ]
                            }
                          }
                        }
                      },
                      "required": [
                        "album_type",
                        "total_tracks",
                        "available_markets",
                        "external_urls",
                        "href",
                        "id",
                        "images",
                        "name",
                        "release_date",
                        "release_date_precision",
                        "type",
                        "uri",
                        "artists"
                      ]
                    },
                    "artists": {
                      "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                      "type": "array",
                      "items": {
                        "id": "ArtistObject",
                        "title": "ArtistObject",
                        "type": "object",
                        "properties": {
                          "external_urls": {
                            "$ref": "ExternalUrlObject"
                          },
                          "followers": {
                            "id": "FollowersObject",
                            "title": "FollowersObject",
                            "description": "Information about the followers of the artist.",
                            "type": "object",
                            "properties": {
                              "href": {
                                "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "total": {
                                "description": "The total number of followers.",
                                "type": "integer",
                                "format": "int32"
                              }
                            }
                          },
                          "genres": {
                            "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                            "example": [
                              "Prog rock",
                              "Grunge"
                            ],
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "href": {
                            "description": "A link to the Web API endpoint providing full details of the artist.",
                            "type": "string"
                          },
                          "id": {
                            "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                            "type": "string"
                          },
                          "images": {
                            "description": "Images of the artist in various sizes, widest first.",
                            "type": "array",
                            "items": {
                              "$ref": "ImageObject"
                            }
                          },
                          "name": {
                            "description": "The name of the artist.",
                            "type": "string"
                          },
                          "popularity": {
                            "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                            "type": "integer",
                            "format": "int32"
                          },
                          "type": {
                            "$ref": "SimplifiedArtistObject#/properties/type"
                          },
                          "uri": {
                            "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                            "type": "string"
                          }
                        }
                      }
                    },
                    "available_markets": {
                      "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "disc_number": {
                      "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                      "type": "integer",
                      "format": "int32"
                    },
                    "duration_ms": {
                      "description": "The track length in milliseconds.",
                      "type": "integer",
                      "format": "int32"
                    },
                    "explicit": {
                      "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                      "type": "boolean"
                    },
                    "external_ids": {
                      "id": "ExternalIdObject",
                      "title": "ExternalIdObject",
                      "description": "Known external IDs for the track.",
                      "type": "object",
                      "properties": {
                        "isrc": {
                          "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                          "type": "string"
                        },
                        "ean": {
                          "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                          "type": "string"
                        },
                        "upc": {
                          "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                          "type": "string"
                        }
                      }
                    },
                    "external_urls": {
                      "$ref": "ExternalUrlObject"
                    },
                    "href": {
                      "description": "A link to the Web API endpoint providing full details of the track.",
                      "type": "string"
                    },
                    "id": {
                      "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                      "type": "string"
                    },
                    "is_playable": {
                      "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                      "type": "boolean"
                    },
                    "linked_from": {
                      "id": "LinkedTrackObject",
                      "title": "LinkedTrackObject",
                      "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied, and the requested track has been replaced with different track. The track in the `linked_from` object contains information about the originally requested track.",
                      "type": "object",
                      "properties": {
                        "external_urls": {
                          "$ref": "ExternalUrlObject"
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the track.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        },
                        "type": {
                          "description": "The object type: \"track\".",
                          "type": "string"
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        }
                      }
                    },
                    "restrictions": {
                      "id": "TrackRestrictionObject",
                      "title": "TrackRestrictionObject",
                      "description": "Included in the response when a content restriction is applied.",
                      "type": "object",
                      "properties": {
                        "reason": {
                          "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                          "type": "string"
                        }
                      }
                    },
                    "name": {
                      "description": "The name of the track.",
                      "type": "string"
                    },
                    "popularity": {
                      "description": "The popularity of the track. The value will be between 0 and 100, with 100 being the most popular.<br/>The popularity of a track is a value between 0 and 100, with 100 being the most popular. The popularity is calculated by algorithm and is based, in the most part, on the total number of plays the track has had and how recent those plays are.<br/>Generally speaking, songs that are being played a lot now will have a higher popularity than songs that were played a lot in the past. Duplicate tracks (e.g. the same track from a single and an album) are rated independently. Artist and album popularity is derived mathematically from track popularity. _**Note**: the popularity value may lag actual popularity by a few days: the value is not updated in real time._",
                      "type": "integer",
                      "format": "int32"
                    },
                    "preview_url": {
                      "description": "A link to a 30 second preview (MP3 format) of the track. Can be `null`",
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "track_number": {
                      "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                      "type": "integer",
                      "format": "int32"
                    },
                    "type": {
                      "title": "Type2",
                      "description": "The object type: \"track\".",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "track"
                      ]
                    },
                    "uri": {
                      "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                      "type": "string"
                    },
                    "is_local": {
                      "description": "Whether or not the track is from a local file.",
                      "type": "boolean"
                    }
                  }
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
  get:
    securedBy:
    - oauth_2_0
    description: >
      Get Spotify catalog information for multiple tracks based on their Spotify IDs.
    queryParameters:
      ids:
        type: string
        example: 7ouMYWpwJ422jRcDASZB7P,4VqPOruhp5EdPBeR92t6lQ,2takcwOaAZWiXQijPHIx7B
        required: true
        displayName: ids
      market:
        type: string
        example: ES
        required: false
        displayName: market
    responses:
      '200':
        description: A set of tracks
        body:
          application/json:
            schema: |
              {
                "id": "ManyTracks",
                "title": "ManyTracks",
                "type": "object",
                "properties": {
                  "tracks": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "TrackObject",
                      "title": "TrackObject",
                      "type": "object",
                      "properties": {
                        "album": {
                          "id": "SimplifiedAlbumObject",
                          "title": "SimplifiedAlbumObject",
                          "description": "The album on which the track appears. The album object includes a link in `href` to full information about the album.",
                          "type": "object",
                          "properties": {
                            "album_type": {
                              "title": "AlbumType",
                              "description": "The type of the album.",
                              "example": "compilation",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "album",
                                "single",
                                "compilation"
                              ]
                            },
                            "total_tracks": {
                              "description": "The number of tracks in the album.",
                              "example": 9,
                              "type": "integer",
                              "format": "int32"
                            },
                            "available_markets": {
                              "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                              "example": [
                                "CA",
                                "BR",
                                "IT"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "Known external URLs for this track.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the album.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "images": {
                              "description": "The cover art for the album in various sizes, widest first.",
                              "type": "array",
                              "items": {
                                "id": "ImageObject",
                                "title": "ImageObject",
                                "type": "object",
                                "properties": {
                                  "url": {
                                    "description": "The source URL of the image.",
                                    "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                    "type": "string"
                                  },
                                  "height": {
                                    "description": "The image height in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  },
                                  "width": {
                                    "description": "The image width in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "url",
                                  "height",
                                  "width"
                                ]
                              }
                            },
                            "name": {
                              "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                              "type": "string"
                            },
                            "release_date": {
                              "description": "The date the album was first released.",
                              "example": "1981-12",
                              "type": "string"
                            },
                            "release_date_precision": {
                              "title": "ReleaseDatePrecision",
                              "description": "The precision with which `release_date` value is known.",
                              "example": "year",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "year",
                                "month",
                                "day"
                              ]
                            },
                            "type": {
                              "description": "The object type.",
                              "type": "string",
                              "enum": [
                                "album"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "artists": {
                              "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                              "type": "array",
                              "items": {
                                "id": "SimplifiedArtistObject",
                                "title": "SimplifiedArtistObject",
                                "type": "object",
                                "properties": {
                                  "external_urls": {
                                    "$ref": "ExternalUrlObject"
                                  },
                                  "href": {
                                    "description": "A link to the Web API endpoint providing full details of the artist.",
                                    "type": "string"
                                  },
                                  "id": {
                                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  },
                                  "name": {
                                    "description": "The name of the artist.",
                                    "type": "string"
                                  },
                                  "type": {
                                    "title": "Type",
                                    "description": "The object type.",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "artist"
                                    ]
                                  },
                                  "uri": {
                                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  }
                                }
                              }
                            },
                            "restrictions": {
                              "id": "AlbumRestrictionObject",
                              "title": "AlbumRestrictionObject",
                              "description": "Included in the response when a content restriction is applied.",
                              "type": "object",
                              "properties": {
                                "reason": {
                                  "title": "Reason",
                                  "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "market",
                                    "product",
                                    "explicit"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "album_type",
                            "total_tracks",
                            "available_markets",
                            "external_urls",
                            "href",
                            "id",
                            "images",
                            "name",
                            "release_date",
                            "release_date_precision",
                            "type",
                            "uri",
                            "artists"
                          ]
                        },
                        "artists": {
                          "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                          "type": "array",
                          "items": {
                            "id": "ArtistObject",
                            "title": "ArtistObject",
                            "type": "object",
                            "properties": {
                              "external_urls": {
                                "$ref": "ExternalUrlObject"
                              },
                              "followers": {
                                "id": "FollowersObject",
                                "title": "FollowersObject",
                                "description": "Information about the followers of the artist.",
                                "type": "object",
                                "properties": {
                                  "href": {
                                    "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "total": {
                                    "description": "The total number of followers.",
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                }
                              },
                              "genres": {
                                "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                                "example": [
                                  "Prog rock",
                                  "Grunge"
                                ],
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the artist.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              },
                              "images": {
                                "description": "Images of the artist in various sizes, widest first.",
                                "type": "array",
                                "items": {
                                  "$ref": "ImageObject"
                                }
                              },
                              "name": {
                                "description": "The name of the artist.",
                                "type": "string"
                              },
                              "popularity": {
                                "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                                "type": "integer",
                                "format": "int32"
                              },
                              "type": {
                                "$ref": "SimplifiedArtistObject#/properties/type"
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              }
                            }
                          }
                        },
                        "available_markets": {
                          "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "disc_number": {
                          "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                          "type": "integer",
                          "format": "int32"
                        },
                        "duration_ms": {
                          "description": "The track length in milliseconds.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "explicit": {
                          "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                          "type": "boolean"
                        },
                        "external_ids": {
                          "id": "ExternalIdObject",
                          "title": "ExternalIdObject",
                          "description": "Known external IDs for the track.",
                          "type": "object",
                          "properties": {
                            "isrc": {
                              "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                              "type": "string"
                            },
                            "ean": {
                              "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                              "type": "string"
                            },
                            "upc": {
                              "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                              "type": "string"
                            }
                          }
                        },
                        "external_urls": {
                          "$ref": "ExternalUrlObject"
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the track.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        },
                        "is_playable": {
                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                          "type": "boolean"
                        },
                        "linked_from": {
                          "id": "LinkedTrackObject",
                          "title": "LinkedTrackObject",
                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied, and the requested track has been replaced with different track. The track in the `linked_from` object contains information about the originally requested track.",
                          "type": "object",
                          "properties": {
                            "external_urls": {
                              "$ref": "ExternalUrlObject"
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the track.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            },
                            "type": {
                              "description": "The object type: \"track\".",
                              "type": "string"
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            }
                          }
                        },
                        "restrictions": {
                          "id": "TrackRestrictionObject",
                          "title": "TrackRestrictionObject",
                          "description": "Included in the response when a content restriction is applied.",
                          "type": "object",
                          "properties": {
                            "reason": {
                              "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                              "type": "string"
                            }
                          }
                        },
                        "name": {
                          "description": "The name of the track.",
                          "type": "string"
                        },
                        "popularity": {
                          "description": "The popularity of the track. The value will be between 0 and 100, with 100 being the most popular.<br/>The popularity of a track is a value between 0 and 100, with 100 being the most popular. The popularity is calculated by algorithm and is based, in the most part, on the total number of plays the track has had and how recent those plays are.<br/>Generally speaking, songs that are being played a lot now will have a higher popularity than songs that were played a lot in the past. Duplicate tracks (e.g. the same track from a single and an album) are rated independently. Artist and album popularity is derived mathematically from track popularity. _**Note**: the popularity value may lag actual popularity by a few days: the value is not updated in real time._",
                          "type": "integer",
                          "format": "int32"
                        },
                        "preview_url": {
                          "description": "A link to a 30 second preview (MP3 format) of the track. Can be `null`",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "track_number": {
                          "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "type": {
                          "title": "Type2",
                          "description": "The object type: \"track\".",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "track"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        },
                        "is_local": {
                          "description": "Whether or not the track is from a local file.",
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "tracks"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/audio-features:
  /{id}:
    uriParameters:
      id:
        type: string
        example: 11dFghVXANMlKmJXsNCbNl
        required: true
        displayName: id
    get:
      securedBy:
      - oauth_2_0
      description: >
        Get audio feature information for a single track identified by its unique

        Spotify ID.
      responses:
        '200':
          description: Audio features for one track
          body:
            application/json:
              schema: |
                {
                  "id": "AudioFeaturesObject",
                  "title": "AudioFeaturesObject",
                  "type": "object",
                  "properties": {
                    "acousticness": {
                      "description": "A confidence measure from 0.0 to 1.0 of whether the track is acoustic. 1.0 represents high confidence the track is acoustic.",
                      "example": 0.00242,
                      "type": "number",
                      "minimum": 0.0,
                      "maximum": 1.0
                    },
                    "analysis_url": {
                      "description": "A URL to access the full audio analysis of this track. An access token is required to access this data.",
                      "example": "https://api.spotify.com/v1/audio-analysis/2takcwOaAZWiXQijPHIx7B\n",
                      "type": "string"
                    },
                    "danceability": {
                      "description": "Danceability describes how suitable a track is for dancing based on a combination of musical elements including tempo, rhythm stability, beat strength, and overall regularity. A value of 0.0 is least danceable and 1.0 is most danceable.",
                      "example": 0.585,
                      "type": "number"
                    },
                    "duration_ms": {
                      "description": "The duration of the track in milliseconds.",
                      "example": 237040,
                      "type": "integer",
                      "format": "int32"
                    },
                    "energy": {
                      "description": "Energy is a measure from 0.0 to 1.0 and represents a perceptual measure of intensity and activity. Typically, energetic tracks feel fast, loud, and noisy. For example, death metal has high energy, while a Bach prelude scores low on the scale. Perceptual features contributing to this attribute include dynamic range, perceived loudness, timbre, onset rate, and general entropy.",
                      "example": 0.842,
                      "type": "number"
                    },
                    "id": {
                      "description": "The Spotify ID for the track.",
                      "example": "2takcwOaAZWiXQijPHIx7B",
                      "type": "string"
                    },
                    "instrumentalness": {
                      "description": "Predicts whether a track contains no vocals. \"Ooh\" and \"aah\" sounds are treated as instrumental in this context. Rap or spoken word tracks are clearly \"vocal\". The closer the instrumentalness value is to 1.0, the greater likelihood the track contains no vocal content. Values above 0.5 are intended to represent instrumental tracks, but confidence is higher as the value approaches 1.0.",
                      "example": 0.00686,
                      "type": "number"
                    },
                    "key": {
                      "description": "The key the track is in. Integers map to pitches using standard [Pitch Class notation](https://en.wikipedia.org/wiki/Pitch_class). E.g. 0 = C, 1 = C♯/D♭, 2 = D, and so on. If no key was detected, the value is -1.",
                      "example": 9,
                      "type": "integer",
                      "minimum": -1.0,
                      "maximum": 11.0,
                      "format": "int32"
                    },
                    "liveness": {
                      "description": "Detects the presence of an audience in the recording. Higher liveness values represent an increased probability that the track was performed live. A value above 0.8 provides strong likelihood that the track is live.",
                      "example": 0.0866,
                      "type": "number"
                    },
                    "loudness": {
                      "description": "The overall loudness of a track in decibels (dB). Loudness values are averaged across the entire track and are useful for comparing relative loudness of tracks. Loudness is the quality of a sound that is the primary psychological correlate of physical strength (amplitude). Values typically range between -60 and 0 db.",
                      "example": -5.883,
                      "type": "number"
                    },
                    "mode": {
                      "description": "Mode indicates the modality (major or minor) of a track, the type of scale from which its melodic content is derived. Major is represented by 1 and minor is 0.",
                      "example": 0,
                      "type": "integer",
                      "format": "int32"
                    },
                    "speechiness": {
                      "description": "Speechiness detects the presence of spoken words in a track. The more exclusively speech-like the recording (e.g. talk show, audio book, poetry), the closer to 1.0 the attribute value. Values above 0.66 describe tracks that are probably made entirely of spoken words. Values between 0.33 and 0.66 describe tracks that may contain both music and speech, either in sections or layered, including such cases as rap music. Values below 0.33 most likely represent music and other non-speech-like tracks.",
                      "example": 0.0556,
                      "type": "number"
                    },
                    "tempo": {
                      "description": "The overall estimated tempo of a track in beats per minute (BPM). In musical terminology, tempo is the speed or pace of a given piece and derives directly from the average beat duration.",
                      "example": 118.211,
                      "type": "number"
                    },
                    "time_signature": {
                      "description": "An estimated time signature. The time signature (meter) is a notational convention to specify how many beats are in each bar (or measure). The time signature ranges from 3 to 7 indicating time signatures of \"3/4\", to \"7/4\".",
                      "example": 4,
                      "type": "integer",
                      "minimum": 3.0,
                      "maximum": 7.0,
                      "format": "int32"
                    },
                    "track_href": {
                      "description": "A link to the Web API endpoint providing full details of the track.",
                      "example": "https://api.spotify.com/v1/tracks/2takcwOaAZWiXQijPHIx7B\n",
                      "type": "string"
                    },
                    "type": {
                      "title": "Type5",
                      "description": "The object type.",
                      "type": "string",
                      "additionalProperties": false,
                      "enum": [
                        "audio_features"
                      ]
                    },
                    "uri": {
                      "description": "The Spotify URI for the track.",
                      "example": "spotify:track:2takcwOaAZWiXQijPHIx7B",
                      "type": "string"
                    },
                    "valence": {
                      "description": "A measure from 0.0 to 1.0 describing the musical positiveness conveyed by a track. Tracks with high valence sound more positive (e.g. happy, cheerful, euphoric), while tracks with low valence sound more negative (e.g. sad, depressed, angry).",
                      "example": 0.428,
                      "type": "number",
                      "minimum": 0.0,
                      "maximum": 1.0
                    }
                  }
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
  get:
    securedBy:
    - oauth_2_0
    description: >
      Get audio features for multiple tracks based on their Spotify IDs.
    queryParameters:
      ids:
        type: string
        example: 7ouMYWpwJ422jRcDASZB7P,4VqPOruhp5EdPBeR92t6lQ,2takcwOaAZWiXQijPHIx7B
        required: true
        displayName: ids
    responses:
      '200':
        description: A set of audio features
        body:
          application/json:
            schema: |
              {
                "id": "ManyAudioFeatures",
                "title": "ManyAudioFeatures",
                "type": "object",
                "properties": {
                  "audio_features": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "id": "AudioFeaturesObject",
                      "title": "AudioFeaturesObject",
                      "type": "object",
                      "properties": {
                        "acousticness": {
                          "description": "A confidence measure from 0.0 to 1.0 of whether the track is acoustic. 1.0 represents high confidence the track is acoustic.",
                          "example": 0.00242,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "analysis_url": {
                          "description": "A URL to access the full audio analysis of this track. An access token is required to access this data.",
                          "example": "https://api.spotify.com/v1/audio-analysis/2takcwOaAZWiXQijPHIx7B\n",
                          "type": "string"
                        },
                        "danceability": {
                          "description": "Danceability describes how suitable a track is for dancing based on a combination of musical elements including tempo, rhythm stability, beat strength, and overall regularity. A value of 0.0 is least danceable and 1.0 is most danceable.",
                          "example": 0.585,
                          "type": "number"
                        },
                        "duration_ms": {
                          "description": "The duration of the track in milliseconds.",
                          "example": 237040,
                          "type": "integer",
                          "format": "int32"
                        },
                        "energy": {
                          "description": "Energy is a measure from 0.0 to 1.0 and represents a perceptual measure of intensity and activity. Typically, energetic tracks feel fast, loud, and noisy. For example, death metal has high energy, while a Bach prelude scores low on the scale. Perceptual features contributing to this attribute include dynamic range, perceived loudness, timbre, onset rate, and general entropy.",
                          "example": 0.842,
                          "type": "number"
                        },
                        "id": {
                          "description": "The Spotify ID for the track.",
                          "example": "2takcwOaAZWiXQijPHIx7B",
                          "type": "string"
                        },
                        "instrumentalness": {
                          "description": "Predicts whether a track contains no vocals. \"Ooh\" and \"aah\" sounds are treated as instrumental in this context. Rap or spoken word tracks are clearly \"vocal\". The closer the instrumentalness value is to 1.0, the greater likelihood the track contains no vocal content. Values above 0.5 are intended to represent instrumental tracks, but confidence is higher as the value approaches 1.0.",
                          "example": 0.00686,
                          "type": "number"
                        },
                        "key": {
                          "description": "The key the track is in. Integers map to pitches using standard [Pitch Class notation](https://en.wikipedia.org/wiki/Pitch_class). E.g. 0 = C, 1 = C♯/D♭, 2 = D, and so on. If no key was detected, the value is -1.",
                          "example": 9,
                          "type": "integer",
                          "minimum": -1.0,
                          "maximum": 11.0,
                          "format": "int32"
                        },
                        "liveness": {
                          "description": "Detects the presence of an audience in the recording. Higher liveness values represent an increased probability that the track was performed live. A value above 0.8 provides strong likelihood that the track is live.",
                          "example": 0.0866,
                          "type": "number"
                        },
                        "loudness": {
                          "description": "The overall loudness of a track in decibels (dB). Loudness values are averaged across the entire track and are useful for comparing relative loudness of tracks. Loudness is the quality of a sound that is the primary psychological correlate of physical strength (amplitude). Values typically range between -60 and 0 db.",
                          "example": -5.883,
                          "type": "number"
                        },
                        "mode": {
                          "description": "Mode indicates the modality (major or minor) of a track, the type of scale from which its melodic content is derived. Major is represented by 1 and minor is 0.",
                          "example": 0,
                          "type": "integer",
                          "format": "int32"
                        },
                        "speechiness": {
                          "description": "Speechiness detects the presence of spoken words in a track. The more exclusively speech-like the recording (e.g. talk show, audio book, poetry), the closer to 1.0 the attribute value. Values above 0.66 describe tracks that are probably made entirely of spoken words. Values between 0.33 and 0.66 describe tracks that may contain both music and speech, either in sections or layered, including such cases as rap music. Values below 0.33 most likely represent music and other non-speech-like tracks.",
                          "example": 0.0556,
                          "type": "number"
                        },
                        "tempo": {
                          "description": "The overall estimated tempo of a track in beats per minute (BPM). In musical terminology, tempo is the speed or pace of a given piece and derives directly from the average beat duration.",
                          "example": 118.211,
                          "type": "number"
                        },
                        "time_signature": {
                          "description": "An estimated time signature. The time signature (meter) is a notational convention to specify how many beats are in each bar (or measure). The time signature ranges from 3 to 7 indicating time signatures of \"3/4\", to \"7/4\".",
                          "example": 4,
                          "type": "integer",
                          "minimum": 3.0,
                          "maximum": 7.0,
                          "format": "int32"
                        },
                        "track_href": {
                          "description": "A link to the Web API endpoint providing full details of the track.",
                          "example": "https://api.spotify.com/v1/tracks/2takcwOaAZWiXQijPHIx7B\n",
                          "type": "string"
                        },
                        "type": {
                          "title": "Type5",
                          "description": "The object type.",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "audio_features"
                          ]
                        },
                        "uri": {
                          "description": "The Spotify URI for the track.",
                          "example": "spotify:track:2takcwOaAZWiXQijPHIx7B",
                          "type": "string"
                        },
                        "valence": {
                          "description": "A measure from 0.0 to 1.0 describing the musical positiveness conveyed by a track. Tracks with high valence sound more positive (e.g. happy, cheerful, euphoric), while tracks with low valence sound more negative (e.g. sad, depressed, angry).",
                          "example": 0.428,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        }
                      }
                    }
                  }
                },
                "required": [
                  "audio_features"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/audio-analysis/{id}:
  uriParameters:
    id:
      type: string
      example: 11dFghVXANMlKmJXsNCbNl
      required: true
      displayName: id
  get:
    securedBy:
    - oauth_2_0
    description: >
      Get a low-level audio analysis for a track in the Spotify catalog. The audio analysis describes the track’s structure and musical content, including rhythm, pitch, and timbre.
    responses:
      '200':
        description: Audio analysis for one track
        body:
          application/json:
            schema: |
              {
                "id": "AudioAnalysisObject",
                "title": "AudioAnalysisObject",
                "type": "object",
                "properties": {
                  "meta": {
                    "id": "Meta",
                    "title": "Meta",
                    "type": "object",
                    "properties": {
                      "analyzer_version": {
                        "description": "The version of the Analyzer used to analyze this track.",
                        "example": "4.0.0",
                        "type": "string"
                      },
                      "platform": {
                        "description": "The platform used to read the track's audio data.",
                        "example": "Linux",
                        "type": "string"
                      },
                      "detailed_status": {
                        "description": "A detailed status code for this track. If analysis data is missing, this code may explain why.",
                        "example": "OK",
                        "type": "string"
                      },
                      "status_code": {
                        "description": "The return code of the analyzer process. 0 if successful, 1 if any errors occurred.",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "timestamp": {
                        "description": "The Unix timestamp (in seconds) at which this track was analyzed.",
                        "example": 1495193577,
                        "type": "integer",
                        "format": "int64"
                      },
                      "analysis_time": {
                        "description": "The amount of time taken to analyze this track.",
                        "example": 6.93906,
                        "type": "number"
                      },
                      "input_process": {
                        "description": "The method used to read the track's audio data.",
                        "example": "libvorbisfile L+R 44100->22050",
                        "type": "string"
                      }
                    }
                  },
                  "track": {
                    "id": "Track",
                    "title": "Track",
                    "type": "object",
                    "properties": {
                      "num_samples": {
                        "description": "The exact number of audio samples analyzed from this track. See also `analysis_sample_rate`.",
                        "example": 4585515,
                        "type": "integer",
                        "format": "int32"
                      },
                      "duration": {
                        "description": "Length of the track in seconds.",
                        "example": 207.95985,
                        "type": "number"
                      },
                      "sample_md5": {
                        "description": "This field will always contain the empty string.",
                        "type": "string"
                      },
                      "offset_seconds": {
                        "description": "An offset to the start of the region of the track that was analyzed. (As the entire track is analyzed, this should always be 0.)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "window_seconds": {
                        "description": "The length of the region of the track was analyzed, if a subset of the track was analyzed. (As the entire track is analyzed, this should always be 0.)",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "analysis_sample_rate": {
                        "description": "The sample rate used to decode and analyze this track. May differ from the actual sample rate of this track available on Spotify.",
                        "example": 22050,
                        "type": "integer",
                        "format": "int32"
                      },
                      "analysis_channels": {
                        "description": "The number of channels used for analysis. If 1, all channels are summed together to mono before analysis.",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "end_of_fade_in": {
                        "description": "The time, in seconds, at which the track's fade-in period ends. If the track has no fade-in, this will be 0.0.",
                        "example": 0,
                        "type": "number"
                      },
                      "start_of_fade_out": {
                        "description": "The time, in seconds, at which the track's fade-out period starts. If the track has no fade-out, this should match the track's length.",
                        "example": 201.13705,
                        "type": "number"
                      },
                      "loudness": {
                        "description": "The overall loudness of a track in decibels (dB). Loudness values are averaged across the entire track and are useful for comparing relative loudness of tracks. Loudness is the quality of a sound that is the primary psychological correlate of physical strength (amplitude). Values typically range between -60 and 0 db.",
                        "example": -5.883,
                        "type": "number"
                      },
                      "tempo": {
                        "description": "The overall estimated tempo of a track in beats per minute (BPM). In musical terminology, tempo is the speed or pace of a given piece and derives directly from the average beat duration.",
                        "example": 118.211,
                        "type": "number"
                      },
                      "tempo_confidence": {
                        "description": "The confidence, from 0.0 to 1.0, of the reliability of the `tempo`.",
                        "example": 0.73,
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                      },
                      "time_signature": {
                        "description": "An estimated time signature. The time signature (meter) is a notational convention to specify how many beats are in each bar (or measure). The time signature ranges from 3 to 7 indicating time signatures of \"3/4\", to \"7/4\".",
                        "example": 4,
                        "type": "integer",
                        "minimum": 3.0,
                        "maximum": 7.0,
                        "format": "int32"
                      },
                      "time_signature_confidence": {
                        "description": "The confidence, from 0.0 to 1.0, of the reliability of the `time_signature`.",
                        "example": 0.994,
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                      },
                      "key": {
                        "description": "The key the track is in. Integers map to pitches using standard [Pitch Class notation](https://en.wikipedia.org/wiki/Pitch_class). E.g. 0 = C, 1 = C♯/D♭, 2 = D, and so on. If no key was detected, the value is -1.",
                        "example": 9,
                        "type": "integer",
                        "minimum": -1.0,
                        "maximum": 11.0,
                        "format": "int32"
                      },
                      "key_confidence": {
                        "description": "The confidence, from 0.0 to 1.0, of the reliability of the `key`.",
                        "example": 0.408,
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                      },
                      "mode": {
                        "description": "Mode indicates the modality (major or minor) of a track, the type of scale from which its melodic content is derived. Major is represented by 1 and minor is 0.",
                        "example": 0,
                        "type": "integer",
                        "format": "int32"
                      },
                      "mode_confidence": {
                        "description": "The confidence, from 0.0 to 1.0, of the reliability of the `mode`.",
                        "example": 0.485,
                        "type": "number",
                        "minimum": 0.0,
                        "maximum": 1.0
                      },
                      "codestring": {
                        "description": "An [Echo Nest Musical Fingerprint (ENMFP)](https://academiccommons.columbia.edu/doi/10.7916/D8Q248M4) codestring for this track.",
                        "type": "string"
                      },
                      "code_version": {
                        "description": "A version number for the Echo Nest Musical Fingerprint format used in the codestring field.",
                        "example": 3.15,
                        "type": "number"
                      },
                      "echoprintstring": {
                        "description": "An [EchoPrint](https://github.com/spotify/echoprint-codegen) codestring for this track.",
                        "type": "string"
                      },
                      "echoprint_version": {
                        "description": "A version number for the EchoPrint format used in the echoprintstring field.",
                        "example": 4.15,
                        "type": "number"
                      },
                      "synchstring": {
                        "description": "A [Synchstring](https://github.com/echonest/synchdata) for this track.",
                        "type": "string"
                      },
                      "synch_version": {
                        "description": "A version number for the Synchstring used in the synchstring field.",
                        "example": 1,
                        "type": "number"
                      },
                      "rhythmstring": {
                        "description": "A Rhythmstring for this track. The format of this string is similar to the Synchstring.",
                        "type": "string"
                      },
                      "rhythm_version": {
                        "description": "A version number for the Rhythmstring used in the rhythmstring field.",
                        "example": 1,
                        "type": "number"
                      }
                    }
                  },
                  "bars": {
                    "description": "The time intervals of the bars throughout the track. A bar (or measure) is a segment of time defined as a given number of beats.",
                    "type": "array",
                    "items": {
                      "id": "TimeIntervalObject",
                      "title": "TimeIntervalObject",
                      "type": "object",
                      "properties": {
                        "start": {
                          "description": "The starting point (in seconds) of the time interval.",
                          "example": 0.49567,
                          "type": "number"
                        },
                        "duration": {
                          "description": "The duration (in seconds) of the time interval.",
                          "example": 2.18749,
                          "type": "number"
                        },
                        "confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the interval.",
                          "example": 0.925,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        }
                      }
                    }
                  },
                  "beats": {
                    "description": "The time intervals of beats throughout the track. A beat is the basic time unit of a piece of music; for example, each tick of a metronome. Beats are typically multiples of tatums.",
                    "type": "array",
                    "items": {
                      "$ref": "TimeIntervalObject"
                    }
                  },
                  "sections": {
                    "description": "Sections are defined by large variations in rhythm or timbre, e.g. chorus, verse, bridge, guitar solo, etc. Each section contains its own descriptions of tempo, key, mode, time_signature, and loudness.",
                    "type": "array",
                    "items": {
                      "id": "SectionObject",
                      "title": "SectionObject",
                      "type": "object",
                      "properties": {
                        "start": {
                          "description": "The starting point (in seconds) of the section.",
                          "example": 0,
                          "type": "number"
                        },
                        "duration": {
                          "description": "The duration (in seconds) of the section.",
                          "example": 6.97092,
                          "type": "number"
                        },
                        "confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the section's \"designation\".",
                          "example": 1,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "loudness": {
                          "description": "The overall loudness of the section in decibels (dB). Loudness values are useful for comparing relative loudness of sections within tracks.",
                          "example": -14.938,
                          "type": "number"
                        },
                        "tempo": {
                          "description": "The overall estimated tempo of the section in beats per minute (BPM). In musical terminology, tempo is the speed or pace of a given piece and derives directly from the average beat duration.",
                          "example": 113.178,
                          "type": "number"
                        },
                        "tempo_confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the tempo. Some tracks contain tempo changes or sounds which don't contain tempo (like pure speech) which would correspond to a low value in this field.",
                          "example": 0.647,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "key": {
                          "description": "The estimated overall key of the section. The values in this field ranging from 0 to 11 mapping to pitches using standard Pitch Class notation (E.g. 0 = C, 1 = C♯/D♭, 2 = D, and so on). If no key was detected, the value is -1.",
                          "example": 9,
                          "type": "integer",
                          "format": "int32"
                        },
                        "key_confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the key. Songs with many key changes may correspond to low values in this field.",
                          "example": 0.297,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "mode": {
                          "title": "Mode",
                          "description": "Indicates the modality (major or minor) of a section, the type of scale from which its melodic content is derived. This field will contain a 0 for \"minor\", a 1 for \"major\", or a -1 for no result. Note that the major key (e.g. C major) could more likely be confused with the minor key at 3 semitones lower (e.g. A minor) as both keys carry the same pitches.",
                          "type": "integer",
                          "additionalProperties": false,
                          "enum": [
                            -1,
                            0,
                            1
                          ]
                        },
                        "mode_confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the `mode`.",
                          "example": 0.471,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "time_signature": {
                          "description": "An estimated time signature. The time signature (meter) is a notational convention to specify how many beats are in each bar (or measure). The time signature ranges from 3 to 7 indicating time signatures of \"3/4\", to \"7/4\".",
                          "example": 4,
                          "type": "integer",
                          "minimum": 3.0,
                          "maximum": 7.0,
                          "format": "int32"
                        },
                        "time_signature_confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the `time_signature`. Sections with time signature changes may correspond to low values in this field.",
                          "example": 1,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        }
                      }
                    }
                  },
                  "segments": {
                    "description": "Each segment contains a roughly conisistent sound throughout its duration.",
                    "type": "array",
                    "items": {
                      "id": "SegmentObject",
                      "title": "SegmentObject",
                      "type": "object",
                      "properties": {
                        "start": {
                          "description": "The starting point (in seconds) of the segment.",
                          "example": 0.70154,
                          "type": "number"
                        },
                        "duration": {
                          "description": "The duration (in seconds) of the segment.",
                          "example": 0.19891,
                          "type": "number"
                        },
                        "confidence": {
                          "description": "The confidence, from 0.0 to 1.0, of the reliability of the segmentation. Segments of the song which are difficult to logically segment (e.g: noise) may correspond to low values in this field.",
                          "example": 0.435,
                          "type": "number",
                          "minimum": 0.0,
                          "maximum": 1.0
                        },
                        "loudness_start": {
                          "description": "The onset loudness of the segment in decibels (dB). Combined with `loudness_max` and `loudness_max_time`, these components can be used to describe the \"attack\" of the segment.",
                          "example": -23.053,
                          "type": "number"
                        },
                        "loudness_max": {
                          "description": "The peak loudness of the segment in decibels (dB). Combined with `loudness_start` and `loudness_max_time`, these components can be used to describe the \"attack\" of the segment.",
                          "example": -14.25,
                          "type": "number"
                        },
                        "loudness_max_time": {
                          "description": "The segment-relative offset of the segment peak loudness in seconds. Combined with `loudness_start` and `loudness_max`, these components can be used to desctibe the \"attack\" of the segment.",
                          "example": 0.07305,
                          "type": "number"
                        },
                        "loudness_end": {
                          "description": "The offset loudness of the segment in decibels (dB). This value should be equivalent to the loudness_start of the following segment.",
                          "example": 0,
                          "type": "number"
                        },
                        "pitches": {
                          "description": "Pitch content is given by a “chroma” vector, corresponding to the 12 pitch classes C, C#, D to B, with values ranging from 0 to 1 that describe the relative dominance of every pitch in the chromatic scale. For example a C Major chord would likely be represented by large values of C, E and G (i.e. classes 0, 4, and 7).\n\nVectors are normalized to 1 by their strongest dimension, therefore noisy sounds are likely represented by values that are all close to 1, while pure tones are described by one value at 1 (the pitch) and others near 0.\nAs can be seen below, the 12 vector indices are a combination of low-power spectrum values at their respective pitch frequencies.\n![pitch vector](https://developer.spotify.com/assets/audio/Pitch_vector.png)",
                          "example": [
                            0.212,
                            0.141,
                            0.294
                          ],
                          "type": "array",
                          "items": {
                            "type": "number",
                            "minimum": 0.0,
                            "maximum": 1.0
                          }
                        },
                        "timbre": {
                          "description": "Timbre is the quality of a musical note or sound that distinguishes different types of musical instruments, or voices. It is a complex notion also referred to as sound color, texture, or tone quality, and is derived from the shape of a segment’s spectro-temporal surface, independently of pitch and loudness. The timbre feature is a vector that includes 12 unbounded values roughly centered around 0. Those values are high level abstractions of the spectral surface, ordered by degree of importance.\n\nFor completeness however, the first dimension represents the average loudness of the segment; second emphasizes brightness; third is more closely correlated to the flatness of a sound; fourth to sounds with a stronger attack; etc. See an image below representing the 12 basis functions (i.e. template segments).\n![timbre basis functions](https://developer.spotify.com/assets/audio/Timbre_basis_functions.png)\n\nThe actual timbre of the segment is best described as a linear combination of these 12 basis functions weighted by the coefficient values: timbre = c1 x b1 + c2 x b2 + ... + c12 x b12, where c1 to c12 represent the 12 coefficients and b1 to b12 the 12 basis functions as displayed below. Timbre vectors are best used in comparison with each other.",
                          "example": [
                            42.115,
                            64.373,
                            -0.233
                          ],
                          "type": "array",
                          "items": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  },
                  "tatums": {
                    "description": "A tatum represents the lowest regular pulse train that a listener intuitively infers from the timing of perceived musical events (segments).",
                    "type": "array",
                    "items": {
                      "$ref": "TimeIntervalObject"
                    }
                  }
                }
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/recommendations:
  /available-genre-seeds:
    get:
      securedBy:
      - oauth_2_0
      description: >
        Retrieve a list of available genres seed parameter values for [recommendations](/documentation/web-api/reference/get-recommendations).
      responses:
        '200':
          description: A set of genres
          body:
            application/json:
              schema: |
                {
                  "id": "ManyGenres",
                  "title": "ManyGenres",
                  "type": "object",
                  "properties": {
                    "genres": {
                      "description": "",
                      "example": [
                        "alternative",
                        "samba"
                      ],
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "required": [
                    "genres"
                  ]
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
  get:
    securedBy:
    - oauth_2_0
    description: >
      Recommendations are generated based on the available information for a given seed entity and matched against similar artists and tracks. If there is sufficient information about the provided seeds, a list of tracks will be returned together with pool size details.


      For artists and tracks that are very new or obscure there might not be enough data to generate a list of tracks.
    queryParameters:
      limit:
        type: integer
        example: '10'
        default: '20'
        required: false
        displayName: limit
        minimum: '1'
        maximum: '100'
      market:
        type: string
        example: ES
        required: false
        displayName: market
      seed_artists:
        type: string
        example: 4NHQUGzhtTLFvgF5SZesLK
        required: false
        displayName: seed_artists
      seed_genres:
        type: string
        example: classical,country
        required: false
        displayName: seed_genres
      seed_tracks:
        type: string
        example: 0c6xIDDpzE81m2q797ordA
        required: false
        displayName: seed_tracks
      min_acousticness:
        type: number
        required: false
        displayName: min_acousticness
        minimum: '0'
        maximum: '1'
      max_acousticness:
        type: number
        required: false
        displayName: max_acousticness
        minimum: '0'
        maximum: '1'
      target_acousticness:
        type: number
        required: false
        displayName: target_acousticness
        minimum: '0'
        maximum: '1'
      min_danceability:
        type: number
        required: false
        displayName: min_danceability
        minimum: '0'
        maximum: '1'
      max_danceability:
        type: number
        required: false
        displayName: max_danceability
        minimum: '0'
        maximum: '1'
      target_danceability:
        type: number
        required: false
        displayName: target_danceability
        minimum: '0'
        maximum: '1'
      min_duration_ms:
        type: integer
        required: false
        displayName: min_duration_ms
      max_duration_ms:
        type: integer
        required: false
        displayName: max_duration_ms
      target_duration_ms:
        type: integer
        required: false
        displayName: target_duration_ms
      min_energy:
        type: number
        required: false
        displayName: min_energy
        minimum: '0'
        maximum: '1'
      max_energy:
        type: number
        required: false
        displayName: max_energy
        minimum: '0'
        maximum: '1'
      target_energy:
        type: number
        required: false
        displayName: target_energy
        minimum: '0'
        maximum: '1'
      min_instrumentalness:
        type: number
        required: false
        displayName: min_instrumentalness
        minimum: '0'
        maximum: '1'
      max_instrumentalness:
        type: number
        required: false
        displayName: max_instrumentalness
        minimum: '0'
        maximum: '1'
      target_instrumentalness:
        type: number
        required: false
        displayName: target_instrumentalness
        minimum: '0'
        maximum: '1'
      min_key:
        type: integer
        required: false
        displayName: min_key
        minimum: '0'
        maximum: '11'
      max_key:
        type: integer
        required: false
        displayName: max_key
        minimum: '0'
        maximum: '11'
      target_key:
        type: integer
        required: false
        displayName: target_key
        minimum: '0'
        maximum: '11'
      min_liveness:
        type: number
        required: false
        displayName: min_liveness
        minimum: '0'
        maximum: '1'
      max_liveness:
        type: number
        required: false
        displayName: max_liveness
        minimum: '0'
        maximum: '1'
      target_liveness:
        type: number
        required: false
        displayName: target_liveness
        minimum: '0'
        maximum: '1'
      min_loudness:
        type: number
        required: false
        displayName: min_loudness
      max_loudness:
        type: number
        required: false
        displayName: max_loudness
      target_loudness:
        type: number
        required: false
        displayName: target_loudness
      min_mode:
        type: integer
        required: false
        displayName: min_mode
        minimum: '0'
        maximum: '1'
      max_mode:
        type: integer
        required: false
        displayName: max_mode
        minimum: '0'
        maximum: '1'
      target_mode:
        type: integer
        required: false
        displayName: target_mode
        minimum: '0'
        maximum: '1'
      min_popularity:
        type: integer
        required: false
        displayName: min_popularity
        minimum: '0'
        maximum: '100'
      max_popularity:
        type: integer
        required: false
        displayName: max_popularity
        minimum: '0'
        maximum: '100'
      target_popularity:
        type: integer
        required: false
        displayName: target_popularity
        minimum: '0'
        maximum: '100'
      min_speechiness:
        type: number
        required: false
        displayName: min_speechiness
        minimum: '0'
        maximum: '1'
      max_speechiness:
        type: number
        required: false
        displayName: max_speechiness
        minimum: '0'
        maximum: '1'
      target_speechiness:
        type: number
        required: false
        displayName: target_speechiness
        minimum: '0'
        maximum: '1'
      min_tempo:
        type: number
        required: false
        displayName: min_tempo
      max_tempo:
        type: number
        required: false
        displayName: max_tempo
      target_tempo:
        type: number
        required: false
        displayName: target_tempo
      min_time_signature:
        type: integer
        required: false
        displayName: min_time_signature
        maximum: '11'
      max_time_signature:
        type: integer
        required: false
        displayName: max_time_signature
      target_time_signature:
        type: integer
        required: false
        displayName: target_time_signature
      min_valence:
        type: number
        required: false
        displayName: min_valence
        minimum: '0'
        maximum: '1'
      max_valence:
        type: number
        required: false
        displayName: max_valence
        minimum: '0'
        maximum: '1'
      target_valence:
        type: number
        required: false
        displayName: target_valence
        minimum: '0'
        maximum: '1'
    responses:
      '200':
        description: A set of recommendations
        body:
          application/json:
            schema: |
              {
                "id": "RecommendationsObject",
                "title": "RecommendationsObject",
                "type": "object",
                "properties": {
                  "seeds": {
                    "description": "An array of recommendation seed objects.",
                    "type": "array",
                    "items": {
                      "id": "RecommendationSeedObject",
                      "title": "RecommendationSeedObject",
                      "type": "object",
                      "properties": {
                        "afterFilteringSize": {
                          "description": "The number of tracks available after min\\_\\* and max\\_\\* filters have been applied.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "afterRelinkingSize": {
                          "description": "The number of tracks available after relinking for regional availability.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "href": {
                          "description": "A link to the full track or artist data for this seed. For tracks this will be a link to a Track Object. For artists a link to an Artist Object. For genre seeds, this value will be `null`.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The id used to select this seed. This will be the same as the string used in the `seed_artists`, `seed_tracks` or `seed_genres` parameter.",
                          "type": "string"
                        },
                        "initialPoolSize": {
                          "description": "The number of recommended tracks available for this seed.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "type": {
                          "description": "The entity type of this seed. One of `artist`, `track` or `genre`.",
                          "type": "string"
                        }
                      }
                    }
                  },
                  "tracks": {
                    "description": "An array of track objects ordered according to the parameters supplied.",
                    "type": "array",
                    "items": {
                      "id": "TrackObject",
                      "title": "TrackObject",
                      "type": "object",
                      "properties": {
                        "album": {
                          "id": "SimplifiedAlbumObject",
                          "title": "SimplifiedAlbumObject",
                          "description": "The album on which the track appears. The album object includes a link in `href` to full information about the album.",
                          "type": "object",
                          "properties": {
                            "album_type": {
                              "title": "AlbumType",
                              "description": "The type of the album.",
                              "example": "compilation",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "album",
                                "single",
                                "compilation"
                              ]
                            },
                            "total_tracks": {
                              "description": "The number of tracks in the album.",
                              "example": 9,
                              "type": "integer",
                              "format": "int32"
                            },
                            "available_markets": {
                              "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                              "example": [
                                "CA",
                                "BR",
                                "IT"
                              ],
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "external_urls": {
                              "id": "ExternalUrlObject",
                              "title": "ExternalUrlObject",
                              "description": "Known external URLs for this track.",
                              "type": "object",
                              "properties": {
                                "spotify": {
                                  "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                  "type": "string"
                                }
                              }
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the album.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "images": {
                              "description": "The cover art for the album in various sizes, widest first.",
                              "type": "array",
                              "items": {
                                "id": "ImageObject",
                                "title": "ImageObject",
                                "type": "object",
                                "properties": {
                                  "url": {
                                    "description": "The source URL of the image.",
                                    "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                    "type": "string"
                                  },
                                  "height": {
                                    "description": "The image height in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  },
                                  "width": {
                                    "description": "The image width in pixels.",
                                    "example": 300,
                                    "type": [
                                      "integer",
                                      "null"
                                    ],
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "url",
                                  "height",
                                  "width"
                                ]
                              }
                            },
                            "name": {
                              "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                              "type": "string"
                            },
                            "release_date": {
                              "description": "The date the album was first released.",
                              "example": "1981-12",
                              "type": "string"
                            },
                            "release_date_precision": {
                              "title": "ReleaseDatePrecision",
                              "description": "The precision with which `release_date` value is known.",
                              "example": "year",
                              "type": "string",
                              "additionalProperties": false,
                              "enum": [
                                "year",
                                "month",
                                "day"
                              ]
                            },
                            "type": {
                              "description": "The object type.",
                              "type": "string",
                              "enum": [
                                "album"
                              ]
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                              "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                              "type": "string"
                            },
                            "artists": {
                              "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                              "type": "array",
                              "items": {
                                "id": "SimplifiedArtistObject",
                                "title": "SimplifiedArtistObject",
                                "type": "object",
                                "properties": {
                                  "external_urls": {
                                    "$ref": "ExternalUrlObject"
                                  },
                                  "href": {
                                    "description": "A link to the Web API endpoint providing full details of the artist.",
                                    "type": "string"
                                  },
                                  "id": {
                                    "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  },
                                  "name": {
                                    "description": "The name of the artist.",
                                    "type": "string"
                                  },
                                  "type": {
                                    "title": "Type",
                                    "description": "The object type.",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "artist"
                                    ]
                                  },
                                  "uri": {
                                    "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                    "type": "string"
                                  }
                                }
                              }
                            },
                            "restrictions": {
                              "id": "AlbumRestrictionObject",
                              "title": "AlbumRestrictionObject",
                              "description": "Included in the response when a content restriction is applied.",
                              "type": "object",
                              "properties": {
                                "reason": {
                                  "title": "Reason",
                                  "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                  "type": "string",
                                  "additionalProperties": false,
                                  "enum": [
                                    "market",
                                    "product",
                                    "explicit"
                                  ]
                                }
                              }
                            }
                          },
                          "required": [
                            "album_type",
                            "total_tracks",
                            "available_markets",
                            "external_urls",
                            "href",
                            "id",
                            "images",
                            "name",
                            "release_date",
                            "release_date_precision",
                            "type",
                            "uri",
                            "artists"
                          ]
                        },
                        "artists": {
                          "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                          "type": "array",
                          "items": {
                            "id": "ArtistObject",
                            "title": "ArtistObject",
                            "type": "object",
                            "properties": {
                              "external_urls": {
                                "$ref": "ExternalUrlObject"
                              },
                              "followers": {
                                "id": "FollowersObject",
                                "title": "FollowersObject",
                                "description": "Information about the followers of the artist.",
                                "type": "object",
                                "properties": {
                                  "href": {
                                    "description": "This will always be set to null, as the Web API does not support it at the moment.",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "total": {
                                    "description": "The total number of followers.",
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                }
                              },
                              "genres": {
                                "description": "A list of the genres the artist is associated with. If not yet classified, the array is empty.",
                                "example": [
                                  "Prog rock",
                                  "Grunge"
                                ],
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the artist.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              },
                              "images": {
                                "description": "Images of the artist in various sizes, widest first.",
                                "type": "array",
                                "items": {
                                  "$ref": "ImageObject"
                                }
                              },
                              "name": {
                                "description": "The name of the artist.",
                                "type": "string"
                              },
                              "popularity": {
                                "description": "The popularity of the artist. The value will be between 0 and 100, with 100 being the most popular. The artist's popularity is calculated from the popularity of all the artist's tracks.",
                                "type": "integer",
                                "format": "int32"
                              },
                              "type": {
                                "$ref": "SimplifiedArtistObject#/properties/type"
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                "type": "string"
                              }
                            }
                          }
                        },
                        "available_markets": {
                          "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "disc_number": {
                          "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                          "type": "integer",
                          "format": "int32"
                        },
                        "duration_ms": {
                          "description": "The track length in milliseconds.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "explicit": {
                          "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                          "type": "boolean"
                        },
                        "external_ids": {
                          "id": "ExternalIdObject",
                          "title": "ExternalIdObject",
                          "description": "Known external IDs for the track.",
                          "type": "object",
                          "properties": {
                            "isrc": {
                              "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                              "type": "string"
                            },
                            "ean": {
                              "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                              "type": "string"
                            },
                            "upc": {
                              "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                              "type": "string"
                            }
                          }
                        },
                        "external_urls": {
                          "$ref": "ExternalUrlObject"
                        },
                        "href": {
                          "description": "A link to the Web API endpoint providing full details of the track.",
                          "type": "string"
                        },
                        "id": {
                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        },
                        "is_playable": {
                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                          "type": "boolean"
                        },
                        "linked_from": {
                          "id": "LinkedTrackObject",
                          "title": "LinkedTrackObject",
                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking) is applied, and the requested track has been replaced with different track. The track in the `linked_from` object contains information about the originally requested track.",
                          "type": "object",
                          "properties": {
                            "external_urls": {
                              "$ref": "ExternalUrlObject"
                            },
                            "href": {
                              "description": "A link to the Web API endpoint providing full details of the track.",
                              "type": "string"
                            },
                            "id": {
                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            },
                            "type": {
                              "description": "The object type: \"track\".",
                              "type": "string"
                            },
                            "uri": {
                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                              "type": "string"
                            }
                          }
                        },
                        "restrictions": {
                          "id": "TrackRestrictionObject",
                          "title": "TrackRestrictionObject",
                          "description": "Included in the response when a content restriction is applied.",
                          "type": "object",
                          "properties": {
                            "reason": {
                              "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                              "type": "string"
                            }
                          }
                        },
                        "name": {
                          "description": "The name of the track.",
                          "type": "string"
                        },
                        "popularity": {
                          "description": "The popularity of the track. The value will be between 0 and 100, with 100 being the most popular.<br/>The popularity of a track is a value between 0 and 100, with 100 being the most popular. The popularity is calculated by algorithm and is based, in the most part, on the total number of plays the track has had and how recent those plays are.<br/>Generally speaking, songs that are being played a lot now will have a higher popularity than songs that were played a lot in the past. Duplicate tracks (e.g. the same track from a single and an album) are rated independently. Artist and album popularity is derived mathematically from track popularity. _**Note**: the popularity value may lag actual popularity by a few days: the value is not updated in real time._",
                          "type": "integer",
                          "format": "int32"
                        },
                        "preview_url": {
                          "description": "A link to a 30 second preview (MP3 format) of the track. Can be `null`",
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "track_number": {
                          "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                          "type": "integer",
                          "format": "int32"
                        },
                        "type": {
                          "title": "Type2",
                          "description": "The object type: \"track\".",
                          "type": "string",
                          "additionalProperties": false,
                          "enum": [
                            "track"
                          ]
                        },
                        "uri": {
                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                          "type": "string"
                        },
                        "is_local": {
                          "description": "Whether or not the track is from a local file.",
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "seeds",
                  "tracks"
                ]
              }
      '401':
        description: |
          Bad or expired token. This can happen if the user revoked a token or

          the access token has expired. You should re-authenticate the user.
        body:
          application/json:
            schema: |
              {
                "id": "Unauthorized1",
                "title": "Unauthorized1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '403':
        description: |
          Bad OAuth request (wrong consumer key, bad nonce, expired

          timestamp...). Unfortunately, re-authenticating the user won't help here.
        body:
          application/json:
            schema: |
              {
                "id": "Forbidden1",
                "title": "Forbidden1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            schema: |
              {
                "id": "TooManyRequests1",
                "title": "TooManyRequests1",
                "type": "object",
                "properties": {
                  "error": {
                    "id": "ErrorObject",
                    "title": "ErrorObject",
                    "type": "object",
                    "properties": {
                      "status": {
                        "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                        "type": "integer",
                        "minimum": 400.0,
                        "maximum": 599.0,
                        "format": "int32"
                      },
                      "message": {
                        "description": "A short description of the cause of the error.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "status",
                      "message"
                    ]
                  }
                },
                "required": [
                  "error"
                ]
              }
/me:
  /albums:
    /contains:
      get:
        securedBy:
        - oauth_2_0:
            scopes:
            - user-library-read
        description: >
          Check if one or more albums is already saved in the current Spotify user's 'Your Music' library.
        queryParameters:
          ids:
            type: string
            example: 382ObEPsp2rxGrnsizN5TX,1A2GTWGtFfWp7KSQTwWOyo,2noRn2Aes5aoNVsU6iWThc
            required: true
            displayName: ids
        responses:
          '200':
            description: Array of booleans
            body:
              application/json:
                schema: |
                  {
                    "description": "",
                    "example": [
                      false,
                      true
                    ],
                    "type": "array",
                    "items": {
                      "type": "boolean"
                    }
                  }
                example: |
                  [
                    false,
                    true
                  ]
          '401':
            description: |
              Bad or expired token. This can happen if the user revoked a token or

              the access token has expired. You should re-authenticate the user.
            body:
              application/json:
                schema: |
                  {
                    "id": "Unauthorized1",
                    "title": "Unauthorized1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '403':
            description: |
              Bad OAuth request (wrong consumer key, bad nonce, expired

              timestamp...). Unfortunately, re-authenticating the user won't help here.
            body:
              application/json:
                schema: |
                  {
                    "id": "Forbidden1",
                    "title": "Forbidden1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
          '429':
            description: The app has exceeded its rate limits.
            body:
              application/json:
                schema: |
                  {
                    "id": "TooManyRequests1",
                    "title": "TooManyRequests1",
                    "type": "object",
                    "properties": {
                      "error": {
                        "id": "ErrorObject",
                        "title": "ErrorObject",
                        "type": "object",
                        "properties": {
                          "status": {
                            "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                            "type": "integer",
                            "minimum": 400.0,
                            "maximum": 599.0,
                            "format": "int32"
                          },
                          "message": {
                            "description": "A short description of the cause of the error.",
                            "type": "string"
                          }
                        },
                        "required": [
                          "status",
                          "message"
                        ]
                      }
                    },
                    "required": [
                      "error"
                    ]
                  }
    get:
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-read
      description: >
        Get a list of the albums saved in the current Spotify user's 'Your Music' library.
      queryParameters:
        limit:
          type: integer
          example: '10'
          default: '20'
          required: false
          displayName: limit
          minimum: '1'
          maximum: '50'
        offset:
          type: integer
          example: '5'
          default: '0'
          required: false
          displayName: offset
        market:
          type: string
          example: ES
          required: false
          displayName: market
      responses:
        '200':
          description: Pages of albums
          body:
            application/json:
              schema: |
                {
                  "id": "PagingSavedAlbumObject",
                  "title": "PagingSavedAlbumObject",
                  "type": "object",
                  "properties": {
                    "href": {
                      "description": "A link to the Web API endpoint returning the full result of the request",
                      "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                      "type": "string"
                    },
                    "limit": {
                      "description": "The maximum number of items in the response (as set in the query or by default).",
                      "example": 20,
                      "type": "integer",
                      "format": "int32"
                    },
                    "next": {
                      "description": "URL to the next page of items. ( `null` if none)",
                      "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "offset": {
                      "description": "The offset of the items returned (as set in the query or by default)",
                      "example": 0,
                      "type": "integer",
                      "format": "int32"
                    },
                    "previous": {
                      "description": "URL to the previous page of items. ( `null` if none)",
                      "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "total": {
                      "description": "The total number of items available to return.",
                      "example": 4,
                      "type": "integer",
                      "format": "int32"
                    },
                    "items": {
                      "description": "",
                      "type": "array",
                      "items": {
                        "id": "SavedAlbumObject",
                        "title": "SavedAlbumObject",
                        "type": "object",
                        "properties": {
                          "added_at": {
                            "description": "The date and time the album was saved\nTimestamps are returned in ISO 8601 format as Coordinated Universal Time (UTC) with a zero offset: YYYY-MM-DDTHH:MM:SSZ.\nIf the time is imprecise (for example, the date/time of an album release), an additional field indicates the precision; see for example, release_date in an album object.",
                            "type": "string",
                            "format": "date-time"
                          },
                          "album": {
                            "id": "AlbumObject",
                            "title": "AlbumObject",
                            "description": "Information about the album.",
                            "type": "object",
                            "properties": {
                              "album_type": {
                                "title": "AlbumType",
                                "description": "The type of the album.",
                                "example": "compilation",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "album",
                                  "single",
                                  "compilation"
                                ]
                              },
                              "total_tracks": {
                                "description": "The number of tracks in the album.",
                                "example": 9,
                                "type": "integer",
                                "format": "int32"
                              },
                              "available_markets": {
                                "description": "The markets in which the album is available: [ISO 3166-1 alpha-2 country codes](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). _**NOTE**: an album is considered available in a market when at least 1 of its tracks is available in that market._",
                                "example": [
                                  "CA",
                                  "BR",
                                  "IT"
                                ],
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "external_urls": {
                                "id": "ExternalUrlObject",
                                "title": "ExternalUrlObject",
                                "description": "Known external URLs for this track.",
                                "type": "object",
                                "properties": {
                                  "spotify": {
                                    "description": "The [Spotify URL](/documentation/web-api/concepts/spotify-uris-ids) for the object.",
                                    "type": "string"
                                  }
                                }
                              },
                              "href": {
                                "description": "A link to the Web API endpoint providing full details of the album.",
                                "type": "string"
                              },
                              "id": {
                                "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                "example": "2up3OPMp9Tb4dAKM2erWXQ",
                                "type": "string"
                              },
                              "images": {
                                "description": "The cover art for the album in various sizes, widest first.",
                                "type": "array",
                                "items": {
                                  "id": "ImageObject",
                                  "title": "ImageObject",
                                  "type": "object",
                                  "properties": {
                                    "url": {
                                      "description": "The source URL of the image.",
                                      "example": "https://i.scdn.co/image/ab67616d00001e02ff9ca10b55ce82ae553c8228\n",
                                      "type": "string"
                                    },
                                    "height": {
                                      "description": "The image height in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    },
                                    "width": {
                                      "description": "The image width in pixels.",
                                      "example": 300,
                                      "type": [
                                        "integer",
                                        "null"
                                      ],
                                      "format": "int32"
                                    }
                                  },
                                  "required": [
                                    "url",
                                    "height",
                                    "width"
                                  ]
                                }
                              },
                              "name": {
                                "description": "The name of the album. In case of an album takedown, the value may be an empty string.",
                                "type": "string"
                              },
                              "release_date": {
                                "description": "The date the album was first released.",
                                "example": "1981-12",
                                "type": "string"
                              },
                              "release_date_precision": {
                                "title": "ReleaseDatePrecision",
                                "description": "The precision with which `release_date` value is known.",
                                "example": "year",
                                "type": "string",
                                "additionalProperties": false,
                                "enum": [
                                  "year",
                                  "month",
                                  "day"
                                ]
                              },
                              "type": {
                                "description": "The object type.",
                                "type": "string",
                                "enum": [
                                  "album"
                                ]
                              },
                              "uri": {
                                "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the album.",
                                "example": "spotify:album:2up3OPMp9Tb4dAKM2erWXQ",
                                "type": "string"
                              },
                              "artists": {
                                "description": "The artists of the album. Each artist object includes a link in `href` to more detailed information about the artist.",
                                "type": "array",
                                "items": {
                                  "id": "SimplifiedArtistObject",
                                  "title": "SimplifiedArtistObject",
                                  "type": "object",
                                  "properties": {
                                    "external_urls": {
                                      "$ref": "ExternalUrlObject"
                                    },
                                    "href": {
                                      "description": "A link to the Web API endpoint providing full details of the artist.",
                                      "type": "string"
                                    },
                                    "id": {
                                      "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                      "type": "string"
                                    },
                                    "name": {
                                      "description": "The name of the artist.",
                                      "type": "string"
                                    },
                                    "type": {
                                      "title": "Type",
                                      "description": "The object type.",
                                      "type": "string",
                                      "additionalProperties": false,
                                      "enum": [
                                        "artist"
                                      ]
                                    },
                                    "uri": {
                                      "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the artist.",
                                      "type": "string"
                                    }
                                  }
                                }
                              },
                              "tracks": {
                                "id": "PagingSimplifiedTrackObject",
                                "title": "PagingSimplifiedTrackObject",
                                "description": "The tracks of the album.",
                                "type": "object",
                                "properties": {
                                  "href": {
                                    "description": "A link to the Web API endpoint returning the full result of the request",
                                    "example": "https://api.spotify.com/v1/me/shows?offset=0&limit=20\n",
                                    "type": "string"
                                  },
                                  "limit": {
                                    "description": "The maximum number of items in the response (as set in the query or by default).",
                                    "example": 20,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "next": {
                                    "description": "URL to the next page of items. ( `null` if none)",
                                    "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "offset": {
                                    "description": "The offset of the items returned (as set in the query or by default)",
                                    "example": 0,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "previous": {
                                    "description": "URL to the previous page of items. ( `null` if none)",
                                    "example": "https://api.spotify.com/v1/me/shows?offset=1&limit=1",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "total": {
                                    "description": "The total number of items available to return.",
                                    "example": 4,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "items": {
                                    "description": "",
                                    "type": "array",
                                    "items": {
                                      "id": "SimplifiedTrackObject",
                                      "title": "SimplifiedTrackObject",
                                      "type": "object",
                                      "properties": {
                                        "artists": {
                                          "description": "The artists who performed the track. Each artist object includes a link in `href` to more detailed information about the artist.",
                                          "type": "array",
                                          "items": {
                                            "$ref": "SimplifiedArtistObject"
                                          }
                                        },
                                        "available_markets": {
                                          "description": "A list of the countries in which the track can be played, identified by their [ISO 3166-1 alpha-2](http://en.wikipedia.org/wiki/ISO_3166-1_alpha-2) code.",
                                          "type": "array",
                                          "items": {
                                            "type": "string"
                                          }
                                        },
                                        "disc_number": {
                                          "description": "The disc number (usually `1` unless the album consists of more than one disc).",
                                          "type": "integer",
                                          "format": "int32"
                                        },
                                        "duration_ms": {
                                          "description": "The track length in milliseconds.",
                                          "type": "integer",
                                          "format": "int32"
                                        },
                                        "explicit": {
                                          "description": "Whether or not the track has explicit lyrics ( `true` = yes it does; `false` = no it does not OR unknown).",
                                          "type": "boolean"
                                        },
                                        "external_urls": {
                                          "$ref": "ExternalUrlObject"
                                        },
                                        "href": {
                                          "description": "A link to the Web API endpoint providing full details of the track.",
                                          "type": "string"
                                        },
                                        "id": {
                                          "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                          "type": "string"
                                        },
                                        "is_playable": {
                                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking/) is applied. If `true`, the track is playable in the given market. Otherwise `false`.",
                                          "type": "boolean"
                                        },
                                        "linked_from": {
                                          "id": "LinkedTrackObject",
                                          "title": "LinkedTrackObject",
                                          "description": "Part of the response when [Track Relinking](/documentation/web-api/concepts/track-relinking/) is applied and is only part of the response if the track linking, in fact, exists. The requested track has been replaced with a different track. The track in the `linked_from` object contains information about the originally requested track.",
                                          "type": "object",
                                          "properties": {
                                            "external_urls": {
                                              "$ref": "ExternalUrlObject"
                                            },
                                            "href": {
                                              "description": "A link to the Web API endpoint providing full details of the track.",
                                              "type": "string"
                                            },
                                            "id": {
                                              "description": "The [Spotify ID](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                              "type": "string"
                                            },
                                            "type": {
                                              "description": "The object type: \"track\".",
                                              "type": "string"
                                            },
                                            "uri": {
                                              "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                              "type": "string"
                                            }
                                          }
                                        },
                                        "restrictions": {
                                          "id": "TrackRestrictionObject",
                                          "title": "TrackRestrictionObject",
                                          "description": "Included in the response when a content restriction is applied.",
                                          "type": "object",
                                          "properties": {
                                            "reason": {
                                              "description": "The reason for the restriction. Supported values:\n- `market` - The content item is not available in the given market.\n- `product` - The content item is not available for the user's subscription type.\n- `explicit` - The content item is explicit and the user's account is set to not play explicit content.\n\nAdditional reasons may be added in the future.\n**Note**: If you use this field, make sure that your application safely handles unknown values.",
                                              "type": "string"
                                            }
                                          }
                                        },
                                        "name": {
                                          "description": "The name of the track.",
                                          "type": "string"
                                        },
                                        "preview_url": {
                                          "description": "A URL to a 30 second preview (MP3 format) of the track.",
                                          "type": [
                                            "string",
                                            "null"
                                          ]
                                        },
                                        "track_number": {
                                          "description": "The number of the track. If an album has several discs, the track number is the number on the specified disc.",
                                          "type": "integer",
                                          "format": "int32"
                                        },
                                        "type": {
                                          "description": "The object type: \"track\".",
                                          "type": "string"
                                        },
                                        "uri": {
                                          "description": "The [Spotify URI](/documentation/web-api/concepts/spotify-uris-ids) for the track.",
                                          "type": "string"
                                        },
                                        "is_local": {
                                          "description": "Whether or not the track is from a local file.",
                                          "type": "boolean"
                                        }
                                      }
                                    }
                                  }
                                },
                                "required": [
                                  "href",
                                  "limit",
                                  "next",
                                  "offset",
                                  "previous",
                                  "total",
                                  "items"
                                ]
                              },
                              "copyrights": {
                                "description": "The copyright statements of the album.",
                                "type": "array",
                                "items": {
                                  "id": "CopyrightObject",
                                  "title": "CopyrightObject",
                                  "type": "object",
                                  "properties": {
                                    "text": {
                                      "description": "The copyright text for this content.",
                                      "type": "string"
                                    },
                                    "type": {
                                      "description": "The type of copyright: `C` = the copyright, `P` = the sound recording (performance) copyright.",
                                      "type": "string"
                                    }
                                  }
                                }
                              },
                              "external_ids": {
                                "id": "ExternalIdObject",
                                "title": "ExternalIdObject",
                                "description": "Known external IDs for the album.",
                                "type": "object",
                                "properties": {
                                  "isrc": {
                                    "description": "[International Standard Recording Code](http://en.wikipedia.org/wiki/International_Standard_Recording_Code)",
                                    "type": "string"
                                  },
                                  "ean": {
                                    "description": "[International Article Number](http://en.wikipedia.org/wiki/International_Article_Number_%28EAN%29)",
                                    "type": "string"
                                  },
                                  "upc": {
                                    "description": "[Universal Product Code](http://en.wikipedia.org/wiki/Universal_Product_Code)",
                                    "type": "string"
                                  }
                                }
                              },
                              "genres": {
                                "description": "A list of the genres the album is associated with. If not yet classified, the array is empty.",
                                "example": [
                                  "Egg punk",
                                  "Noise rock"
                                ],
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "label": {
                                "description": "The label associated with the album.",
                                "type": "string"
                              },
                              "popularity": {
                                "description": "The popularity of the album. The value will be between 0 and 100, with 100 being the most popular.",
                                "type": "integer",
                                "format": "int32"
                              },
                              "restrictions": {
                                "id": "AlbumRestrictionObject",
                                "title": "AlbumRestrictionObject",
                                "description": "Included in the response when a content restriction is applied.",
                                "type": "object",
                                "properties": {
                                  "reason": {
                                    "title": "Reason",
                                    "description": "The reason for the restriction. Albums may be restricted if the content is not available in a given market, to the user's subscription type, or when the user's account is set to not play explicit content.\nAdditional reasons may be added in the future.",
                                    "type": "string",
                                    "additionalProperties": false,
                                    "enum": [
                                      "market",
                                      "product",
                                      "explicit"
                                    ]
                                  }
                                }
                              }
                            },
                            "required": [
                              "album_type",
                              "total_tracks",
                              "available_markets",
                              "external_urls",
                              "href",
                              "id",
                              "images",
                              "name",
                              "release_date",
                              "release_date_precision",
                              "type",
                              "uri",
                              "artists",
                              "tracks",
                              "copyrights",
                              "external_ids",
                              "genres",
                              "label",
                              "popularity"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "href",
                    "limit",
                    "next",
                    "offset",
                    "previous",
                    "total",
                    "items"
                  ]
                }
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
    put:
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-modify
      description: >
        Save one or more albums to the current user's 'Your Music' library.
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      queryParameters:
        ids:
          type: string
          example: 382ObEPsp2rxGrnsizN5TX,1A2GTWGtFfWp7KSQTwWOyo,2noRn2Aes5aoNVsU6iWThc
          required: true
          displayName: ids
      body:
        application/json:
          schema: |
            {
              "id": "MeAlbumsRequest",
              "title": "MeAlbumsRequest",
              "type": "object",
              "properties": {
                "ids": {
                  "description": "A JSON array of the [Spotify IDs](/documentation/web-api/concepts/spotify-uris-ids). For example: `[\"4iV5W9uYEdYUVa79Axb7Rh\", \"1301WleyT98MSxVHPZCA6M\"]`<br/>A maximum of 50 items can be specified in one request. _**Note**: if the `ids` parameter is present in the query string, any IDs listed here in the body will be ignored._",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          example: ''
      responses:
        '200':
          description: The album is saved
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              schema: |
                {
                  "id": "Unauthorized1",
                  "title": "Unauthorized1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              schema: |
                {
                  "id": "Forbidden1",
                  "title": "Forbidden1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
                        "status": {
                          "description": "The HTTP status code (also returned in the response header; see [Response Status Codes](/documentation/web-api/concepts/api-calls#response-status-codes) for more information).",
                          "type": "integer",
                          "minimum": 400.0,
                          "maximum": 599.0,
                          "format": "int32"
                        },
                        "message": {
                          "description": "A short description of the cause of the error.",
                          "type": "string"
                        }
                      },
                      "required": [
                        "status",
                        "message"
                      ]
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              schema: |
                {
                  "id": "TooManyRequests1",
                  "title": "TooManyRequests1",
                  "type": "object",
                  "properties": {
                    "error": {
                      "id": "ErrorObject",
                      "title": "ErrorObject",
                      "type": "object",
                      "properties": {
