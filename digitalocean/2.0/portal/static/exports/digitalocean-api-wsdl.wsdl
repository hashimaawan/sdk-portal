      <fault name="GET_account_get_429" message="wsdl:GET_account_get_429">
        <documentation>API Rate limit exceeded</documentation>
      </fault>
      <fault name="GET_account_get_500" message="wsdl:GET_account_get_500">
        <documentation>Server error.</documentation>
      </fault>
      <fault name="GET_account_get_0" message="wsdl:GET_account_get_0">
        <documentation>Unexpected error</documentation>
      </fault>
    </operation>
    <operation name="GET_actions_list">
      <documentation>This will be the entire list of actions taken on your account, so it will be quite large. As with any large collection returned by the API, the results will be paginated with only 20 on each page by default.</documentation>
      <input message="wsdl:GET_actions_list_InputMessage" />
      <output message="wsdl:GET_actions_list_OutputMessage">
        <documentation>The results will be returned as a JSON object with an actions key.  This will be set to an array filled with action objects containing the standard action attributes</documentation>
      </output>
      <fault name="GET_actions_list_401" message="wsdl:GET_actions_list_401">
        <documentation>Unauthorized</documentation>
      </fault>
      <fault name="GET_actions_list_429" message="wsdl:GET_actions_list_429">
        <documentation>API Rate limit exceeded</documentation>
      </fault>
      <fault name="GET_actions_list_500" message="wsdl:GET_actions_list_500">
        <documentation>Server error.</documentation>
      </fault>
      <fault name="GET_actions_list_0" message="wsdl:GET_actions_list_0">
        <documentation>Unexpected error</documentation>
      </fault>
    </operation>
    <operation name="GET_actions_get">
      <documentation>To retrieve a specific action object, send a GET request to `/v2/actions/$ACTION_ID`.</documentation>
      <input message="wsdl:GET_actions_get_InputMessage" />
      <output message="wsdl:GET_actions_get_OutputMessage">
