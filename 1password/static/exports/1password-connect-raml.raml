- HealthResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "HealthResponse",
      "title": "HealthResponse",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "description": "The Connect server's version",
          "type": "string"
        },
        "dependencies": {
          "description": "",
          "type": "array",
          "items": {
            "id": "ServiceDependency",
            "title": "ServiceDependency",
