      '429':
        description: The app has exceeded its rate limits.
        body:
          application/json:
            displayName: response429
            description: ''
            type: TooManyRequests1
  /albums:
    get:
      displayName: get-users-saved-albums
      description: >
        Get a list of the albums saved in the current Spotify user's 'Your Music' library.
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-read
      queryParameters:
        limit:
          required: false
          default: '20'
          example:
            value: 10
          displayName: limit
          type: integer
          minimum: 1
          maximum: 50
          format: int32
        offset:
          required: false
          default: '0'
          example:
            value: 5
          displayName: offset
          type: integer
          format: int32
        market:
          required: false
          example:
            value: ES
          displayName: market
          type: string
      responses:
        '200':
          description: Pages of albums
          body:
            application/json:
              displayName: response200
              description: ''
              type: PagingSavedAlbumObject
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    put:
      displayName: save-albums-user
      description: >
        Save one or more albums to the current user's 'Your Music' library.
      body:
        application/json:
          displayName: body
          type: MeAlbumsRequest
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-modify
      queryParameters:
        ids:
          required: true
          example:
            value: 382ObEPsp2rxGrnsizN5TX,1A2GTWGtFfWp7KSQTwWOyo,2noRn2Aes5aoNVsU6iWThc
          displayName: ids
          type: string
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: The album is saved
          body: {}
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
            application/json:
              displayName: response401
              description: ''
              type: Unauthorized1
        '403':
          description: |
            Bad OAuth request (wrong consumer key, bad nonce, expired

            timestamp...). Unfortunately, re-authenticating the user won't help here.
          body:
            application/json:
              displayName: response403
              description: ''
              type: Forbidden1
        '429':
          description: The app has exceeded its rate limits.
          body:
            application/json:
              displayName: response429
              description: ''
              type: TooManyRequests1
    delete:
      displayName: remove-albums-user
      description: >
        Remove one or more albums from the current user's 'Your Music' library.
      body:
        application/json:
          displayName: body
          type: MeAlbumsRequest
      securedBy:
      - oauth_2_0:
          scopes:
          - user-library-modify
      queryParameters:
        ids:
          required: true
          example:
            value: 382ObEPsp2rxGrnsizN5TX,1A2GTWGtFfWp7KSQTwWOyo,2noRn2Aes5aoNVsU6iWThc
          displayName: ids
          type: string
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          type: string
          enum:
          - application/json
      responses:
        '200':
          description: Album(s) have been removed from the library
          body: {}
        '401':
          description: |
            Bad or expired token. This can happen if the user revoked a token or

            the access token has expired. You should re-authenticate the user.
          body:
