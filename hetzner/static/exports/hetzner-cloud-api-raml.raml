- LocationsResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LocationsResponse",
      "title": "LocationsResponse",
      "type": "object",
      "properties": {
        "locations": {
          "description": "",
          "type": "array",
          "items": {
            "id": "Location",
            "title": "Location",
            "type": "object",
            "properties": {
              "city": {
                "description": "City the Location is closest to",
                "example": "Falkenstein",
                "type": "string"
              },
              "country": {
                "description": "ISO 3166-1 alpha-2 code of the country the Location resides in",
                "example": "DE",
                "type": "string"
              },
              "description": {
                "description": "Description of the Location",
                "example": "Falkenstein DC Park 1",
                "type": "string"
              },
              "id": {
                "description": "ID of the Location",
                "example": 1,
                "type": "number"
              },
              "latitude": {
                "description": "Latitude of the city closest to the Location",
                "example": 50.47612,
                "type": "number"
              },
              "longitude": {
                "description": "Longitude of the city closest to the Location",
                "example": 12.370071,
                "type": "number"
              },
              "name": {
                "description": "Unique identifier of the Location",
                "example": "fsn1",
                "type": "string"
              },
              "network_zone": {
                "description": "Name of network zone this Location resides in",
                "example": "eu-central",
                "type": "string"
              }
            },
            "required": [
              "city",
              "country",
              "description",
              "id",
              "latitude",
              "longitude",
              "name",
              "network_zone"
            ]
          }
        }
      },
      "required": [
        "locations"
      ]
    }
