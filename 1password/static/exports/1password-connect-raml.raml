                          "id": "ErrorResponse",
                          "title": "ErrorResponse",
                          "examples": [
                            {
                              "Id": "fileNotFound",
                              "Name": "File not found",
                              "Value": "{\"message\":\"file {fileUuid} not found\",\"status\":404}",
                              "ExternalValue": null,
                              "Description": null
                            },
                            {
                              "Id": "itemNotFound",
                              "Name": "Item not found",
                              "Value": "{\"message\":\"item {itemUuid} not found\",\"status\":404}",
                              "ExternalValue": null,
                              "Description": null
                            },
                            {
                              "Id": "vaultNotFound",
                              "Name": "Vault not found",
                              "Value": "{\"message\":\"vault {vaultUuid} not found\",\"status\":404}",
                              "ExternalValue": null,
                              "Description": null
                            }
                          ],
                          "example": {
