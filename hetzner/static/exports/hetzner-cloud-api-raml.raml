  post:
    description: >
      Creates a new Firewall.


      #### Call specific error codes


      | Code                          | Description                                                   |

      |------------------------------ |-------------------------------------------------------------- |

      | `server_already_added`        | Server added more than one time to resource                   |

      | `incompatible_network_type`   | The Network type is incompatible for the given resource       |

      | `firewall_resource_not_found` | The resource the Firewall should be attached to was not found |
    headers:
      Content-Type:
        example: application/json
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "CreateFirewallRequest",
            "title": "CreateFirewallRequest",
            "examples": [
              {
                "Id": "request",
                "Name": null,
                "Value": "{\"apply_to\":[{\"server\":{\"id\":42},\"type\":\"server\"}],\"labels\":{\"env\":\"dev\"},\"name\":\"Corporate Intranet Protection\",\"rules\":[{\"description\":\"Allow port 80\",\"direction\":\"in\",\"port\":\"80\",\"protocol\":\"tcp\",\"source_ips\":[\"28.239.13.1/32\",\"28.239.14.0/24\",\"ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128\"]}]}",
                "ExternalValue": null,
                "Description": null
              }
            ],
            "example": {
              "apply_to": [
                {
                  "server": {
                    "id": 42
                  },
                  "type": "server"
                }
              ],
              "labels": {
                "env": "dev"
              },
              "name": "Corporate Intranet Protection",
              "rules": [
                {
                  "description": "Allow port 80",
                  "direction": "in",
                  "port": "80",
                  "protocol": "tcp",
                  "source_ips": [
                    "28.239.13.1/32",
                    "28.239.14.0/24",
                    "ff21:1eac:9a3b:ee58:5ca:990c:8bc9:c03b/128"
                  ]
                }
