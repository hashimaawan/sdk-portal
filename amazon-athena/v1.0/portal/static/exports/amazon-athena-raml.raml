- QueryRuntimeStatistics: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "QueryRuntimeStatistics",
      "title": "QueryRuntimeStatistics",
      "description": "The query execution timeline, statistics on input and output rows and bytes, and the different query stages that form the query execution plan.",
      "type": "object",
      "properties": {
        "Timeline": {
          "id": "QueryRuntimeStatisticsTimeline",
          "title": "QueryRuntimeStatisticsTimeline",
          "description": "Timeline statistics such as query queue time, planning time, execution time, service processing time, and total execution time.",
          "type": "object",
          "properties": {
            "QueryQueueTimeInMillis": {
              "type": "integer",
              "format": "int32"
            },
            "QueryPlanningTimeInMillis": {
              "type": "integer",
              "format": "int32"
            },
            "EngineExecutionTimeInMillis": {
              "type": "integer",
              "format": "int32"
            },
            "ServiceProcessingTimeInMillis": {
              "type": "integer",
              "format": "int32"
            },
            "TotalExecutionTimeInMillis": {
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "Rows": {
          "id": "QueryRuntimeStatisticsRows",
          "title": "QueryRuntimeStatisticsRows",
          "description": "Statistics such as input rows and bytes read by the query, rows and bytes output by the query, and the number of rows written by the query.",
          "type": "object",
          "properties": {
            "InputRows": {
              "type": "integer",
              "format": "int32"
            },
            "InputBytes": {
              "type": "integer",
              "format": "int32"
            },
            "OutputBytes": {
              "type": "integer",
              "format": "int32"
            },
            "OutputRows": {
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "OutputStage": {
          "id": "OutputStage",
          "title": "OutputStage",
          "type": "object",
          "properties": {
            "StageId": {
              "type": "integer",
              "format": "int32"
            },
            "State": {
              "type": "string"
            },
            "OutputBytes": {
              "type": "integer",
              "format": "int32"
            },
            "OutputRows": {
              "type": "integer",
              "format": "int32"
            },
            "InputBytes": {
              "type": "integer",
              "format": "int32"
            },
            "InputRows": {
              "type": "integer",
              "format": "int32"
            },
            "ExecutionTime": {
              "type": "integer",
              "format": "int32"
            },
            "QueryStagePlan": {
              "id": "QueryStagePlan",
              "title": "QueryStagePlan",
              "type": "object",
              "properties": {
                "Name": {
                  "type": "string"
                },
                "Identifier": {
                  "type": "string"
                },
                "Children": {
                  "description": "",
                  "type": "array",
                  "items": {
                    "id": "QueryStagePlanNode",
                    "title": "QueryStagePlanNode",
                    "description": "Stage plan information such as name, identifier, sub plans, and remote sources.",
                    "type": "object",
                    "properties": {
                      "Name": {
                        "type": "string"
                      },
                      "Identifier": {
                        "type": "string"
                      },
                      "Children": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "$ref": "QueryStagePlanNode"
                        }
                      },
                      "RemoteSources": {
                        "description": "",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "RemoteSources": {
                  "description": "",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "SubStages": {
              "description": "",
              "type": "array",
              "items": {
                "id": "QueryStage",
                "title": "QueryStage",
                "description": "Stage statistics such as input and output rows and bytes, execution time and stage state. This information also includes substages and the query stage plan.",
                "type": "object",
                "properties": {
                  "StageId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "State": {
                    "type": "string"
                  },
                  "OutputBytes": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "OutputRows": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "InputBytes": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "InputRows": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "ExecutionTime": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "QueryStagePlan": {
                    "$ref": "QueryStagePlan"
                  },
                  "SubStages": {
                    "description": "",
                    "type": "array",
                    "items": {
                      "$ref": "QueryStage"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
- SessionConfiguration: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SessionConfiguration",
      "title": "SessionConfiguration",
      "description": "Contains session configuration information.",
      "type": "object",
      "properties": {
        "ExecutionRole": {
          "type": "string",
          "minLength": 20,
          "maxLength": 2048,
          "pattern": "^arn:aws[a-z\\-]*:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$"
        },
        "WorkingDirectory": {
          "type": "string"
        },
        "IdleTimeoutSeconds": {
          "type": "integer",
          "format": "int32"
        },
        "EncryptionConfiguration": {
          "id": "EncryptionConfiguration",
          "title": "EncryptionConfiguration",
          "description": "If query and calculation results are encrypted in Amazon S3, indicates the encryption option used (for example, <code>SSE_KMS</code> or <code>CSE_KMS</code>) and key information.",
          "type": "object",
          "properties": {
            "EncryptionOption": {
              "title": "EncryptionOption1",
              "description": "<p>Indicates whether Amazon S3 server-side encryption with Amazon S3-managed keys (<code>SSE_S3</code>), server-side encryption with KMS-managed keys (<code>SSE_KMS</code>), or client-side encryption with KMS-managed keys (<code>CSE_KMS</code>) is used.</p> <p>If a query runs in a workgroup and the workgroup overrides client-side settings, then the workgroup's setting for encryption is used. It specifies whether query results must be encrypted, for all queries that run in this workgroup. </p>",
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "SSE_S3",
                "SSE_KMS",
                "CSE_KMS"
              ]
            },
            "KmsKey": {
              "type": "string"
            }
          },
          "required": [
            "EncryptionOption"
          ]
        }
      }
    }
- SessionStatus: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SessionStatus",
      "title": "SessionStatus",
      "description": "Contains information about the status of a session.",
      "type": "object",
      "properties": {
        "StartDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "LastModifiedDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "EndDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "IdleSinceDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "State": {
          "title": "SessionState1",
          "description": "<p>The state of the session. A description of each state follows.</p> <p> <code>CREATING</code> - The session is being started, including acquiring resources.</p> <p> <code>CREATED</code> - The session has been started.</p> <p> <code>IDLE</code> - The session is able to accept a calculation.</p> <p> <code>BUSY</code> - The session is processing another task and is unable to accept a calculation.</p> <p> <code>TERMINATING</code> - The session is in the process of shutting down.</p> <p> <code>TERMINATED</code> - The session and its resources are no longer running.</p> <p> <code>DEGRADED</code> - The session has no healthy coordinators.</p> <p> <code>FAILED</code> - Due to a failure, the session and its resources are no longer running.</p>",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "CREATING",
            "CREATED",
            "IDLE",
            "BUSY",
            "TERMINATING",
            "TERMINATED",
            "DEGRADED",
            "FAILED"
          ]
        },
        "StateChangeReason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    }
- SessionStatistics: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
