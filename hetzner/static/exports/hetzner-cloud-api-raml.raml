              "primary_disk_size",
              "private_net",
              "protection",
              "public_net",
              "rescue_enabled",
              "server_type",
              "status"
            ]
          }
        },
        "meta": {
          "id": "Meta",
          "title": "Meta",
          "type": "object",
          "properties": {
            "pagination": {
              "id": "Pagination",
              "title": "Pagination",
              "type": "object",
              "properties": {
