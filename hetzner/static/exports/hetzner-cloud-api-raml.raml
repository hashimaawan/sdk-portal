                      },
                      "meta": {
                        "id": "Meta",
                        "title": "Meta",
                        "type": "object",
                        "properties": {
                          "pagination": {
                            "id": "Pagination",
                            "title": "Pagination",
                            "type": "object",
                            "properties": {
                              "last_page": {
                                "description": "ID of the last page available. Can be null if the current page is the last one.",
                                "example": 4,
