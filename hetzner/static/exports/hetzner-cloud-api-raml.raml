                          "description": "Latitude of the city closest to the Location",
                          "example": 50.47612,
                          "type": "number"
                        },
                        "longitude": {
                          "description": "Longitude of the city closest to the Location",
                          "example": 12.370071,
                          "type": "number"
                        },
                        "name": {
                          "description": "Unique identifier of the Location",
                          "example": "fsn1",
                          "type": "string"
                        },
                        "network_zone": {
                          "description": "Name of network zone this Location resides in",
                          "example": "eu-central",
                          "type": "string"
                        }
                      },
                      "required": [
                        "city",
                        "country",
                        "description",
                        "id",
                        "latitude",
                        "longitude",
                        "name",
                        "network_zone"
                      ]
                    }
                  },
                  "required": [
                    "location"
                  ]
                }
  get:
    description: Returns all Location objects.
