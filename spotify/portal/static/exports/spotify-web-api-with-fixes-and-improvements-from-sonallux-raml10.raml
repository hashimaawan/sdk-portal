        type: integer
        format: int32
      target_duration_ms:
        required: false
        displayName: target_duration_ms
        type: integer
        format: int32
      min_energy:
        required: false
        displayName: min_energy
        type: number
        minimum: 0
        maximum: 1
        format: double
      max_energy:
        required: false
        displayName: max_energy
        type: number
        minimum: 0
        maximum: 1
        format: double
      target_energy:
        required: false
        displayName: target_energy
        type: number
        minimum: 0
        maximum: 1
        format: double
      min_instrumentalness:
        required: false
