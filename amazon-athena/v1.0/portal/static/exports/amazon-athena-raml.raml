          "type": "object",
          "properties": {
            "ColumnInfo": {
              "description": "",
              "type": "array",
              "items": {
                "id": "ColumnInfo",
                "title": "ColumnInfo",
                "description": "Information about the columns in a query execution result.",
                "type": "object",
                "properties": {
                  "Name": {
                    "type": "string"
                  },
                  "Type": {
                    "type": "string"
                  },
                  "CatalogName": {
                    "type": "string"
                  },
                  "SchemaName": {
                    "type": "string"
                  },
                  "TableName": {
                    "type": "string"
                  },
                  "Label": {
                    "type": "string"
                  },
                  "Precision": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Scale": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Nullable": {
                    "title": "ColumnNullable2",
                    "description": "Indicates the column's nullable status.",
                    "type": "string",
                    "additionalProperties": false,
                    "enum": [
                      "NOT_NULL",
                      "NULLABLE",
                      "UNKNOWN"
                    ]
                  },
                  "CaseSensitive": {
                    "type": "boolean"
                  }
                },
                "required": [
