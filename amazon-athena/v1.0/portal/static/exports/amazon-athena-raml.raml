      X-Amz-Security-Token:
        type: string
        required: false
        displayName: X-Amz-Security-Token
      X-Amz-Signature:
        type: string
        required: false
        displayName: X-Amz-Signature
      X-Amz-SignedHeaders:
        type: string
        required: false
        displayName: X-Amz-SignedHeaders
    body:
